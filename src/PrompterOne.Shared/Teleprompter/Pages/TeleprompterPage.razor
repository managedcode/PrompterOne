@page "/teleprompter"
@namespace PrompterOne.Shared.Pages
@using PrompterOne.Shared.Contracts

<div id="@UiDomIds.Design.TeleprompterScreen"
     class="screen active"
     tabindex="0"
     @ref="_screenRoot"
     @onkeydown="HandleTeleprompterKeyDownAsync"
     @onkeydown:preventDefault="true"
     data-testid="@UiTestIds.Teleprompter.Page">
    <div class="rd">
        <div class="@BuildReaderGradientCssClass()" id="rd-gradient"></div>
        <video class="@BuildCameraCssClass()"
               id="@_cameraLayer.ElementId"
               autoplay
               muted
               playsinline
               data-camera-device-id="@_cameraLayer.DeviceId"
               data-camera-role="@_cameraLayer.Role"
               data-camera-order="@_cameraLayer.Order"
               data-camera-autostart="@BuildBooleanDataAttribute(_cameraLayer.AutoStart)"
               data-testid="@_cameraLayer.TestId"
               style="@_cameraLayer.Style"></video>
        <div class="@BuildCameraTintCssClass()" id="@UiDomIds.Teleprompter.CameraTint"></div>

        <div class="rd-ui">
            <button class="rd-back" @onclick="NavigateBackToEditorAsync" data-testid="@UiTestIds.Teleprompter.Back">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15,18 9,12 15,6" /></svg>
            </button>

            <div class="@BuildCountdownCssClass()" id="@UiDomIds.Teleprompter.Countdown">@BuildCountdownLabel()</div>

            <div class="rd-mirror-controls" data-testid="@UiTestIds.Teleprompter.MirrorControls">
                <div class="rd-rail-tip-anchor">
                    <button class="@BuildReaderMirrorButtonCssClass(_isReaderMirrorHorizontal)"
                            @onclick="ToggleReaderMirrorHorizontalAsync"
                            aria-label="@ReaderMirrorHorizontalTitle"
                            data-testid="@UiTestIds.Teleprompter.MirrorHorizontalToggle"
                            data-test-id="@UiTestIds.Teleprompter.MirrorHorizontalToggle">
                        @ReaderMirrorHorizontalLabel
                    </button>
                    <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey)"
                          class="@BuildRailTooltipCssClass(placeOnRightSide: true)"
                          role="tooltip"
                          data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey)"
                          data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey)">@ReaderMirrorHorizontalTitle</span>
                </div>
                <div class="rd-rail-tip-anchor">
                    <button class="@BuildReaderMirrorButtonCssClass(_isReaderMirrorVertical)"
                            @onclick="ToggleReaderMirrorVerticalAsync"
                            aria-label="@ReaderMirrorVerticalTitle"
                            data-testid="@UiTestIds.Teleprompter.MirrorVerticalToggle"
                            data-test-id="@UiTestIds.Teleprompter.MirrorVerticalToggle">
                        @ReaderMirrorVerticalLabel
                    </button>
                    <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey)"
                          class="@BuildRailTooltipCssClass(placeOnRightSide: true)"
                          role="tooltip"
                          data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey)"
                          data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey)">@ReaderMirrorVerticalTitle</span>
                </div>
                <div class="rd-rail-tip-anchor">
                    <button class="@BuildReaderOrientationButtonCssClass()"
                            @onclick="ToggleReaderOrientationAsync"
                            aria-label="@ReaderOrientationTitle"
                            data-testid="@UiTestIds.Teleprompter.OrientationToggle"
                            data-test-id="@UiTestIds.Teleprompter.OrientationToggle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M7 3H3v4"></path>
                            <path d="M3 7a9 9 0 0 1 14.3-3.6"></path>
                            <path d="M17 21h4v-4"></path>
                            <path d="M21 17a9 9 0 0 1-14.3 3.6"></path>
                        </svg>
                    </button>
                    <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey)"
                          class="@BuildRailTooltipCssClass(placeOnRightSide: true)"
                          role="tooltip"
                          data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey)"
                          data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey)">@ReaderOrientationTitle</span>
                </div>
                <div class="rd-rail-tip-anchor">
                    <button class="@BuildReaderFullscreenButtonCssClass()"
                            @onclick="ToggleReaderFullscreenAsync"
                            aria-label="@ReaderFullscreenTitle"
                            data-testid="@UiTestIds.Teleprompter.FullscreenToggle"
                            data-test-id="@UiTestIds.Teleprompter.FullscreenToggle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <polyline points="8,3 3,3 3,8"></polyline>
                            <polyline points="16,3 21,3 21,8"></polyline>
                            <polyline points="3,16 3,21 8,21"></polyline>
                            <polyline points="16,21 21,21 21,16"></polyline>
                        </svg>
                    </button>
                    <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey)"
                          class="@BuildRailTooltipCssClass(placeOnRightSide: true)"
                          role="tooltip"
                          data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey)"
                          data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey)">@ReaderFullscreenTitle</span>
                </div>
                <span class="rd-rail-divider" aria-hidden="true"></span>
                <div class="rd-align-controls"
                     data-testid="@UiTestIds.Teleprompter.AlignmentControls"
                     data-test-id="@UiTestIds.Teleprompter.AlignmentControls">
                    <div class="rd-rail-tip-anchor">
                        <button class="@BuildReaderAlignmentButtonCssClass(ReaderTextAlignment.Left)"
                                @onclick="@(() => SetReaderTextAlignmentAsync(ReaderTextAlignment.Left))"
                                aria-label="@ReaderTextAlignLeftTitle"
                                data-testid="@UiTestIds.Teleprompter.AlignmentLeft"
                                data-test-id="@UiTestIds.Teleprompter.AlignmentLeft">
                            <svg class="rd-align-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <line x1="3" y1="4.5" x2="13" y2="4.5" />
                                <line x1="3" y1="10" x2="17" y2="10" />
                                <line x1="3" y1="15.5" x2="11.5" y2="15.5" />
                            </svg>
                        </button>
                        <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipLeftKey)"
                              class="@BuildRailTooltipCssClass(placeOnRightSide: true)"
                              role="tooltip"
                              data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipLeftKey)"
                              data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipLeftKey)">@ReaderTextAlignLeftTitle</span>
                    </div>
                    <div class="rd-rail-tip-anchor">
                        <button class="@BuildReaderAlignmentButtonCssClass(ReaderTextAlignment.Center)"
                                @onclick="@(() => SetReaderTextAlignmentAsync(ReaderTextAlignment.Center))"
                                aria-label="@ReaderTextAlignCenterTitle"
                                data-testid="@UiTestIds.Teleprompter.AlignmentCenter"
                                data-test-id="@UiTestIds.Teleprompter.AlignmentCenter">
                            <svg class="rd-align-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <line x1="5" y1="4.5" x2="15" y2="4.5" />
                                <line x1="3" y1="10" x2="17" y2="10" />
                                <line x1="6" y1="15.5" x2="14" y2="15.5" />
                            </svg>
                        </button>
                        <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipCenterKey)"
                              class="@BuildRailTooltipCssClass(placeOnRightSide: true)"
                              role="tooltip"
                              data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipCenterKey)"
                              data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipCenterKey)">@ReaderTextAlignCenterTitle</span>
                    </div>
                    <div class="rd-rail-tip-anchor">
                        <button class="@BuildReaderAlignmentButtonCssClass(ReaderTextAlignment.Right)"
                                @onclick="@(() => SetReaderTextAlignmentAsync(ReaderTextAlignment.Right))"
                                aria-label="@ReaderTextAlignRightTitle"
                                data-testid="@UiTestIds.Teleprompter.AlignmentRight"
                                data-test-id="@UiTestIds.Teleprompter.AlignmentRight">
                            <svg class="rd-align-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <line x1="7" y1="4.5" x2="17" y2="4.5" />
                                <line x1="3" y1="10" x2="17" y2="10" />
                                <line x1="8.5" y1="15.5" x2="17" y2="15.5" />
                            </svg>
                        </button>
                        <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipRightKey)"
                              class="@BuildRailTooltipCssClass(placeOnRightSide: true)"
                              role="tooltip"
                              data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipRightKey)"
                              data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipRightKey)">@ReaderTextAlignRightTitle</span>
                    </div>
                    <div class="rd-rail-tip-anchor">
                        <button class="@BuildReaderAlignmentButtonCssClass(ReaderTextAlignment.Justify)"
                                @onclick="@(() => SetReaderTextAlignmentAsync(ReaderTextAlignment.Justify))"
                                aria-label="@ReaderTextAlignJustifyTitle"
                                data-testid="@UiTestIds.Teleprompter.AlignmentJustify"
                                data-test-id="@UiTestIds.Teleprompter.AlignmentJustify">
                            <svg class="rd-align-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <line x1="3" y1="4.5" x2="17" y2="4.5" />
                                <line x1="3" y1="8.75" x2="17" y2="8.75" />
                                <line x1="3" y1="13" x2="17" y2="13" />
                                <line x1="3" y1="17.25" x2="17" y2="17.25" />
                            </svg>
                        </button>
                        <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipJustifyKey)"
                              class="@BuildRailTooltipCssClass(placeOnRightSide: true)"
                              role="tooltip"
                              data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipJustifyKey)"
                              data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipJustifyKey)">@ReaderTextAlignJustifyTitle</span>
                    </div>
                </div>
            </div>

            <div class="rd-sliders" data-testid="@UiTestIds.Teleprompter.Sliders">
                <div class="rd-rail-tip-anchor">
                <div class="rd-slider-group">
                    <svg class="rd-slider-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="8" x2="3" y2="16" /><line x1="21" y1="8" x2="21" y2="16" /></svg>
                    <input type="range"
                           class="rd-vslider"
                           id="rd-focal-slider"
                           min="15"
                           max="55"
                           value="@_readerFocalPointPercent"
                           @oninput="HandleReaderFocalPointInputAsync"
                           @onkeydown:stopPropagation="true"
                           aria-label="@ReaderFocalSliderTitle"
                           data-testid="@UiTestIds.Teleprompter.FocalSlider"
                           data-test-id="@UiTestIds.Teleprompter.FocalSlider">
                    <span class="rd-slider-val" id="rd-focal-val">@_readerFocalPointPercent%</span>
                </div>
                <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipFocalKey)"
                      class="@BuildRailTooltipCssClass(placeOnRightSide: false)"
                      role="tooltip"
                      data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipFocalKey)"
                      data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipFocalKey)">@ReaderFocalSliderTitle</span>
                </div>
                <div class="rd-rail-tip-anchor">
                <div class="rd-slider-group">
                    <svg class="rd-slider-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="8,9 5,12 8,15" /><polyline points="16,9 19,12 16,15" /></svg>
                    <input type="range"
                           class="rd-vslider"
                           id="rd-width-slider"
                           min="400"
                           max="1100"
                           value="@_readerTextWidth"
                           @oninput="HandleReaderTextWidthInputAsync"
                           @onkeydown:stopPropagation="true"
                           aria-label="@ReaderWidthSliderTitle"
                           data-testid="@UiTestIds.Teleprompter.WidthSlider"
                           data-test-id="@UiTestIds.Teleprompter.WidthSlider">
                    <span class="rd-slider-val" id="@UiDomIds.Teleprompter.WidthValue">@_readerTextWidth</span>
                </div>
                <span id="@BuildRailTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipWidthKey)"
                      class="@BuildRailTooltipCssClass(placeOnRightSide: false)"
                      role="tooltip"
                      data-testid="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipWidthKey)"
                      data-test-id="@BuildRailTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipWidthKey)">@ReaderWidthSliderTitle</span>
                </div>
            </div>

            <div class="rd-stage"
                 id="@UiDomIds.Teleprompter.Stage"
                 data-testid="@UiTestIds.Teleprompter.Stage">
                <div class="rd-center-guide"></div>
                <div class="@BuildFocalGuideCssClass()"
                     id="@UiDomIds.Teleprompter.FocalGuide"
                     data-testid="@UiTestIds.Teleprompter.FocalGuide"
                     style="@BuildFocalGuideStyle()"></div>
                <div class="@BuildWidthGuideCssClass(true)"
                     id="@UiDomIds.Teleprompter.WidthGuideLeft"
                     style="@BuildWidthGuideStyle(true)"></div>
                <div class="@BuildWidthGuideCssClass(false)"
                     id="@UiDomIds.Teleprompter.WidthGuideRight"
                     style="@BuildWidthGuideStyle(false)"></div>

                <div class="rd-cluster-wrap"
                     id="@UiDomIds.Teleprompter.ClusterWrap"
                     data-reader-orientation="@BuildReaderOrientationDataAttribute()"
                     data-reader-text-alignment="@BuildReaderTextAlignmentDataAttribute()"
                     data-testid="@UiTestIds.Teleprompter.ClusterWrap"
                     style="@BuildClusterWrapStyle()">
                    @foreach (var entry in _cards.Select((card, index) => (card, index)))
                    {
                        <div class="@BuildReaderCardCssClass(entry.index)"
                             data-testid="@entry.card.TestId">
                            <div class="rd-cluster rd-cluster-active">
                                <div class="rd-cluster-emotion">
                                    <span class="rd-emo-dot" style="background:@entry.card.AccentColor"></span>
                                    <span class="rd-emo-name">@entry.card.EmotionLabel</span>
                                    <span class="rd-emo-wpm">@entry.card.TargetWpm <small>WPM</small></span>
                                </div>
                                <p class="rd-cluster-text"
                                   id="@UiDomIds.Teleprompter.CardText(entry.index)"
                                   style="@BuildReaderCardTextStyle(entry.index)"
                                   data-testid="@UiTestIds.Teleprompter.CardText(entry.index)">
                                    @for (var chunkIndex = 0; chunkIndex < entry.card.Chunks.Count; chunkIndex++)
                                    {
                                        var chunk = entry.card.Chunks[chunkIndex];
                                        var nextChunk = chunkIndex < entry.card.Chunks.Count - 1
                                            ? entry.card.Chunks[chunkIndex + 1]
                                            : null;
                                        if (chunk is ReaderGroupViewModel group)
                                        {
                                            <span class="@BuildReaderGroupCssClass(entry.index, chunkIndex)"
                                                  data-testid="@UiTestIds.Teleprompter.CardGroup(entry.index, chunkIndex)">
                                                @for (var wordIndex = 0; wordIndex < group.Words.Count; wordIndex++)
                                                {
                                                    var word = group.Words[wordIndex];
                                                    <span class="@BuildReaderWordCssClass(entry.index, chunkIndex, wordIndex)"
                                                          id="@UiDomIds.Teleprompter.CardWord(entry.index, chunkIndex, wordIndex)"
                                                          data-ms="@word.DurationMs"
                                                          data-pause-ms="@word.PauseAfterMs"
                                                          data-effective-wpm="@word.EffectiveWpm"
                                                          data-pronunciation="@word.PronunciationGuide"
                                                          @attributes="word.Attributes"
                                                          title="@word.Title"
                                                          style="@word.Style"
                                                          data-testid="@UiTestIds.Teleprompter.CardWord(entry.index, chunkIndex, wordIndex)">@word.Text</span>
                                                    @if (wordIndex < group.Words.Count - 1)
                                                    {
                                                        @(" ")
                                                    }
                                                }
                                            </span>
                                        }
                                        else if (chunk is ReaderPauseViewModel pause)
                                        {
                                            <span class="@pause.CssClass" data-ms="@pause.DurationMs"></span>
                                        }

                                        if (nextChunk is ReaderGroupViewModel)
                                        {
                                            @(" ")
                                        }
                                    }
                                </p>
                            </div>
                        </div>
                    }
                </div>

                <div class="rd-pause-indicator" id="rd-pause-bar">
                    <div class="rd-pause-fill" id="@UiDomIds.Teleprompter.PauseFill"></div>
                </div>
            </div>

            <div class="@BuildReaderEdgeProgressCssClass()">
                <div class="rd-edge-fill" id="@UiDomIds.Teleprompter.ProgressFill" style="@BuildReaderProgressStyle()"></div>
                <div class="rd-edge-segs">
                    @foreach (var entry in _cards.Select((card, index) => (card, index)))
                    {
                        <div style="@BuildEdgeSegmentStyle(entry.card, entry.index)"></div>
                    }
                </div>
            </div>
            <div class="@BuildReaderEdgeInfoCssClass()" data-testid="@UiTestIds.Teleprompter.EdgeInfo">
                <span class="rd-edge-section" data-testid="@UiTestIds.Teleprompter.EdgeSection">@_edgeSectionLabel</span>
                <span class="rd-time"
                      id="@UiDomIds.Teleprompter.Time"
                      data-total-seconds="@_totalSeconds"
                      data-total-ms="@_totalDurationMilliseconds">@BuildElapsedLabel()</span>
            </div>

            <div class="@BuildReaderProgressShellCssClass()" data-testid="@UiTestIds.Teleprompter.Progress">
                <div class="rd-progress-meta">
                    <span class="rd-progress-title">@BuildBlockIndicatorLabel()</span>
                    <span class="rd-progress-label" data-testid="@UiTestIds.Teleprompter.ProgressLabel">@BuildReaderProgressLabel()</span>
                </div>
                <div class="rd-progress-track" data-testid="@UiTestIds.Teleprompter.ProgressSegments">
                    @foreach (var entry in _cards.Select((card, index) => (card, index)))
                    {
                        <div class="rd-progress-segment" style="@BuildReaderProgressSegmentStyle(entry.card)">
                            <div class="rd-progress-segment-fill"
                                 data-testid="@UiTestIds.Teleprompter.ProgressSegmentFill(entry.index)"
                                 style="@BuildReaderProgressSegmentFillStyle(entry.index)"></div>
                        </div>
                    }
                </div>
            </div>

            <div class="@BuildReaderControlsCssClass()" data-testid="@UiTestIds.Teleprompter.Controls">
                <div class="rd-ctrl-group">
                    <button class="rd-ctrl-btn" @onclick="DecreaseReaderFontSizeAsync" title="Smaller text" data-testid="@UiTestIds.Teleprompter.FontDown">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    </button>
                    <span class="rd-ctrl-label" id="@UiDomIds.Teleprompter.FontLabel">@_readerFontSize</span>
                    <button class="rd-ctrl-btn" @onclick="IncreaseReaderFontSizeAsync" title="Larger text" data-testid="@UiTestIds.Teleprompter.FontUp">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    </button>
                </div>

                <div class="rd-ctrl-group rd-ctrl-main">
                    <button class="rd-ctrl-btn" @onclick="JumpToPreviousReaderCardAsync" title="Previous block" data-testid="@UiTestIds.Teleprompter.PreviousBlock"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="19,20 9,12 19,4" /><line x1="5" y1="4" x2="5" y2="20" /></svg></button>
                    <button class="rd-ctrl-btn rd-ctrl-sm" @onclick="StepReaderBackwardAsync" title="Back one word" data-testid="@UiTestIds.Teleprompter.PreviousWord"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15,18 9,12 15,6" /></svg></button>
                    <button class="rd-ctrl-btn rd-ctrl-play" id="tp-play-btn" @onclick="ToggleReaderPlaybackAsync" title="Play / Pause" data-testid="@UiTestIds.Teleprompter.PlayToggle">
                        <span data-toggle-icon="play" hidden="@_isReaderPlaying">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5,3 19,12 5,21" /></svg>
                        </span>
                        <span data-toggle-icon="pause" hidden="@(!_isReaderPlaying)">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16" /><rect x="14" y="4" width="4" height="16" /></svg>
                        </span>
                    </button>
                    <button class="rd-ctrl-btn rd-ctrl-sm" @onclick="StepReaderForwardAsync" title="Forward one word" data-testid="@UiTestIds.Teleprompter.NextWord"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,6 15,12 9,18" /></svg></button>
                    <button class="rd-ctrl-btn" @onclick="JumpToNextReaderCardAsync" title="Next block" data-testid="@UiTestIds.Teleprompter.NextBlock"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5,4 15,12 5,20" /><line x1="19" y1="4" x2="19" y2="20" /></svg></button>
                </div>

                <div class="rd-ctrl-group">
                    <span class="rd-ctrl-label rd-block-indicator" id="@UiDomIds.Teleprompter.BlockIndicator">@BuildBlockIndicatorLabel()</span>
                    <button class="@BuildCameraButtonCssClass()" id="@UiDomIds.Teleprompter.CameraButton" @onclick="ToggleReaderCameraAsync" title="Camera" data-testid="@UiTestIds.Teleprompter.CameraToggle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" /><circle cx="12" cy="13" r="4" /></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
