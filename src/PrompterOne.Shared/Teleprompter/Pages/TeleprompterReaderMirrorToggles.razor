@namespace PrompterOne.Shared.Pages
@using Microsoft.AspNetCore.Components.Web
@using PrompterOne.Shared.Contracts

<div class="rd-mirror-controls" data-test="@UiTestIds.Teleprompter.MirrorControls">
    <div class="rd-rail-tip-anchor"
         @onmouseenter="@(() => HandleTooltipPointerEnter(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey))"
         @onmouseleave="@(() => HandleTooltipPointerLeave(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey))"
         @onfocusin="@(() => HandleTooltipFocusIn(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey))"
         @onfocusout="@(() => HandleTooltipFocusOut(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey))"
         @onpointerdown="@(() => HandleTooltipPointerDown(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey))"
         @onkeydown="@((KeyboardEventArgs args) => HandleTooltipKeyDown(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey, args))">
        <button class="@MirrorHorizontalButtonCssClass"
                @onclick="OnToggleMirrorHorizontal"
                aria-label="@MirrorHorizontalTitle"
                data-active="@BuildBooleanDataAttribute(IsMirrorHorizontal)"
                data-test="@UiTestIds.Teleprompter.MirrorHorizontalToggle">
            @MirrorHorizontalLabel
        </button>
        <span id="@BuildTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey)"
              class="@BuildTooltipCssClass(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey, true)"
              role="tooltip"
              data-test="@BuildTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipMirrorHorizontalKey)">@MirrorHorizontalTitle</span>
    </div>
    <div class="rd-rail-tip-anchor"
         @onmouseenter="@(() => HandleTooltipPointerEnter(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey))"
         @onmouseleave="@(() => HandleTooltipPointerLeave(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey))"
         @onfocusin="@(() => HandleTooltipFocusIn(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey))"
         @onfocusout="@(() => HandleTooltipFocusOut(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey))"
         @onpointerdown="@(() => HandleTooltipPointerDown(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey))"
         @onkeydown="@((KeyboardEventArgs args) => HandleTooltipKeyDown(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey, args))">
        <button class="@MirrorVerticalButtonCssClass"
                @onclick="OnToggleMirrorVertical"
                aria-label="@MirrorVerticalTitle"
                data-active="@BuildBooleanDataAttribute(IsMirrorVertical)"
                data-test="@UiTestIds.Teleprompter.MirrorVerticalToggle">
            @MirrorVerticalLabel
        </button>
        <span id="@BuildTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey)"
              class="@BuildTooltipCssClass(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey, true)"
              role="tooltip"
              data-test="@BuildTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipMirrorVerticalKey)">@MirrorVerticalTitle</span>
    </div>
    <div class="rd-rail-tip-anchor"
         @onmouseenter="@(() => HandleTooltipPointerEnter(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey))"
         @onmouseleave="@(() => HandleTooltipPointerLeave(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey))"
         @onfocusin="@(() => HandleTooltipFocusIn(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey))"
         @onfocusout="@(() => HandleTooltipFocusOut(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey))"
         @onpointerdown="@(() => HandleTooltipPointerDown(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey))"
         @onkeydown="@((KeyboardEventArgs args) => HandleTooltipKeyDown(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey, args))">
        <button class="@OrientationButtonCssClass"
                @onclick="OnToggleOrientation"
                aria-label="@OrientationTitle"
                data-active="@BuildBooleanDataAttribute(IsPortraitOrientation)"
                data-test="@UiTestIds.Teleprompter.OrientationToggle">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M7 3H3v4"></path>
                <path d="M3 7a9 9 0 0 1 14.3-3.6"></path>
                <path d="M17 21h4v-4"></path>
                <path d="M21 17a9 9 0 0 1-14.3 3.6"></path>
            </svg>
        </button>
        <span id="@BuildTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey)"
              class="@BuildTooltipCssClass(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey, true)"
              role="tooltip"
              data-test="@BuildTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipOrientationKey)">@OrientationTitle</span>
    </div>
    <div class="rd-rail-tip-anchor"
         @onmouseenter="@(() => HandleTooltipPointerEnter(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey))"
         @onmouseleave="@(() => HandleTooltipPointerLeave(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey))"
         @onfocusin="@(() => HandleTooltipFocusIn(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey))"
         @onfocusout="@(() => HandleTooltipFocusOut(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey))"
         @onpointerdown="@(() => HandleTooltipPointerDown(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey))"
         @onkeydown="@((KeyboardEventArgs args) => HandleTooltipKeyDown(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey, args))">
        <button class="@FullscreenButtonCssClass"
                @onclick="OnToggleFullscreen"
                aria-label="@FullscreenTitle"
                data-active="@BuildBooleanDataAttribute(IsFullscreenActive)"
                data-test="@UiTestIds.Teleprompter.FullscreenToggle">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <polyline points="8,3 3,3 3,8"></polyline>
                <polyline points="16,3 21,3 21,8"></polyline>
                <polyline points="3,16 3,21 8,21"></polyline>
                <polyline points="16,21 21,21 21,16"></polyline>
            </svg>
        </button>
        <span id="@BuildTooltipDomId(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey)"
              class="@BuildTooltipCssClass(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey, true)"
              role="tooltip"
              data-test="@BuildTooltipTestId(UiTestIds.Teleprompter.AlignmentTooltipFullscreenKey)">@FullscreenTitle</span>
    </div>
    <span class="rd-rail-divider" aria-hidden="true"></span>
</div>

@code {
    [Parameter] public bool IsFullscreenActive { get; set; }
    [Parameter] public bool IsMirrorHorizontal { get; set; }
    [Parameter] public bool IsMirrorVertical { get; set; }
    [Parameter] public bool IsPortraitOrientation { get; set; }
    [Parameter, EditorRequired] public string FullscreenButtonCssClass { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string FullscreenTitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string MirrorHorizontalButtonCssClass { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string MirrorHorizontalLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string MirrorHorizontalTitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string MirrorVerticalButtonCssClass { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string MirrorVerticalLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string MirrorVerticalTitle { get; set; } = string.Empty;
    [Parameter] public EventCallback OnToggleFullscreen { get; set; }
    [Parameter] public EventCallback OnToggleMirrorHorizontal { get; set; }
    [Parameter] public EventCallback OnToggleMirrorVertical { get; set; }
    [Parameter] public EventCallback OnToggleOrientation { get; set; }
    [Parameter, EditorRequired] public string OrientationButtonCssClass { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string OrientationTitle { get; set; } = string.Empty;
    [Parameter] public Action<string>? TooltipFocusIn { get; set; }
    [Parameter] public Action<string>? TooltipFocusOut { get; set; }
    [Parameter] public Action<string, KeyboardEventArgs>? TooltipKeyDown { get; set; }
    [Parameter] public Action<string>? TooltipPointerDown { get; set; }
    [Parameter] public Action<string>? TooltipPointerEnter { get; set; }
    [Parameter] public Action<string>? TooltipPointerLeave { get; set; }
    [Parameter, EditorRequired] public Func<string, bool, string> TooltipCssClassFactory { get; set; } = (_, _) => string.Empty;
    [Parameter, EditorRequired] public Func<string, string> TooltipDomIdFactory { get; set; } = key => key;
    [Parameter, EditorRequired] public Func<string, string> TooltipTestIdFactory { get; set; } = key => key;

    private static string BuildBooleanDataAttribute(bool value) => value ? "true" : "false";

    private string BuildTooltipCssClass(string key, bool placeOnRightSide) => TooltipCssClassFactory(key, placeOnRightSide);

    private string BuildTooltipDomId(string key) => TooltipDomIdFactory(key);

    private string BuildTooltipTestId(string key) => TooltipTestIdFactory(key);

    private void HandleTooltipFocusIn(string key) => TooltipFocusIn?.Invoke(key);

    private void HandleTooltipFocusOut(string key) => TooltipFocusOut?.Invoke(key);

    private void HandleTooltipKeyDown(string key, KeyboardEventArgs args) => TooltipKeyDown?.Invoke(key, args);

    private void HandleTooltipPointerDown(string key) => TooltipPointerDown?.Invoke(key);

    private void HandleTooltipPointerEnter(string key) => TooltipPointerEnter?.Invoke(key);

    private void HandleTooltipPointerLeave(string key) => TooltipPointerLeave?.Invoke(key);
}
