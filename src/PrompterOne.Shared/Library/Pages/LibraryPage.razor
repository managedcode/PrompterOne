@page "/"
@page "/library"
@namespace PrompterOne.Shared.Pages
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<div id="screen-library"
     class="screen active"
     data-test="@UiTestIds.Library.Page"
     @onclick="HandleLibrarySurfaceClick">
    <LibrarySidebar Folders="_folderNodes"
                    AllScriptCount="_allCards.Count"
                    IsAllSelected="IsAllSelected"
                    OnSelectFolder="SelectFolder"
                    OnStartCreateFolder="StartCreateFolder" />

    <main class="lib-main">
        <div class="lib-scroll">
            <div class="lib-sort-bar">
                <span class="sort-label" data-test="@UiTestIds.Library.SortLabel">@Text(UiTextKey.LibrarySortBy)</span>
                <button class="sort-btn @GetSortClass(LibrarySortMode.Name)"
                        @onclick="() => SetSortMode(LibrarySortMode.Name)"
                        data-active="@(GetSortModeState(LibrarySortMode.Name))"
                        data-test="@UiTestIds.Library.SortName">@Text(UiTextKey.LibrarySortName)</button>
                <button class="sort-btn @GetSortClass(LibrarySortMode.Date)"
                        @onclick="() => SetSortMode(LibrarySortMode.Date)"
                        data-active="@(GetSortModeState(LibrarySortMode.Date))"
                        data-test="@UiTestIds.Library.SortDate">@Text(UiTextKey.LibrarySortDate)</button>
                <button class="sort-btn @GetSortClass(LibrarySortMode.Duration)"
                        @onclick="() => SetSortMode(LibrarySortMode.Duration)"
                        data-active="@(GetSortModeState(LibrarySortMode.Duration))"
                        data-test="@UiTestIds.Library.SortDuration">@Text(UiTextKey.LibrarySortDuration)</button>
                <button class="sort-btn @GetSortClass(LibrarySortMode.Wpm)"
                        @onclick="() => SetSortMode(LibrarySortMode.Wpm)"
                        data-active="@(GetSortModeState(LibrarySortMode.Wpm))"
                        data-test="@UiTestIds.Library.SortWpm">@Text(UiTextKey.LibrarySortWpm)</button>
            </div>

            <LibraryCardsGrid Cards="_cards"
                              DismissMenuRevision="_dismissCardMenuRevision"
                              FolderOptions="_folderOptions"
                              OnOpenScript="OpenScriptAsync"
                              OnDuplicateScript="DuplicateScriptAsync"
                              OnMoveScript="MoveScriptAsync"
                              OnDeleteScript="DeleteScriptAsync"
                              OnLearnScript="LearnScriptAsync"
                              OnReadScript="ReadScriptAsync"
                              OnCreateScript="CreateScriptAsync"
                              OnStartCreateFolder="StartCreateFolder" />
        </div>
    </main>
</div>

@if (_isCreatingFolder)
{
    <LibraryFolderCreateModal FolderOptions="@_folderOptions"
                              FolderDraftName="@_folderDraftName"
                              FolderDraftParentId="@_folderDraftParentId"
                              OnCancelCreateFolder="CancelCreateFolder"
                              OnSubmitCreateFolder="SubmitCreateFolderAsync"
                              OnFolderDraftNameChanged="UpdateFolderDraftName"
                              OnFolderDraftParentChanged="UpdateFolderDraftParent" />
}

@code {
    private const string ActiveStateValue = "active";
    private const string InactiveStateValue = "inactive";

    private string GetSortModeState(LibrarySortMode sortMode) =>
        sortMode == _sortMode ? ActiveStateValue : InactiveStateValue;

    private string Text(UiTextKey key) => Localizer[key.ToString()];

    private string Format(UiTextKey key, params object[] arguments) =>
        string.Format(System.Globalization.CultureInfo.CurrentCulture, Text(key), arguments);
}
