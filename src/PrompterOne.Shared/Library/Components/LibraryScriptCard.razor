@namespace PrompterOne.Shared.Components.Library
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<article class="dcard"
         style="--emo:@Card.AccentColor"
         @onclick="HandleCardClickAsync"
         data-test="@Card.TestId">
    <div class="@MenuWrapCssClass"
         data-expanded="@MenuExpandedState"
         data-test="@UiTestIds.Library.CardMenuWrap(Card.Id)"
         @onclick:stopPropagation="true">
        <TooltipAnchor OwnerTestId="@UiTestIds.Library.CardMenu(Card.Id)"
                       Placement="TooltipPlacement.LeftCenter"
                       Text="@Text(UiTextKey.TooltipMoreScriptActions)">
            <button class="dcard-menu-btn"
                    type="button"
                    aria-label="@Text(UiTextKey.TooltipMoreScriptActions)"
                    data-test="@UiTestIds.Library.CardMenu(Card.Id)"
                    @onclick:stopPropagation="true"
                    @onclick="HandleToggleMenuAsync">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <circle cx="12" cy="5" r="2" />
                    <circle cx="12" cy="12" r="2" />
                    <circle cx="12" cy="19" r="2" />
                </svg>
            </button>
        </TooltipAnchor>
        @if (IsMenuOpen)
        {
            <div class="dcard-dropdown"
                 data-test="@UiTestIds.Library.CardMenuDropdown(Card.Id)"
                 @onclick:stopPropagation="true">
                <button type="button"
                        @onclick:stopPropagation="true"
                        @onclick="HandleOpenScriptAsync">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                    </svg>
                    @Text(UiTextKey.CommonRename)
                </button>
                <button type="button"
                        @onclick:stopPropagation="true"
                        @onclick="HandleDuplicateScriptAsync"
                        data-test="@UiTestIds.Library.CardDuplicate(Card.Id)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="9" y="9" width="13" height="13" rx="2" />
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                    </svg>
                    @Text(UiTextKey.CommonDuplicate)
                </button>
                <div class="dcard-dropdown-group">
                    <div class="dcard-dropdown-label">@Text(UiTextKey.CommonMoveToEllipsis)</div>
                    <button type="button"
                            data-test="@UiTestIds.Library.Move(Card.Id, LibrarySelectionKeys.None)"
                            @onclick:stopPropagation="true"
                            @onclick="() => HandleMoveScriptAsync(null)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="6" y1="6" x2="18" y2="18" />
                            <line x1="6" y1="18" x2="18" y2="6" />
                        </svg>
                        @Text(UiTextKey.CommonNoFolder)
                    </button>
                    @foreach (var folder in FolderOptions)
                    {
                        <button type="button"
                                data-test="@UiTestIds.Library.Move(Card.Id, folder.Id)"
                                @onclick:stopPropagation="true"
                                @onclick="() => HandleMoveScriptAsync(folder.Id)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                            </svg>
                            @folder.Label
                        </button>
                    }
                </div>
                <div class="dcard-dropdown-sep"></div>
                <button type="button"
                        class="dcard-dropdown-danger"
                        @onclick:stopPropagation="true"
                        @onclick="HandleDeleteScriptAsync">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3,6 5,6 21,6" />
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                    </svg>
                    @Text(UiTextKey.CommonDelete)
                </button>
            </div>
        }
    </div>
    <div class="dcard-inner" data-test="@UiTestIds.Library.CardSurface(Card.Id)">
        <div class="dcard-cover @Card.CoverClass">
            <div class="dcover-orb dcover-orb1"></div>
            <div class="dcover-orb dcover-orb2"></div>
            <h3 class="dcard-title">@Card.Title</h3>
            <div class="dcover-meta">
                <span class="dcover-emo">@Card.Emotion</span>
                <span>@Card.ModeLabel</span>
                <span data-test="@UiTestIds.Library.CardDuration(Card.Id)">@Card.DurationLabel</span>
            </div>
        </div>
        <div class="dcard-data">
            <div class="ddata-row">
                <span data-test="@UiTestIds.Library.CardWpm(Card.Id)">@Card.AverageWpm @Text(UiTextKey.CommonWpm)</span>
                <span data-test="@UiTestIds.Library.CardWordCount(Card.Id)">@Format(UiTextKey.LibraryCardWordsFormat, Card.WordCount)</span>
                <span data-test="@UiTestIds.Library.CardSegmentCount(Card.Id)">@BuildSegmentCountLabel(Card.SegmentCount)</span>
            </div>
            <div class="ddata-foot">
                <span>@Card.Author</span>
                <span>@Card.UpdatedLabel</span>
            </div>
        </div>
        <div class="dcard-actions">
            <button class="dcard-act"
                    @onclick:stopPropagation="true"
                    @onclick="HandleLearnScriptAsync"
                    data-test="@UiTestIds.Library.CardLearn(Card.Id)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                </svg>
                @Text(UiTextKey.LibraryCardLearn)
            </button>
            <button class="dcard-act dcard-act-go"
                    @onclick:stopPropagation="true"
                    @onclick="HandleReadScriptAsync"
                    data-test="@UiTestIds.Library.CardRead(Card.Id)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="5,3 19,12 5,21" />
                </svg>
                @Text(UiTextKey.LibraryCardRead)
            </button>
        </div>
    </div>
</article>

@code {
    private const string CardMenuWrapClass = "dcard-menu-wrap";
    private const string CardMenuWrapOpenClass = CardMenuWrapClass + " open";
    private const string ExpandedStateClosedValue = "closed";
    private const string ExpandedStateOpenValue = "open";

    private string MenuExpandedState => IsMenuOpen ? ExpandedStateOpenValue : ExpandedStateClosedValue;

    private string MenuWrapCssClass => IsMenuOpen ? CardMenuWrapOpenClass : CardMenuWrapClass;

    [Parameter, EditorRequired] public LibraryCardViewModel Card { get; set; } = null!;
    [Parameter, EditorRequired] public IReadOnlyList<LibraryFolderOptionViewModel> FolderOptions { get; set; } = [];
    [Parameter] public bool IsMenuOpen { get; set; }
    [Parameter] public EventCallback OnCardClick { get; set; }
    [Parameter] public EventCallback OnDeleteScript { get; set; }
    [Parameter] public EventCallback OnDuplicateScript { get; set; }
    [Parameter] public EventCallback OnLearnScript { get; set; }
    [Parameter] public EventCallback<string?> OnMoveScript { get; set; }
    [Parameter] public EventCallback OnOpenScript { get; set; }
    [Parameter] public EventCallback OnReadScript { get; set; }
    [Parameter] public EventCallback OnToggleMenu { get; set; }

    private string BuildSegmentCountLabel(int segmentCount) =>
        segmentCount == 1
            ? Text(UiTextKey.LibraryCardOneSegment)
            : Format(UiTextKey.LibraryCardSegmentsFormat, segmentCount);

    private string Format(UiTextKey key, params object[] args) => Localizer[key.ToString(), args];

    private Task HandleCardClickAsync() => OnCardClick.InvokeAsync();

    private Task HandleDeleteScriptAsync() => OnDeleteScript.InvokeAsync();

    private Task HandleDuplicateScriptAsync() => OnDuplicateScript.InvokeAsync();

    private Task HandleLearnScriptAsync() => OnLearnScript.InvokeAsync();

    private Task HandleMoveScriptAsync(string? folderId) => OnMoveScript.InvokeAsync(folderId);

    private Task HandleOpenScriptAsync() => OnOpenScript.InvokeAsync();

    private Task HandleReadScriptAsync() => OnReadScript.InvokeAsync();

    private Task HandleToggleMenuAsync() => OnToggleMenu.InvokeAsync();

    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
