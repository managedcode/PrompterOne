@using System.Globalization
@namespace PrompterOne.Shared.Components

<div class="@CssClassValue" style="@WidthStyle" @attributes="AdditionalAttributes"></div>

@code {
    private const string BaseCssClass = "ui-percent-fill";
    private const string WidthStyleFormat = "width:{0:0.##}%";

    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] public double Percent { get; set; }

    private string CssClassValue =>
        string.IsNullOrWhiteSpace(Class) ? BaseCssClass : $"{BaseCssClass} {Class}";

    private string WidthStyle =>
        string.Format(CultureInfo.InvariantCulture, WidthStyleFormat, Math.Clamp(Percent, 0d, 100d));
}
