@namespace PrompterOne.Shared.Components

<span class="@CssClassValue" aria-hidden="@AriaHidden">
    <span class="ui-crosshair-guide__line ui-crosshair-guide__line--vertical"></span>
    <span class="ui-crosshair-guide__line ui-crosshair-guide__line--horizontal"></span>
    <span class="ui-crosshair-guide__dot"></span>
</span>

@code {
    private const string BaseCssClass = "ui-crosshair-guide";

    [Parameter] public bool AriaHidden { get; set; } = true;
    [Parameter] public string CssClass { get; set; } = string.Empty;

    private string CssClassValue =>
        string.IsNullOrWhiteSpace(CssClass) ? BaseCssClass : $"{BaseCssClass} {CssClass}";
}
