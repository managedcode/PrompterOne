@namespace PrompterOne.Shared.Components.Settings
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Contracts
@using PrompterOne.Shared.Localization
@using PrompterOne.Shared.Pages
@using PrompterOne.Shared.Settings.Components
@using PrompterOne.Shared.Settings.Models
@inject IStringLocalizer<SharedResource> Localizer

<section class="set-section set-panel"
         id="set-ai"
         style="@DisplayStyle"
         data-test="@UiTestIds.Settings.AiPanel">
    <h3 class="set-section-title">@Text(UiTextKey.SettingsAiSectionTitle)</h3>
    <p class="set-section-desc">@Text(UiTextKey.SettingsAiSectionDescription)</p>

    <div class="set-device-list">
        <SettingsAiProviderCard Title="@Text(UiTextKey.SettingsAiClaudeTitle)"
                                Subtitle="@BuildClaudeSubtitle(_settings.ClaudeApi)"
                                StatusLabel="@BuildStatusLabel(SettingsAiProviderIds.ClaudeApi)"
                                StatusClass="@BuildStatusClass(SettingsAiProviderIds.ClaudeApi)"
                                IconTone="UiIconSurfaceTone.Gold"
                                AdditionalCssClass="@BuildCardCssClass(_settings.ClaudeApi.IsConfigured())"
                                IsOpen="@IsCardOpen(ClaudeApiCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(ClaudeApiCardId))"
                                SubtitleTestId="@UiTestIds.Settings.AiProviderSubtitle(SettingsAiProviderIds.ClaudeApi)"
                                TestId="@UiTestIds.Settings.AiProvider(SettingsAiProviderIds.ClaudeApi)"
                                Save="@(() => SaveProviderAsync(SettingsAiProviderIds.ClaudeApi))"
                                Clear="@(() => ClearProviderAsync(SettingsAiProviderIds.ClaudeApi, () => _settings.ClaudeApi = new AnthropicAiProviderSettings()))"
                                SaveTestId="@UiTestIds.Settings.AiProviderSave(SettingsAiProviderIds.ClaudeApi)"
                                ClearTestId="@UiTestIds.Settings.AiProviderClear(SettingsAiProviderIds.ClaudeApi)"
                                Message="@GetMessage(SettingsAiProviderIds.ClaudeApi)"
                                MessageTestId="@UiTestIds.Settings.AiProviderMessage(SettingsAiProviderIds.ClaudeApi)">
            <Icon>
                <UiIcon Kind="UiIconKind.Spark" Size="17" />
            </Icon>
            <ChildContent>
                <div class="set-device-fields">
                    <div class="set-field">
                        <label>@Text(UiTextKey.CommonApiKey)</label>
                        <input type="password"
                               class="set-input"
                               placeholder="sk-ant-..."
                               data-test="@UiTestIds.Settings.AiProviderField(SettingsAiProviderIds.ClaudeApi, ApiKeyFieldId)"
                               @bind="_settings.ClaudeApi.ApiKey"
                               @onclick:stopPropagation="true" />
                    </div>
                    <div class="set-field">
                        <label>@Text(UiTextKey.CommonBaseUrlOptional)</label>
                        <input type="text"
                               class="set-input"
                               placeholder="https://api.anthropic.com"
                               data-test="@UiTestIds.Settings.AiProviderField(SettingsAiProviderIds.ClaudeApi, UrlFieldId)"
                               @bind="_settings.ClaudeApi.BaseUrl"
                               @onclick:stopPropagation="true" />
                    </div>
                </div>

                <SettingsAiModelCatalog ProviderId="@SettingsAiProviderIds.ClaudeApi"
                                        Models="@_settings.ClaudeApi.Models"
                                        ModelNameLabel="@Text(UiTextKey.CommonModel)"
                                        ModelNamePlaceholder="model-name"
                                        OnChanged="HandleModelCatalogChangedAsync" />
            </ChildContent>
        </SettingsAiProviderCard>

        <SettingsAiProviderCard Title="@Text(UiTextKey.SettingsAiOpenAiTitle)"
                                Subtitle="@BuildOpenAiSubtitle(_settings.OpenAi)"
                                StatusLabel="@BuildStatusLabel(SettingsAiProviderIds.OpenAi)"
                                StatusClass="@BuildStatusClass(SettingsAiProviderIds.OpenAi)"
                                IconTone="UiIconSurfaceTone.Emerald"
                                AdditionalCssClass="@BuildCardCssClass(_settings.OpenAi.IsConfigured())"
                                IsOpen="@IsCardOpen(OpenAiCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(OpenAiCardId))"
                                SubtitleTestId="@UiTestIds.Settings.AiProviderSubtitle(SettingsAiProviderIds.OpenAi)"
                                TestId="@UiTestIds.Settings.AiProvider(SettingsAiProviderIds.OpenAi)"
                                Save="@(() => SaveProviderAsync(SettingsAiProviderIds.OpenAi))"
                                Clear="@(() => ClearProviderAsync(SettingsAiProviderIds.OpenAi, () => _settings.OpenAi = new OpenAiProviderSettings()))"
                                SaveTestId="@UiTestIds.Settings.AiProviderSave(SettingsAiProviderIds.OpenAi)"
                                ClearTestId="@UiTestIds.Settings.AiProviderClear(SettingsAiProviderIds.OpenAi)"
                                Message="@GetMessage(SettingsAiProviderIds.OpenAi)"
                                MessageTestId="@UiTestIds.Settings.AiProviderMessage(SettingsAiProviderIds.OpenAi)">
            <Icon>
                <UiIcon Kind="UiIconKind.OpenAiBurst" Size="17" />
            </Icon>
            <ChildContent>
                <div class="set-device-fields">
                    <div class="set-field">
                        <label>@Text(UiTextKey.CommonApiKey)</label>
                        <input type="password"
                               class="set-input"
                               placeholder="sk-..."
                               data-test="@UiTestIds.Settings.AiProviderField(SettingsAiProviderIds.OpenAi, ApiKeyFieldId)"
                               @bind="_settings.OpenAi.ApiKey"
                               @onclick:stopPropagation="true" />
                    </div>
                    <div class="set-field">
                        <label>@Text(UiTextKey.CommonBaseUrlOptional)</label>
                        <input type="text"
                               class="set-input"
                               placeholder="https://api.openai.com/v1"
                               data-test="@UiTestIds.Settings.AiProviderField(SettingsAiProviderIds.OpenAi, UrlFieldId)"
                               @bind="_settings.OpenAi.BaseUrl"
                               @onclick:stopPropagation="true" />
                    </div>
                </div>

                <SettingsAiModelCatalog ProviderId="@SettingsAiProviderIds.OpenAi"
                                        Models="@_settings.OpenAi.Models"
                                        ModelNameLabel="@Text(UiTextKey.CommonModel)"
                                        ModelNamePlaceholder="model-name"
                                        OnChanged="HandleModelCatalogChangedAsync" />
            </ChildContent>
        </SettingsAiProviderCard>

        <SettingsAiProviderCard Title="@Text(UiTextKey.SettingsAiAzureOpenAiTitle)"
                                Subtitle="@BuildAzureOpenAiSubtitle(_settings.AzureOpenAi)"
                                StatusLabel="@BuildStatusLabel(SettingsAiProviderIds.AzureOpenAi)"
                                StatusClass="@BuildStatusClass(SettingsAiProviderIds.AzureOpenAi)"
                                IconTone="UiIconSurfaceTone.Cobalt"
                                AdditionalCssClass="@BuildCardCssClass(_settings.AzureOpenAi.IsConfigured())"
                                IsOpen="@IsCardOpen(AzureOpenAiCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(AzureOpenAiCardId))"
                                SubtitleTestId="@UiTestIds.Settings.AiProviderSubtitle(SettingsAiProviderIds.AzureOpenAi)"
                                TestId="@UiTestIds.Settings.AiProvider(SettingsAiProviderIds.AzureOpenAi)"
                                Save="@(() => SaveProviderAsync(SettingsAiProviderIds.AzureOpenAi))"
                                Clear="@(() => ClearProviderAsync(SettingsAiProviderIds.AzureOpenAi, () => _settings.AzureOpenAi = new AzureOpenAiProviderSettings()))"
                                SaveTestId="@UiTestIds.Settings.AiProviderSave(SettingsAiProviderIds.AzureOpenAi)"
                                ClearTestId="@UiTestIds.Settings.AiProviderClear(SettingsAiProviderIds.AzureOpenAi)"
                                Message="@GetMessage(SettingsAiProviderIds.AzureOpenAi)"
                                MessageTestId="@UiTestIds.Settings.AiProviderMessage(SettingsAiProviderIds.AzureOpenAi)">
            <Icon>
                <UiIcon Kind="UiIconKind.Cloud" Size="17" />
            </Icon>
            <ChildContent>
                <div class="set-device-fields">
                    <div class="set-field">
                        <label>@Text(UiTextKey.CommonEndpoint)</label>
                        <input type="text"
                               class="set-input"
                               placeholder="https://your-resource.openai.azure.com"
                               data-test="@UiTestIds.Settings.AiProviderField(SettingsAiProviderIds.AzureOpenAi, EndpointFieldId)"
                               @bind="_settings.AzureOpenAi.Endpoint"
                               @onclick:stopPropagation="true" />
                    </div>
                    <div class="set-field">
                        <label>@Text(UiTextKey.CommonApiKey)</label>
                        <input type="password"
                               class="set-input"
                               placeholder="azure-openai-key"
                               data-test="@UiTestIds.Settings.AiProviderField(SettingsAiProviderIds.AzureOpenAi, ApiKeyFieldId)"
                               @bind="_settings.AzureOpenAi.ApiKey"
                               @onclick:stopPropagation="true" />
                    </div>
                </div>

                <SettingsAiModelCatalog ProviderId="@SettingsAiProviderIds.AzureOpenAi"
                                        Models="@_settings.AzureOpenAi.Models"
                                        ModelNameLabel="@Text(UiTextKey.CommonDeployment)"
                                        ModelNamePlaceholder="deployment-name"
                                        OnChanged="HandleModelCatalogChangedAsync" />
            </ChildContent>
        </SettingsAiProviderCard>

        <SettingsAiProviderCard Title="@Text(UiTextKey.SettingsAiOllamaTitle)"
                                Subtitle="@BuildOllamaSubtitle(_settings.Ollama)"
                                StatusLabel="@BuildStatusLabel(SettingsAiProviderIds.Ollama)"
                                StatusClass="@BuildStatusClass(SettingsAiProviderIds.Ollama)"
                                IconTone="UiIconSurfaceTone.Indigo"
                                AdditionalCssClass="@BuildCardCssClass(_settings.Ollama.IsConfigured())"
                                IsOpen="@IsCardOpen(OllamaCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(OllamaCardId))"
                                SubtitleTestId="@UiTestIds.Settings.AiProviderSubtitle(SettingsAiProviderIds.Ollama)"
                                TestId="@UiTestIds.Settings.AiProvider(SettingsAiProviderIds.Ollama)"
                                Save="@(() => SaveProviderAsync(SettingsAiProviderIds.Ollama))"
                                Clear="@(() => ClearProviderAsync(SettingsAiProviderIds.Ollama, () => _settings.Ollama = new OllamaAiProviderSettings()))"
                                SaveTestId="@UiTestIds.Settings.AiProviderSave(SettingsAiProviderIds.Ollama)"
                                ClearTestId="@UiTestIds.Settings.AiProviderClear(SettingsAiProviderIds.Ollama)"
                                Message="@GetMessage(SettingsAiProviderIds.Ollama)"
                                MessageTestId="@UiTestIds.Settings.AiProviderMessage(SettingsAiProviderIds.Ollama)">
            <Icon>
                <UiIcon Kind="UiIconKind.Monitor" Size="17" />
            </Icon>
            <ChildContent>
                <div class="set-device-fields">
                    <div class="set-field">
                        <label>@Text(UiTextKey.SettingsAiOllamaUrlLabel)</label>
                        <input type="text"
                               class="set-input"
                               placeholder="http://localhost:11434"
                               data-test="@UiTestIds.Settings.AiProviderField(SettingsAiProviderIds.Ollama, UrlFieldId)"
                               @bind="_settings.Ollama.Endpoint"
                               @onclick:stopPropagation="true" />
                    </div>
                </div>

                <SettingsAiModelCatalog ProviderId="@SettingsAiProviderIds.Ollama"
                                        Models="@_settings.Ollama.Models"
                                        ModelNameLabel="@Text(UiTextKey.CommonModel)"
                                        ModelNamePlaceholder="model-name"
                                        OnChanged="HandleModelCatalogChangedAsync" />
            </ChildContent>
        </SettingsAiProviderCard>

        <SettingsAiProviderCard Title="@Text(UiTextKey.SettingsAiLlamaSharpTitle)"
                                Subtitle="@BuildLlamaSharpSubtitle(_settings.LlamaSharp)"
                                StatusLabel="@BuildStatusLabel(SettingsAiProviderIds.LlamaSharp)"
                                StatusClass="@BuildStatusClass(SettingsAiProviderIds.LlamaSharp)"
                                IconTone="UiIconSurfaceTone.Slate"
                                AdditionalCssClass="@BuildCardCssClass(_settings.LlamaSharp.IsConfigured())"
                                IsOpen="@IsCardOpen(LlamaSharpCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(LlamaSharpCardId))"
                                SubtitleTestId="@UiTestIds.Settings.AiProviderSubtitle(SettingsAiProviderIds.LlamaSharp)"
                                TestId="@UiTestIds.Settings.AiProvider(SettingsAiProviderIds.LlamaSharp)"
                                Save="@(() => SaveProviderAsync(SettingsAiProviderIds.LlamaSharp))"
                                Clear="@(() => ClearProviderAsync(SettingsAiProviderIds.LlamaSharp, () => _settings.LlamaSharp = new LlamaSharpProviderSettings()))"
                                SaveTestId="@UiTestIds.Settings.AiProviderSave(SettingsAiProviderIds.LlamaSharp)"
                                ClearTestId="@UiTestIds.Settings.AiProviderClear(SettingsAiProviderIds.LlamaSharp)"
                                Message="@GetMessage(SettingsAiProviderIds.LlamaSharp)"
                                MessageTestId="@UiTestIds.Settings.AiProviderMessage(SettingsAiProviderIds.LlamaSharp)">
            <Icon>
                <UiIcon Kind="UiIconKind.Database" Size="17" />
            </Icon>
            <ChildContent>
                <SettingsAiModelCatalog ProviderId="@SettingsAiProviderIds.LlamaSharp"
                                        Models="@_settings.LlamaSharp.Models"
                                        ModelNameLabel="@Text(UiTextKey.CommonModel)"
                                        ModelNamePlaceholder="model-name"
                                        ModelPathPlaceholder="/models/local-model.gguf"
                                        ShowModelPath="true"
                                        OnChanged="HandleModelCatalogChangedAsync" />
            </ChildContent>
        </SettingsAiProviderCard>
    </div>
</section>

@code {
    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
