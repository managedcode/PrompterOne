        AppHotkeyIds.Definitions.EditorRedo => Text(UiTextKey.SettingsHotkeyEditorRedoLabel),
        AppHotkeyIds.Definitions.EditorSelectAll => Text(UiTextKey.SettingsHotkeyEditorSelectAllLabel),
        AppHotkeyIds.Definitions.LearnBack => Text(UiTextKey.SettingsHotkeyLearnBackLabel),
        AppHotkeyIds.Definitions.LearnPlayPause => Text(UiTextKey.SettingsHotkeyLearnPlayPauseLabel),
        AppHotkeyIds.Definitions.LearnSpeedDown => Text(UiTextKey.SettingsHotkeyLearnSpeedDownLabel),
        AppHotkeyIds.Definitions.LearnSpeedUp => Text(UiTextKey.SettingsHotkeyLearnSpeedUpLabel),
        AppHotkeyIds.Definitions.LearnStepBackward => Text(UiTextKey.SettingsHotkeyLearnStepBackwardLabel),
        AppHotkeyIds.Definitions.LearnStepBackwardLarge => Text(UiTextKey.SettingsHotkeyLearnStepBackwardLargeLabel),
        AppHotkeyIds.Definitions.LearnStepForward => Text(UiTextKey.SettingsHotkeyLearnStepForwardLabel),
        AppHotkeyIds.Definitions.LearnStepForwardLarge => Text(UiTextKey.SettingsHotkeyLearnStepForwardLargeLabel),
        AppHotkeyIds.Definitions.LearnToggleLoop => Text(UiTextKey.SettingsHotkeyLearnLoopLabel),
        AppHotkeyIds.Definitions.TeleprompterBack => Text(UiTextKey.SettingsHotkeyTeleprompterBackLabel),
        AppHotkeyIds.Definitions.TeleprompterPlayPause => Text(UiTextKey.SettingsHotkeyTeleprompterPlayPauseLabel),
        AppHotkeyIds.Definitions.TeleprompterPreviousBlock => Text(UiTextKey.SettingsHotkeyTeleprompterPreviousBlockLabel),
        AppHotkeyIds.Definitions.TeleprompterNextBlock => Text(UiTextKey.SettingsHotkeyTeleprompterNextBlockLabel),
        AppHotkeyIds.Definitions.TeleprompterMirrorHorizontal => Text(UiTextKey.SettingsHotkeyTeleprompterMirrorHorizontalLabel),
        AppHotkeyIds.Definitions.TeleprompterMirrorVertical => Text(UiTextKey.SettingsHotkeyTeleprompterMirrorVerticalLabel),
        AppHotkeyIds.Definitions.TeleprompterOrientation => Text(UiTextKey.SettingsHotkeyTeleprompterOrientationLabel),
        AppHotkeyIds.Definitions.TeleprompterFullscreen => Text(UiTextKey.SettingsHotkeyTeleprompterFullscreenLabel),
        AppHotkeyIds.Definitions.TeleprompterAlignmentLeft => Text(UiTextKey.SettingsHotkeyTeleprompterAlignLeftLabel),
        AppHotkeyIds.Definitions.TeleprompterAlignmentCenter => Text(UiTextKey.SettingsHotkeyTeleprompterAlignCenterLabel),
        AppHotkeyIds.Definitions.TeleprompterAlignmentRight => Text(UiTextKey.SettingsHotkeyTeleprompterAlignRightLabel),
        AppHotkeyIds.Definitions.TeleprompterAlignmentJustify => Text(UiTextKey.SettingsHotkeyTeleprompterAlignJustifyLabel),
        AppHotkeyIds.Definitions.TeleprompterCamera => Text(UiTextKey.SettingsHotkeyTeleprompterCameraLabel),
        AppHotkeyIds.Definitions.GoLiveDirectorMode => Text(UiTextKey.SettingsHotkeyGoLiveDirectorModeLabel),
        AppHotkeyIds.Definitions.GoLiveStudioMode => Text(UiTextKey.SettingsHotkeyGoLiveStudioModeLabel),
        AppHotkeyIds.Definitions.GoLiveToggleLeftRail => Text(UiTextKey.SettingsHotkeyGoLiveLeftRailLabel),
        AppHotkeyIds.Definitions.GoLiveToggleRightRail => Text(UiTextKey.SettingsHotkeyGoLiveRightRailLabel),
        AppHotkeyIds.Definitions.GoLiveToggleFullProgram => Text(UiTextKey.SettingsHotkeyGoLiveFullProgramLabel),
        AppHotkeyIds.Definitions.GoLiveTakeToAir => Text(UiTextKey.SettingsHotkeyGoLiveTakeToAirLabel),
        AppHotkeyIds.Definitions.GoLiveToggleRecording => Text(UiTextKey.SettingsHotkeyGoLiveRecordingLabel),
        AppHotkeyIds.Definitions.GoLiveToggleStream => Text(UiTextKey.SettingsHotkeyGoLiveStreamLabel),
        _ => definition.Id
    };

    private string GroupSubtitle(AppHotkeyGroup group) => group.Id switch
    {
        AppHotkeyIds.Groups.Editor => Text(UiTextKey.SettingsHotkeysGroupEditorSubtitle),
        AppHotkeyIds.Groups.Learn => Text(UiTextKey.SettingsHotkeysGroupLearnSubtitle),
        AppHotkeyIds.Groups.Teleprompter => Text(UiTextKey.SettingsHotkeysGroupTeleprompterSubtitle),
        AppHotkeyIds.Groups.GoLive => Text(UiTextKey.SettingsHotkeysGroupGoLiveSubtitle),
        _ => group.Id
    };

    private string GroupTitle(AppHotkeyGroup group) => group.Id switch
    {
        AppHotkeyIds.Groups.Editor => Text(UiTextKey.SettingsHotkeysGroupEditorTitle),
        AppHotkeyIds.Groups.Learn => Text(UiTextKey.SettingsHotkeysGroupLearnTitle),
        AppHotkeyIds.Groups.Teleprompter => Text(UiTextKey.SettingsHotkeysGroupTeleprompterTitle),
        AppHotkeyIds.Groups.GoLive => Text(UiTextKey.SettingsHotkeysGroupGoLiveTitle),
        _ => group.Id
    };

    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
