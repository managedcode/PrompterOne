@namespace PrompterOne.Shared.Components.Settings
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Contracts
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<section class="set-section set-panel"
         id="set-shortcuts"
         style="@DisplayStyle"
         data-testid="@UiTestIds.Settings.ShortcutsPanel"
         data-test-id="@UiTestIds.Settings.ShortcutsPanel">
    <h3 class="set-section-title">@Text(UiTextKey.SettingsShortcutsSectionTitle)</h3>
    <p class="set-section-desc">@Text(UiTextKey.SettingsShortcutsSectionDescription)</p>

    <div class="set-device-list">
        @foreach (var group in AppHotkeys.Groups)
        {
            <SettingsExpandableCard Title="@GroupTitle(group)"
                                    Subtitle="@GroupSubtitle(group)"
                                    IconTone="@BuildIconTone(group.Surface)"
                                    IsOpen="@IsCardOpen(group.Id)"
                                    OnToggle="@(() => ToggleCard.InvokeAsync(group.Id))"
                                    TestId="@UiTestIds.Settings.ShortcutsGroup(group.Id)">
                <UiIcon Kind="UiIconKind.Keyboard" Size="17" />
                <div class="set-shortcut-grid">
                    @foreach (var definition in group.Definitions)
                    {
                        <div class="set-shortcut-row"
                             data-testid="@UiTestIds.Settings.ShortcutsAction(group.Id, definition.Id)"
                             data-test-id="@UiTestIds.Settings.ShortcutsAction(group.Id, definition.Id)">
                            <div class="set-shortcut-copy">
                                <span class="set-shortcut-name">@ActionLabel(definition)</span>
                                <span class="set-shortcut-desc">@ActionDescription(definition)</span>
                            </div>
                            <div class="set-shortcut-chords">
                                @foreach (var shortcut in definition.Shortcuts)
                                {
                                    <kbd class="set-shortcut-key">@shortcut.DisplayText</kbd>
                                }
                            </div>
                        </div>
                    }
                </div>
            </SettingsExpandableCard>
        }
    </div>
</section>

@code {
    [Parameter] public string DisplayStyle { get; set; } = string.Empty;

    [Parameter] public Func<string, bool> IsCardOpen { get; set; } = _ => false;

    [Parameter] public EventCallback<string> ToggleCard { get; set; }

    private static UiIconSurfaceTone BuildIconTone(AppHotkeySurface surface) => surface switch
    {
        AppHotkeySurface.Editor => UiIconSurfaceTone.Indigo,
        AppHotkeySurface.Learn => UiIconSurfaceTone.Emerald,
        AppHotkeySurface.Teleprompter => UiIconSurfaceTone.Amber,
        AppHotkeySurface.GoLive => UiIconSurfaceTone.Red,
        _ => UiIconSurfaceTone.Slate
    };

    private string ActionDescription(AppHotkeyDefinition definition) => definition.Id switch
    {
        AppHotkeyIds.Definitions.EditorUndo => Text(UiTextKey.SettingsHotkeyEditorUndoDescription),
        AppHotkeyIds.Definitions.EditorRedo => Text(UiTextKey.SettingsHotkeyEditorRedoDescription),
        AppHotkeyIds.Definitions.EditorSelectAll => Text(UiTextKey.SettingsHotkeyEditorSelectAllDescription),
        AppHotkeyIds.Definitions.LearnBack => Text(UiTextKey.SettingsHotkeyLearnBackDescription),
        AppHotkeyIds.Definitions.LearnPlayPause => Text(UiTextKey.SettingsHotkeyLearnPlayPauseDescription),
        AppHotkeyIds.Definitions.LearnSpeedDown => Text(UiTextKey.SettingsHotkeyLearnSpeedDownDescription),
        AppHotkeyIds.Definitions.LearnSpeedUp => Text(UiTextKey.SettingsHotkeyLearnSpeedUpDescription),
        AppHotkeyIds.Definitions.LearnStepBackward => Text(UiTextKey.SettingsHotkeyLearnStepBackwardDescription),
        AppHotkeyIds.Definitions.LearnStepBackwardLarge => Text(UiTextKey.SettingsHotkeyLearnStepBackwardLargeDescription),
        AppHotkeyIds.Definitions.LearnStepForward => Text(UiTextKey.SettingsHotkeyLearnStepForwardDescription),
        AppHotkeyIds.Definitions.LearnStepForwardLarge => Text(UiTextKey.SettingsHotkeyLearnStepForwardLargeDescription),
        AppHotkeyIds.Definitions.LearnToggleLoop => Text(UiTextKey.SettingsHotkeyLearnLoopDescription),
        AppHotkeyIds.Definitions.TeleprompterBack => Text(UiTextKey.SettingsHotkeyTeleprompterBackDescription),
        AppHotkeyIds.Definitions.TeleprompterPlayPause => Text(UiTextKey.SettingsHotkeyTeleprompterPlayPauseDescription),
        AppHotkeyIds.Definitions.TeleprompterPreviousBlock => Text(UiTextKey.SettingsHotkeyTeleprompterPreviousBlockDescription),
        AppHotkeyIds.Definitions.TeleprompterNextBlock => Text(UiTextKey.SettingsHotkeyTeleprompterNextBlockDescription),
        AppHotkeyIds.Definitions.TeleprompterMirrorHorizontal => Text(UiTextKey.SettingsHotkeyTeleprompterMirrorHorizontalDescription),
        AppHotkeyIds.Definitions.TeleprompterMirrorVertical => Text(UiTextKey.SettingsHotkeyTeleprompterMirrorVerticalDescription),
        AppHotkeyIds.Definitions.TeleprompterOrientation => Text(UiTextKey.SettingsHotkeyTeleprompterOrientationDescription),
        AppHotkeyIds.Definitions.TeleprompterFullscreen => Text(UiTextKey.SettingsHotkeyTeleprompterFullscreenDescription),
        AppHotkeyIds.Definitions.TeleprompterAlignmentLeft => Text(UiTextKey.SettingsHotkeyTeleprompterAlignLeftDescription),
        AppHotkeyIds.Definitions.TeleprompterAlignmentCenter => Text(UiTextKey.SettingsHotkeyTeleprompterAlignCenterDescription),
        AppHotkeyIds.Definitions.TeleprompterAlignmentRight => Text(UiTextKey.SettingsHotkeyTeleprompterAlignRightDescription),
        AppHotkeyIds.Definitions.TeleprompterAlignmentJustify => Text(UiTextKey.SettingsHotkeyTeleprompterAlignJustifyDescription),
        AppHotkeyIds.Definitions.TeleprompterCamera => Text(UiTextKey.SettingsHotkeyTeleprompterCameraDescription),
        AppHotkeyIds.Definitions.GoLiveDirectorMode => Text(UiTextKey.SettingsHotkeyGoLiveDirectorModeDescription),
        AppHotkeyIds.Definitions.GoLiveStudioMode => Text(UiTextKey.SettingsHotkeyGoLiveStudioModeDescription),
        AppHotkeyIds.Definitions.GoLiveToggleLeftRail => Text(UiTextKey.SettingsHotkeyGoLiveLeftRailDescription),
        AppHotkeyIds.Definitions.GoLiveToggleRightRail => Text(UiTextKey.SettingsHotkeyGoLiveRightRailDescription),
        AppHotkeyIds.Definitions.GoLiveToggleFullProgram => Text(UiTextKey.SettingsHotkeyGoLiveFullProgramDescription),
        AppHotkeyIds.Definitions.GoLiveTakeToAir => Text(UiTextKey.SettingsHotkeyGoLiveTakeToAirDescription),
        AppHotkeyIds.Definitions.GoLiveToggleRecording => Text(UiTextKey.SettingsHotkeyGoLiveRecordingDescription),
        AppHotkeyIds.Definitions.GoLiveToggleStream => Text(UiTextKey.SettingsHotkeyGoLiveStreamDescription),
        _ => definition.Id
    };

