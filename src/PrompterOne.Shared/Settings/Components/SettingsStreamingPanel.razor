@namespace PrompterOne.Shared.Components.Settings
@using PrompterOne.Core.Models.Streaming
@using PrompterOne.Core.Models.Workspace
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Settings.Components
@using PrompterOne.Shared.Settings.Models

<div class="set-subsection">
    <h4 class="set-sub-title">@Text(SettingsStreamingText.ProgramCaptureTitle)</h4>
    <div class="set-devices">
        <div class="set-field">
            <label>@Text(SettingsStreamingText.OutputResolutionLabel)</label>
            <SettingsSelect Value="@ProgramCapture.ResolutionPreset.ToString()"
                           Options="@OutputResolutionOptions"
                           OnChange="OutputResolutionChanged"
                           TestId="@UiTestIds.Settings.StreamingOutputResolution" />
        </div>
        <div class="set-field">
            <label>@Text(SettingsStreamingText.BitrateLabel)</label>
            <input type="number"
                   class="set-input"
                   value="@ProgramCapture.BitrateKbps"
                   @oninput="BitrateChanged"
                   data-testid="@UiTestIds.Settings.StreamingBitrate" />
        </div>
        <div class="set-field set-field-toggle">
            <label>@Text(SettingsStreamingText.ShowTextOverlayLabel)</label>
            <div class="set-toggle @(ProgramCapture.ShowTextOverlay ? OnCssClass : null)"
                 @onclick="ToggleTextOverlay"
                 data-testid="@UiTestIds.Settings.StreamingTextOverlay">
                <div class="set-toggle-thumb"></div>
            </div>
        </div>
        <div class="set-field set-field-toggle">
            <label>@Text(SettingsStreamingText.IncludeCameraInOutputLabel)</label>
            <div class="set-toggle @(ProgramCapture.IncludeCameraInOutput ? OnCssClass : null)"
                 @onclick="ToggleIncludeCamera"
                 data-testid="@UiTestIds.Settings.StreamingIncludeCamera">
                <div class="set-toggle-thumb"></div>
            </div>
        </div>
    </div>
</div>

<div class="set-sub-header set-sub-header-tight">
    <h4 class="set-sub-title">@Text(SettingsStreamingText.LocalRecordingTitle)</h4>
</div>

<div class="set-device-list">
    @foreach (var localTarget in LocalTargetCards)
    {
        <SettingsStreamingTargetCard Title="@Text(localTarget.NameKey)"
                                     Account="@Text(localTarget.AccountLabelKey)"
                                     Description="@Text(localTarget.DescriptionKey)"
                                     Summary="@BuildLocalSummary(localTarget.TargetId)"
                                     StatusLabel="@BuildLocalTargetStatusLabel(localTarget.TargetId)"
                                     StatusClass="@BuildLocalTargetStatusClass(localTarget.TargetId)"
                                     IsEnabled="@IsLocalTargetEnabled(localTarget.TargetId)"
                                     IsOpen="@IsCardOpen(localTarget.CardId)"
                                     IsReady="@BuildLocalTargetIsReady(localTarget.TargetId)"
                                     ToggleTestId="@localTarget.ToggleTestId"
                                     CardTestId="@UiTestIds.Settings.StreamingProviderCard(localTarget.TargetId)"
                                     ToggleEnabled="@(() => ToggleLocalTargetAsync(localTarget.TargetId))"
                                     OnCardToggle="@(() => ToggleStreamingCardAsync(localTarget.CardId))">
            <div class="set-field set-field-toggle">
                <label>@Text(SettingsStreamingText.AvailableInProgramRoutingLabel)</label>
                <span class="set-dest-status @(BuildLocalTargetIsReady(localTarget.TargetId) ? SelectedStatusClass : string.Empty)">
                    @BuildLocalSummary(localTarget.TargetId)
                </span>
            </div>
        </SettingsStreamingTargetCard>
    }
</div>

<div class="set-sub-header set-sub-header-section">
    <h4 class="set-sub-title">@Text(SettingsStreamingText.TransportConnectionsTitle)</h4>
    <button class="set-btn-outline set-btn-sm"
            type="button"
            data-testid="@UiTestIds.Settings.StreamingTransportAdd"
            @onclick="ToggleTransportConnectionMenu">
        <UiIcon Kind="UiIconKind.Plus"
                Size="12"
                StrokeWidth="2.5m" />
        @Text(SettingsStreamingText.AddTransportConnectionButtonLabel)
    </button>
</div>

<div class="@AddTransportConnectionMenuCssClass">
    @foreach (var platform in StreamingPlatformCatalog.TransportModules)
    {
        <button class="set-add-source-opt"
                type="button"
                data-testid="@UiTestIds.Settings.StreamingTransportAddOption(platform.IdPrefix)"
                @onclick="@(() => AddTransportConnectionAndOpenCardAsync(platform.Kind))">
            @platform.DisplayName
        </button>
    }
</div>

<div class="set-device-list">
    @foreach (var connection in TransportConnections)
    {
        <SettingsStreamingTransportConnectionCard Settings="@Settings"
                                                 Connection="@connection"
                                                 Sources="@Sources"
                                                 IsCardOpen="IsCardOpen"
                                                 ToggleCard="ToggleCard"
                                                 ToggleConnection="ToggleTransportConnection"
                                                 RemoveConnection="RemoveTransportConnection"
                                                 ToggleSource="ToggleTransportConnectionSource"
                                                 UpdateField="UpdateTransportConnectionField"
                                                 UpdateRole="UpdateTransportConnectionRole" />
    }
</div>

<div class="set-sub-header set-sub-header-section">
    <h4 class="set-sub-title">@Text(SettingsStreamingText.DistributionTargetsTitle)</h4>
    <button class="set-btn-outline set-btn-sm"
            type="button"
            data-testid="@UiTestIds.Settings.StreamingDistributionAdd"
            @onclick="ToggleDistributionTargetMenu">
        <UiIcon Kind="UiIconKind.Plus"
                Size="12"
                StrokeWidth="2.5m" />
        @Text(SettingsStreamingText.AddDistributionTargetButtonLabel)
    </button>
</div>

<div class="@AddDistributionTargetMenuCssClass">
    @foreach (var platform in StreamingPlatformCatalog.DistributionTargets)
    {
        <button class="set-add-source-opt"
                type="button"
                data-testid="@UiTestIds.Settings.StreamingDistributionAddOption(platform.IdPrefix)"
                @onclick="@(() => AddDistributionTargetAndOpenCardAsync(platform.Kind))">
            @platform.DisplayName
        </button>
    }
</div>

<div class="set-device-list">
    @foreach (var target in DistributionTargets)
    {
        <SettingsStreamingDistributionTargetCard Target="@target"
                                                TransportConnections="@TransportConnections"
                                                IsCardOpen="IsCardOpen"
                                                ToggleCard="ToggleCard"
                                                ToggleTarget="ToggleDistributionTarget"
                                                ToggleBoundTransport="ToggleDistributionTargetTransport"
                                                RemoveTarget="RemoveDistributionTarget"
                                                UpdateField="UpdateDistributionTargetField" />
    }
</div>
