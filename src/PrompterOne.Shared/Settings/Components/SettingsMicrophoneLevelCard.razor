@implements IAsyncDisposable
@namespace PrompterOne.Shared.Components
@using System.Globalization
@using Microsoft.JSInterop
@using PrompterOne.Shared.Services
@inject Microsoft.Extensions.Logging.ILogger<SettingsMicrophoneLevelCard> Logger
@inject MicrophoneLevelInterop MicrophoneLevelInterop

<section class="@CardCssClass"
         data-testid="@CardTestId">
    <div class="set-device-header">
        <div class="set-device-preview set-mic-preview @(CanRenderMonitor && IsEnabled ? string.Empty : "set-mic-off")">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
                <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
                <line x1="12" y1="19" x2="12" y2="23" />
                <line x1="8" y1="23" x2="16" y2="23" />
            </svg>
            <div class="set-mic-level-indicator">
                <div class="set-mic-bar" style="@BuildHeaderBarStyle(0.18)"></div>
                <div class="set-mic-bar" style="@BuildHeaderBarStyle(0.00)"></div>
                <div class="set-mic-bar" style="@BuildHeaderBarStyle(-0.12)"></div>
            </div>
        </div>
        <div class="set-device-info">
            <span class="set-device-name"
                  data-testid="@LabelTestId">
                @(CanRenderMonitor ? MicrophoneLabel : EmptyTitle)
            </span>
            <span class="set-device-meta">@MonitorDescription</span>
        </div>
        @if (HeaderAction is not null)
        {
            @HeaderAction
        }
        else
        {
            <span class="live-status @(CanMonitor ? ReadyStatusCssClass : PendingStatusCssClass)">
                @(CanMonitor ? ReadyStatusLabel : PendingStatusLabel)
            </span>
        }
    </div>

    @if (CanRenderMonitor)
    {
        <div id="@ResolvedMonitorElementId"
             class="set-vu-meter"
             data-live-level="@_levelPercent"
             data-live-state="@MonitorState"
             data-testid="@MeterTestId">
            <div class="set-vu-track">
                <div class="set-vu-fill" style="@MonitorFillStyle"></div>
                <div class="set-vu-peak" style="@MonitorPeakStyle"></div>
            </div>
            <span class="set-vu-db">@MonitorValueText</span>
        </div>
    }
    else
    {
        <div class="set-empty-card"
             data-testid="@EmptyTestId">
            <div>
                <div class="set-account-name">@EmptyTitle</div>
                <div class="live-card-desc">@EmptyDescription</div>
            </div>
        </div>
    }

    @if (ChildContent is not null)
    {
        <div class="set-device-body">
            @ChildContent
        </div>
    }
</section>

@code {
    private const string ActiveStateValue = "active";
    private const string DefaultDescription = "Speak into the selected microphone to confirm the browser sees a live signal before recording or streaming.";
    private const string DefaultTitle = "Microphone Activity";
    private const string IdleStateValue = "idle";
    private const string NoMicrophoneDescription = "Pick a default microphone to see a live level meter here.";
    private const string NoMicrophoneTitle = "No microphone selected";
    private const string PendingStatusCssClass = "pending";
    private const string PendingStatusLabel = "Waiting";
    private const string PermissionDescription = "Enable microphone access in Cameras first, then return here to confirm live input activity.";
    private const string PermissionTitle = "Microphone access required";
    private const string PreviewDescription = "Live browser input monitor";
    private const string ReadyStatusCssClass = "ready";
    private const string ReadyStatusLabel = "Live level";
    private const string StartMonitorFailureMessage = "Failed to start Settings microphone monitor for device {DeviceId}.";
    private const string StopMonitorFailureMessage = "Failed to stop Settings microphone monitor.";

    [Parameter] public bool AccessGranted { get; set; }

    [Parameter] public string? CardTestId { get; set; } = UiTestIds.Settings.MicPreviewCard;

    [Parameter] public bool IsActive { get; set; }

    [Parameter] public bool IsEnabled { get; set; } = true;

    [Parameter] public MediaDeviceInfo? Microphone { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string Description { get; set; } = DefaultDescription;

    [Parameter] public RenderFragment? HeaderAction { get; set; }

    [Parameter] public string? EmptyTestId { get; set; } = UiTestIds.Settings.MicPreviewEmpty;

    [Parameter] public string? LabelTestId { get; set; } = UiTestIds.Settings.MicPreviewLabel;

    [Parameter] public string MetaText { get; set; } = string.Empty;

    [Parameter] public string? MeterTestId { get; set; } = UiTestIds.Settings.MicPreviewMeter;

    [Parameter] public string? MonitorElementId { get; set; }

    [Parameter] public string Title { get; set; } = DefaultTitle;

    private string CardCssClass =>
        IsEnabled ? "set-device-card active" : "set-device-card";

    private bool CanMonitor => AccessGranted && IsActive && IsEnabled && !string.IsNullOrWhiteSpace(Microphone?.DeviceId);

    private bool CanRenderMonitor => AccessGranted && !string.IsNullOrWhiteSpace(Microphone?.DeviceId);

    private string EmptyDescription =>
        !AccessGranted
            ? PermissionDescription
            : NoMicrophoneDescription;

    private string EmptyTitle =>
        !AccessGranted
            ? PermissionTitle
            : NoMicrophoneTitle;

    private string MicrophoneLabel => MediaDeviceLabelSanitizer.Sanitize(Microphone?.Label);

    private string MonitorDescription =>
        CanRenderMonitor
            ? string.IsNullOrWhiteSpace(MetaText) ? PreviewDescription : MetaText
            : EmptyDescription;

    private string MonitorFillStyle =>
        string.Format(CultureInfo.InvariantCulture, "width: {0}%;", _levelPercent);

    private string MonitorPeakStyle =>
        string.Format(CultureInfo.InvariantCulture, "left: {0}%;", Math.Clamp(_levelPercent, 2, 100));

    private string MonitorState => _levelPercent > 0 && IsEnabled ? ActiveStateValue : IdleStateValue;

    private string MonitorValueText =>
        string.Concat(ConvertLevelToDb(_levelPercent).ToString(CultureInfo.InvariantCulture), " dB");

    private string ResolvedMonitorElementId =>
        string.IsNullOrWhiteSpace(MonitorElementId)
            ? UiDomIds.Settings.MicrophoneLevelMonitor
            : MonitorElementId;

    private string? _attachedDeviceId;
    private DotNetObjectReference<MicrophoneLevelObserver>? _observerReference;
    private int _levelPercent;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (!CanMonitor)
            {
                await StopMonitoringAsync();
                return;
            }

            var nextDeviceId = Microphone!.DeviceId;
            if (string.Equals(_attachedDeviceId, nextDeviceId, StringComparison.Ordinal))
            {
                return;
            }

            await StopMonitoringAsync();
            _attachedDeviceId = nextDeviceId;
            _observerReference ??= DotNetObjectReference.Create(new MicrophoneLevelObserver(HandleLevelChangedAsync));
            await MicrophoneLevelInterop.StartAsync(ResolvedMonitorElementId, nextDeviceId, _observerReference);
        }
        catch (Exception exception)
        {
            Microsoft.Extensions.Logging.LoggerExtensions.LogWarning(Logger, exception, StartMonitorFailureMessage, Microphone?.DeviceId);
            _attachedDeviceId = null;
            await ResetLevelAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopMonitoringAsync();
        _observerReference?.Dispose();
    }

    private string BuildHeaderBarStyle(double offset)
    {
        var adjustedPercent = Math.Clamp((int)Math.Round((_levelPercent * (0.65d + offset)) + 18d, MidpointRounding.AwayFromZero), 18, 100);
        return string.Format(CultureInfo.InvariantCulture, "height:{0}%", adjustedPercent);
    }

    private static int ConvertLevelToDb(int levelPercent) =>
        levelPercent switch
        {
            <= 0 => -60,
            _ => Math.Clamp((int)Math.Round(-60 + (levelPercent * 0.48), MidpointRounding.AwayFromZero), -60, -12)
        };

    private Task HandleLevelChangedAsync(int levelPercent)
    {
        var nextLevel = Math.Clamp(levelPercent, 0, 100);
        if (_levelPercent == nextLevel)
        {
            return Task.CompletedTask;
        }

        _levelPercent = nextLevel;
        return InvokeAsync(StateHasChanged);
    }

    private Task ResetLevelAsync() => HandleLevelChangedAsync(0);

    private async Task StopMonitoringAsync()
    {
        if (string.IsNullOrWhiteSpace(_attachedDeviceId))
        {
            await ResetLevelAsync();
            return;
        }

        try
        {
            await MicrophoneLevelInterop.StopAsync(ResolvedMonitorElementId);
        }
        catch (Exception exception)
        {
            Microsoft.Extensions.Logging.LoggerExtensions.LogWarning(Logger, exception, StopMonitorFailureMessage);
        }
        finally
        {
            _attachedDeviceId = null;
            await ResetLevelAsync();
        }
    }
}
