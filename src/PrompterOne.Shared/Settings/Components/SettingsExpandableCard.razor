@namespace PrompterOne.Shared.Components.Settings
@using PrompterOne.Shared.Components

<article class="@CardCssClass"
         data-testid="@TestId"
         @onclick="OnToggle">
    <div class="set-dest-header">
        <UiIconSurface Tone="@IconTone"
                       AdditionalCssClass="@IconCssClass">
            @if (Icon is not null)
            {
                @Icon
            }
        </UiIconSurface>
        <div class="set-dest-info">
            <span class="set-dest-name">@Title</span>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <span class="set-dest-description">@Description</span>
            }
            <span class="set-dest-account" @attributes="SubtitleAttributes">@Subtitle</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(StatusLabel))
        {
            <span class="@StatusCssClass">@StatusLabel</span>
        }
        <UiIcon Kind="UiIconKind.ChevronDown"
                Size="14"
                CssClass="set-dest-chevron" />
    </div>
    <div class="set-dest-body" @onclick:stopPropagation="true">
        @ChildContent
    </div>
</article>

@code {
    private string CardCssClass =>
        string.Join(
            ' ',
            new[]
            {
                "set-dest-card",
                IsOpen ? "open" : string.Empty,
                AdditionalCssClass
            }.Where(cssClass => !string.IsNullOrWhiteSpace(cssClass)));

    private string IconCssClass =>
        string.IsNullOrWhiteSpace(IconClass)
            ? "set-dest-icon"
            : $"set-dest-icon {IconClass}";

    private string StatusCssClass =>
        string.IsNullOrWhiteSpace(StatusClass)
            ? "set-dest-status"
            : $"set-dest-status {StatusClass}";

    private IReadOnlyDictionary<string, object> SubtitleAttributes =>
        string.IsNullOrWhiteSpace(SubtitleTestId)
            ? EmptyAttributes
            : new Dictionary<string, object>(StringComparer.Ordinal)
            {
                [DataTestIdAttributeName] = SubtitleTestId
            };

    private static IReadOnlyDictionary<string, object> EmptyAttributes { get; } =
        new Dictionary<string, object>(StringComparer.Ordinal);

    private const string DataTestIdAttributeName = "data-testid";

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public RenderFragment? Icon { get; set; }

    [Parameter] public string IconClass { get; set; } = string.Empty;

    [Parameter] public UiIconSurfaceTone IconTone { get; set; } = UiIconSurfaceTone.Slate;

    [Parameter] public bool IsOpen { get; set; }

    [Parameter] public string AdditionalCssClass { get; set; } = string.Empty;

    [Parameter] public string Description { get; set; } = string.Empty;

    [Parameter] public EventCallback OnToggle { get; set; }

    [Parameter] public string StatusClass { get; set; } = string.Empty;

    [Parameter] public string StatusLabel { get; set; } = string.Empty;

    [Parameter] public string Subtitle { get; set; } = string.Empty;

    [Parameter] public string SubtitleTestId { get; set; } = string.Empty;

    [Parameter] public string TestId { get; set; } = string.Empty;

    [Parameter] public string Title { get; set; } = string.Empty;
}
