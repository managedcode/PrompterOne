@namespace PrompterOne.Shared.Components.Settings
@using PrompterOne.Shared.Components

<section class="set-section set-panel"
         id="set-about"
         style="@DisplayStyle"
         data-test="@UiTestIds.Settings.AboutPanel">
    <h3 class="set-section-title">@AboutSectionTitle</h3>
    <p class="set-section-desc">@AboutSectionDescription</p>

    <div class="set-device-list">
        <SettingsExpandableCard Title="@OnboardingCardTitle"
                                Subtitle="@OnboardingCardSubtitle"
                                IconTone="UiIconSurfaceTone.Sky"
                                TestId="@UiTestIds.Settings.AboutOnboardingCard"
                                IsOpen="@IsCardOpen(OnboardingCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(OnboardingCardId))">
            <UiIcon Kind="UiIconKind.HelpCircle" Size="17" />
            <p class="set-card-copy">@OnboardingCardCopy</p>
            <button type="button"
                    class="btn-ghost set-card-cta"
                    @onclick="OpenOnboarding"
                    data-test="@UiTestIds.Settings.AboutOnboardingRestart">@OnboardingCardAction</button>
        </SettingsExpandableCard>

        @if (ShowFeedbackCard)
        {
            <SettingsExpandableCard Title="@FeedbackCardTitle"
                                    Subtitle="@FeedbackCardSubtitle"
                                    IconTone="UiIconSurfaceTone.Pink"
                                    TestId="@UiTestIds.Settings.AboutFeedbackCard"
                                    IsOpen="@IsCardOpen(FeedbackCardId)"
                                    OnToggle="@(() => ToggleCard.InvokeAsync(FeedbackCardId))">
                <UiIcon Kind="UiIconKind.Message" Size="17" />
                <p class="set-card-copy">@FeedbackCardCopy</p>
                <button type="button"
                        class="btn-ghost set-card-cta"
                        @onclick="OpenFeedback"
                        data-test="@UiTestIds.Settings.AboutFeedbackOpen">@FeedbackCardAction</button>
            </SettingsExpandableCard>
        }

        <SettingsExpandableCard Title="@AppCardTitle"
                                Subtitle="@AppCardSubtitle"
                                SubtitleTestId="@UiTestIds.Settings.AboutVersion"
                                StatusLabel="@LicensedStatusLabel"
                                StatusClass="set-dest-ok"
                                IconTone="UiIconSurfaceTone.Gold"
                                IconTestId="@UiTestIds.Settings.AboutAppIconSurface"
                                TestId="@UiTestIds.Settings.AboutAppCard"
                                IsOpen="@IsCardOpen(AppCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(AppCardId))">
            <UiIcon Kind="UiIconKind.TextLines" Size="17" />
            <div class="set-device-fields">
                <div class="set-field set-field-toggle">
                    <label>@SoftwareUpdatesLabel</label>
                    <span class="set-dest-status set-dest-ok set-dest-status-compact">@UpToDateLabel</span>
                </div>
                <div class="set-field set-field-toggle">
                    <label>@AutomaticUpdatesLabel</label>
                    <div class="set-toggle on">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
            </div>
            <div class="set-device-fields">
                @foreach (var link in AppLinks)
                {
                    <a class="set-about-link set-field set-field-toggle"
                       href="@link.Href"
                       target="_blank"
                       rel="noreferrer"
                       data-test="@link.TestId">
                        <div class="set-about-link-copy">
                            <label>@link.Label</label>
                            <span class="set-about-link-meta">@link.Description</span>
                        </div>
                        <UiIcon Kind="UiIconKind.ChevronRight"
                                Size="13"
                                CssClass="set-about-link-chevron" />
                    </a>
                }
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="@ManagedCodeCardTitle"
                                Subtitle="@ManagedCodeCardSubtitle"
                                IconTone="UiIconSurfaceTone.Gold"
                                TestId="@UiTestIds.Settings.AboutCompanyCard"
                                IsOpen="@IsCardOpen(CompanyCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(CompanyCardId))">
            <UiIcon Kind="UiIconKind.Check" Size="17" />
            <p class="set-card-copy">@ManagedCodeCardCopy</p>
            <div class="set-device-fields">
                @foreach (var link in CompanyLinks)
                {
                    <a class="set-about-link set-field set-field-toggle"
                       href="@link.Href"
                       target="_blank"
                       rel="noreferrer"
                       data-test="@link.TestId">
                        <div class="set-about-link-copy">
                            <label>@link.Label</label>
                            <span class="set-about-link-meta">@link.Description</span>
                        </div>
                        <UiIcon Kind="UiIconKind.ChevronRight"
                                Size="13"
                                CssClass="set-about-link-chevron" />
                    </a>
                }
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="@OpenSourceCardTitle"
                                Subtitle="@OpenSourceCardSubtitle"
                                IconTone="UiIconSurfaceTone.Indigo"
                                IsOpen="@IsCardOpen(OpenSourceCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(OpenSourceCardId))">
            <UiIcon Kind="UiIconKind.CodeArrows" Size="17" />
            <div class="set-oss-list">
                @foreach (var library in Libraries)
                {
                    <div class="set-oss-item">
                        <div class="set-oss-info">
                            <span class="set-oss-name">@library.Name</span>
                            <span class="set-oss-desc">@library.Description</span>
                        </div>
                        <span class="set-oss-license">@library.License</span>
                    </div>
                }
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="@ResourcesCardTitle"
                                Subtitle="@ResourcesCardSubtitle"
                                IconTone="UiIconSurfaceTone.Sky"
                                IsOpen="@IsCardOpen(ResourcesCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(ResourcesCardId))">
            <UiIcon Kind="UiIconKind.HelpCircle" Size="17" />
            <div class="set-device-fields">
                @foreach (var link in ResourceLinks)
                {
                    <a class="set-about-link set-field set-field-toggle"
                       href="@link.Href"
                       target="_blank"
                       rel="noreferrer"
                       data-test="@link.TestId">
                        <div class="set-about-link-copy">
                            <label>@link.Label</label>
                            <span class="set-about-link-meta">@link.Description</span>
                        </div>
                        <UiIcon Kind="UiIconKind.ChevronRight"
                                Size="13"
                                CssClass="set-about-link-chevron" />
                    </a>
                }
            </div>
        </SettingsExpandableCard>
    </div>

    <div class="set-about-footer">@FooterText</div>
</section>
