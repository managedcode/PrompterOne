@namespace PrompterOne.Shared.Components.Settings

<div class="set-path-field set-path-field-actions">
    <button type="button"
            class="set-btn-golden"
            data-testid="@ConnectTestId"
            @onclick="Connect">
        @ConnectLabel
    </button>
    <button type="button"
            class="set-btn-outline set-btn-sm"
            data-testid="@ExportTestId"
            disabled="@(!IsConnected)"
            @onclick="Export">
        @ExportLabel
    </button>
    <button type="button"
            class="set-btn-outline set-btn-sm"
            data-testid="@ImportTestId"
            disabled="@(!IsConnected)"
            @onclick="Import">
        @ImportLabel
    </button>
    <button type="button"
            class="set-btn-outline set-btn-sm set-danger-action"
            data-testid="@DisconnectTestId"
            disabled="@(!IsConnected)"
            @onclick="Disconnect">
        @DisconnectLabel
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <p class="set-card-copy" data-testid="@MessageTestId">@Message</p>
}

@code {
    [Parameter] public EventCallback Connect { get; set; }
    [Parameter] public string ConnectLabel { get; set; } = string.Empty;
    [Parameter] public string ConnectTestId { get; set; } = string.Empty;
    [Parameter] public EventCallback Disconnect { get; set; }
    [Parameter] public string DisconnectLabel { get; set; } = string.Empty;
    [Parameter] public string DisconnectTestId { get; set; } = string.Empty;
    [Parameter] public EventCallback Export { get; set; }
    [Parameter] public string ExportLabel { get; set; } = string.Empty;
    [Parameter] public string ExportTestId { get; set; } = string.Empty;
    [Parameter] public EventCallback Import { get; set; }
    [Parameter] public string ImportLabel { get; set; } = string.Empty;
    [Parameter] public string ImportTestId { get; set; } = string.Empty;
    [Parameter] public bool IsConnected { get; set; }
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string MessageTestId { get; set; } = string.Empty;
}
