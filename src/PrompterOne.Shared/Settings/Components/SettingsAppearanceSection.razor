@namespace PrompterOne.Shared.Components.Settings
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Localization
@using PrompterOne.Shared.Settings.Components
@using PrompterOne.Shared.Settings.Models
@inject IStringLocalizer<SharedResource> Localizer

<section class="set-section set-panel"
         id="set-appearance"
         style="@DisplayStyle"
         data-testid="@UiTestIds.Settings.AppearancePanel">
    <h3 class="set-section-title">@Text(UiTextKey.SettingsAppearanceSectionTitle)</h3>
    <p class="set-section-desc">@Text(UiTextKey.SettingsAppearanceSectionDescription)</p>

    <div class="set-device-list">
        <SettingsExpandableCard Title="@Text(UiTextKey.SettingsAppearanceThemeTitle)"
                                Subtitle="@ThemeSubtitle"
                                IconStyle="background:rgba(196,160,96,.10); color:var(--gold);"
                                IsOpen="@IsCardOpen(ThemeCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(ThemeCardId))">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5" />
                <line x1="12" y1="1" x2="12" y2="3" />
                <line x1="12" y1="21" x2="12" y2="23" />
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                <line x1="1" y1="12" x2="3" y2="12" />
                <line x1="21" y1="12" x2="23" y2="12" />
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
            </svg>
            <div class="set-device-fields">
                <div class="set-field">
                    <label>@Text(UiTextKey.SettingsAppearanceColorSchemeLabel)</label>
                    <div class="set-theme-options">
                        @foreach (var option in ThemeOptions)
                        {
                            <label class="@(option.Value == ColorScheme ? "set-theme-opt active" : "set-theme-opt")"
                                   data-testid="@UiTestIds.Settings.ThemeOption(option.Value)"
                                   @onclick:stopPropagation="true">
                                <input type="radio"
                                       name="theme"
                                       checked="@(option.Value == ColorScheme)"
                                       @onchange="@(() => UpdateColorScheme.InvokeAsync(option.Value))" />
                                <div class="set-theme-swatch" style="@option.SwatchStyle">@((MarkupString)option.IconMarkup)</div>
                                <span>@option.Label</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.SettingsAppearanceAccentColorLabel)</label>
                    <div class="set-accent-options">
                        @foreach (var accent in AccentOptions)
                        {
                            <button class="@(accent.Value == AccentColor ? "set-accent-swatch active" : "set-accent-swatch")"
                                    style="@($"background:{accent.Value}")"
                                    title="@accent.Label"
                                    type="button"
                                    @onclick="() => UpdateAccentColor.InvokeAsync(accent.Value)"
                                    @onclick:stopPropagation="true"></button>
                        }
                    </div>
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.SettingsAppearanceLanguageLabel)</label>
                    <SettingsSelect Value="@SelectedLanguageCulture"
                                   Options="@LanguageOptions"
                                   OnChange="OnLanguageChanged"
                                   TestId="@UiTestIds.Settings.LanguageSelect" />
                </div>
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="@Text(UiTextKey.SettingsAppearanceTeleprompterTitle)"
                                Subtitle="@Text(UiTextKey.SettingsAppearanceTeleprompterSubtitle)"
                                IconStyle="background:rgba(59,130,246,.10); color:#60A5FA;"
                                IsOpen="@IsCardOpen(TeleprompterCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(TeleprompterCardId))">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 6h16M4 12h12M4 18h14" />
            </svg>
            <div class="set-device-fields">
                <div class="set-field">
                    <label>@Text(UiTextKey.SettingsAppearanceFontLabel)</label>
                    <SettingsSelect Value="@TeleprompterFont"
                                   Options="@TeleprompterFontOptions"
                                   OnChange="OnFontChanged" />
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.SettingsAppearanceDefaultFontSizeLabel)</label>
                    <div class="set-size-row">
                        <span class="set-size-label">A</span>
                        <input type="range"
                               class="set-range"
                               min="24"
                               max="96"
                               value="@TeleprompterFontSize"
                               @oninput="UpdateTeleprompterFontSize"
                               @onclick:stopPropagation="true" />
                        <span class="set-size-label set-size-label-lg">A</span>
                    </div>
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.SettingsAppearanceTextColorLabel)</label>
                    <div class="set-accent-options">
                        @foreach (var swatch in TextColorOptions)
                        {
                            <button class="@(swatch.Value == TeleprompterTextColor ? "set-accent-swatch active" : "set-accent-swatch")"
                                    style="@($"background:{swatch.Value}")"
                                    title="@swatch.Label"
                                    type="button"
                                    @onclick="() => UpdateTeleprompterTextColor.InvokeAsync(swatch.Value)"
                                    @onclick:stopPropagation="true"></button>
                        }
                    </div>
                </div>
                <div class="set-field set-field-toggle">
                    <label>@Text(UiTextKey.SettingsAppearanceMirrorTextLabel)</label>
                    <div class="set-toggle @(MirrorTeleprompterText ? "on" : null)"
                         @onclick="ToggleMirrorTeleprompterText"
                         @onclick:stopPropagation="true">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
                <div class="set-field set-field-toggle">
                    <label>@Text(UiTextKey.SettingsAppearanceShowWordHighlightLabel)</label>
                    <div class="set-toggle @(ShowWordHighlight ? "on" : null)"
                         @onclick="ToggleShowWordHighlight"
                         @onclick:stopPropagation="true">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="@Text(UiTextKey.SettingsAppearanceInterfaceTitle)"
                                Subtitle="@Text(UiTextKey.SettingsAppearanceInterfaceSubtitle)"
                                IconStyle="background:rgba(139,92,246,.10); color:#A78BFA;"
                                IsOpen="@IsCardOpen(InterfaceCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(InterfaceCardId))">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <path d="M3 9h18M9 21V9" />
            </svg>
            <div class="set-device-fields">
                <div class="set-field">
                    <label>@Text(UiTextKey.SettingsAppearanceUiDensityLabel)</label>
                    <div class="set-theme-options">
                        @foreach (var density in DensityOptions)
                        {
                            <label class="@(density.Value == UiDensity ? "set-theme-opt active" : "set-theme-opt")"
                                   @onclick:stopPropagation="true">
                                <input type="radio"
                                       name="density"
                                       checked="@(density.Value == UiDensity)"
                                       @onchange="@(() => UpdateUiDensity.InvokeAsync(density.Value))" />
                                <div class="set-theme-swatch set-density-swatch">@((MarkupString)density.IconMarkup)</div>
                                <span>@density.Label</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="set-field set-field-toggle">
                    <label>@Text(UiTextKey.SettingsAppearanceReduceMotionLabel)</label>
                    <div class="set-toggle @(ReduceMotion ? "on" : null)"
                         @onclick="ToggleReduceMotion"
                         @onclick:stopPropagation="true">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
                <div class="set-field set-field-toggle">
                    <label>@Text(UiTextKey.SettingsAppearanceShowShortcutOverlayLabel)</label>
                    <div class="set-toggle @(ShowShortcutOverlay ? "on" : null)"
                         @onclick="ToggleShowShortcutOverlay"
                         @onclick:stopPropagation="true">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
            </div>
        </SettingsExpandableCard>
    </div>
</section>

@code {
    private const string InterfaceCardId = "appearance-interface";
    private const string TeleprompterCardId = "appearance-teleprompter";
    private const string ThemeCardId = "appearance-theme";

    private static readonly IReadOnlyList<SettingsSelectOption> TeleprompterFontOptions =
    [
        new("Inter (Default)", "Inter (Default)"),
        new("Playfair Display", "Playfair Display"),
        new("JetBrains Mono", "JetBrains Mono"),
        new("Georgia", "Georgia"),
        new("System Serif", "System Serif"),
    ];

    private static readonly ThemeOption[] AccentOptions =
    [
        new("Gold", "#C4A060"),
        new("Blue", "#60A5FA"),
        new("Emerald", "#34D399"),
        new("Pink", "#F472B6"),
        new("Purple", "#A78BFA"),
        new("Orange", "#FB923C")
    ];

    private ThemeOption[] DensityOptions =>
    [
        new(SettingsAppearanceValues.CompactDensity, Text(UiTextKey.SettingsAppearanceDensityCompact), "background:rgba(196,160,96,.08);display:flex;align-items:center;justify-content:center;", "<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" style=\"color:var(--t3)\"><line x1=\"4\" y1=\"6\" x2=\"20\" y2=\"6\"/><line x1=\"4\" y1=\"12\" x2=\"20\" y2=\"12\"/><line x1=\"4\" y1=\"18\" x2=\"20\" y2=\"18\"/></svg>"),
        new(SettingsAppearanceValues.DefaultDensity, Text(UiTextKey.SettingsAppearanceDensityDefault), "background:rgba(196,160,96,.08);display:flex;align-items:center;justify-content:center;", "<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" style=\"color:var(--gold)\"><line x1=\"4\" y1=\"7\" x2=\"20\" y2=\"7\"/><line x1=\"4\" y1=\"14\" x2=\"20\" y2=\"14\"/></svg>"),
        new(SettingsAppearanceValues.SpaciousDensity, Text(UiTextKey.SettingsAppearanceDensitySpacious), "background:rgba(196,160,96,.08);display:flex;align-items:center;justify-content:center;", "<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" style=\"color:var(--t3)\"><line x1=\"4\" y1=\"8\" x2=\"20\" y2=\"8\"/><line x1=\"4\" y1=\"16\" x2=\"20\" y2=\"16\"/></svg>")
    ];

    private static readonly ThemeOption[] TextColorOptions =
    [
        new("White", "#FFFFFF"),
        new("Warm White", "#F5E6D0"),
        new("Amber", "#FDE68A"),
        new("Mint", "#6EE7B7")
    ];

    private ThemeOption[] ThemeOptions =>
    [
        new(SettingsAppearanceValues.DarkColorScheme, Text(UiTextKey.SettingsAppearanceThemeDark), "background:linear-gradient(135deg,#0a0e14,#141c28)", "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" style=\"color:rgba(196,160,96,.7)\"><path d=\"M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"/></svg>"),
        new(SettingsAppearanceValues.LightColorScheme, Text(UiTextKey.SettingsAppearanceThemeLight), "background:linear-gradient(135deg,#f0ebe4,#e0d8cc)", "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#8B7355\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"5\"/><line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"3\"/><line x1=\"12\" y1=\"21\" x2=\"12\" y2=\"23\"/></svg>"),
        new(SettingsAppearanceValues.SystemColorScheme, Text(UiTextKey.SettingsAppearanceThemeSystem), "background:linear-gradient(135deg,#0a0e14 50%,#f0ebe4 50%)", "<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" style=\"color:rgba(196,160,96,.9)\"><rect x=\"2\" y=\"3\" width=\"20\" height=\"14\" rx=\"2\"/><line x1=\"8\" y1=\"21\" x2=\"16\" y2=\"21\"/><line x1=\"12\" y1=\"17\" x2=\"12\" y2=\"21\"/></svg>")
    ];

    private string ThemeSubtitle =>
        ColorScheme switch
        {
            SettingsAppearanceValues.LightColorScheme => Text(UiTextKey.SettingsAppearanceThemeSubtitleLight),
            SettingsAppearanceValues.SystemColorScheme => Text(UiTextKey.SettingsAppearanceThemeSubtitleSystem),
            _ => Text(UiTextKey.SettingsAppearanceThemeSubtitleDark)
        };

    [Parameter] public string AccentColor { get; set; } = string.Empty;
    [Parameter] public string ColorScheme { get; set; } = string.Empty;
    [Parameter] public string DisplayStyle { get; set; } = string.Empty;
    [Parameter] public Func<string, bool> IsCardOpen { get; set; } = static _ => false;
    [Parameter] public string SelectedLanguageCulture { get; set; } = string.Empty;
    [Parameter] public bool MirrorTeleprompterText { get; set; }
    [Parameter] public bool ReduceMotion { get; set; }
    [Parameter] public bool ShowShortcutOverlay { get; set; }
    [Parameter] public bool ShowWordHighlight { get; set; }
    [Parameter] public string TeleprompterFont { get; set; } = string.Empty;
    [Parameter] public int TeleprompterFontSize { get; set; }
    [Parameter] public string TeleprompterTextColor { get; set; } = string.Empty;
    [Parameter] public string UiDensity { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ToggleCard { get; set; }
    [Parameter] public EventCallback ToggleMirrorTeleprompterText { get; set; }
    [Parameter] public EventCallback ToggleReduceMotion { get; set; }
    [Parameter] public EventCallback ToggleShowShortcutOverlay { get; set; }
    [Parameter] public EventCallback ToggleShowWordHighlight { get; set; }
    [Parameter] public EventCallback<string> UpdateAccentColor { get; set; }
    [Parameter] public EventCallback<string> UpdateColorScheme { get; set; }
    [Parameter] public EventCallback<string> UpdateLanguageCulture { get; set; }
    [Parameter] public EventCallback<string> UpdateTeleprompterFont { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> UpdateTeleprompterFontSize { get; set; }
    [Parameter] public EventCallback<string> UpdateTeleprompterTextColor { get; set; }
    [Parameter] public EventCallback<string> UpdateUiDensity { get; set; }

    private static readonly IReadOnlyList<SettingsSelectOption> LanguageOptions = PrompterOne.Core.Localization.AppCultureCatalog
        .SupportedCultureDefinitionsInDisplayOrder
        .Select(culture => new SettingsSelectOption(culture.CultureName, culture.DisplayName))
        .ToArray();

    private string Text(UiTextKey key) => Localizer[key.ToString()];

    private void OnFontChanged(ChangeEventArgs args) =>
        UpdateTeleprompterFont.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private void OnLanguageChanged(ChangeEventArgs args) =>
        UpdateLanguageCulture.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private sealed record ThemeOption(string Label, string Value)
    {
        public ThemeOption(string value, string label, string swatchStyle, string iconMarkup) : this(label, value)
        {
            SwatchStyle = swatchStyle;
            IconMarkup = iconMarkup;
        }

        public string IconMarkup { get; init; } = string.Empty;
        public string SwatchStyle { get; init; } = string.Empty;
    }
}
