@namespace PrompterOne.Shared.Components.Settings
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Localization
@using PrompterOne.Shared.Settings.Components
@using PrompterOne.Shared.Settings.Models
@inject IStringLocalizer<SharedResource> Localizer

<section class="set-section set-panel"
         id="set-files"
         style="@DisplayStyle"
         data-test="@UiTestIds.Settings.FilesPanel">
    <h3 class="set-section-title">@Text(UiTextKey.SettingsFilesSectionTitle)</h3>
    <p class="set-section-desc">@Text(UiTextKey.SettingsFilesSectionDescription)</p>

    <div class="set-device-list">
        <SettingsExpandableCard Title="@Text(UiTextKey.CommonScripts)"
                                Subtitle="@_viewState.Scripts.Subtitle"
                                IconTone="UiIconSurfaceTone.Gold"
                                TestId="@UiTestIds.Settings.FilesScriptsCard"
                                IsOpen="@IsCardOpen(ScriptsCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(ScriptsCardId))">
            <UiIcon Kind="UiIconKind.DocumentLines" Size="17" />
            <div class="set-device-fields">
                <div class="set-field">
                    <label>@Text(UiTextKey.CommonStorageMode)</label>
                    <input type="text" class="set-input" value="@_viewState.Scripts.ScopeLabel" readonly />
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.CommonBrowserKeys)</label>
                    <input type="text" class="set-input" value="@_viewState.Scripts.LocationLabel" readonly />
                </div>
                <p class="set-card-copy">@_viewState.Scripts.DetailLabel</p>
                <div class="set-field set-field-toggle">
                    <label>@ScriptsAutoSaveLabel</label>
                    <div class="@BuildToggleCssClass(_settings.FileAutoSaveEnabled)"
                         data-enabled="@(_settings.FileAutoSaveEnabled ? EnabledStateValue : DisabledStateValue)"
                         data-test="@UiTestIds.Settings.FileAutoSave"
                         @onclick="ToggleAutoSaveAsync"
                         @onclick:stopPropagation="true">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
                <div class="set-field set-field-toggle">
                    <label>@ScriptsHistoryLabel</label>
                    <div class="@BuildToggleCssClass(_settings.FileBackupCopiesEnabled)"
                         data-enabled="@(_settings.FileBackupCopiesEnabled ? EnabledStateValue : DisabledStateValue)"
                         data-test="@UiTestIds.Settings.FileBackupCopies"
                         @onclick="ToggleBackupCopiesAsync"
                         @onclick:stopPropagation="true">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="@Text(UiTextKey.CommonRecordings)"
                                Subtitle="@_viewState.Recordings.Subtitle"
                                IconTone="UiIconSurfaceTone.Red"
                                TestId="@UiTestIds.Settings.FilesRecordingsCard"
                                IsOpen="@IsCardOpen(RecordingsCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(RecordingsCardId))">
            <UiIcon Kind="UiIconKind.RecordTarget" Size="17" />
            <div class="set-device-fields">
                <div class="set-field">
                    <label>@Text(UiTextKey.CommonStorageScope)</label>
                    <input type="text" class="set-input" value="@_viewState.Recordings.ScopeLabel" readonly />
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.CommonBrowserContainerPath)</label>
                    <input type="text" class="set-input" value="@_viewState.Recordings.LocationLabel" readonly />
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.CommonMaxStorage)</label>
                    <SettingsSelect Value="@_settings.RecordingsStorageLimit"
                                   Options="@StorageLimitOptions"
                                   OnChange="OnStorageLimitChanged" />
                </div>
                <p class="set-card-copy">@_viewState.Recordings.DetailLabel</p>
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="@Text(UiTextKey.CommonExports)"
                                Subtitle="@_viewState.Exports.Subtitle"
                                IconTone="UiIconSurfaceTone.Indigo"
                                TestId="@UiTestIds.Settings.FilesExportsCard"
                                IsOpen="@IsCardOpen(ExportsCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(ExportsCardId))">
            <UiIcon Kind="UiIconKind.ExportArrow" Size="17" />
            <div class="set-device-fields">
                <div class="set-field">
                    <label>@Text(UiTextKey.CommonDefaultExportFormat)</label>
                    <SettingsSelect Value="@_settings.ExportFormat"
                                   Options="@ExportFormatOptions"
                                   OnChange="OnExportFormatChanged" />
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.CommonBrowserContainerPath)</label>
                    <input type="text" class="set-input" value="@_viewState.Exports.LocationLabel" readonly />
                </div>
                <div class="set-field">
                    <label>@Text(UiTextKey.CommonStorageScope)</label>
                    <input type="text" class="set-input" value="@_viewState.Exports.ScopeLabel" readonly />
                </div>
                <p class="set-card-copy">@_viewState.Exports.DetailLabel</p>
            </div>
        </SettingsExpandableCard>
    </div>
</section>

@code {
    private const string DisabledStateValue = "false";
    private const string EnabledStateValue = "true";

    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
