@namespace PrompterOne.Shared.Components.Settings
@using PrompterOne.Shared.Settings.Components
@using PrompterOne.Shared.Settings.Models

<section class="set-section set-panel"
         id="set-files"
         style="@DisplayStyle"
         data-testid="@UiTestIds.Settings.FilesPanel">
    <h3 class="set-section-title">@SettingsNavigationText.FileStorageLabel</h3>
    <p class="set-section-desc">PrompterOne is browser-only. Scripts stay in the browser library store, while recordings and exports use the browser-local storage container instead of fake desktop folders.</p>

    <div class="set-device-list">
        <SettingsExpandableCard Title="Scripts"
                                Subtitle="@_viewState.Scripts.Subtitle"
                                IconStyle="background:rgba(196,160,96,.14); color:var(--gold);"
                                IsOpen="@IsCardOpen(ScriptsCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(ScriptsCardId))">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14,2 14,8 20,8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
            </svg>
            <div class="set-device-fields">
                <div class="set-field">
                    <label>Storage Mode</label>
                    <input type="text" class="set-input" value="@_viewState.Scripts.ScopeLabel" readonly />
                </div>
                <div class="set-field">
                    <label>Browser Keys</label>
                    <input type="text" class="set-input" value="@_viewState.Scripts.LocationLabel" readonly />
                </div>
                <p class="set-card-copy">@_viewState.Scripts.DetailLabel</p>
                <div class="set-field set-field-toggle">
                    <label>Auto-save every 30 seconds</label>
                    <div class="@BuildToggleCssClass(_settings.FileAutoSaveEnabled)"
                         data-testid="@UiTestIds.Settings.FileAutoSave"
                         @onclick="ToggleAutoSaveAsync"
                         @onclick:stopPropagation="true">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
                <div class="set-field set-field-toggle">
                    <label>Keep backup copies</label>
                    <div class="@BuildToggleCssClass(_settings.FileBackupCopiesEnabled)"
                         data-testid="@UiTestIds.Settings.FileBackupCopies"
                         @onclick="ToggleBackupCopiesAsync"
                         @onclick:stopPropagation="true">
                        <div class="set-toggle-thumb"></div>
                    </div>
                </div>
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="Recordings"
                                Subtitle="@_viewState.Recordings.Subtitle"
                                IconStyle="background:rgba(239,68,68,.14); color:#F87171;"
                                IsOpen="@IsCardOpen(RecordingsCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(RecordingsCardId))">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none" />
            </svg>
            <div class="set-device-fields">
                <div class="set-field">
                    <label>Storage Scope</label>
                    <input type="text" class="set-input" value="@_viewState.Recordings.ScopeLabel" readonly />
                </div>
                <div class="set-field">
                    <label>Browser Container Path</label>
                    <input type="text" class="set-input" value="@_viewState.Recordings.LocationLabel" readonly />
                </div>
                <div class="set-field">
                    <label>Max Storage</label>
                    <SettingsSelect Value="@_settings.RecordingsStorageLimit"
                                   Options="@StorageLimitOptions"
                                   OnChange="OnStorageLimitChanged" />
                </div>
                <p class="set-card-copy">@_viewState.Recordings.DetailLabel</p>
            </div>
        </SettingsExpandableCard>

        <SettingsExpandableCard Title="Exports"
                                Subtitle="@_viewState.Exports.Subtitle"
                                IconStyle="background:rgba(99,102,241,.16); color:#A5B4FC;"
                                IsOpen="@IsCardOpen(ExportsCardId)"
                                OnToggle="@(() => ToggleCard.InvokeAsync(ExportsCardId))">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7,10 12,15 17,10" />
                <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            <div class="set-device-fields">
                <div class="set-field">
                    <label>Default Export Format</label>
                    <SettingsSelect Value="@_settings.ExportFormat"
                                   Options="@ExportFormatOptions"
                                   OnChange="OnExportFormatChanged" />
                </div>
                <div class="set-field">
                    <label>Browser Container Path</label>
                    <input type="text" class="set-input" value="@_viewState.Exports.LocationLabel" readonly />
                </div>
                <div class="set-field">
                    <label>Storage Scope</label>
                    <input type="text" class="set-input" value="@_viewState.Exports.ScopeLabel" readonly />
                </div>
                <p class="set-card-copy">@_viewState.Exports.DetailLabel</p>
            </div>
        </SettingsExpandableCard>
    </div>
</section>
