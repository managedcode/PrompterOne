@page "/settings"
@implements IDisposable
@namespace PrompterOne.Shared.Pages
@using PrompterOne.Core.Abstractions
@using PrompterOne.Core.Models.Media
@using PrompterOne.Core.Models.Workspace
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Components.Settings
@using PrompterOne.Shared.Localization
@using PrompterOne.Shared.Services
@using PrompterOne.Shared.Services.Diagnostics
@using PrompterOne.Shared.Settings.Components
@using PrompterOne.Shared.Settings.Models
@using PrompterOne.Shared.Storage

@inject AppBootstrapper Bootstrapper
@inject AppShellService Shell
@inject IUserSettingsStore SettingsStore
@inject StudioSettingsStore StudioSettingsStore
@inject UiDiagnosticsService Diagnostics
@inject IMediaPermissionService MediaPermissionService
@inject IMediaDeviceService MediaDeviceService
@inject IMediaSceneService MediaSceneService
@inject IScriptSessionService SessionService

<div id="screen-settings" class="screen active" data-test="@UiTestIds.Settings.Page">
    <div class="set-layout">
        <div class="set-sidebar">
            <div class="set-back-row">
                <h2 class="set-title" data-test="@UiTestIds.Settings.Title">@Text(UiTextKey.SettingsTitle)</h2>
            </div>
            <SettingsSidebarNavigation Items="@NavigationItems"
                                       ActiveSection="@_activeSection"
                                       OnSelect="ShowSection" />
        </div>

        <div class="set-main">
            <SettingsCloudSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Cloud)"
                                  IsCardOpen="IsCardOpen"
                                  SettingsImported="ReloadPreferencesAsync"
                                  ToggleCard="TogglePreferenceCardAsync"
                                  />

            <SettingsFilesSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Files)"
                                  IsCardOpen="IsCardOpen"
                                  ToggleCard="TogglePreferenceCardAsync" />

            <SettingsCamerasSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Cameras)"
                                    MediaAccessActionLabel="@MediaAccessActionLabel"
                                    CameraAccessGranted="@_permissions.CameraGranted"
                                    Cameras="@_cameraDevices"
                                    CameraResolutionOptions="@CameraResolutionOptions"
                                    CameraResolutionChanged="OnCameraResolutionChanged"
                                    CameraPreviewDescription="@BuildCameraPreviewDescription()"
                                    PreviewCamera="@PreviewCamera"
                                    PreviewSceneCamera="@PreviewSceneCamera"
                                    IsSectionActive="@IsCameraSectionActive"
                                    SelectedCameraId="@SelectedCameraId"
                                    StudioSettings="@_studioSettings"
                                    ReaderCameraEnabled="@SessionService.State.ReaderSettings.ShowCameraScene"
                                    AllSceneCamerasIncludedInOutput="@AllSceneCamerasIncludedInOutput"
                                    BuildCameraCardCssClass="BuildCameraCardCssClass"
                                    BuildCameraFeedCssClass="BuildCameraFeedCssClass"
                                    BuildCameraMeta="BuildCameraMeta"
                                    BuildToggleCssClass="BuildToggleCssClass"
                                    ResolveSceneCamera="ResolveSceneCamera"
                                    RequestMediaAccess="RequestMediaAccessAsync"
                                    SelectCameraPreview="SelectCameraPreview"
                                    ToggleCameraSelection="ToggleCameraSelectionAsync"
                                    ToggleSceneMirror="ToggleSceneMirrorAsync"
                                    ToggleReaderCameraScene="ToggleReaderCameraSceneAsync"
                                    SetPrimaryCamera="SetPrimaryCameraAsync"
                                    ToggleAllSceneOutputs="ToggleAllSceneOutputsAsync" />

            <SettingsMicrophonesSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Mics)"
                                        MediaAccessActionLabel="@MediaAccessActionLabel"
                                        MicrophoneAccessGranted="@_permissions.MicrophoneGranted"
                                        ShouldShowMediaAccessAction="@ShouldShowMediaAccessAction"
                                        Microphones="@_microphoneDevices"
                                        SelectedMicrophone="@SelectedMicrophone"
                                        SelectedMicrophoneId="@SelectedMicrophoneId"
                                        MicrophoneSettings="@_studioSettings.Microphone"
                                        IsSectionActive="@IsMicrophoneSectionActive"
                                        AllMicrophonesMutedOutsideGoLive="@AllMicrophonesMutedOutsideGoLive"
                                        BuildLevelFillStyle="BuildLevelFillStyle"
                                        BuildLevelThumbStyle="BuildLevelThumbStyle"
                                        BuildMicrophoneMeta="BuildMicrophoneMeta"
                                        BuildToggleCssClass="BuildToggleCssClass"
                                        ConvertGainToPercent="ConvertGainToPercent"
                                        GetAudioInput="GetAudioInput"
                                        IsMicrophoneEnabled="IsMicrophoneEnabled"
                                        RequestMediaAccess="RequestMediaAccessAsync"
                                        SelectPrimaryMicrophone="SelectPrimaryMicrophoneAsync"
                                        ToggleMicrophoneSelection="ToggleMicrophoneSelectionAsync"
                                        UpdatePrimaryMicLevel="UpdatePrimaryMicLevelAsync"
                                        UpdateAudioDelay="UpdateAudioDelayAsync"
                                        UpdateAudioGain="UpdateAudioGainAsync"
                                        ToggleNoiseSuppression="ToggleNoiseSuppressionAsync"
                                        ToggleEchoCancellation="ToggleEchoCancellationAsync"
                                        ToggleMuteAllMicrophones="ToggleMuteAllMicrophonesAsync" />

            <section class="set-section set-panel"
                     id="set-streaming"
                     style="@GetSectionDisplayStyle(SettingsSection.Streaming)"
                     data-test="@UiTestIds.Settings.StreamingPanel">
                <h3 class="set-section-title">@Text(UiTextKey.SettingsStreamingSectionTitle)</h3>
                <p class="set-section-desc">@Text(UiTextKey.SettingsStreamingSectionDescription)</p>

                <SettingsStreamingPanel Settings="@_studioSettings.Streaming"
                                        Sources="@_sceneCameras"
                                        IsCardOpen="IsCardOpen"
                                        AddTransportConnection="AddTransportConnectionAsync"
                                        AddDistributionTarget="AddDistributionTargetAsync"
                                        ToggleRecording="ToggleRecordingOutputAsync"
                                        ToggleTransportConnection="ToggleTransportConnectionAsync"
                                        RemoveTransportConnection="RemoveTransportConnectionAsync"
                                        UpdateTransportConnectionField="UpdateTransportConnectionFieldAsync"
                                        UpdateTransportConnectionRole="UpdateTransportConnectionRoleAsync"
                                        ToggleTransportConnectionSource="ToggleStreamingDestinationSourceAsync"
                                        ToggleDistributionTarget="ToggleDistributionTargetAsync"
                                        ToggleDistributionTargetTransport="ToggleDistributionTargetTransportAsync"
                                        RemoveDistributionTarget="RemoveDistributionTargetAsync"
                                        UpdateDistributionTargetField="UpdateDistributionTargetFieldAsync"
                                        ToggleCard="TogglePreferenceCardAsync"
                                        OutputResolutionChanged="OnStreamingOutputResolutionChanged"
                                        BitrateChanged="UpdateStreamingBitrateAsync"
                                        ToggleTextOverlay="ToggleSettingsTextOverlayAsync"
                                        ToggleIncludeCamera="ToggleSettingsIncludeCameraAsync" />
            </section>

            <SettingsRecordingSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Recording)"
                                      IsCardOpen="IsCardOpen"
                                      AutoRecordWhenStreaming="@_pagePreferences.AutoRecordWhenStreaming"
                                      SplitRecordingHourly="@_pagePreferences.SplitRecordingHourly"
                                      RecordingFolder="@_pagePreferences.RecordingFolder"
                                      RecordingNamingPattern="@_pagePreferences.RecordingNamingPattern"
                                      RecordingContainer="@_pagePreferences.RecordingContainer"
                                      RecordingVideoCodec="@_pagePreferences.RecordingVideoCodec"
                                      RecordingVideoResolution="@_pagePreferences.RecordingVideoResolution"
                                      RecordingVideoFrameRate="@_pagePreferences.RecordingVideoFrameRate"
                                      RecordingVideoBitrateKbps="@_pagePreferences.RecordingVideoBitrateKbps"
                                      RecordingAudioCodec="@_pagePreferences.RecordingAudioCodec"
                                      RecordingAudioSampleRate="@_pagePreferences.RecordingAudioSampleRate"
                                      RecordingAudioBitrateKbps="@_pagePreferences.RecordingAudioBitrateKbps"
                                      RecordingAudioChannels="@_pagePreferences.RecordingAudioChannels"
                                      ToggleCard="TogglePreferenceCardAsync"
                                      ToggleAutoRecordWhenStreaming="ToggleAutoRecordWhenStreamingAsync"
                                      ToggleSplitRecordingHourly="ToggleSplitRecordingHourlyAsync"
                                      UpdateRecordingNamingPattern="UpdateRecordingNamingPatternAsync"
                                      UpdateRecordingContainer="UpdateRecordingContainerAsync"
                                      UpdateRecordingVideoCodec="UpdateRecordingVideoCodecAsync"
                                      UpdateRecordingVideoResolution="UpdateRecordingVideoResolutionAsync"
                                      UpdateRecordingVideoFrameRate="UpdateRecordingVideoFrameRateAsync"
                                      UpdateRecordingVideoBitrate="UpdateRecordingVideoBitrateAsync"
                                      UpdateRecordingAudioCodec="UpdateRecordingAudioCodecAsync"
                                      UpdateRecordingAudioSampleRate="UpdateRecordingAudioSampleRateAsync"
                                      UpdateRecordingAudioBitrate="UpdateRecordingAudioBitrateAsync"
                                      UpdateRecordingAudioChannels="UpdateRecordingAudioChannelsAsync" />

            <SettingsAiSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Ai)"
                               IsCardOpen="IsCardOpen"
                               ToggleCard="TogglePreferenceCardAsync" />

            <SettingsAppearanceSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Appearance)"
                                       IsCardOpen="IsCardOpen"
                                       ColorScheme="@_pagePreferences.ColorScheme"
                                       AccentColor="@_pagePreferences.AccentColor"
                                       TeleprompterFont="@_pagePreferences.TeleprompterFont"
                                       TeleprompterFontSize="@_pagePreferences.TeleprompterFontSize"
                                       TeleprompterTextColor="@_pagePreferences.TeleprompterTextColor"
                                       MirrorTeleprompterText="@_pagePreferences.MirrorTeleprompterText"
                                       ShowWordHighlight="@_pagePreferences.ShowWordHighlight"
                                       UiDensity="@_pagePreferences.UiDensity"
                                       ReduceMotion="@_pagePreferences.ReduceMotion"
                                       ShowShortcutOverlay="@_pagePreferences.ShowShortcutOverlay"
                                       ToggleCard="TogglePreferenceCardAsync"
                                       UpdateColorScheme="UpdateColorSchemeAsync"
                                       UpdateAccentColor="UpdateAccentColorAsync"
                                       UpdateTeleprompterFont="UpdateTeleprompterFontAsync"
                                       UpdateTeleprompterFontSize="UpdateTeleprompterFontSizeAsync"
                                       UpdateTeleprompterTextColor="UpdateTeleprompterTextColorAsync"
                                       ToggleMirrorTeleprompterText="ToggleMirrorTeleprompterTextAsync"
                                       ToggleShowWordHighlight="ToggleShowWordHighlightAsync"
                                       UpdateUiDensity="UpdateUiDensityAsync"
                                       ToggleReduceMotion="ToggleReduceMotionAsync"
                                       ToggleShowShortcutOverlay="ToggleShowShortcutOverlayAsync" />

            <SettingsLanguageSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Language)"
                                     IsCardOpen="IsCardOpen"
                                     SelectedLanguageCulture="@SelectedLanguageCulture"
                                     ToggleCard="TogglePreferenceCardAsync"
                                     UpdateLanguageCulture="UpdateLanguageCultureAsync" />

            <SettingsHotkeysSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Shortcuts)"
                                    IsCardOpen="IsCardOpen"
                                    ToggleCard="TogglePreferenceCardAsync" />

            <SettingsFeedbackSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Feedback)"
                                     IsCardOpen="IsCardOpen"
                                     ToggleCard="TogglePreferenceCardAsync" />

            <SettingsAboutSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.About)"
                                  IsCardOpen="IsCardOpen"
                                  ToggleCard="TogglePreferenceCardAsync"
                                  OpenOnboarding="HandleOpenOnboardingAsync" />
        </div>
    </div>
</div>
