@namespace PrompterOne.Shared.Components.Editor

@switch (Kind)
{
    case EditorActionIconKind.SemanticDotVoice:
        <span class="@GetDotCss(EditorActionIconTone.Voice)" aria-hidden="true"></span>
        break;
    case EditorActionIconKind.SemanticDotEmotion:
        <span class="@GetDotCss(EditorActionIconTone.Emotion)" aria-hidden="true"></span>
        break;
    case EditorActionIconKind.ChevronDown:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
            <polyline points="6,9 12,15 18,9" />
        </svg>
        break;
    case EditorActionIconKind.Spark:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 2L9 9 2 12l7 3 3 7 3-7 7-3-7-3z" />
        </svg>
        break;
    case EditorActionIconKind.PauseClock:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12,6 12,12 16,14" />
        </svg>
        break;
    case EditorActionIconKind.PauseBars:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="6" y="4" width="4" height="16"></rect>
            <rect x="14" y="4" width="4" height="16"></rect>
        </svg>
        break;
    case EditorActionIconKind.Lightning:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polygon points="13,2 3,14 12,14 11,22 21,10 12,10" />
        </svg>
        break;
    case EditorActionIconKind.EditPoint:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
        </svg>
        break;
    case EditorActionIconKind.Highlight:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="14" width="18" height="6" rx="2"></rect>
            <path d="M8 14V8a4 4 0 0 1 8 0v6"></path>
        </svg>
        break;
    case EditorActionIconKind.Phonetic:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
            <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
        </svg>
        break;
    case EditorActionIconKind.SpeakerHigh:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polygon points="11,5 6,9 2,9 2,15 6,15 11,19"></polygon>
            <path d="M15 9a5 5 0 0 1 0 6"></path>
            <path d="M18 7a8 8 0 0 1 0 10"></path>
        </svg>
        break;
    case EditorActionIconKind.Undo:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="1,4 1,10 7,10" />
            <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
        </svg>
        break;
    case EditorActionIconKind.Redo:
        <svg class="@GetSvgCss()" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="23,4 23,10 17,10" />
            <path d="M20.49 15a9 9 0 1 1-2.13-9.36L23 10" />
        </svg>
        break;
}

@code {
    [Parameter] public EditorActionIconKind Kind { get; set; }

    [Parameter] public EditorActionIconTone Tone { get; set; }

    private string GetDotCss(EditorActionIconTone tone) =>
        $"ed-action-dot {GetToneCss(tone)}";

    private string GetSvgCss() =>
        $"ed-action-icon {GetToneCss(Tone)}";

    private static string GetToneCss(EditorActionIconTone tone) =>
        tone switch
        {
            EditorActionIconTone.Gold => "ed-action-tone--gold",
            EditorActionIconTone.Red => "ed-action-tone--red",
            EditorActionIconTone.Orange => "ed-action-tone--orange",
            EditorActionIconTone.Purple => "ed-action-tone--purple",
            EditorActionIconTone.Voice => "ed-action-tone--voice",
            EditorActionIconTone.Emotion => "ed-action-tone--emotion",
            _ => string.Empty
        };
}
