@namespace PrompterOne.Shared.Components.Editor
@using PrompterOne.Core.Models.Editor
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Rendering
@using PrompterOne.Shared.Services.Editor
@using Microsoft.AspNetCore.Components
@inject EditorInterop SemanticInterop
@inject EditorMonacoInterop MonacoInterop

<div class="ed-main" data-testid="@UiTestIds.Editor.MainPanel">
    <div class="ed-toolbar" data-testid="@UiTestIds.Editor.Toolbar">
        @for (var sectionIndex = 0; sectionIndex < ToolbarSections.Count; sectionIndex++)
        {
            var toolbarSection = ToolbarSections[sectionIndex];
            <div class="@GetToolbarSectionCss(toolbarSection)">
                <div class="tb-label">@toolbarSection.Label</div>
                <div class="tb-row">
                    @foreach (var toolbarAction in toolbarSection.MainActions)
                    {
                        <EditorActionButton Action="@toolbarAction"
                                            ActionSelected="ExecuteToolbarActionAsync"
                                            AriaExpanded="@GetActionAriaExpanded(toolbarAction)"
                                            Disabled="@GetActionDisabled(toolbarAction)"
                                            TooltipCssClass="@GetTooltipCssClass(EditorToolbarTooltipPlacement.Toolbar)"
                                            TooltipPlacementValue="@GetTooltipPlacementValue(EditorToolbarTooltipPlacement.Toolbar)" />
                    }
                </div>

                @if (toolbarSection.HasDropdown)
                {
                    <div class="@GetToolbarDropdownCss(toolbarSection)" data-testid="@toolbarSection.DropdownTestId">
                        @for (var groupIndex = 0; groupIndex < toolbarSection.DropdownGroups.Count; groupIndex++)
                        {
                            var dropdownGroup = toolbarSection.DropdownGroups[groupIndex];
                            @if (dropdownGroup.HasSeparatorBefore)
                            {
                                <div class="tb-drop-sep"></div>
                            }
                            <div class="tb-drop-label">@dropdownGroup.Label</div>
                                <div class="@GetDropdownListCss(toolbarSection)">
                                    @foreach (var dropdownAction in dropdownGroup.Actions)
                                    {
                                        <EditorActionButton Action="@dropdownAction"
                                                            ActionSelected="ExecuteToolbarActionAsync"
                                                            TooltipCssClass="@GetTooltipCssClass(EditorToolbarTooltipPlacement.ToolbarMenu)"
                                                            TooltipPlacementValue="@GetTooltipPlacementValue(EditorToolbarTooltipPlacement.ToolbarMenu)" />
                                    }
                                </div>
                            }
                    </div>
                }
            </div>

            @if (sectionIndex < ToolbarSections.Count - 1)
            {
                <span class="tb-div"></span>
            }
        }

        <div class="ed-toolbar-tools">
            <button type="button"
                    class="ed-find-toggle"
                    @onclick="ToggleFindBarAsync"
                    aria-expanded="@(_showFindBar ? "true" : "false")"
                    data-testid="@UiTestIds.Editor.FindToggle">
                <UiIcon Kind="UiIconKind.Search" Size="14" />
                <span>@L(UiTextKey.EditorFindOpen)</span>
            </button>
        </div>
    </div>

    @if (_showFindBar)
    {
        <div class="ed-find-bar" data-testid="@UiTestIds.Editor.FindBar">
            <label class="ed-find-input-shell">
                <UiIcon Kind="UiIconKind.Search" Size="14" />
                <input class="ed-find-input"
                       type="text"
                       value="@_findQuery"
                       placeholder="@L(UiTextKey.EditorFindPlaceholder)"
                       aria-label="@L(UiTextKey.EditorFindPlaceholder)"
                       @oninput="OnFindQueryInputAsync"
                       data-testid="@UiTestIds.Editor.FindInput" />
            </label>

            @if (ShouldRenderFindResult)
            {
                <span class="ed-find-result" data-testid="@UiTestIds.Editor.FindResult">@FindResultLabel</span>
            }

            <div class="ed-find-actions">
                <button type="button"
                        class="ed-find-nav"
                        @onclick="NavigateToPreviousFindMatchAsync"
                        disabled="@(!CanNavigateFindMatches)"
                        data-testid="@UiTestIds.Editor.FindPrevious">@L(UiTextKey.EditorFindPrevious)</button>
                <button type="button"
                        class="ed-find-nav"
                        @onclick="NavigateToNextFindMatchAsync"
                        disabled="@(!CanNavigateFindMatches)"
                        data-testid="@UiTestIds.Editor.FindNext">@L(UiTextKey.EditorFindNext)</button>
                <button type="button"
                        class="ed-find-close"
                        @onclick="CloseFindBarAsync"
                        data-testid="@UiTestIds.Editor.FindClose">@L(UiTextKey.EditorFindClose)</button>
            </div>
        </div>
    }

    <div class="ed-content ed-source-shell"
         data-testid="@UiTestIds.Editor.SourceScrollHost">
        <div class="ed-source-stage">
            <div class="ed-source-monaco"
                 @ref="_editorHostRef"
                 data-testid="@UiTestIds.Editor.SourceStage"
                 data-editor-ready="false"></div>
            <div class="ed-source-highlight"
                 @ref="_semanticSnapshotRef"
                 data-testid="@UiTestIds.Editor.SourceHighlight">
                @if (!_surfaceInteropReady)
                {
                    @TpsSourceHighlighter.Render(Text)
                }
            </div>
            <textarea class="ed-source-input"
                      data-testid="@UiTestIds.Editor.SourceInput"
                      spellcheck="false"
                      autocapitalize="off"
                      autocomplete="off"
                      autocorrect="off"
                      tabindex="-1"
                      aria-hidden="true"
                      value="@Text"
                      @ref="_textareaRef"
                      @oninput="OnSourceInputAsync"
                      @onkeydown="OnSourceKeyDownAsync"
                      @onmouseup="OnSelectionInteractionAsync"
                      @onselect="OnSourceSelectAsync"></textarea>

            @if (ShouldRenderFloatingBar)
            {
                <span class="ed-float-bar"
                      data-testid="@UiTestIds.Editor.FloatingBar"
                      style="@FloatingBarStyle">
                    @for (var groupIndex = 0; groupIndex < FloatingActionGroups.Count; groupIndex++)
                    {
                        var group = FloatingActionGroups[groupIndex];
                        @foreach (var action in group)
                        {
                            <EditorActionButton Action="@action"
                                                ActionSelected="ExecuteToolbarActionAsync"
                                                AriaExpanded="@GetActionAriaExpanded(action)"
                                                Disabled="@GetActionDisabled(action)"
                                                TooltipCssClass="@GetTooltipCssClass(EditorToolbarTooltipPlacement.FloatingToolbar)"
                                                TooltipPlacementValue="@GetTooltipPlacementValue(EditorToolbarTooltipPlacement.FloatingToolbar)" />
                        }

                        @if (groupIndex < FloatingActionGroups.Count - 1)
                        {
                            <span class="efb-sep"></span>
                        }
                    }

                    @if (OpenFloatingMenu is { } floatingMenu)
                    {
                        <span class="@GetFloatingMenuCss(floatingMenu)"
                              data-testid="@floatingMenu.PanelTestId"
                              >
                            @for (var groupIndex = 0; groupIndex < floatingMenu.DropdownGroups.Count; groupIndex++)
                            {
                                var dropdownGroup = floatingMenu.DropdownGroups[groupIndex];
                                @if (dropdownGroup.HasSeparatorBefore)
                                {
                                    <div class="efb-drop-sep"></div>
                                }
                                <span class="efb-dropdown-label">@dropdownGroup.Label</span>
                                <span class="efb-menu-list">
                                    @foreach (var action in dropdownGroup.Actions)
                                    {
                                        <EditorActionButton Action="@action"
                                                            ActionSelected="ExecuteToolbarActionAsync"
                                                            TooltipCssClass="@GetTooltipCssClass(EditorToolbarTooltipPlacement.FloatingMenu)"
                                                            TooltipPlacementValue="@GetTooltipPlacementValue(EditorToolbarTooltipPlacement.FloatingMenu)" />
                                    }
                                </span>
                            }
                        </span>
                    }
                </span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="ed-source-error" data-testid="@UiTestIds.Editor.Error">@ErrorMessage</div>
        }
    </div>

    <div class="ed-statusbar">
        <span>@StatusLineShortLabel @Status.Line, @StatusColumnShortLabel @Status.Column</span>
        <span>@Status.Profile</span>
        <span>@Status.BaseWpm @L(UiTextKey.CommonWpm)</span>
        <span>@StatusSegmentsLabel</span>
        <span>@StatusWordCountLabel</span>
        <span>~@Status.Duration</span>
        <span>@StatusVersionLabel</span>
    </div>
</div>
