        ["about"] = new("edgeSemantic", 1.8, .9),
        ["connects"] = new("edgeSemantic", 1.65, .86, new[] { 7, 6 }),
        ["mentions"] = new("edgeMention", 1.55, .84, new[] { 5, 6 }),
        ["co-occurs"] = new("edgeSemantic", 1.55, .84, new[] { 5, 5 }),
        ["token similarity"] = new("edgeSemantic", 1.8, .9, new[] { 8, 5 }),
        ["features"] = new("edgeMention", 1.55, .84, new[] { 4, 5 }),
        ["references"] = new("edgeReference", 1.85, .92),
        ["spoken by"] = new("edgeCharacter", 1.9, .92),
        ["derived from"] = new("edgeStructural", 1.45, .78, new[] { 6, 8 }),
    };

    private static readonly HashSet<string> NonVisualNodeKinds = new(StringComparer.Ordinal)
    {
        "Line",
        "Pace",
        "Timing",
        "Cue",
        "Archetype",
        "Literal",
        "Uri",
    };

    private static readonly HashSet<string> StoryNodeKinds = new(StringComparer.Ordinal)
    {
        "Document",
        "Section",
        "Heading",
        "TpsSegment",
        "Idea",
        "Character",
        "Reference",
        "Plot",
        "Location",
        "Object",
        "Timeline",
        "Entity",
        "Term",
        "Claim",
        "SimilarityChunk",
        "Custom",
        "Mention",
        "Story",
    };

    private static readonly Dictionary<string, HashSet<string>> ModeLaneFilters = new(StringComparer.Ordinal)
    {
        [ScriptGraphLayoutModes.Knowledge] = new HashSet<string>(StringComparer.Ordinal) { "knowledge", "character", "tag", "main" },
        [ScriptGraphLayoutModes.Structure] = new HashSet<string>(StringComparer.Ordinal) { "main", "structure", "block" },
        [ScriptGraphLayoutModes.Delivery] = new HashSet<string>(StringComparer.Ordinal) { "main", "structure", "delivery" },
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Artifact is null || Artifact.IsEmpty)
        {
            return;
        }

        var revision = CreateRenderRevision(Artifact);
        if (string.Equals(_renderedRevision, revision, StringComparison.Ordinal) ||
            string.Equals(_renderingRevision, revision, StringComparison.Ordinal))
        {
            return;
        }

        _callbackReference ??= DotNetObjectReference.Create(this);
        _renderingRevision = revision;
        try
        {
            await GraphViewer.RenderAsync(_graphElement, Artifact, BuildGraphConfig(_callbackReference));
            _renderedRevision = revision;
        }
        finally
        {
            if (string.Equals(_renderingRevision, revision, StringComparison.Ordinal))
            {
                _renderingRevision = null;
            }
        }
    }

    private string CreateRenderRevision(ScriptKnowledgeGraphArtifact artifact) =>
        $"{RuntimeHelpers.GetHashCode(artifact)}:{artifact.Revision.Value}:{artifact.SemanticStatus}:{LayoutMode}:{NodeStyleMode}:{IsGraphOnly}";

    private string Text(UiTextKey key) => Localizer[key.ToString()];

    private string GraphModeToggleLabel =>
        IsGraphOnly
            ? Text(UiTextKey.EditorGraphSplitMode)
            : Text(UiTextKey.EditorGraphOnlyMode);

    private string Format(UiTextKey key, params object[] args) =>
        string.Format(System.Globalization.CultureInfo.CurrentCulture, Text(key), args);

    private bool TryReadSemanticStatus(out string title, out string detail, out bool canRunTokenizer)
    {
        title = string.Empty;
        detail = string.Empty;
        canRunTokenizer = false;
        if (Artifact is null)
        {
            return false;
        }

        switch (Artifact.SemanticStatus)
        {
            case ScriptKnowledgeGraphSemanticStatus.ModelUnavailable:
                title = Text(UiTextKey.EditorGraphSemanticUnavailableTitle);
                detail = Text(UiTextKey.EditorGraphSemanticUnavailableDetail);
                canRunTokenizer = Artifact.SemanticMode != ScriptKnowledgeGraphSemanticMode.TokenizerSimilarity;
                return true;
            case ScriptKnowledgeGraphSemanticStatus.ModelFailed:
                title = Text(UiTextKey.EditorGraphSemanticFailedTitle);
                detail = Text(UiTextKey.EditorGraphSemanticFailedDetail);
                canRunTokenizer = Artifact.SemanticMode != ScriptKnowledgeGraphSemanticMode.TokenizerSimilarity;
                return true;
            case ScriptKnowledgeGraphSemanticStatus.TokenizerSimilarity:
                title = Text(UiTextKey.EditorGraphTokenizerActiveTitle);
                detail = Text(UiTextKey.EditorGraphTokenizerActiveDetail);
                return true;
            default:
                return false;
        }
    }

    private async Task OnLayoutSelectChangedAsync(ChangeEventArgs args)
    {
        var nextMode = ScriptGraphLayoutModes.Normalize(args.Value?.ToString());
        if (string.Equals(nextMode, LayoutMode, StringComparison.Ordinal))
        {
            return;
        }

        await LayoutModeChanged.InvokeAsync(nextMode);
    }

    private Task ToggleGraphOnlyModeAsync() =>
        IsGraphOnlyChanged.InvokeAsync(!IsGraphOnly);

    [JSInvokable]
    public async Task OnGraphNodeRequestedAsync(string? nodeId)
    {
        var sourceRange = Artifact?.SourceRanges.FirstOrDefault(range =>
            string.Equals(range.NodeId, nodeId, StringComparison.Ordinal));
        if (sourceRange is null)
        {
            return;
        }

        await SourceRangeRequested.InvokeAsync(sourceRange);
    }

    public ValueTask DisposeAsync()
    {
        _callbackReference?.Dispose();
        return ValueTask.CompletedTask;
    }

    private GraphStats CreateGraphStats(ScriptKnowledgeGraphArtifact artifact)
    {
        var visibleNodeIds = artifact.Nodes
            .Where(NodeIsVisible)
            .Select(node => node.Id)
            .ToHashSet(StringComparer.Ordinal);
        var parentByNode = artifact.Edges
            .Where(edge => !string.IsNullOrWhiteSpace(edge.SourceId) && !string.IsNullOrWhiteSpace(edge.TargetId))
            .GroupBy(edge => edge.TargetId, StringComparer.Ordinal)
            .ToDictionary(group => group.Key, group => group.First().SourceId, StringComparer.Ordinal);
        var edgeCount = artifact.Edges
            .Select(edge => ReadVisibleEdge(edge, visibleNodeIds, parentByNode))
            .Where(edge => !string.IsNullOrWhiteSpace(edge.Source) &&
                           !string.IsNullOrWhiteSpace(edge.Target) &&
                           !string.Equals(edge.Source, edge.Target, StringComparison.Ordinal))
            .Distinct()
            .Count();
        var sourceRangeCount = artifact.SourceRanges.Count(range => visibleNodeIds.Contains(range.NodeId));
        return new GraphStats(visibleNodeIds.Count, edgeCount, sourceRangeCount);
    }

    private (string? Source, string? Target, string Label) ReadVisibleEdge(
        ScriptKnowledgeGraphEdge edge,
        IReadOnlySet<string> visibleNodeIds,
        IReadOnlyDictionary<string, string> parentByNode)
    {
        if (!string.Equals(LayoutMode, ScriptGraphLayoutModes.Story, StringComparison.Ordinal))
        {
            return (
                visibleNodeIds.Contains(edge.SourceId) ? edge.SourceId : null,
                visibleNodeIds.Contains(edge.TargetId) ? edge.TargetId : null,
                edge.Label);
        }

        return (
            ResolveVisibleAncestor(edge.SourceId, visibleNodeIds, parentByNode),
            visibleNodeIds.Contains(edge.TargetId) ? edge.TargetId : null,
            edge.Label);
    }

    private static string? ResolveVisibleAncestor(
        string nodeId,
        IReadOnlySet<string> visibleNodeIds,
        IReadOnlyDictionary<string, string> parentByNode)
    {
        var current = nodeId;
        var seen = new HashSet<string>(StringComparer.Ordinal);
        while (!string.IsNullOrWhiteSpace(current) && seen.Add(current))
        {
            if (visibleNodeIds.Contains(current))
            {
                return current;
            }

            if (!parentByNode.TryGetValue(current, out current))
            {
                return null;
            }
        }

        return null;
    }

    private bool NodeIsVisible(ScriptKnowledgeGraphNode node)
    {
        if (string.IsNullOrWhiteSpace(node.Id) || NonVisualNodeKinds.Contains(node.Kind))
        {
            return false;
        }

        if (string.Equals(LayoutMode, ScriptGraphLayoutModes.Story, StringComparison.Ordinal))
        {
            return StoryNodeKinds.Contains(node.Kind);
        }

        return !ModeLaneFilters.TryGetValue(LayoutMode, out var lanes) || lanes.Contains(ReadLane(node.Kind));
    }

    private static string ReadLane(string kind) =>
        LaneByKind.TryGetValue(kind, out var lane) ? lane : "knowledge";

    private object BuildGraphConfig(DotNetObjectReference<ScriptGraphPanel> callbackReference) => new
    {
        layoutMode = LayoutMode,
        callbackReference,
        laneOrder = LaneOrder,
        laneByKind = LaneByKind,
        nodeStyleMode = NodeStyleMode,
        nodeStylePresets = NodeVisualStyles,
        nonVisualKinds = NonVisualNodeKinds,
        storyKinds = StoryNodeKinds,
        modeLaneFilters = ModeLaneFilters.ToDictionary(pair => pair.Key, pair => pair.Value.ToArray(), StringComparer.Ordinal),
        kindStyles = KindStyles,
        edgeStyles = EdgeStyles,
        laneTitles = new Dictionary<string, string>
        {
            ["character"] = Text(UiTextKey.EditorGraphLanePeople),
            ["tag"] = Text(UiTextKey.EditorGraphLaneThemes),
            ["main"] = Text(UiTextKey.EditorGraphLaneDocument),
            ["structure"] = Text(UiTextKey.EditorGraphLaneSections),
            ["block"] = Text(UiTextKey.EditorGraphLaneBlocks),
            ["delivery"] = Text(UiTextKey.EditorGraphLaneDelivery),
            ["knowledge"] = Text(UiTextKey.EditorGraphLaneKnowledge),
        },
        sourceHint = Text(UiTextKey.EditorGraphJumpToSourceHint),
        colors = new Dictionary<string, string>
        {
            ["documentFill"] = "--script-graph-document-fill",
            ["documentStroke"] = "--script-graph-document-stroke",
            ["sectionFill"] = "--script-graph-section-fill",
            ["sectionStroke"] = "--script-graph-section-stroke",
            ["blockFill"] = "--script-graph-block-fill",
            ["blockStroke"] = "--script-graph-block-stroke",
            ["ideaFill"] = "--script-graph-idea-fill",
            ["ideaStroke"] = "--script-graph-idea-stroke",
            ["characterFill"] = "--script-graph-character-fill",
            ["characterStroke"] = "--script-graph-character-stroke",
            ["themeFill"] = "--script-graph-theme-fill",
            ["themeStroke"] = "--script-graph-theme-stroke",
            ["termFill"] = "--script-graph-term-fill",
            ["termStroke"] = "--script-graph-term-stroke",
            ["claimFill"] = "--script-graph-claim-fill",
            ["claimStroke"] = "--script-graph-claim-stroke",
            ["defaultFill"] = "--script-graph-default-fill",
            ["defaultStroke"] = "--script-graph-default-stroke",
            ["activeStroke"] = "--script-graph-document-stroke",
            ["edgeStroke"] = "--script-graph-edge-default",
            ["edgeStructural"] = "--script-graph-edge-structural",
            ["edgeSemantic"] = "--script-graph-edge-semantic",
            ["edgeMention"] = "--script-graph-edge-mention",
            ["edgeReference"] = "--script-graph-edge-reference",
            ["edgeCharacter"] = "--script-graph-edge-reference",
