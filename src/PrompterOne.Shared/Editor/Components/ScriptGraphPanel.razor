@namespace PrompterOne.Shared.Components.Editor
@using System.Runtime.CompilerServices
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using PrompterOne.Core.AI.Models
@using PrompterOne.Shared.Contracts
@using PrompterOne.Shared.Localization
@using PrompterOne.Shared.Services.Editor
@implements IAsyncDisposable
@inject ScriptGraphViewerInterop GraphViewer
@inject IStringLocalizer<SharedResource> Localizer

<section class="script-graph-panel" data-test="@UiTestIds.Editor.GraphPanel">
    @if (IsLoading)
    {
        <div class="script-graph-empty" data-test="@UiTestIds.Editor.GraphEmpty">@Text(UiTextKey.EditorGraphBuilding)</div>
    }
    else if (Artifact is null || Artifact.IsEmpty)
    {
        <div class="script-graph-empty" data-test="@UiTestIds.Editor.GraphEmpty">@Text(UiTextKey.EditorGraphEmpty)</div>
    }
    else
    {
        var graphStats = CreateGraphStats(Artifact);
        <header class="script-graph-summary" data-test="@UiTestIds.Editor.GraphSummary">
            <div class="script-graph-metrics">
                <strong>@Format(UiTextKey.EditorGraphNodesFormat, graphStats.NodeCount)</strong>
                <span>@Format(UiTextKey.EditorGraphLinksFormat, graphStats.EdgeCount)</span>
                <span>@Format(UiTextKey.EditorGraphSourceRangesFormat, graphStats.SourceRangeCount)</span>
            </div>
            <div class="script-graph-controls" data-test="@UiTestIds.Editor.GraphControls">
                <button type="button"
                        data-graph-control="zoom-in"
                        data-test="@UiTestIds.Editor.GraphZoomIn"
                        title="@Text(UiTextKey.EditorGraphZoomIn)"
                        aria-label="@Text(UiTextKey.EditorGraphZoomIn)">
                    <svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="8.5" cy="8.5" r="5.5" /><line x1="13" y1="13" x2="17" y2="17" />
                        <line x1="6" y1="8.5" x2="11" y2="8.5" /><line x1="8.5" y1="6" x2="8.5" y2="11" />
                    </svg>
                </button>
                <button type="button"
                        data-graph-control="zoom-out"
                        data-test="@UiTestIds.Editor.GraphZoomOut"
                        title="@Text(UiTextKey.EditorGraphZoomOut)"
                        aria-label="@Text(UiTextKey.EditorGraphZoomOut)">
                    <svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="8.5" cy="8.5" r="5.5" /><line x1="13" y1="13" x2="17" y2="17" />
                        <line x1="6" y1="8.5" x2="11" y2="8.5" />
                    </svg>
                </button>
                <button type="button"
                        data-graph-control="fit"
                        data-test="@UiTestIds.Editor.GraphFit"
                        title="@Text(UiTextKey.EditorGraphFit)"
                        aria-label="@Text(UiTextKey.EditorGraphFit)">
                    <svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M3 7V3h4M13 3h4v4M17 13v4h-4M7 17H3v-4" />
                    </svg>
                </button>
                <button type="button"
                        class="script-graph-auto-layout"
                        data-graph-control="auto-layout"
                        data-test="@UiTestIds.Editor.GraphAutoLayout"
                        title="@Text(UiTextKey.EditorGraphAutoLayout)"
                        aria-label="@Text(UiTextKey.EditorGraphAutoLayout)">
                    @Text(UiTextKey.EditorGraphAutoLayout)
                </button>
                <button type="button"
                        class="script-graph-analyze"
                        data-test="@UiTestIds.Editor.GraphAnalyze"
                        title="@Text(UiTextKey.EditorGraphAnalyze)"
                        aria-label="@Text(UiTextKey.EditorGraphAnalyze)"
                        @onclick="() => AnalyzeRequested.InvokeAsync()">
                    @Text(UiTextKey.EditorGraphAnalyze)
                </button>
                <button type="button"
                        class="script-graph-mode-toggle"
                        data-test="@UiTestIds.Editor.GraphOnlyToggle"
                        aria-pressed="@IsGraphOnly.ToString().ToLowerInvariant()"
                        title="@GraphModeToggleLabel"
                        aria-label="@GraphModeToggleLabel"
                        @onclick="ToggleGraphOnlyModeAsync">
                    @GraphModeToggleLabel
                </button>
                <select class="script-graph-layout-select"
                        value="@LayoutMode"
                        aria-label="@Text(UiTextKey.EditorGraphLayout)"
                        data-test="@UiTestIds.Editor.GraphLayoutMode"
                        @onchange="OnLayoutSelectChangedAsync">
                    <option value="@ScriptGraphLayoutModes.Story">@Text(UiTextKey.EditorGraphStoryLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Compact">@Text(UiTextKey.EditorGraphCompactLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Knowledge">@Text(UiTextKey.EditorGraphKnowledgeLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Structure">@Text(UiTextKey.EditorGraphStructureLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Delivery">@Text(UiTextKey.EditorGraphDeliveryLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Relationship">@Text(UiTextKey.EditorGraphRelationshipLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Dagre">@Text(UiTextKey.EditorGraphDagreLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Radial">@Text(UiTextKey.EditorGraphRadialLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Grid">@Text(UiTextKey.EditorGraphGridLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Concentric">@Text(UiTextKey.EditorGraphConcentricLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Circular">@Text(UiTextKey.EditorGraphCircularLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Mds">@Text(UiTextKey.EditorGraphMdsLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Fruchterman">@Text(UiTextKey.EditorGraphFruchtermanLayout)</option>
                    <option value="@ScriptGraphLayoutModes.ForceAtlas2">@Text(UiTextKey.EditorGraphForceAtlasLayout)</option>
                    <option value="@ScriptGraphLayoutModes.D3Force">@Text(UiTextKey.EditorGraphD3ForceLayout)</option>
                    <option value="@ScriptGraphLayoutModes.AntvDagre">@Text(UiTextKey.EditorGraphAntvDagreLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Force">@Text(UiTextKey.EditorGraphForceLayout)</option>
                    <option value="@ScriptGraphLayoutModes.Indented">@Text(UiTextKey.EditorGraphIndentedLayout)</option>
                </select>
            </div>
        </header>
        @if (TryReadSemanticStatus(out var statusTitle, out var statusDetail, out var canRunTokenizer))
        {
            <div class="script-graph-semantic-status"
                 data-test="@UiTestIds.Editor.GraphSemanticStatus"
                 data-status="@Artifact.SemanticStatus.ToString()">
                <div>
                    <strong>@statusTitle</strong>
                    <span>@statusDetail</span>
                </div>
                @if (canRunTokenizer)
                {
                    <button type="button"
                            data-test="@UiTestIds.Editor.GraphTokenizerAnalyze"
                            @onclick="() => TokenizerAnalysisRequested.InvokeAsync()">
                        @Text(UiTextKey.EditorGraphTokenizerAnalyze)
                    </button>
                }
            </div>
        }
        <div class="script-graph-canvas"
             @ref="_graphElement"
             tabindex="0"
             data-graph-layout="@LayoutMode"
             data-graph-node-style="@NodeStyleMode"
             data-test="@UiTestIds.Editor.GraphCanvas"></div>
    }
</section>

@code {
    private ElementReference _graphElement;
    private string? _renderedRevision;
    private string? _renderingRevision;
    private DotNetObjectReference<ScriptGraphPanel>? _callbackReference;

    [Parameter] public ScriptKnowledgeGraphArtifact? Artifact { get; set; }

    [Parameter] public bool IsLoading { get; set; }

    [Parameter] public string LayoutMode { get; set; } = ScriptGraphLayoutModes.Knowledge;

    [Parameter] public EventCallback<string> LayoutModeChanged { get; set; }

    [Parameter] public string NodeStyleMode { get; set; } = ScriptGraphNodeStyleModes.Compact;

    [Parameter] public bool IsGraphOnly { get; set; }

    [Parameter] public EventCallback<bool> IsGraphOnlyChanged { get; set; }

    [Parameter] public EventCallback AnalyzeRequested { get; set; }

    [Parameter] public EventCallback TokenizerAnalysisRequested { get; set; }

    [Parameter] public EventCallback<ScriptKnowledgeGraphSourceRange> SourceRangeRequested { get; set; }

