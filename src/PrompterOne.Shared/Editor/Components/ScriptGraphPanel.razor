        ["TpsBlock"] = "block",
        ["Character"] = "character",
        ["Theme"] = "tag",
        ["Reference"] = "tag",
        ["Plot"] = "tag",
        ["Location"] = "tag",
        ["Object"] = "tag",
        ["Timeline"] = "tag",
        ["Entity"] = "tag",
        ["Term"] = "tag",
        ["Claim"] = "knowledge",
        ["SimilarityChunk"] = "knowledge",
        ["Custom"] = "tag",
        ["Mention"] = "tag",
        ["Story"] = "tag",
    };

