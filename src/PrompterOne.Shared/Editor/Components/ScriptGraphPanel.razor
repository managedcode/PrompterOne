        ["Entity"] = new("themeFill", "themeStroke", "labelLight", 15, 600, 4, new[] { 166, 48 }, new[] { 188, 52 }),
        ["Term"] = new("termFill", "termStroke", "labelLight", 18, 650, 4, new[] { 184, 54 }, new[] { 224, 62 }),
