@namespace PrompterOne.Shared.Components.Editor
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<div class="ed-structure-inspector">
    <div class="ed-section-label">@Text(UiTextKey.EditorStructureActiveSegment)</div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonName)</label>
        <input class="ed-meta-input"
               type="text"
               value="@ActiveSegment.Name"
               data-testid="@UiTestIds.Editor.ActiveSegmentName"
               @onchange="eventArgs => OnSegmentChanged(nameof(EditorStructureHeaderEditorViewModel.Name), eventArgs.Value?.ToString() ?? string.Empty)" />
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonWpm)</label>
        <input class="ed-meta-input ed-meta-num"
               type="number"
               value="@GetNumericValue(ActiveSegment.TargetWpm)"
               min="80"
               max="600"
               data-testid="@UiTestIds.Editor.ActiveSegmentWpm"
               @onchange="eventArgs => OnSegmentChanged(nameof(EditorStructureHeaderEditorViewModel.TargetWpm), eventArgs.Value?.ToString() ?? string.Empty)" />
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonEmotion)</label>
        <select class="ed-meta-select"
                value="@ActiveSegment.EmotionLabel"
                data-testid="@UiTestIds.Editor.ActiveSegmentEmotion"
                @onchange="eventArgs => OnSegmentChanged(nameof(EditorStructureHeaderEditorViewModel.EmotionLabel), eventArgs.Value?.ToString() ?? string.Empty)">
            @foreach (var option in EditorEmotionCatalog.Options)
            {
                <option value="@option.Label">@option.Label</option>
            }
        </select>
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonSpeaker)</label>
        <input class="ed-meta-input"
               type="text"
               value="@ActiveSegment.Speaker"
               data-testid="@UiTestIds.Editor.ActiveSegmentSpeaker"
               @onchange="eventArgs => OnSegmentChanged(nameof(EditorStructureHeaderEditorViewModel.Speaker), eventArgs.Value?.ToString() ?? string.Empty)" />
    </div>

    @if (ActiveSegment.SupportsTiming)
    {
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonTiming)</label>
            <input class="ed-meta-input"
                   type="text"
                   value="@ActiveSegment.Timing"
                   placeholder="0:00-0:00"
                   data-testid="@UiTestIds.Editor.ActiveSegmentTiming"
                   @onchange="eventArgs => OnSegmentChanged(nameof(EditorStructureHeaderEditorViewModel.Timing), eventArgs.Value?.ToString() ?? string.Empty)" />
        </div>
    }

    <div class="ed-section-label ed-section-label--section-break">@Text(UiTextKey.EditorStructureActiveBlock)</div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonName)</label>
        <input class="ed-meta-input"
               type="text"
               value="@ActiveBlock.Name"
               data-testid="@UiTestIds.Editor.ActiveBlockName"
               @onchange="eventArgs => OnBlockChanged(nameof(EditorStructureHeaderEditorViewModel.Name), eventArgs.Value?.ToString() ?? string.Empty)" />
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonWpm)</label>
        <input class="ed-meta-input ed-meta-num"
               type="number"
               value="@GetNumericValue(ActiveBlock.TargetWpm)"
               min="80"
               max="600"
               data-testid="@UiTestIds.Editor.ActiveBlockWpm"
               @onchange="eventArgs => OnBlockChanged(nameof(EditorStructureHeaderEditorViewModel.TargetWpm), eventArgs.Value?.ToString() ?? string.Empty)" />
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonEmotion)</label>
        <select class="ed-meta-select"
                value="@ActiveBlock.EmotionLabel"
                data-testid="@UiTestIds.Editor.ActiveBlockEmotion"
                @onchange="eventArgs => OnBlockChanged(nameof(EditorStructureHeaderEditorViewModel.EmotionLabel), eventArgs.Value?.ToString() ?? string.Empty)">
            <option value="">@Text(UiTextKey.CommonInherit)</option>
            @foreach (var option in EditorEmotionCatalog.Options)
            {
                <option value="@option.Label">@option.Label</option>
            }
        </select>
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonSpeaker)</label>
        <input class="ed-meta-input"
               type="text"
               value="@ActiveBlock.Speaker"
               data-testid="@UiTestIds.Editor.ActiveBlockSpeaker"
               @onchange="eventArgs => OnBlockChanged(nameof(EditorStructureHeaderEditorViewModel.Speaker), eventArgs.Value?.ToString() ?? string.Empty)" />
    </div>
</div>

@code {
    [Parameter] public EditorStructureHeaderEditorViewModel ActiveBlock { get; set; } = EditorStructureHeaderEditorViewModel.Empty("Block", false);

    [Parameter] public EventCallback<EditorStructureHeaderEditorViewModel> ActiveBlockChanged { get; set; }

    [Parameter] public EditorStructureHeaderEditorViewModel ActiveSegment { get; set; } = EditorStructureHeaderEditorViewModel.Empty("Segment", true);

    [Parameter] public EventCallback<EditorStructureHeaderEditorViewModel> ActiveSegmentChanged { get; set; }

    private string Text(UiTextKey key) => Localizer[key.ToString()];

    private static string GetNumericValue(int? value) =>
        value?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;

    private Task OnBlockChanged(string propertyName, string value) =>
        ActiveBlockChanged.InvokeAsync(ApplyChange(ActiveBlock, propertyName, value));

    private Task OnSegmentChanged(string propertyName, string value) =>
        ActiveSegmentChanged.InvokeAsync(ApplyChange(ActiveSegment, propertyName, value));

    private static EditorStructureHeaderEditorViewModel ApplyChange(
        EditorStructureHeaderEditorViewModel model,
        string propertyName,
        string value)
    {
        return propertyName switch
        {
            nameof(EditorStructureHeaderEditorViewModel.Name) => model with { Name = value.Trim() },
            nameof(EditorStructureHeaderEditorViewModel.TargetWpm) => model with
            {
                TargetWpm = int.TryParse(value, out var parsedWpm) ? parsedWpm : null
            },
            nameof(EditorStructureHeaderEditorViewModel.EmotionLabel) => model with { EmotionLabel = value.Trim() },
            nameof(EditorStructureHeaderEditorViewModel.Speaker) => model with { Speaker = value.Trim() },
            nameof(EditorStructureHeaderEditorViewModel.Timing) => model with { Timing = value.Trim() },
            _ => model
        };
    }
}
