@namespace PrompterOne.Shared.Components.Editor
@using PrompterOne.Shared.Contracts
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<span class="ed-action-content">
    @if (Content.HasLeadingIcon)
    {
        <span data-test="@UiTestIds.Editor.ToolbarActionLeadingIcon(ActionTestId)">
            <EditorActionIcon Kind="@Content.LeadingIcon" Tone="@Content.LeadingIconTone" />
        </span>
    }

    @if (Content.HasLeadingText)
    {
        <span class="@GetLeadingTextCss()" data-test="@UiTestIds.Editor.ToolbarActionLeading(ActionTestId)">@Content.LeadingText</span>
    }

    @if (Content.HasLabel || Content.HasMetaText)
    {
        <span class="ed-action-copy">
            @if (Content.HasLabel)
            {
                <span class="ed-action-label" data-test="@UiTestIds.Editor.ToolbarActionLabel(ActionTestId)">@LocalizeActionText(Content.Label)</span>
            }

            @if (Content.HasMetaText)
            {
                <small class="ed-action-meta" data-test="@UiTestIds.Editor.ToolbarActionMeta(ActionTestId)">@LocalizeActionText(Content.MetaText)</small>
            }
        </span>
    }

    @if (Content.HasTrailingIcon)
    {
        <span data-test="@UiTestIds.Editor.ToolbarActionTrailingIcon(ActionTestId)">
            <EditorActionIcon Kind="@Content.TrailingIcon" Tone="@Content.TrailingIconTone" />
        </span>
    }
</span>

@code {
    [Parameter] public string ActionTestId { get; set; } = string.Empty;

    [Parameter] public EditorActionContentDescriptor Content { get; set; } = new();

    private string LocalizeActionText(string value) =>
        value switch
        {
            "1 second" => T("EditorActionLabelOneSecond"),
            "2 seconds" => T("EditorActionLabelTwoSeconds"),
            "3 seconds" => T("EditorActionLabelThreeSeconds"),
            "Aside" => T("EditorActionLabelAside"),
            "Block" => T("EditorActionLabelBlock"),
            "Bold" => T("EditorActionLabelBold"),
            "Breath" => T("EditorActionLabelBreath"),
            "Building" => T("EditorActionLabelBuilding"),
            "Calm" => T("EditorActionLabelCalm"),
            "Concerned" => T("EditorActionLabelConcerned"),
            "Custom (ms)" => T("EditorActionLabelCustomMs"),
            "Custom WPM" => T("EditorActionLabelCustomWpm"),
            "Emphasis" => T("EditorActionLabelEmphasis"),
            "Energetic" => T("EditorActionLabelEnergetic"),
            "Energy" => T("EditorActionLabelEnergy"),
            "Excited" => T("EditorActionLabelExcited"),
            "Extra Fast" => T("EditorActionLabelExtraFast"),
            "Extra Slow" => T("EditorActionLabelExtraSlow"),
            "Fast" => T("EditorActionLabelFast"),
            "Focused" => T("EditorActionLabelFocused"),
            "Happy" => T("EditorActionLabelHappy"),
            "High priority" => T("EditorActionLabelHighPriority"),
            "Highlight" => T("EditorActionLabelHighlight"),
            "Italic" => T("EditorActionLabelItalic"),
            "Legato" => T("EditorActionLabelLegato"),
            "Loud" => T("EditorActionLabelLoud"),
            "Medium pause" => T("EditorActionLabelMediumPause"),
            "Medium priority" => T("EditorActionLabelMediumPriority"),
            "Melody" => T("EditorActionLabelMelody"),
            "Motivational" => T("EditorActionLabelMotivational"),
            "Neutral" => T("EditorActionLabelNeutral"),
            "Normal" => T("EditorActionLabelNormal"),
            "Phonetic (IPA)" => T("EditorActionLabelPhoneticIpa"),
            "Professional" => T("EditorActionLabelProfessional"),
            "Pronunciation" => T("EditorActionLabelPronunciation"),
            "Remove cues" => T("EditorActionLabelRemoveCues"),
            "Rhetorical" => T("EditorActionLabelRhetorical"),
            "Sad" => T("EditorActionLabelSad"),
            "Sarcasm" => T("EditorActionLabelSarcasm"),
            "Segment" => T("EditorActionLabelSegment"),
            "Short pause" => T("EditorActionLabelShortPause"),
            "Slow" => T("EditorActionLabelSlow"),
            "Soft" => T("EditorActionLabelSoft"),
            "Staccato" => T("EditorActionLabelStaccato"),
            "Standard" => T("EditorActionLabelStandard"),
            "Stress" => T("EditorActionLabelStress"),
            "Stress guide" => T("EditorActionLabelStressGuide"),
            "Urgent" => T("EditorActionLabelUrgent"),
            "Warm" => T("EditorActionLabelWarm"),
            "Whisper" => T("EditorActionLabelWhisper"),
            "Archetype aware" => T("EditorActionMetaArchetypeAware"),
            "Speaker aware" => T("EditorActionMetaSpeakerAware"),
            _ => value
        };

    private string T(string key) => Localizer[key];

    private string GetLeadingTextCss()
    {
        var classes = new List<string> { "ed-action-leading" };

        if (Content.LeadingBold)
        {
            classes.Add("ed-action-leading--bold");
        }

        if (Content.LeadingItalic)
        {
            classes.Add("ed-action-leading--italic");
        }

        if (Content.LeadingMono)
        {
            classes.Add("ed-action-leading--mono");
        }

        classes.Add(Content.LeadingTone switch
        {
            EditorActionContentTone.Emphasis => "ed-action-leading--emphasis",
            EditorActionContentTone.Highlight => "ed-action-leading--highlight",
            EditorActionContentTone.Loud => "ed-action-leading--loud",
            EditorActionContentTone.Soft => "ed-action-leading--soft",
            EditorActionContentTone.Whisper => "ed-action-leading--whisper",
            EditorActionContentTone.Legato => "ed-action-leading--legato",
            EditorActionContentTone.Staccato => "ed-action-leading--staccato",
            EditorActionContentTone.Energy => "ed-action-leading--energy",
            EditorActionContentTone.Melody => "ed-action-leading--melody",
            EditorActionContentTone.Stress => "ed-action-leading--stress",
            EditorActionContentTone.SpeedXslow => "ed-action-leading--speed-xslow",
            EditorActionContentTone.SpeedSlow => "ed-action-leading--speed-slow",
            EditorActionContentTone.SpeedNormal => "ed-action-leading--speed-normal",
            EditorActionContentTone.SpeedFast => "ed-action-leading--speed-fast",
            EditorActionContentTone.SpeedXfast => "ed-action-leading--speed-xfast",
            EditorActionContentTone.Structure => "ed-action-leading--structure",
            EditorActionContentTone.Pronunciation => "ed-action-leading--pronunciation",
            EditorActionContentTone.Reset => "ed-action-leading--reset",
            EditorActionContentTone.DeliverySarcasm => "ed-action-leading--delivery-sarcasm",
            EditorActionContentTone.DeliveryAside => "ed-action-leading--delivery-aside",
            EditorActionContentTone.DeliveryRhetorical => "ed-action-leading--delivery-rhetorical",
            EditorActionContentTone.DeliveryBuilding => "ed-action-leading--delivery-building",
            EditorActionContentTone.EmotionNeutral => "ed-action-leading--emotion-neutral",
            EditorActionContentTone.EmotionWarm => "ed-action-leading--emotion-warm",
            EditorActionContentTone.EmotionProfessional => "ed-action-leading--emotion-professional",
            EditorActionContentTone.EmotionFocused => "ed-action-leading--emotion-focused",
            EditorActionContentTone.EmotionConcerned => "ed-action-leading--emotion-concerned",
            EditorActionContentTone.EmotionUrgent => "ed-action-leading--emotion-urgent",
            EditorActionContentTone.EmotionMotivational => "ed-action-leading--emotion-motivational",
            EditorActionContentTone.EmotionExcited => "ed-action-leading--emotion-excited",
            EditorActionContentTone.EmotionHappy => "ed-action-leading--emotion-happy",
            EditorActionContentTone.EmotionSad => "ed-action-leading--emotion-sad",
            EditorActionContentTone.EmotionCalm => "ed-action-leading--emotion-calm",
            EditorActionContentTone.EmotionEnergetic => "ed-action-leading--emotion-energetic",
            _ => string.Empty
        });

        return string.Join(" ", classes.Where(static value => !string.IsNullOrWhiteSpace(value)));
    }
}
