@namespace PrompterOne.Shared.Components.Editor
@using Microsoft.Extensions.Localization
@using PrompterOne.Core.Models.Editor
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<div id="@UiDomIds.Editor.MetadataPanel"
     class="ed-meta-panel ed-meta-panel--metadata"
     role="tabpanel"
     aria-labelledby="@UiDomIds.Editor.MetadataTab"
     data-test="@UiTestIds.Editor.MetadataPanel">
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonTitle)</label>
        <input type="text"
               class="ed-meta-input"
               value="@Title"
               @onchange="OnTitleChange"
               data-test="@UiTestIds.Editor.Title" />
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonProfile)</label>
        <select class="ed-meta-select"
                value="@Profile"
                @onchange="OnProfileChange"
                data-test="@UiTestIds.Editor.Profile">
            <option value="@ActorProfileValue">@Text(UiTextKey.CommonActor)</option>
            <option value="@RsvpProfileValue">@Text(UiTextKey.CommonRsvp)</option>
        </select>
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonBaseWpm)</label>
        <input type="number"
               class="ed-meta-input"
               value="@BaseWpm"
               min="80"
               max="600"
               @onchange="OnBaseWpmChange"
               data-test="@UiTestIds.Editor.BaseWpm" />
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonDuration)</label>
        <input type="text"
               class="ed-meta-input"
               value="@Duration"
               @onchange="OnDurationChange"
               data-test="@UiTestIds.Editor.Duration" />
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonAuthor)</label>
        <input type="text"
               class="ed-meta-input"
               value="@Author"
               @onchange="OnAuthorChange"
               data-test="@UiTestIds.Editor.Author" />
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonCreated)</label>
        <div class="ed-meta-date-wrap">
            <input type="date"
                   class="ed-meta-input ed-meta-date-input"
                   value="@CreatedDate"
                   @onchange="OnCreatedDateChange"
                   data-test="@UiTestIds.Editor.Created" />
            <span class="ed-meta-date-icon" data-test="@UiTestIds.Editor.CreatedIcon" aria-hidden="true">
                <UiIcon Kind="UiIconKind.Calendar" Size="14" StrokeWidth="1.8m" />
            </span>
        </div>
    </div>
    <div class="ed-meta-field">
        <label>@Text(UiTextKey.CommonVersion)</label>
        <input type="text"
               class="ed-meta-input"
               value="@Version"
               @onchange="OnVersionChange"
               data-test="@UiTestIds.Editor.Version" />
    </div>

    <div class="ed-meta-panel-section">
        <div class="ed-section-label ed-meta-subsection">@Text(UiTextKey.EditorMetadataSpeedOffsetsSection)</div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonXslow)</label>
            <div class="ed-meta-row">
                <input type="number"
                       class="ed-meta-input ed-meta-num"
                       value="@XslowOffset"
                       @onchange="OnXslowOffsetChange"
                       data-test="@UiTestIds.Editor.SpeedXslow" />
                <span class="ed-meta-unit ed-meta-unit--xslow">%</span>
            </div>
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonSlow)</label>
            <div class="ed-meta-row">
                <input type="number"
                       class="ed-meta-input ed-meta-num"
                       value="@SlowOffset"
                       @onchange="OnSlowOffsetChange"
                       data-test="@UiTestIds.Editor.SpeedSlow" />
                <span class="ed-meta-unit ed-meta-unit--slow">%</span>
            </div>
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonFast)</label>
            <div class="ed-meta-row">
                <input type="number"
                       class="ed-meta-input ed-meta-num"
                       value="@FastOffset"
                       @onchange="OnFastOffsetChange"
                       data-test="@UiTestIds.Editor.SpeedFast" />
                <span class="ed-meta-unit ed-meta-unit--fast">%</span>
            </div>
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonXfast)</label>
            <div class="ed-meta-row">
                <input type="number"
                       class="ed-meta-input ed-meta-num"
                       value="@XfastOffset"
                       @onchange="OnXfastOffsetChange"
                       data-test="@UiTestIds.Editor.SpeedXfast" />
                <span class="ed-meta-unit ed-meta-unit--xfast">%</span>
            </div>
        </div>
    </div>

    <div class="ed-meta-panel-section">
        <div class="ed-section-label ed-meta-subsection">@Text(UiTextKey.EditorMetadataStatsSection)</div>
        <div class="ed-stat"><span>@Text(UiTextKey.CommonWords)</span><b>~@Status.WordCount</b></div>
        <div class="ed-stat"><span>@Text(UiTextKey.CommonEstimatedTime)</span><b>@Status.Duration</b></div>
        <div class="ed-stat"><span>@Text(UiTextKey.CommonSegments)</span><b>@Status.SegmentCount</b></div>
        <div class="ed-stat"><span>@Text(UiTextKey.CommonBlocks)</span><b>@Status.BlockCount</b></div>
    </div>
</div>

@code {
    [Parameter] public string Author { get; set; } = string.Empty;

    [Parameter] public int BaseWpm { get; set; }

    [Parameter] public string CreatedDate { get; set; } = string.Empty;

    [Parameter] public string Duration { get; set; } = string.Empty;

    [Parameter] public int FastOffset { get; set; }

    [Parameter] public string Profile { get; set; } = string.Empty;

    [Parameter] public EditorStatusViewModel Status { get; set; } = new(1, 1, "Actor", 140, 0, 0, 0, "0:00", "1.0");

    [Parameter] public string Title { get; set; } = string.Empty;

    [Parameter] public string Version { get; set; } = string.Empty;

    [Parameter] public int XfastOffset { get; set; }

    [Parameter] public int XslowOffset { get; set; }

    [Parameter] public int SlowOffset { get; set; }

    [Parameter] public EventCallback<string> AuthorChanged { get; set; }

    [Parameter] public EventCallback<int> BaseWpmChanged { get; set; }

    [Parameter] public EventCallback<string> CreatedDateChanged { get; set; }

    [Parameter] public EventCallback<string> DurationChanged { get; set; }

    [Parameter] public EventCallback<int> FastOffsetChanged { get; set; }

    [Parameter] public EventCallback<string> ProfileChanged { get; set; }

    [Parameter] public EventCallback<int> SlowOffsetChanged { get; set; }

    [Parameter] public EventCallback<string> TitleChanged { get; set; }

    [Parameter] public EventCallback<string> VersionChanged { get; set; }

    [Parameter] public EventCallback<int> XfastOffsetChanged { get; set; }

    [Parameter] public EventCallback<int> XslowOffsetChanged { get; set; }

    private const string ActorProfileValue = "Actor";
    private const string RsvpProfileValue = "RSVP";

    private Task OnAuthorChange(ChangeEventArgs args) =>
        AuthorChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnCreatedDateChange(ChangeEventArgs args) =>
        CreatedDateChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnDurationChange(ChangeEventArgs args) =>
        DurationChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnProfileChange(ChangeEventArgs args) =>
        ProfileChanged.InvokeAsync(args.Value?.ToString() ?? ActorProfileValue);

    private Task OnTitleChange(ChangeEventArgs args) =>
        TitleChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnVersionChange(ChangeEventArgs args) =>
        VersionChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnFastOffsetChange(ChangeEventArgs args) =>
        FastOffsetChanged.InvokeAsync(ParseInt(args.Value?.ToString(), FastOffset));

    private Task OnSlowOffsetChange(ChangeEventArgs args) =>
        SlowOffsetChanged.InvokeAsync(ParseInt(args.Value?.ToString(), SlowOffset));

    private Task OnBaseWpmChange(ChangeEventArgs args) =>
        BaseWpmChanged.InvokeAsync(ParseInt(args.Value?.ToString(), BaseWpm));

    private Task OnXfastOffsetChange(ChangeEventArgs args) =>
        XfastOffsetChanged.InvokeAsync(ParseInt(args.Value?.ToString(), XfastOffset));

    private Task OnXslowOffsetChange(ChangeEventArgs args) =>
        XslowOffsetChanged.InvokeAsync(ParseInt(args.Value?.ToString(), XslowOffset));

    private static int ParseInt(string? value, int fallback) =>
        int.TryParse(value, out var parsed) ? parsed : fallback;

    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
