@namespace PrompterOne.Shared.Components.Editor
@using Microsoft.Extensions.Localization
@using PrompterOne.Core.Models.Editor
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<div class="ed-right" data-test="@UiTestIds.Editor.MetadataRail" data-collapsed="@GetCollapsedAttributeValue()">
    <div class="ed-meta-header">
        @if (!IsCollapsed)
        {
            <div class="ed-meta-tabs"
                 role="tablist"
                 aria-label="@Text(UiTextKey.EditorMetadataSection)"
                 data-test="@UiTestIds.Editor.MetadataRailTabs">
                <button type="button"
                        id="@UiDomIds.Editor.MetadataTab"
                        class="@GetTabClass(EditorMetadataRailTab.Metadata)"
                        role="tab"
                        aria-selected="@GetTabSelectedAttribute(EditorMetadataRailTab.Metadata)"
                        aria-controls="@UiDomIds.Editor.MetadataPanel"
                        tabindex="@GetTabIndexValue(EditorMetadataRailTab.Metadata)"
                        data-test="@UiTestIds.Editor.MetadataTab"
                        @onclick="() => SelectTabAsync(EditorMetadataRailTab.Metadata)">
                    @Text(UiTextKey.EditorMetadataSection)
                </button>
                <button type="button"
                        id="@UiDomIds.Editor.ToolsTab"
                        class="@GetTabClass(EditorMetadataRailTab.Tools)"
                        role="tab"
                        aria-selected="@GetTabSelectedAttribute(EditorMetadataRailTab.Tools)"
                        aria-controls="@UiDomIds.Editor.ToolsPanel"
                        tabindex="@GetTabIndexValue(EditorMetadataRailTab.Tools)"
                        data-test="@UiTestIds.Editor.ToolsTab"
                        @onclick="() => SelectTabAsync(EditorMetadataRailTab.Tools)">
                    @Text(UiTextKey.CommonTools)
                </button>
            </div>
        }

        <button type="button"
                class="ed-meta-toggle"
                aria-controls="@UiDomIds.Editor.MetadataRailBody"
                aria-expanded="@GetExpandedAttributeValue()"
                aria-label="@ToggleLabel"
                data-chevron-direction="@GetToggleChevronDirection()"
                @onclick="() => ToggleRequested.InvokeAsync()"
                data-test="@UiTestIds.Editor.MetadataRailToggle">
            <UiIcon Kind="@(IsCollapsed ? UiIconKind.ChevronLeft : UiIconKind.ChevronRight)"
                    Size="14"
                    StrokeWidth="2.2m" />
        </button>
    </div>

    <div id="@UiDomIds.Editor.MetadataRailBody"
         data-test="@UiTestIds.Editor.MetadataRailBody"
         class="ed-meta-body"
         hidden="@IsCollapsed"
         aria-hidden="@IsCollapsed">
        @if (_selectedTab == EditorMetadataRailTab.Metadata)
        {
            <EditorMetadataDetailsPanel Author="@Author"
                                        BaseWpm="@BaseWpm"
                                        CreatedDate="@CreatedDate"
                                        Duration="@Duration"
                                        FastOffset="@FastOffset"
                                        Profile="@Profile"
                                        Status="@Status"
                                        Title="@Title"
                                        Version="@Version"
                                        XfastOffset="@XfastOffset"
                                        XslowOffset="@XslowOffset"
                                        SlowOffset="@SlowOffset"
                                        AuthorChanged="AuthorChanged"
                                        BaseWpmChanged="BaseWpmChanged"
                                        CreatedDateChanged="CreatedDateChanged"
                                        DurationChanged="DurationChanged"
                                        FastOffsetChanged="FastOffsetChanged"
                                        ProfileChanged="ProfileChanged"
                                        SlowOffsetChanged="SlowOffsetChanged"
                                        TitleChanged="TitleChanged"
                                        VersionChanged="VersionChanged"
                                        XfastOffsetChanged="XfastOffsetChanged"
                                        XslowOffsetChanged="XslowOffsetChanged" />
        }
        else
        {
            <EditorMetadataToolsPanel AutoSaveEnabled="@AutoSaveEnabled"
                                      LastLocalSaveAt="@LastLocalSaveAt"
                                      LocalHistory="@LocalHistory"
                                      OpenLibraryRequested="OpenLibraryRequested"
                                      LocalHistoryRestoreRequested="LocalHistoryRestoreRequested"
                                      SplitFeedback="@SplitFeedback"
                                      SplitRequested="SplitRequested" />
        }
    </div>
</div>

@code {
    [Parameter] public string Author { get; set; } = string.Empty;

    [Parameter] public int BaseWpm { get; set; }

    [Parameter] public string CreatedDate { get; set; } = string.Empty;

    [Parameter] public string Duration { get; set; } = string.Empty;

    [Parameter] public int FastOffset { get; set; }

    [Parameter] public bool IsCollapsed { get; set; }

    [Parameter] public EventCallback<string> ProfileChanged { get; set; }

    [Parameter] public bool AutoSaveEnabled { get; set; }

    [Parameter] public DateTimeOffset? LastLocalSaveAt { get; set; }

    [Parameter] public IReadOnlyList<EditorLocalRevisionViewModel> LocalHistory { get; set; } = [];

    [Parameter] public EventCallback OpenLibraryRequested { get; set; }

    [Parameter] public EventCallback<string> LocalHistoryRestoreRequested { get; set; }

    [Parameter] public string Profile { get; set; } = string.Empty;

    [Parameter] public EditorSplitFeedbackViewModel? SplitFeedback { get; set; }

    [Parameter] public EventCallback<TpsDocumentSplitMode> SplitRequested { get; set; }

    [Parameter] public EditorStatusViewModel Status { get; set; } = new(1, 1, "Actor", 140, 0, 0, 0, "0:00", "1.0");

    [Parameter] public string Title { get; set; } = string.Empty;

    [Parameter] public string ToggleLabel { get; set; } = string.Empty;

    [Parameter] public EventCallback ToggleRequested { get; set; }

    [Parameter] public EditorMetadataRailTab SelectedTab { get; set; } = EditorMetadataRailTab.Metadata;

    [Parameter] public EventCallback<EditorMetadataRailTab> SelectedTabChanged { get; set; }

    [Parameter] public string Version { get; set; } = string.Empty;

    [Parameter] public int XfastOffset { get; set; }

    [Parameter] public int XslowOffset { get; set; }

    [Parameter] public int SlowOffset { get; set; }

    [Parameter] public EventCallback<string> AuthorChanged { get; set; }

    [Parameter] public EventCallback<int> BaseWpmChanged { get; set; }

    [Parameter] public EventCallback<string> CreatedDateChanged { get; set; }

    [Parameter] public EventCallback<string> DurationChanged { get; set; }

    [Parameter] public EventCallback<int> FastOffsetChanged { get; set; }

    [Parameter] public EventCallback<int> SlowOffsetChanged { get; set; }

    [Parameter] public EventCallback<string> TitleChanged { get; set; }

    [Parameter] public EventCallback<string> VersionChanged { get; set; }

    [Parameter] public EventCallback<int> XfastOffsetChanged { get; set; }

    [Parameter] public EventCallback<int> XslowOffsetChanged { get; set; }

    private const string LeftChevronDirection = "left";
    private const string RightChevronDirection = "right";
    private EditorMetadataRailTab _selectedTab = EditorMetadataRailTab.Metadata;

    protected override void OnParametersSet()
    {
        _selectedTab = SelectedTab;
    }

    private string GetCollapsedAttributeValue() => IsCollapsed ? "true" : "false";

    private string GetExpandedAttributeValue() => IsCollapsed ? "false" : "true";

    private string GetToggleChevronDirection() => IsCollapsed ? LeftChevronDirection : RightChevronDirection;

    private async Task SelectTabAsync(EditorMetadataRailTab tab)
    {
        if (_selectedTab == tab)
        {
            return;
        }

        _selectedTab = tab;
        await SelectedTabChanged.InvokeAsync(tab);
    }

    private string GetTabClass(EditorMetadataRailTab tab) =>
        tab == _selectedTab ? "ed-meta-tab is-active" : "ed-meta-tab";

    private string GetTabIndexValue(EditorMetadataRailTab tab) => tab == _selectedTab ? "0" : "-1";

    private string GetTabSelectedAttribute(EditorMetadataRailTab tab) => tab == _selectedTab ? "true" : "false";

    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
