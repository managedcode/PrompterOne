@namespace PrompterOne.Shared.Components.Editor
@using System.Globalization
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<div class="ed-right" data-testid="@UiTestIds.Editor.MetadataRail" data-collapsed="@GetCollapsedAttributeValue()">
    <div class="ed-meta-header">
        @if (!IsCollapsed)
        {
            <div class="ed-section-label ed-meta-header-label">@Text(UiTextKey.EditorMetadataSection)</div>
        }

        <button type="button"
                class="ed-meta-toggle"
                aria-controls="@UiDomIds.Editor.MetadataRailBody"
                aria-expanded="@GetExpandedAttributeValue()"
                aria-label="@ToggleLabel"
                data-chevron-direction="@GetToggleChevronDirection()"
                @onclick="() => ToggleRequested.InvokeAsync()"
                data-testid="@UiTestIds.Editor.MetadataRailToggle">
            <UiIcon Kind="@(IsCollapsed ? UiIconKind.ChevronLeft : UiIconKind.ChevronRight)"
                    Size="14"
                    StrokeWidth="2.2m" />
        </button>
    </div>

    <div id="@UiDomIds.Editor.MetadataRailBody"
         class="ed-meta-body"
         hidden="@IsCollapsed"
         aria-hidden="@IsCollapsed">
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonTitle)</label>
            <input type="text"
                   class="ed-meta-input"
                   value="@Title"
                   @onchange="OnTitleChange"
                   data-testid="@UiTestIds.Editor.Title" />
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonProfile)</label>
            <select class="ed-meta-select"
                    value="@Profile"
                    @onchange="OnProfileChange"
                    data-testid="@UiTestIds.Editor.Profile">
                <option value="Actor">@Text(UiTextKey.CommonActor)</option>
                <option value="RSVP">@Text(UiTextKey.CommonRsvp)</option>
            </select>
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonBaseWpm)</label>
            <input type="number"
                   class="ed-meta-input"
                   value="@BaseWpm"
                   min="80"
                   max="600"
                   @onchange="OnBaseWpmChange"
                   data-testid="@UiTestIds.Editor.BaseWpm" />
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonDuration)</label>
            <input type="text"
                   class="ed-meta-input"
                   value="@Duration"
                   @onchange="OnDurationChange"
                   data-testid="@UiTestIds.Editor.Duration" />
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonAuthor)</label>
            <input type="text"
                   class="ed-meta-input"
                   value="@Author"
                   @onchange="OnAuthorChange"
                   data-testid="@UiTestIds.Editor.Author" />
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonCreated)</label>
            <div class="ed-meta-date-wrap">
                <input type="date"
                       class="ed-meta-input ed-meta-date-input"
                       value="@CreatedDate"
                       @onchange="OnCreatedDateChange"
                       data-testid="@UiTestIds.Editor.Created" />
                <span class="ed-meta-date-icon" data-testid="@UiTestIds.Editor.CreatedIcon" aria-hidden="true">
                    <UiIcon Kind="UiIconKind.Calendar" Size="14" StrokeWidth="1.8m" />
                </span>
            </div>
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonVersion)</label>
            <input type="text"
                   class="ed-meta-input"
                   value="@Version"
                   @onchange="OnVersionChange"
                   data-testid="@UiTestIds.Editor.Version" />
        </div>

        <div class="ed-section-label ed-meta-subsection">@Text(UiTextKey.EditorMetadataSpeedOffsetsSection)</div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonXslow)</label>
            <div class="ed-meta-row">
                <input type="number"
                       class="ed-meta-input ed-meta-num"
                       value="@XslowOffset"
                       @onchange="OnXslowOffsetChange"
                       data-testid="@UiTestIds.Editor.SpeedXslow" />
                <span class="ed-meta-unit ed-meta-unit--xslow">%</span>
            </div>
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonSlow)</label>
            <div class="ed-meta-row">
                <input type="number"
                       class="ed-meta-input ed-meta-num"
                       value="@SlowOffset"
                       @onchange="OnSlowOffsetChange"
                       data-testid="@UiTestIds.Editor.SpeedSlow" />
                <span class="ed-meta-unit ed-meta-unit--slow">%</span>
            </div>
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonFast)</label>
            <div class="ed-meta-row">
                <input type="number"
                       class="ed-meta-input ed-meta-num"
                       value="@FastOffset"
                       @onchange="OnFastOffsetChange"
                       data-testid="@UiTestIds.Editor.SpeedFast" />
                <span class="ed-meta-unit ed-meta-unit--fast">%</span>
            </div>
        </div>
        <div class="ed-meta-field">
            <label>@Text(UiTextKey.CommonXfast)</label>
            <div class="ed-meta-row">
                <input type="number"
                       class="ed-meta-input ed-meta-num"
                       value="@XfastOffset"
                       @onchange="OnXfastOffsetChange"
                       data-testid="@UiTestIds.Editor.SpeedXfast" />
                <span class="ed-meta-unit ed-meta-unit--xfast">%</span>
            </div>
        </div>

        <div class="ed-section-label ed-meta-subsection">@Text(UiTextKey.EditorMetadataStatsSection)</div>
        <div class="ed-stat"><span>@Text(UiTextKey.CommonWords)</span><b>~@Status.WordCount</b></div>
        <div class="ed-stat"><span>@Text(UiTextKey.CommonEstimatedTime)</span><b>@Status.Duration</b></div>
        <div class="ed-stat"><span>@Text(UiTextKey.CommonSegments)</span><b>@Status.SegmentCount</b></div>
        <div class="ed-stat"><span>@Text(UiTextKey.CommonBlocks)</span><b>@Status.BlockCount</b></div>

        <div class="ed-section-label ed-meta-subsection">@LocalFileSectionLabel</div>
        <div class="ed-stat" data-testid="@UiTestIds.Editor.LocalHistoryStatus"><span>@AutoSaveLabel</span><b>@GetAutoSaveStateLabel()</b></div>
        <div class="ed-stat"><span>@HistoryLabel</span><b>@GetHistoryCountLabel()</b></div>
        <p class="ed-meta-note">@GetLocalFileNote()</p>

        @if (LocalHistory.Count == 0)
        {
            <p class="ed-meta-empty" data-testid="@UiTestIds.Editor.LocalHistoryEmpty">@EmptyHistoryLabel</p>
        }
        else
        {
            <div class="ed-local-history" data-testid="@UiTestIds.Editor.LocalHistoryPanel">
                @for (var index = 0; index < LocalHistory.Count; index++)
                {
                    var revision = LocalHistory[index];
                    <div class="ed-local-history-item" data-testid="@UiTestIds.Editor.LocalHistoryItem(index)">
                        <div class="ed-local-history-copy">
                            <span class="ed-local-history-time">@revision.SavedAtLabel</span>
                            <span class="ed-local-history-file">@revision.DocumentName</span>
                        </div>
                        <button type="button"
                                class="ed-local-history-restore"
                                data-testid="@UiTestIds.Editor.LocalHistoryRestore(index)"
                                @onclick="() => LocalHistoryRestoreRequested.InvokeAsync(revision.Id)">
                            @RestoreLabel
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Author { get; set; } = string.Empty;

    [Parameter] public int BaseWpm { get; set; }

    [Parameter] public string CreatedDate { get; set; } = string.Empty;

    [Parameter] public string Duration { get; set; } = string.Empty;

    [Parameter] public int FastOffset { get; set; }

    [Parameter] public bool IsCollapsed { get; set; }

    [Parameter] public EventCallback<string> ProfileChanged { get; set; }

    [Parameter] public bool AutoSaveEnabled { get; set; }

    [Parameter] public DateTimeOffset? LastLocalSaveAt { get; set; }

    [Parameter] public IReadOnlyList<EditorLocalRevisionViewModel> LocalHistory { get; set; } = [];

    [Parameter] public EventCallback<string> LocalHistoryRestoreRequested { get; set; }

    [Parameter] public string Profile { get; set; } = string.Empty;

    [Parameter] public EditorStatusViewModel Status { get; set; } = new(1, 1, "Actor", 140, 0, 0, 0, "0:00", "1.0");

    [Parameter] public string Title { get; set; } = string.Empty;

    [Parameter] public string ToggleLabel { get; set; } = string.Empty;

    [Parameter] public EventCallback ToggleRequested { get; set; }

    [Parameter] public string Version { get; set; } = string.Empty;

    [Parameter] public int XfastOffset { get; set; }

    [Parameter] public int XslowOffset { get; set; }

    [Parameter] public int SlowOffset { get; set; }

    [Parameter] public EventCallback<string> AuthorChanged { get; set; }

    [Parameter] public EventCallback<int> BaseWpmChanged { get; set; }

    [Parameter] public EventCallback<string> CreatedDateChanged { get; set; }

    [Parameter] public EventCallback<string> DurationChanged { get; set; }

    [Parameter] public EventCallback<int> FastOffsetChanged { get; set; }

    [Parameter] public EventCallback<int> SlowOffsetChanged { get; set; }

    [Parameter] public EventCallback<string> TitleChanged { get; set; }

    [Parameter] public EventCallback<string> VersionChanged { get; set; }

    [Parameter] public EventCallback<int> XfastOffsetChanged { get; set; }

    [Parameter] public EventCallback<int> XslowOffsetChanged { get; set; }

    private const string LastSavedTimestampFormat = "yyyy-MM-dd HH:mm:ss";
    private const string LeftChevronDirection = "left";
    private const string RightChevronDirection = "right";

    private string AutoSaveLabel => Text(UiTextKey.EditorMetadataAutoSave);

    private string EmptyHistoryLabel => Text(UiTextKey.EditorMetadataNoLocalHistory);

    private string HistoryLabel => Text(UiTextKey.CommonHistory);

    private string LocalFileSectionLabel => Text(UiTextKey.EditorMetadataLocalFileSection);

    private string RestoreLabel => Text(UiTextKey.CommonRestore);

    private Task OnAuthorChange(ChangeEventArgs args) =>
        AuthorChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnCreatedDateChange(ChangeEventArgs args) =>
        CreatedDateChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnDurationChange(ChangeEventArgs args) =>
        DurationChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnProfileChange(ChangeEventArgs args) =>
        ProfileChanged.InvokeAsync(args.Value?.ToString() ?? "Actor");

    private Task OnTitleChange(ChangeEventArgs args) =>
        TitleChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnVersionChange(ChangeEventArgs args) =>
        VersionChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task OnFastOffsetChange(ChangeEventArgs args) =>
        FastOffsetChanged.InvokeAsync(ParseInt(args.Value?.ToString(), FastOffset));

    private Task OnSlowOffsetChange(ChangeEventArgs args) =>
        SlowOffsetChanged.InvokeAsync(ParseInt(args.Value?.ToString(), SlowOffset));

    private Task OnBaseWpmChange(ChangeEventArgs args)
    {
        return BaseWpmChanged.InvokeAsync(ParseInt(args.Value?.ToString(), BaseWpm));
    }

    private Task OnXfastOffsetChange(ChangeEventArgs args) =>
        XfastOffsetChanged.InvokeAsync(ParseInt(args.Value?.ToString(), XfastOffset));

    private Task OnXslowOffsetChange(ChangeEventArgs args) =>
        XslowOffsetChanged.InvokeAsync(ParseInt(args.Value?.ToString(), XslowOffset));

    private string GetCollapsedAttributeValue() => IsCollapsed ? "true" : "false";

    private string GetExpandedAttributeValue() => IsCollapsed ? "false" : "true";

    private string GetToggleChevronDirection() => IsCollapsed ? LeftChevronDirection : RightChevronDirection;

    private string GetAutoSaveStateLabel() => AutoSaveEnabled ? Text(UiTextKey.CommonOn) : Text(UiTextKey.CommonOff);

    private string GetHistoryCountLabel()
    {
        var count = LocalHistory.Count;
        return count == 1
            ? Text(UiTextKey.EditorMetadataOneRevision)
            : Format(UiTextKey.EditorMetadataMultipleRevisionsFormat, count);
    }

    private string GetLocalFileNote()
    {
        if (LastLocalSaveAt is null)
        {
            return Text(UiTextKey.EditorMetadataHistoryHint);
        }

        var timestamp = LastLocalSaveAt.Value.LocalDateTime.ToString(LastSavedTimestampFormat, CultureInfo.InvariantCulture);
        return Format(UiTextKey.EditorMetadataLastInternalSaveFormat, timestamp);
    }

    private static int ParseInt(string? value, int fallback) =>
        int.TryParse(value, out var parsed) ? parsed : fallback;

    private string Format(UiTextKey key, params object[] args) => Localizer[key.ToString(), args];

    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
