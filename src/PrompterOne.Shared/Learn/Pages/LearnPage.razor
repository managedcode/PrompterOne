@page "/learn"
@namespace PrompterOne.Shared.Pages
@using PrompterOne.Shared.Contracts

<HeadContent>
    <link rel="stylesheet" href="@DesignStylesheetPaths.Learn" />
</HeadContent>

<div id="@UiDomIds.Design.LearnScreen"
     class="screen active"
     tabindex="0"
     @ref="_screenRoot"
     @onkeydown="HandleLearnKeyDownAsync"
     @onkeydown:preventDefault="true"
     data-testid="@UiTestIds.Learn.Page">
    <div class="rsvp">
        <div class="rsvp-progress">
            <div id="@UiDomIds.Learn.ProgressFill"
                 class="rsvp-progress-fill"
                 style="width:@_progressFillWidth"></div>
        </div>

        <div class="rsvp-display" data-testid="@UiTestIds.Learn.Display">
            <div class="rsvp-crosshair">
                <svg width="16" height="16" viewBox="0 0 16 16">
                    <line x1="8" y1="0" x2="8" y2="16" stroke="rgba(255,82,82,.3)" stroke-width="1.5" stroke-dasharray="3,2" />
                    <line x1="0" y1="8" x2="16" y2="8" stroke="rgba(255,82,82,.3)" stroke-width="1.5" stroke-dasharray="3,2" />
                    <circle cx="8" cy="8" r="2" fill="rgba(255,82,82,.5)" />
                </svg>
            </div>

            <div class="rsvp-h-row" @ref="_focusRow">
                <div class="rsvp-lane rsvp-lane-left">
                    <div class="rsvp-ctx-left" id="@UiDomIds.Learn.ContextLeft" data-testid="@UiTestIds.Learn.ContextLeft">
                        @foreach (var word in _leftContextWords)
                        {
                            <span>@word</span>
                        }
                    </div>
                </div>

                <div class="rsvp-focus-shell"
                     id="@UiDomIds.Learn.WordShell"
                     data-testid="@UiTestIds.Learn.WordShell">
                    <div class="rsvp-focus" id="@UiDomIds.Learn.Word" data-testid="@UiTestIds.Learn.Word">
                        <span class="rsvp-focus-segment rsvp-focus-leading">@_currentWordLeading</span>
                        <span class="rsvp-focus-segment rsvp-focus-orp orp">@_currentWordOrp</span>
                        <span class="rsvp-focus-segment rsvp-focus-trailing">@_currentWordTrailing</span>
                    </div>
                </div>

                <div class="rsvp-lane rsvp-lane-right">
                    <div class="rsvp-ctx-right" id="@UiDomIds.Learn.ContextRight" data-testid="@UiTestIds.Learn.ContextRight">
                        @foreach (var word in _rightContextWords)
                        {
                            <span>@word</span>
                        }
                    </div>
                </div>
            </div>

            <div class="rsvp-orp-line" data-testid="@UiTestIds.Learn.OrpLine"></div>

            <div class="rsvp-phrase">
                <span class="rsvp-phrase-label">Next</span>
                <p id="@UiDomIds.Learn.NextPhrase" data-testid="@UiTestIds.Learn.NextPhrase">@_nextPhrase</p>
            </div>

            <div class="rsvp-pause-track">
                <div id="@UiDomIds.Learn.PauseFill" class="rsvp-pause-fill"></div>
            </div>
        </div>

        <div class="rsvp-bottom">
            <div class="rsvp-speed">
                <button class="rsvp-btn" @onclick="DecreaseRsvpSpeedAsync" data-testid="@UiTestIds.Learn.SpeedDown"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" /></svg></button>
                <div class="rsvp-speed-num"><span id="@UiDomIds.Learn.Speed">@_speed</span><small>WPM</small></div>
                <button class="rsvp-btn" @onclick="IncreaseRsvpSpeedAsync" data-testid="@UiTestIds.Learn.SpeedUp"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg></button>
            </div>
            <div class="rsvp-play-band">
                <div class="rsvp-play-side-slot" aria-hidden="true"></div>
                <div class="rsvp-play-row">
                    <button class="rsvp-btn" @onclick="StepRsvpBackwardLargeAsync" title="Back 5 words" data-testid="@UiTestIds.Learn.StepBackwardLarge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="19,20 9,12 19,4" /><line x1="5" y1="19" x2="5" y2="5" /></svg></button>
                    <button class="rsvp-btn rsvp-btn-sm" @onclick="StepRsvpBackwardAsync" title="Back 1 word" data-testid="@UiTestIds.Learn.StepBackward"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15,18 9,12 15,6" /></svg></button>
                    <button class="rsvp-play"
                            id="rsvp-play-btn"
                            @onclick="ToggleRsvpPlaybackAsync"
                            aria-pressed="@(_isPlaying ? bool.TrueString.ToLowerInvariant() : bool.FalseString.ToLowerInvariant())"
                            data-testid="@UiTestIds.Learn.PlayToggle">
                        <span data-toggle-icon="play" hidden="@_isPlaying">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5,3 19,12 5,21" /></svg>
                        </span>
                        <span data-toggle-icon="pause" hidden="@(!_isPlaying)">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16" /><rect x="14" y="4" width="4" height="16" /></svg>
                        </span>
                    </button>
                    <button class="rsvp-btn rsvp-btn-sm" @onclick="StepRsvpForwardAsync" title="Forward 1 word" data-testid="@UiTestIds.Learn.StepForward"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,6 15,12 9,18" /></svg></button>
                    <button class="rsvp-btn" @onclick="StepRsvpForwardLargeAsync" title="Forward 5 words" data-testid="@UiTestIds.Learn.StepForwardLarge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5,4 15,12 5,20" /><line x1="19" y1="5" x2="19" y2="19" /></svg></button>
                </div>
                <button class="@LoopToggleButtonCssClass"
                        @onclick="ToggleLoopPlaybackAsync"
                        title="@LoopToggleButtonTitle"
                        aria-pressed="@(_isLoopEnabled ? bool.TrueString.ToLowerInvariant() : bool.FalseString.ToLowerInvariant())"
                        data-testid="@UiTestIds.Learn.LoopToggle">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 1l4 4-4 4" />
                        <path d="M3 11V9a4 4 0 0 1 4-4h14" />
                        <path d="M7 23l-4-4 4-4" />
                        <path d="M21 13v2a4 4 0 0 1-4 4H3" />
                    </svg>
                </button>
            </div>
            <div class="rsvp-pos"
                 id="@UiDomIds.Learn.ProgressLabel"
                 data-testid="@UiTestIds.Learn.ProgressLabel">@_progressLabel</div>
        </div>
    </div>
</div>
