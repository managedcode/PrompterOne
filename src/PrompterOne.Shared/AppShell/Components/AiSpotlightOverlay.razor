@namespace PrompterOne.Shared.AppShell.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@using PrompterOne.Core.AI.Models
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Contracts
@using PrompterOne.Shared.Localization
@using PrompterOne.Shared.Services
@using PrompterOne.Shared.Tools
@implements IDisposable
@inject AiSpotlightService Spotlight
@inject IStringLocalizer<SharedResource> Localizer
@inject NavigationManager Navigation

@if (State.IsOpen)
{
    <div class="ai-spotlight-backdrop"
         data-test="@UiTestIds.AiSpotlight.Overlay"
         @onclick="Close">
        <section class="ai-spotlight"
                 role="dialog"
                 aria-modal="true"
                 aria-label="@Text(UiTextKey.HeaderAiSpotlight)"
                 data-mode="@State.Mode.ToString().ToLowerInvariant()"
                 data-test="@UiTestIds.AiSpotlight.Surface"
                 @onclick:stopPropagation="true">
            <header class="ai-spotlight-head">
                <span class="ai-spotlight-mark" data-test="@UiTestIds.AiSpotlight.Mark">
                    <UiIcon Kind="UiIconKind.OpenAiBurst" Size="20" />
                </span>
                <div class="ai-spotlight-title">
                    <strong>@Text(UiTextKey.HeaderAiSpotlight)</strong>
                    <span>@ContextLabel</span>
                </div>
                <button type="button"
                        class="ai-spotlight-close"
                        aria-label="@Text(UiTextKey.AiSpotlightClose)"
                        @onclick="Close"
                        data-test="@UiTestIds.AiSpotlight.Close">
                    @Text(UiTextKey.AiSpotlightEscapeHint)
                </button>
            </header>

            @if (State.Mode == AiSpotlightMode.Idle)
            {
                <div class="ai-spotlight-composer" data-test="@UiTestIds.AiSpotlight.IdleState">
                    <input type="text"
                           value="@State.Prompt"
                           placeholder="@Text(UiTextKey.AiSpotlightPlaceholder)"
                           aria-label="@Text(UiTextKey.AiSpotlightPlaceholder)"
                           data-ai-spotlight-input="true"
                           data-test="@UiTestIds.AiSpotlight.PromptInput"
                           @oninput="HandlePromptInput"
                           @onkeydown="HandlePromptKeyDown" />
                    <button type="button"
                            class="ai-spotlight-mic"
                            aria-label="@Text(UiTextKey.AiSpotlightMicrophone)"
                            data-test="@UiTestIds.AiSpotlight.Microphone">
                        <UiIcon Kind="UiIconKind.Microphone" Size="16" />
                    </button>
                    <button type="button"
                            class="ai-spotlight-submit"
                            @onclick="SubmitAsync"
                            data-test="@UiTestIds.AiSpotlight.Submit">
                        @Text(UiTextKey.AiSpotlightSubmit)
                    </button>
                </div>
                <p class="ai-spotlight-hint">@Text(UiTextKey.AiSpotlightIdleHint)</p>

                @if (Suggestions.Count > 0)
                {
                    <div class="ai-spotlight-suggestions" data-test="@UiTestIds.AiSpotlight.SuggestionList">
                        @foreach (var suggestion in Suggestions)
                        {
                            <button type="button"
                                    class="ai-spotlight-suggestion"
                                    @onclick="() => SelectSuggestionAsync(suggestion)"
                                    data-kind="@suggestion.Kind.ToString().ToLowerInvariant()"
                                    data-tool="@suggestion.Name"
                                    data-test="@UiTestIds.AiSpotlight.SuggestionItem">
                                <span aria-hidden="true"></span>
                                <strong>@Text(suggestion.LabelKey)</strong>
                                <p>@Text(suggestion.DetailKey)</p>
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                <div class="ai-spotlight-running" data-test="@UiTestIds.AiSpotlight.RunningState">
                    <h3>@(State.Mode == AiSpotlightMode.Approval ? Text(UiTextKey.AiSpotlightApprovalTitle) : Text(UiTextKey.AiSpotlightRunningTitle))</h3>
                    @if (!string.IsNullOrWhiteSpace(State.ErrorMessage))
                    {
                        <p class="ai-spotlight-error" data-test="@UiTestIds.AiSpotlight.Error">@State.ErrorMessage</p>
                    }
                    @foreach (var entry in State.Log)
                    {
                        <div class="ai-spotlight-log" data-complete="@entry.IsComplete.ToString().ToLowerInvariant()" data-test="@UiTestIds.AiSpotlight.LogItem">
                            <span></span>
                            <div>
                                <strong>@entry.Label</strong>
                                <p>@entry.Detail</p>
                            </div>
                        </div>
                    }
                    @if (State.Mode == AiSpotlightMode.Approval && State.ApprovalRequest is { } approval)
                    {
                        <div class="ai-spotlight-approval" data-test="@UiTestIds.AiSpotlight.ApprovalState">
                            <div class="ai-spotlight-diff" data-test="@UiTestIds.AiSpotlight.ApprovalBefore">
                                <span>@Text(UiTextKey.AiSpotlightApprovalBefore)</span>
                                <pre>@approval.CurrentText</pre>
                            </div>
                            <div class="ai-spotlight-diff proposed" data-test="@UiTestIds.AiSpotlight.ApprovalAfter">
                                <span>@Text(UiTextKey.AiSpotlightApprovalAfter)</span>
                                <pre>@approval.ProposedText</pre>
                            </div>
                            <div class="ai-spotlight-approval-actions">
                                <button type="button"
                                        class="ai-spotlight-secondary"
                                        @onclick="RejectApproval"
                                        data-test="@UiTestIds.AiSpotlight.ApprovalReject">
                                    @Text(UiTextKey.AiSpotlightApprovalReject)
                                </button>
                                <button type="button"
                                        class="ai-spotlight-run"
                                        @onclick="ApproveAsync"
                                        data-test="@UiTestIds.AiSpotlight.ApprovalApprove">
                                    @Text(UiTextKey.AiSpotlightApprovalApprove)
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    private const int TopSuggestionLimit = 3;
    private const int SearchSuggestionLimit = 7;

    private AiSpotlightState State => Spotlight.State;

    private string ContextLabel => ResolveContextLabel();

    private string GraphLabel => State.Context.Graph is { } graph && !graph.IsEmpty
        ? $"{graph.NodeCount} nodes - {graph.EdgeCount} links"
        : Text(UiTextKey.AiSpotlightGraphMissing);

    private IReadOnlyList<AiSpotlightTool> Suggestions => BuildSuggestions();

    protected override void OnInitialized()
    {
        Spotlight.StateChanged += HandleSpotlightStateChanged;
    }

    private void HandlePromptInput(ChangeEventArgs args) =>
        Spotlight.UpdatePrompt(args.Value?.ToString() ?? string.Empty);

    private async Task HandlePromptKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, UiKeyboardKeys.Enter, StringComparison.Ordinal))
        {
            await SubmitAsync();
        }
    }

    private Task SubmitAsync() => Spotlight.SubmitAsync();

    private Task ApproveAsync() => Spotlight.ApproveAsync();

    private void RejectApproval() => Spotlight.RejectApproval();

    private void Close() => Spotlight.Close();

    private void HandleSpotlightStateChanged() => _ = InvokeAsync(StateHasChanged);

    private string Text(UiTextKey key) => Localizer[key.ToString()];

    private IReadOnlyList<AiSpotlightTool> BuildSuggestions()
    {
        var suggestions = AiSpotlightToolCatalog.BuildSpotlightSuggestions(State.Context);
        var prompt = State.Prompt.Trim();
        if (string.IsNullOrWhiteSpace(prompt))
        {
            return suggestions
                .OrderByDescending(ScoreTopSuggestion)
                .Take(TopSuggestionLimit)
                .ToArray();
        }

        var filtered = suggestions
            .Select(suggestion => new
            {
                Tool = suggestion,
                Score = ScoreSuggestion(suggestion, prompt)
            })
            .Where(match => match.Score > 0)
            .OrderByDescending(match => match.Score)
            .ThenBy(match => Text(match.Tool.LabelKey), StringComparer.OrdinalIgnoreCase)
            .Take(SearchSuggestionLimit)
            .Select(match => match.Tool)
            .ToArray();

        return filtered;
    }

    private int ScoreTopSuggestion(AiSpotlightTool suggestion)
    {
        var score = suggestion.Kind switch
        {
            AiSpotlightSuggestionKind.Command => 40,
            AiSpotlightSuggestionKind.Graph => 35,
            AiSpotlightSuggestionKind.Navigation => 25,
            AiSpotlightSuggestionKind.Settings => 15,
            AiSpotlightSuggestionKind.Hotkey => 10,
            _ => 0
        };

        if (string.Equals(suggestion.Scope, State.Context.Screen, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(suggestion.Scope, State.Context.Editor is null ? string.Empty : "editor", StringComparison.OrdinalIgnoreCase))
        {
            score += 20;
        }

        if (string.Equals(suggestion.Name, AiSpotlightToolNames.AskContext, StringComparison.Ordinal))
        {
            score += 50;
        }

        if (string.Equals(suggestion.Name, AiSpotlightToolNames.EditorSelectionRewrite, StringComparison.Ordinal) &&
            State.Context.Editor?.SelectedRange is not null)
        {
            score += 45;
        }

        if (suggestion.Kind == AiSpotlightSuggestionKind.Graph && State.Context.Screen == AppShellScreen.Editor.ToString())
        {
            score += 35;
        }

        if (!string.IsNullOrWhiteSpace(suggestion.Route) &&
            string.Equals(new Uri(Navigation.Uri).AbsolutePath, suggestion.Route, StringComparison.OrdinalIgnoreCase))
        {
            score -= 50;
        }

        return score;
    }

    private int ScoreSuggestion(AiSpotlightTool suggestion, string prompt)
    {
        var score = 0;
        var label = Text(suggestion.LabelKey);
        var detail = Text(suggestion.DetailKey);

        score += ScoreText(label, prompt, 100, 75, 55);
        score += ScoreText(detail, prompt, 45, 35, 20);
        score += ScoreText(suggestion.Prompt, prompt, 30, 20, 10);
        score += ScoreText(suggestion.Name.Replace('_', ' '), prompt, 25, 15, 10);

        if (score > 0)
        {
            score += Math.Max(0, ScoreTopSuggestion(suggestion) / 10);
        }

        return score;
    }

    private static int ScoreText(string value, string prompt, int exact, int startsWith, int contains)
    {
        if (string.Equals(value, prompt, StringComparison.OrdinalIgnoreCase))
        {
            return exact;
        }

        if (value.StartsWith(prompt, StringComparison.OrdinalIgnoreCase))
        {
            return startsWith;
        }

        return value.Contains(prompt, StringComparison.OrdinalIgnoreCase) ? contains : 0;
    }

    private async Task SelectSuggestionAsync(AiSpotlightTool suggestion)
    {
        if (suggestion.DispatchKind == AiSpotlightToolDispatchKinds.Navigation &&
            !string.IsNullOrWhiteSpace(suggestion.Route))
        {
            Navigation.NavigateTo(suggestion.Route);
            Spotlight.Close();
            return;
        }

        Spotlight.UpdatePrompt(suggestion.Prompt);
        await Spotlight.SubmitAsync();
    }

    private string ResolveContextLabel()
    {
        if (!string.IsNullOrWhiteSpace(State.Context.Editor?.DocumentTitle))
        {
            return $"{Text(UiTextKey.AiSpotlightContextEditor)} - {State.Context.Editor.DocumentTitle}";
        }

        return !string.IsNullOrWhiteSpace(State.Context.Screen)
            ? $"{Text(UiTextKey.AiSpotlightContextRoute)} - {State.Context.Screen}"
            : Text(UiTextKey.AiSpotlightContextRoute);
    }

    public void Dispose()
    {
        Spotlight.StateChanged -= HandleSpotlightStateChanged;
    }
}
