@namespace PrompterOne.Shared.AppShell.Components
@using Microsoft.AspNetCore.Components.Forms
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Contracts

<header class="@CssClass"
        data-test="@UiTestIds.Header.Surface"
        data-reader-muted="@(IsReaderMuted ? EnabledStateValue : DisabledStateValue)">
    <button type="button"
            class="app-header-left app-header-home"
            @onclick="HandleHomeClickAsync"
            data-test="@UiTestIds.Header.Home">
        <div class="logo-icon"
             data-test="@UiTestIds.Header.HomeBrandMark">
            <AppBrandMark />
        </div>
        <span class="app-logo-text" data-test="@UiTestIds.Header.Brand">PrompterOne</span>
    </button>
    <div class="app-header-center" data-test="@UiTestIds.Header.Center">
        @if (IsLibraryScreen)
        {
            <div class="lib-breadcrumb">
                @if (IsLibraryRootBreadcrumb)
                {
                    <span class="bc-item bc-current"
                          data-test="@UiTestIds.Header.LibraryBreadcrumbCurrent">@LibraryBreadcrumbCurrentLabel</span>
                }
                else
                {
                    <span class="bc-item">@LibraryAllScriptsLabel</span>
                    <span class="bc-sep">/</span>
                    <span class="bc-item bc-current"
                          data-test="@UiTestIds.Header.LibraryBreadcrumbCurrent">@LibraryBreadcrumbCurrentLabel</span>
                }
            </div>
        }
        else
        {
            @if (ShowBackButton)
            {
                <button type="button"
                        class="btn-back"
                        @onclick="HandleBackClickAsync"
                        data-test="@UiTestIds.Header.Back">
                    <UiIcon Kind="UiIconKind.ChevronLeft" Size="18" />
                </button>
            }

            <span class="top-bar-title" data-test="@UiTestIds.Header.Title">@HeaderTitle</span>

            @if (ShowHeaderSubtitle)
            {
                <span id="@HeaderSubtitleDomId"
                      class="app-header-subtitle"
                      data-test="@UiTestIds.Header.Subtitle">@HeaderSubtitle</span>
            }
        }
    </div>
    <div class="app-header-right">
        @if (ShowLibraryActions)
        {
            <div class="lib-search" data-test="@UiTestIds.Header.LibrarySearchSurface">
                <UiIcon Kind="UiIconKind.Search" Size="15" />
                <input type="text"
                       value="@SearchText"
                       placeholder="@SearchPlaceholder"
                       @oninput="HandleLibrarySearchInputAsync"
                       data-test="@UiTestIds.Header.LibrarySearch" />
            </div>
        }

        <GoLiveShellButton Label="@GoLiveLabel"
                           Status="@GoLiveStatus"
                           LiveState="@GoLiveState"
                           Subdued="@IsReaderMuted"
                           OnClick="OnOpenGoLive"
                           TestId="@UiTestIds.Header.GoLive" />

        @if (ShowLibraryActions)
        {
            <button type="button"
                    class="btn-ghost"
                    @onclick="HandleOpenOnboardingAsync"
                    title="@RestartTourLabel"
                    aria-label="@RestartTourLabel"
                    data-test="@UiTestIds.Header.Onboarding">
                <UiIcon Kind="UiIconKind.HelpCircle" Size="15" />
            </button>
        }

        @if (ShowImportAction)
        {
            <div class="app-header-file-action"
                 data-busy="@(IsImportInProgress ? EnabledStateValue : DisabledStateValue)"
                 data-test="@ImportActionSurfaceTestId">
                <button type="button"
                        class="btn-ghost btn-open-script"
                        data-test="@ImportActionButtonTestId"
                        aria-haspopup="dialog"
                        aria-busy="@(IsImportInProgress ? EnabledStateValue : DisabledStateValue)"
                        disabled="@IsImportInProgress"
                        @onclick="HandleImportTriggerAsync">
                    <span data-test="@ImportActionIconTestId">
                        <UiIcon Kind="UiIconKind.DocumentImport" Size="16" />
                    </span>
                    <span class="app-header-action-label">@ImportActionLabel</span>
                </button>
                <InputFile @key="ImportPickerVersion"
                           id="@ImportActionInputId"
                           class="app-header-file-input"
                           aria-label="@ImportActionLabel"
                           accept="@SupportedImportAcceptValue"
                           OnChange="HandleImportAsync"
                           data-test="@ImportActionInputTestId" />

                @if (IsImportInProgress)
                {
                    <div class="app-header-import-progress"
                         role="status"
                         aria-live="polite"
                         aria-atomic="true"
                         data-test="@UiTestIds.Header.ImportProgress">
                        <div class="app-header-import-progress-row">
                            <span class="app-header-import-progress-label"
                                  data-test="@UiTestIds.Header.ImportProgressLabel">@ImportProgressLabel</span>
                            <span class="app-header-import-progress-step"
                                  data-test="@UiTestIds.Header.ImportProgressStep">@ImportProgressStepLabel</span>
                        </div>

                        <span class="app-header-import-progress-file"
                              title="@ImportProgressFileName"
                              data-test="@UiTestIds.Header.ImportProgressFile">@ImportProgressFileName</span>

                        <span class="app-header-import-progress-track" aria-hidden="true">
                            <span class="app-header-import-progress-fill"
                                  style="@($"width: {ImportProgressWidth};")"
                                  data-test="@UiTestIds.Header.ImportProgressFill"></span>
                        </span>
                    </div>
                }
            </div>
        }

        @if (ShowLibraryActions)
        {
            <button type="button"
                    class="btn-create"
                    @onclick="HandleCreateScriptClickAsync"
                    data-test="@UiTestIds.Header.LibraryNewScript">
                <span data-test="@UiTestIds.Header.LibraryNewScriptIcon">
                    <UiIcon Kind="UiIconKind.Plus" Size="16" StrokeWidth="2.5m" />
                </span>
                <span class="app-header-action-label">@NewScriptLabel</span>
            </button>
        }

        @if (ShowSaveFileAction)
        {
            <button type="button"
                    class="btn-ghost"
                    @onclick="HandleSaveFileClickAsync"
                    data-test="@UiTestIds.Header.EditorSaveFile">
                <UiIcon Kind="UiIconKind.SaveFile" Size="15" />
                <span class="app-header-action-label">@SaveFileLabel</span>
            </button>
        }

        @if (ShowLearnAction)
        {
            <button type="button"
                    class="btn-ghost"
                    @onclick="HandleOpenLearnClickAsync"
                    data-test="@UiTestIds.Header.EditorLearn">
                <UiIcon Kind="UiIconKind.BookOpen" Size="15" />
                <span class="app-header-action-label">@LearnLabel</span>
            </button>
        }

        @if (ShowLearnWpmBadge)
        {
            <span id="@UiDomIds.Learn.HeaderWpmBadge"
                  class="top-bar-title app-header-wpm"
                  data-test="@UiTestIds.Header.Wpm">@WpmLabel</span>
        }

        @if (ShowReadAction)
        {
            <button type="button"
                    class="btn-gold"
                    @onclick="HandleOpenReadClickAsync"
                    data-test="@UiTestIds.Header.EditorRead">
                <UiIcon Kind="UiIconKind.Play" Size="15" />
                <span class="app-header-action-label">@ReadLabel</span>
            </button>
        }
    </div>
</header>

@code {
    private const string DisabledStateValue = "false";
    private const string EnabledStateValue = "true";

    [Parameter, EditorRequired] public string CssClass { get; set; } = string.Empty;
    [Parameter] public bool IsReaderMuted { get; set; }
    [Parameter] public bool IsLibraryRootBreadcrumb { get; set; }
    [Parameter] public bool IsLibraryScreen { get; set; }
    [Parameter] public bool ShowBackButton { get; set; }
    [Parameter] public bool ShowHeaderSubtitle { get; set; }
    [Parameter] public bool ShowLearnAction { get; set; }
    [Parameter] public bool ShowLearnWpmBadge { get; set; }
    [Parameter] public bool ShowImportAction { get; set; }
    [Parameter] public bool IsImportInProgress { get; set; }
    [Parameter] public bool ShowLibraryActions { get; set; }
    [Parameter] public bool ShowReadAction { get; set; }
    [Parameter] public bool ShowSaveFileAction { get; set; }
    [Parameter] public int ImportPickerVersion { get; set; }
    [Parameter] public string? HeaderSubtitleDomId { get; set; }
    [Parameter, EditorRequired] public string HeaderSubtitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string HeaderTitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportActionButtonTestId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportActionIconTestId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportActionInputId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportActionInputTestId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportActionLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportProgressFileName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportProgressLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportProgressStepLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportProgressWidth { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ImportActionSurfaceTestId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string LearnLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string LibraryAllScriptsLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string LibraryBreadcrumbCurrentLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string GoLiveLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string GoLiveState { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string GoLiveStatus { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string NewScriptLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string ReadLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string RestartTourLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string SaveFileLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string SearchPlaceholder { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string SearchText { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string SupportedImportAcceptValue { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string WpmLabel { get; set; } = string.Empty;
    [Parameter] public EventCallback OnBackClick { get; set; }
    [Parameter] public EventCallback OnCreateScriptClick { get; set; }
    [Parameter] public EventCallback OnHomeClick { get; set; }
    [Parameter] public EventCallback OnImportTrigger { get; set; }
    [Parameter] public EventCallback OnOpenGoLive { get; set; }
    [Parameter] public EventCallback OnOpenLearnClick { get; set; }
    [Parameter] public EventCallback OnOpenOnboarding { get; set; }
    [Parameter] public EventCallback OnOpenReadClick { get; set; }
    [Parameter] public EventCallback OnSaveFileClick { get; set; }
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnImport { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnLibrarySearchInput { get; set; }

    private Task HandleBackClickAsync() => OnBackClick.InvokeAsync();

    private Task HandleCreateScriptClickAsync() => OnCreateScriptClick.InvokeAsync();

    private Task HandleHomeClickAsync() => OnHomeClick.InvokeAsync();

    private Task HandleImportAsync(InputFileChangeEventArgs args) => OnImport.InvokeAsync(args);

    private Task HandleImportTriggerAsync() => OnImportTrigger.InvokeAsync();

    private Task HandleLibrarySearchInputAsync(ChangeEventArgs args) => OnLibrarySearchInput.InvokeAsync(args);

    private Task HandleOpenLearnClickAsync() => OnOpenLearnClick.InvokeAsync();

    private Task HandleOpenOnboardingAsync() => OnOpenOnboarding.InvokeAsync();

    private Task HandleOpenReadClickAsync() => OnOpenReadClick.InvokeAsync();

    private Task HandleSaveFileClickAsync() => OnSaveFileClick.InvokeAsync();
}
