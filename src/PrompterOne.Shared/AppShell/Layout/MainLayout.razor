@namespace PrompterOne.Shared.Layout
@inherits LayoutComponentBase
@using PrompterOne.Shared.AppShell.Components
@using PrompterOne.Shared.Localization

@if (ShowAppHeader)
{
    <MainLayoutHeader CssClass="@BuildAppHeaderCssClass()"
                      HeaderSubtitle="@HeaderSubtitle"
                      HeaderSubtitleDomId="@(ShellState.Screen == AppShellScreen.Teleprompter ? UiDomIds.Teleprompter.HeaderSegment : null)"
                      HeaderTitle="@HeaderTitle"
                      ImportActionButtonTestId="@ImportActionButtonTestId"
                      ImportActionIconTestId="@ImportActionIconTestId"
                      ImportActionInputId="@ImportActionInputDomId"
                      ImportActionInputTestId="@ImportActionInputTestId"
                      ImportActionLabel="@Text(UiTextKey.HeaderOpenScript)"
                      ImportProgressFileName="@ImportProgressFileName"
                      ImportProgressLabel="@ImportProgressLabel"
                      ImportProgressStepLabel="@ImportProgressStepLabel"
                      ImportProgressWidth="@ImportProgressWidth"
                      ImportActionSurfaceTestId="@ImportActionSurfaceTestId"
                      IsImportInProgress="@IsImportInProgress"
                      IsLibraryRootBreadcrumb="@IsLibraryRootBreadcrumb"
                      IsLibraryScreen="@IsLibraryScreen"
                      IsReaderMuted="@IsTeleprompterPlaybackChromeMuted"
                      LearnLabel="@Text(UiTextKey.HeaderLearn)"
                      LibraryAllScriptsLabel="@Text(UiTextKey.LibraryAllScripts)"
                      LibraryBreadcrumbCurrentLabel="@LibraryBreadcrumbCurrentLabel"
                      GoLiveLabel="@Text(UiTextKey.HeaderGoLive)"
                      GoLiveState="@GoLiveIndicatorState"
                      GoLiveStatus="@GoLiveIndicatorStatus"
                      NewScriptLabel="@Text(UiTextKey.HeaderNewScript)"
                      OnBackClick="HandleBackClickAsync"
                      OnCreateScriptClick="HandleCreateScriptClickAsync"
                      OnHomeClick="HandleHomeClickAsync"
                      OnImport="HandleImportScriptAsync"
                      OnImportTrigger="HandleImportScriptTriggerAsync"
                      OnLibrarySearchInput="HandleLibrarySearchInputAsync"
                      OnOpenGoLive="HandleOpenGoLiveClickAsync"
                      OnOpenLearnClick="HandleOpenLearnClickAsync"
                      OnOpenOnboarding="HandleOpenOnboardingAsync"
                      OnOpenReadClick="HandleOpenReadClickAsync"
                      OnSaveFileClick="HandleSaveFileClickAsync"
                      ImportPickerVersion="@_importScriptPickerVersion"
                      ReadLabel="@Text(UiTextKey.HeaderRead)"
                      RestartTourLabel="@Text(UiTextKey.OnboardingRestartTour)"
                      SaveFileLabel="@Text(UiTextKey.HeaderSaveFile)"
                      SearchPlaceholder="@Text(UiTextKey.HeaderSearchPlaceholder)"
                      SearchText="@ShellState.SearchText"
                      ShowBackButton="@ShowBackButton"
                      ShowHeaderSubtitle="@ShowHeaderSubtitle"
                      ShowImportAction="@ShowImportAction"
                      ShowLearnAction="@ShowLearnAction"
                      ShowLearnWpmBadge="@ShowLearnWpmBadge"
                      ShowLibraryActions="@ShowLibraryActions"
                      ShowReadAction="@ShowReadAction"
                      ShowSaveFileAction="@ShowSaveFileAction"
                      SupportedImportAcceptValue="@SupportedImportAcceptValue"
                      WpmLabel="@ShellState.WpmLabel" />
}

<PrompterOne.Shared.Components.Diagnostics.DiagnosticsBanner />
<PrompterOne.Shared.Components.Diagnostics.ConnectivityOverlay />

@Body

@if (ShowOnboarding)
{
    <AppOnboardingOverlay Steps="@_onboardingSteps"
                          CurrentStepIndex="@_onboardingStepIndex"
                          OnBackRequested="HandleOnboardingBackAsync"
                          OnNextRequested="HandleOnboardingNextAsync"
                          OnDismissRequested="HandleOnboardingDismissAsync"
                          OnStepSelected="HandleOnboardingStepSelectedAsync" />
}

<SentryUserFeedbackDialogHost />

@if (ShowGoLiveWidget)
{
    <MainLayoutGoLiveWidget CssClass="@BuildGoLiveWidgetCssClass()"
                            Detail="@GoLiveWidgetDetail"
                            Elapsed="@GoLiveWidgetElapsed"
                            IndicatorCopy="@GoLiveIndicatorCopy"
                            LiveState="@GoLiveIndicatorState"
                            OnClick="HandleOpenGoLiveClickAsync"
                            StateLabel="@GoLiveWidgetStateLabel"
                            Title="@GoLiveWidgetTitle" />
}
