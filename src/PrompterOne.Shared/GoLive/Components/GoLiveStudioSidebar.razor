@namespace PrompterOne.Shared.Components.GoLive
@using Microsoft.Extensions.Localization
@using PrompterOne.Core.Models.Workspace
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.GoLive.Models
@using PrompterOne.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<section class="gl-sidebar-shell">
    <div class="gl-tab-bar">
        <button type="button"
                class="gl-tab @(ActiveTab == GoLiveStudioTab.Stream ? "active" : null)"
                data-testid="@UiTestIds.GoLive.StreamTab"
                @onclick="() => SelectTab.InvokeAsync(GoLiveStudioTab.Stream)">@Text(GoLiveText.Sidebar.StreamTabLabel)</button>
        <button type="button"
                class="gl-tab @(ActiveTab == GoLiveStudioTab.Audio ? "active" : null)"
                data-testid="@UiTestIds.GoLive.AudioTab"
                @onclick="() => SelectTab.InvokeAsync(GoLiveStudioTab.Audio)">@Text(GoLiveText.Sidebar.AudioTabLabel)</button>
        <button type="button"
                class="gl-tab @(ActiveTab == GoLiveStudioTab.Room ? "active" : null)"
                data-testid="@UiTestIds.GoLive.RoomTab"
                @onclick="() => SelectTab.InvokeAsync(GoLiveStudioTab.Room)">@Text(GoLiveText.Sidebar.RoomTabLabel)</button>
    </div>

    <div class="gl-tab-panels">
        @if (ActiveTab == GoLiveStudioTab.Stream)
        {
            <div class="gl-tab-content active">
                <div class="gl-info-section">
                    <span class="gl-info-label">@Text(GoLiveText.Sidebar.DestinationsLabel)</span>
                    <div class="gl-dest-list">
                        @foreach (var destination in Destinations)
                        {
                            <article class="gl-destination-card"
                                     data-testid="@UiTestIds.GoLive.ProviderCard(destination.Id)">
                                <button type="button"
                                        class="gl-dest-row @(destination.IsEnabled ? "on" : null)"
                                        data-testid="@UiTestIds.GoLive.DestinationToggle(destination.Id)"
                                        @onclick="() => ToggleDestination.InvokeAsync(destination.Id)">
                                    <span class="gl-dest-platform-dot @destination.Tone"></span>
                                    <span class="gl-dest-info">
                                        <strong>@destination.Name</strong>
                                        <span>@destination.PlatformLabel</span>
                                    </span>
                                    <span class="gl-toggle-track @(destination.IsEnabled ? "on" : null)">
                                        <span class="gl-toggle-thumb"></span>
                                    </span>
                                </button>
                                <div class="gl-dest-meta">
                                    <span>@destination.Summary</span>
                                    <strong>@destination.StatusLabel</strong>
                                </div>
                            </article>
                        }
                    </div>
                </div>

                <div class="gl-info-section">
                    <span class="gl-info-label">@Text(GoLiveText.Sidebar.StatusLabel)</span>
                    <div class="gl-stats-compact">
                        @foreach (var metric in StatusMetrics)
                        {
                            <div class="gl-stat-item"
                                 data-testid="@UiTestIds.GoLive.StatusMetric(metric.Id)">
                                <span class="gl-stat-val">@metric.Value</span>
                                <span class="gl-stat-lbl">@metric.Label</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="gl-info-section">
                    <span class="gl-info-label">@Text(GoLiveText.Sidebar.RuntimeLabel)</span>
                    <div class="gl-stats-compact">
                        @foreach (var metric in RuntimeMetrics)
                        {
                            <div class="gl-stat-item"
                                 data-testid="@UiTestIds.GoLive.RuntimeMetric(metric.Id)">
                                <span class="gl-stat-val">@metric.Value</span>
                                <span class="gl-stat-lbl">@metric.Label</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (ActiveTab == GoLiveStudioTab.Audio)
        {
            <div class="gl-tab-content active"
                 data-testid="@UiTestIds.GoLive.AudioMixer">
                <div class="gl-audio-mixer">
                    <div class="gl-mix-scale">
                        <span>-60</span>
                        <span>-50</span>
                        <span>-40</span>
                        <span>-30</span>
                        <span>-20</span>
                        <span>-10</span>
                        <span>0</span>
                    </div>

                    @foreach (var channel in AudioChannels)
                    {
                        <div class="gl-mix-ch"
                             data-live-level="@channel.LevelPercent"
                             data-live-state="@(channel.LevelPercent > 0 ? ActiveMeterStateValue : GoLiveText.Session.IdleStateValue)"
                             data-testid="@UiTestIds.GoLive.AudioChannel(channel.Id)">
                            <div class="gl-mix-ch-top">
                                <span class="gl-mix-name">@channel.Name</span>
                                <span class="gl-mix-db-val">@channel.DetailLabel</span>
                                <span class="gl-mix-mute"
                                      aria-hidden="true">
                                    @if (string.Equals(channel.Id, GoLiveText.Sidebar.MicrophoneChannelId, StringComparison.Ordinal))
                                    {
                                        <UiIcon Kind="UiIconKind.Microphone" Size="11" />
                                    }
                                    else
                                    {
                                        <UiIcon Kind="UiIconKind.Speaker" Size="11" />
                                    }
                                </span>
                            </div>
                            <div class="gl-mix-track">
                                <div class="gl-mix-meter-bg"></div>
                                <UiPercentFill Class="gl-mix-level" Percent="@channel.LevelPercent" />
                                <div class="gl-mix-ticks"></div>
                                <input type="range"
                                       class="gl-mix-fader"
                                       min="0"
                                       max="100"
                                       value="@channel.LevelPercent"
                                       disabled
                                       tabindex="-1"
                                       aria-hidden="true" />
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="gl-tab-content active">
                @if (!IsRoomActive)
                {
                    <div class="gl-room-empty"
                         data-testid="@UiTestIds.GoLive.RoomEmpty">
                        <div class="gl-room-empty-icon">
                            <UiIcon Kind="UiIconKind.Users" Size="32" StrokeWidth="1.5m" />
                        </div>
                        <div class="gl-room-empty-title">@Text(GoLiveText.Sidebar.RoomTitle)</div>
                        <div class="gl-room-empty-desc">@Text(GoLiveText.Sidebar.RoomDescription)</div>
                        <button type="button"
                                class="gl-room-create-btn"
                                data-testid="@UiTestIds.GoLive.CreateRoom"
                                @onclick="CreateRoom">
                            <UiIcon Kind="UiIconKind.Plus" Size="14" StrokeWidth="2.5m" />
                            <span>@Text(GoLiveText.Sidebar.CreateRoomLabel)</span>
                        </button>
                    </div>
                }
                else
                {
                    <div class="gl-room-active"
                         data-testid="@UiTestIds.GoLive.RoomActive">
                        <div class="gl-room-header-bar">
                            <div class="gl-room-live-badge">@Text(GoLiveText.Sidebar.LiveBadgeLabel)</div>
                            <span class="gl-room-code-val">@RoomCode</span>
                            <button type="button"
                                    class="gl-room-invite-btn"
                                    data-testid="@UiTestIds.GoLive.RoomInvite">
                                <UiIcon Kind="UiIconKind.UserPlus" Size="12" />
                                <span>@Text(GoLiveText.Sidebar.InviteLabel)</span>
                            </button>
                        </div>

                        <div class="gl-dir-toolbar">
                            <button type="button"
                                    class="gl-dir-btn @(_muteAllGuests ? "active" : null)"
                                    @onclick="ToggleMuteAllGuests">
                                <UiIcon Kind="UiIconKind.Microphone" Size="13" />
                                <span>@Text(GoLiveText.Sidebar.MuteAllLabel)</span>
                            </button>
                            <button type="button"
                                    class="gl-dir-btn @(_talkbackEnabled ? "active" : null)"
                                    @onclick="ToggleTalkback">
                                <UiIcon Kind="UiIconKind.Message" Size="13" />
                                <span>@Text(GoLiveText.Sidebar.TalkLabel)</span>
                            </button>
                            <button type="button"
                                    class="gl-dir-btn gl-dir-btn-cue @(_cueArmed ? "active" : null)"
                                    @onclick="SendCue">
                                <UiIcon Kind="UiIconKind.Play" Size="13" StrokeWidth="2.5m" />
                                <span>@Text(GoLiveText.Sidebar.CueLabel)</span>
                            </button>
                        </div>

                        <div class="gl-room-participants">
                            <div class="gl-room-part-header">
                                <span>@Text(GoLiveText.Sidebar.GuestsLabel)</span>
                                <span class="gl-part-count">@Participants.Count</span>
                            </div>

                            <div class="gl-participants-list">
                                @foreach (var participant in Participants)
                                {
                                    <article class="gl-part-row"
                                             data-testid="@UiTestIds.GoLive.RoomParticipant(participant.Id)">
                                        <div class="gl-part-avatar">@participant.Initial</div>
                                        <span class="gl-part-name">@participant.Name</span>
                                        <span class="gl-part-role">@participant.Role</span>
                                        <div class="gl-part-meter">
                                            <UiPercentFill Class="gl-part-meter-fill" Percent="@participant.LevelPercent" />
                                        </div>
                                        <span class="gl-part-dot @(participant.IsOnline ? "gl-online" : null)"></span>
                                    </article>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    private const string ActiveMeterStateValue = "active";

    [Parameter] public GoLiveStudioTab ActiveTab { get; set; }
    [Parameter] public IReadOnlyList<GoLiveAudioChannelViewModel> AudioChannels { get; set; } = [];
    [Parameter] public EventCallback CreateRoom { get; set; }
    [Parameter] public bool CueArmed { get; set; }
    [Parameter] public IReadOnlyList<GoLiveDestinationSummaryViewModel> Destinations { get; set; } = [];
    [Parameter] public bool IsRoomActive { get; set; }
    [Parameter] public bool MuteAllGuests { get; set; }
    [Parameter] public IReadOnlyList<GoLiveRoomParticipantViewModel> Participants { get; set; } = [];
    [Parameter] public string RoomCode { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<GoLiveMetricViewModel> RuntimeMetrics { get; set; } = [];
    [Parameter] public EventCallback<GoLiveStudioTab> SelectTab { get; set; }
    [Parameter] public EventCallback SendCue { get; set; }
    [Parameter] public IReadOnlyList<GoLiveMetricViewModel> StatusMetrics { get; set; } = [];
    [Parameter] public EventCallback<string> ToggleDestination { get; set; }
    [Parameter] public EventCallback ToggleMuteAllGuests { get; set; }
    [Parameter] public EventCallback ToggleTalkback { get; set; }
    [Parameter] public bool TalkbackEnabled { get; set; }

    private bool _cueArmed => CueArmed;
    private bool _muteAllGuests => MuteAllGuests;
    private bool _talkbackEnabled => TalkbackEnabled;

    private string Text(string key) => Localizer[key];
}
