@namespace PrompterOne.Shared.Components.GoLive
@using Microsoft.Extensions.Localization
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.GoLive.Models
@using PrompterOne.Shared.Localization
@using PrompterOne.Shared.Services
@inject IStringLocalizer<SharedResource> Localizer

<section class="gl-sources-panel">
    <div class="gl-sources-header">
        <span class="section-label">@EffectiveTitle</span>
        <button type="button"
                class="gl-add-src-btn"
                disabled="@(!CanAddCamera)"
                data-test="@UiTestIds.GoLive.AddSource"
                @onclick="AddCamera">
            <UiIcon Kind="UiIconKind.Plus" Size="14" />
        </button>
    </div>

    @if (ShowSingleLocalPreviewHint)
    {
        <div class="gl-preview-limit-hint"
             data-test="@UiTestIds.GoLive.SingleLocalPreviewHint">
            @SingleLocalPreviewHint
        </div>
    }

    <div class="gl-src-list"
         data-test="@UiTestIds.GoLive.SourcesCard">
        @if (Sources.Count == 0)
        {
            <div class="gl-empty-panel">@EmptyStateMessage</div>
        }
        else
        {
            @foreach (var source in Sources)
            {
                var surfaceCamera = ResolveSurfaceCamera(source);
                <article class="@GetSourceCardCssClass(source)"
                         @attributes="GetSourceDiagnostics(source)"
                         data-test="@UiTestIds.GoLive.SourceCamera(source.SourceId)">
                    <button type="button"
                            class="gl-cam-main"
                            data-test="@UiTestIds.GoLive.SourceCameraSelect(source.SourceId)"
                            @onclick="() => SelectSource.InvokeAsync(source.SourceId)">
                        <GoLiveCameraSurface Camera="@surfaceCamera"
                                             ContainerClass="gl-cam-thumb"
                                             VideoClass="gl-source-feed"
                                             VideoDomId="@UiDomIds.GoLive.SourceVideo(source.SourceId)"
                                             VideoTestId="@UiTestIds.GoLive.SourceVideo(source.SourceId)">
                            <OverlayContent>
                                @if (surfaceCamera is not null)
                                {
                                    <span class="@GetSourceBadgeCssClass(source)"
                                          data-test="@UiTestIds.GoLive.SourceCameraBadge(source.SourceId)"
                                          data-live-state="@GetSourceIndicatorState(source)">@GetSourceBadge(source)</span>
                                }
                            </OverlayContent>
                            <EmptyContent>
                                @if (ShowSourcePreviewPlaceholder(source))
                                {
                                    <div class="gl-cam-thumb-limited">
                                        <span class="@GetSourceBadgeCssClass(source)"
                                              data-test="@UiTestIds.GoLive.SourceCameraBadge(source.SourceId)"
                                              data-live-state="@GetSourceIndicatorState(source)">@GetSourceBadge(source)</span>
                                        <span class="gl-cam-thumb-limited-copy">@Text(GoLiveText.Surface.SingleLocalCameraPreviewPlaceholderLabel)</span>
                                    </div>
                                }
                            </EmptyContent>
                        </GoLiveCameraSurface>

                        <div class="gl-cam-meta">
                            <div class="gl-cam-top">
                                <span class="gl-cam-name">@FormatSourceLabel(source)</span>
                                <span class="gl-cam-hw">@GetSourceStatus(source)</span>
                            </div>
                        </div>
                    </button>

                    <button type="button"
                            class="gl-cam-action"
                            @onclick="() => ToggleSource.InvokeAsync(source.SourceId)"
                            data-test="@UiTestIds.GoLive.SourceCameraAction(source.DeviceId)">
                        @(source.Transform.IncludeInOutput ? Text(RemoveLabelKey) : Text(AddLabelKey))
                    </button>
                </article>
            }
        }

        @foreach (var utilitySource in UtilitySources)
        {
            <article class="@GetUtilityCardCssClass(utilitySource)"
                     data-test="@UiTestIds.GoLive.UtilitySource(utilitySource.Id)">
                <div class="gl-cam-thumb gl-cam-thumb-utility">
                    <span class="gl-utility-badge">@utilitySource.BadgeLabel</span>
                </div>
                <div class="gl-cam-meta">
                    <div class="gl-cam-top">
                        <span class="gl-cam-name">@utilitySource.Title</span>
                        <span class="gl-cam-hw">@utilitySource.Subtitle</span>
                    </div>
                </div>
            </article>
        }
    </div>

    <div class="gl-mic-card">
        <span class="section-label">@Text(MicrophoneTitleKey)</span>
        <strong>@DisplayMicrophoneName</strong>
        <span>@MicrophoneRouteLabel</span>
    </div>
</section>

@code {
    private const string AddLabelKey = "GoLiveSourcesAddLabel";
    private const string DefaultTitleKey = "GoLiveSourcesDefaultTitle";
    private const string EmptyStateMessageKey = "GoLiveSourcesEmptyStateMessage";
    private const string MicrophoneTitleKey = "GoLiveSourcesMicrophoneTitle";
    private const string PrompterUtilitySourceId = "prompter-display";
    private const string RemoveLabelKey = "GoLiveSourcesRemoveLabel";
    private const string ScreenShareUtilitySourceId = "screen-share";
    private const string IdleStateValue = "idle";
    private const string SourceIncludedLabelKey = "GoLiveSourcesIncludedLabel";
    private const string SourceLiveLabelKey = "GoLiveSourcesLiveLabel";
    private const string SourceOnAirLabelKey = "GoLiveSourcesOnAirLabel";
    private const string SourceSceneOnlyLabelKey = "GoLiveSourcesSceneOnlyLabel";

    [Parameter] public EventCallback AddCamera { get; set; }
    [Parameter] public string? ActiveSourceId { get; set; }
    [Parameter] public bool CanAddCamera { get; set; }
    [Parameter] public bool HasPrimaryMicrophone { get; set; }
    [Parameter] public IReadOnlyList<string> LiveSourceIds { get; set; } = [];
    [Parameter] public string LiveState { get; set; } = IdleStateValue;
    [Parameter] public string MicrophoneName { get; set; } = string.Empty;
    [Parameter] public string MicrophoneRouteLabel { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectSource { get; set; }
    [Parameter] public string? SelectedSourceId { get; set; }
    [Parameter] public bool ShowSingleLocalPreviewHint { get; set; }
    [Parameter] public string SingleLocalPreviewHint { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<SceneCameraSource> Sources { get; set; } = [];
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ToggleSource { get; set; }
    [Parameter] public IReadOnlyList<GoLiveUtilitySourceViewModel> UtilitySources { get; set; } = [];
    private string DisplayMicrophoneName => MediaDeviceLabelSanitizer.Sanitize(MicrophoneName);
    private string EffectiveTitle => string.IsNullOrWhiteSpace(Title) ? Text(DefaultTitleKey) : Title;
    private string EmptyStateMessage => Text(EmptyStateMessageKey);
    private static string FormatSourceLabel(SceneCameraSource source) => MediaDeviceLabelSanitizer.Sanitize(source.Label);

    private bool IsActive(SceneCameraSource source) =>
        string.Equals(source.SourceId, ActiveSourceId, StringComparison.Ordinal);

    private bool IsLiveSessionActive =>
        !string.Equals(LiveState, IdleStateValue, StringComparison.Ordinal);

    private bool IsOnAir(SceneCameraSource source) =>
        IsLiveSessionActive && IsActive(source);

    private bool IsSelected(SceneCameraSource source) =>
        string.Equals(source.SourceId, SelectedSourceId, StringComparison.Ordinal);

    private SceneCameraSource? ResolveSurfaceCamera(SceneCameraSource source) =>
        CanRenderLiveSource(source)
            ? source
            : null;

    private bool CanRenderLiveSource(SceneCameraSource source) =>
        LiveSourceIds.Count == 0 || LiveSourceIds.Contains(source.SourceId, StringComparer.Ordinal);

    private bool ShowSourcePreviewPlaceholder(SceneCameraSource source) =>
        ShowSingleLocalPreviewHint && !CanRenderLiveSource(source);

    private string GetSourceBadge(SceneCameraSource source)
    {
        if (IsOnAir(source))
        {
            return Text(SourceOnAirLabelKey);
        }

        return IsSelected(source)
            ? Text(SourceLiveLabelKey)
            : source.Transform.IncludeInOutput
                ? Text(SourceIncludedLabelKey)
                : Text(SourceSceneOnlyLabelKey);
    }

    private string GetSourceIndicatorState(SceneCameraSource source) =>
        IsOnAir(source)
            ? LiveState
            : IdleStateValue;

    private string GetSourceCardCssClass(SceneCameraSource source)
    {
        var classes = new List<string> { "gl-cam-card" };
        if (IsOnAir(source))
        {
            classes.Add("gl-cam-onair");
        }
        else if (IsSelected(source))
        {
            classes.Add("gl-cam-inpreview");
        }

        return string.Join(' ', classes);
    }

    private string GetSourceBadgeCssClass(SceneCameraSource source)
    {
        var classes = new List<string> { "gl-cam-status-badge" };
        classes.Add(IsOnAir(source) ? "gl-badge-onair" : "gl-badge-idle");
        return string.Join(' ', classes);
    }

    private static string GetUtilityCardCssClass(GoLiveUtilitySourceViewModel utilitySource)
    {
        return utilitySource.Id switch
        {
            PrompterUtilitySourceId => "gl-cam-card gl-cam-prompter",
            ScreenShareUtilitySourceId => "gl-cam-card gl-src-screen",
            _ => "gl-cam-card"
        };
    }

    private static IReadOnlyDictionary<string, object> GetSourceDiagnostics(SceneCameraSource source)
    {
        return new Dictionary<string, object>(StringComparer.Ordinal)
        {
            [UiTestIds.GoLive.SourceIdAttribute] = source.SourceId,
            [UiTestIds.GoLive.SourceDeviceIdAttribute] = source.DeviceId
        };
    }

    private string GetSourceStatus(SceneCameraSource source)
    {
        if (source.Transform.IncludeInOutput)
        {
            return Text(SourceIncludedLabelKey);
        }

        return source.Transform.Visible
            ? Text(SourceLiveLabelKey)
            : Text(SourceSceneOnlyLabelKey);
    }

    private string Text(string key) => Localizer[key];
}
