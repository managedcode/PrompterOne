@namespace PrompterOne.Shared.Components.GoLive
@using PrompterOne.Shared.Services

<section class="gl-sources-panel">
    <div class="gl-sources-header">
        <span class="section-label">@Title</span>
        <button type="button"
                class="gl-add-src-btn"
                disabled="@(!CanAddCamera)"
                data-testid="@UiTestIds.GoLive.AddSource"
                @onclick="AddCamera">
            <svg width="14"
                 height="14"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="2"
                 aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
        </button>
    </div>

    <div class="gl-src-list"
         data-testid="@UiTestIds.GoLive.SourcesCard">
        @if (Sources.Count == 0)
        {
            <div class="gl-empty-panel">@EmptyStateMessage</div>
        }
        else
        {
            @foreach (var source in Sources)
            {
                <article class="@GetSourceCardCssClass(source)"
                         data-testid="@UiTestIds.GoLive.SourceCamera(source.SourceId)">
                    <button type="button"
                            class="gl-cam-main"
                            data-testid="@UiTestIds.GoLive.SourceCameraSelect(source.SourceId)"
                            @onclick="() => SelectSource.InvokeAsync(source.SourceId)">
                        <GoLiveCameraSurface Camera="@source"
                                             ContainerClass="gl-cam-thumb"
                                             VideoClass="gl-source-feed"
                                             VideoTestId="@UiTestIds.GoLive.SourceVideo(source.SourceId)">
                            <OverlayContent>
                                <span class="@GetSourceBadgeCssClass(source)"
                                      data-testid="@UiTestIds.GoLive.SourceCameraBadge(source.SourceId)"
                                      data-live-state="@GetSourceIndicatorState(source)">@GetSourceBadge(source)</span>
                            </OverlayContent>
                        </GoLiveCameraSurface>

                        <div class="gl-cam-meta">
                            <div class="gl-cam-top">
                                <span class="gl-cam-name">@FormatSourceLabel(source)</span>
                                <span class="gl-cam-hw">@GetSourceStatus(source)</span>
                            </div>
                        </div>
                    </button>

                    <button type="button"
                            class="gl-cam-action"
                            @onclick="() => ToggleSource.InvokeAsync(source.SourceId)"
                            data-testid="@UiTestIds.GoLive.SourceCameraAction(source.DeviceId)">
                        @(source.Transform.IncludeInOutput ? RemoveLabel : AddLabel)
                    </button>
                </article>
            }
        }

        @foreach (var utilitySource in UtilitySources)
        {
            <article class="@GetUtilityCardCssClass(utilitySource)"
                     data-testid="@UiTestIds.GoLive.UtilitySource(utilitySource.Id)">
                <div class="gl-cam-thumb gl-cam-thumb-utility">
                    <span class="gl-utility-badge">@utilitySource.BadgeLabel</span>
                </div>
                <div class="gl-cam-meta">
                    <div class="gl-cam-top">
                        <span class="gl-cam-name">@utilitySource.Title</span>
                        <span class="gl-cam-hw">@utilitySource.Subtitle</span>
                    </div>
                </div>
            </article>
        }
    </div>

    <div class="gl-mic-card">
        <span class="section-label">@MicrophoneTitle</span>
        <strong>@DisplayMicrophoneName</strong>
        <span>@MicrophoneRouteLabel</span>
    </div>
</section>

@code {
    private const string AddLabel = "Include";
    private const string DefaultTitle = "Inputs";
    private const string EmptyStateMessage = "No scene cameras are configured yet. Add them in Settings first.";
    private const string MicrophoneTitle = "Microphone";
    private const string PrompterUtilitySourceId = "prompter-display";
    private const string RemoveLabel = "Remove";
    private const string ScreenShareUtilitySourceId = "screen-share";
    private const string IdleStateValue = "idle";
    private const string SourceIncludedLabel = "Armed for output";
    private const string SourceLiveLabel = "Ready for canvas";
    private const string SourceOnAirLabel = "On air";
    private const string SourceSceneOnlyLabel = "Scene only";

    [Parameter] public EventCallback AddCamera { get; set; }
    [Parameter] public string? ActiveSourceId { get; set; }
    [Parameter] public bool CanAddCamera { get; set; }
    [Parameter] public bool HasPrimaryMicrophone { get; set; }
    [Parameter] public string LiveState { get; set; } = IdleStateValue;
    [Parameter] public string MicrophoneName { get; set; } = string.Empty;
    [Parameter] public string MicrophoneRouteLabel { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectSource { get; set; }
    [Parameter] public string? SelectedSourceId { get; set; }
    [Parameter] public IReadOnlyList<SceneCameraSource> Sources { get; set; } = [];
    [Parameter] public string Title { get; set; } = DefaultTitle;
    [Parameter] public EventCallback<string> ToggleSource { get; set; }
    [Parameter] public IReadOnlyList<GoLiveUtilitySourceViewModel> UtilitySources { get; set; } = [];
    private string DisplayMicrophoneName => MediaDeviceLabelSanitizer.Sanitize(MicrophoneName);
    private static string FormatSourceLabel(SceneCameraSource source) => MediaDeviceLabelSanitizer.Sanitize(source.Label);

    private bool IsActive(SceneCameraSource source) =>
        string.Equals(source.SourceId, ActiveSourceId, StringComparison.Ordinal);

    private bool IsLiveSessionActive =>
        !string.Equals(LiveState, IdleStateValue, StringComparison.Ordinal);

    private bool IsOnAir(SceneCameraSource source) =>
        IsLiveSessionActive && IsActive(source);

    private bool IsSelected(SceneCameraSource source) =>
        string.Equals(source.SourceId, SelectedSourceId, StringComparison.Ordinal);

    private static string GetSourceStatus(SceneCameraSource source)
    {
        if (source.Transform.IncludeInOutput)
        {
            return SourceIncludedLabel;
        }

        return source.Transform.Visible
            ? SourceLiveLabel
            : SourceSceneOnlyLabel;
    }

    private string GetSourceBadge(SceneCameraSource source)
    {
        if (IsOnAir(source))
        {
            return SourceOnAirLabel;
        }

        return IsSelected(source)
            ? SourceLiveLabel
            : source.Transform.IncludeInOutput
                ? SourceIncludedLabel
                : SourceSceneOnlyLabel;
    }

    private string GetSourceIndicatorState(SceneCameraSource source) =>
        IsOnAir(source)
            ? LiveState
            : IdleStateValue;

    private string GetSourceCardCssClass(SceneCameraSource source)
    {
        var classes = new List<string> { "gl-cam-card" };
        if (IsOnAir(source))
        {
            classes.Add("gl-cam-onair");
        }
        else if (IsSelected(source))
        {
            classes.Add("gl-cam-inpreview");
        }

        return string.Join(' ', classes);
    }

    private string GetSourceBadgeCssClass(SceneCameraSource source)
    {
        var classes = new List<string> { "gl-cam-status-badge" };
        classes.Add(IsOnAir(source) ? "gl-badge-onair" : "gl-badge-idle");
        return string.Join(' ', classes);
    }

    private static string GetUtilityCardCssClass(GoLiveUtilitySourceViewModel utilitySource)
    {
        return utilitySource.Id switch
        {
            PrompterUtilitySourceId => "gl-cam-card gl-cam-prompter",
            ScreenShareUtilitySourceId => "gl-cam-card gl-src-screen",
            _ => "gl-cam-card"
        };
    }
}
