@page "/go-live"
@namespace PrompterOne.Shared.Pages
@using PrompterOne.Core.Models.Workspace
@using PrompterOne.Shared.Components
@using PrompterOne.Shared.Components.GoLive
@using PrompterOne.Shared.GoLive.Models

<div id="screen-go-live"
     class="screen active"
     tabindex="0"
     @ref="_screenRoot"
     @onkeydown="HandleGoLiveKeyDownAsync"
     @onkeydown:preventDefault="true"
     data-testid="@UiTestIds.GoLive.Page">
    <div class="gl-studio">
        <section class="gl-topbar"
                 data-testid="@UiTestIds.GoLive.SessionBar">
            <div class="gl-topbar-left">
                <a class="gl-back-btn"
                   href="@BackRoute"
                   data-testid="@UiTestIds.GoLive.Back">
                    <UiIcon Kind="UiIconKind.ChevronLeft" Size="16" />
                    <span>@Text(GoLiveText.Chrome.BackLabel)</span>
                </a>
                <span class="gl-title"
                      data-testid="@UiTestIds.GoLive.ScreenTitle">@ScreenTitle</span>
                <span class="gl-badge @SessionBadgeCssClass">@PrimarySessionBadge</span>
                <button type="button"
                        class="gl-panel-toggle @(ShowLeftRail ? "active" : null)"
                        data-testid="@UiTestIds.GoLive.LeftPanelToggle"
                        @onclick="ToggleLeftRailAsync">
                    <UiIcon Kind="UiIconKind.PanelLeft" Size="14" />
                </button>
            </div>

            <div class="gl-topbar-center">
                <div class="gl-timer @(IsLiveSessionActive ? "active" : null)"
                     data-testid="@UiTestIds.GoLive.SessionTimer">@ProgramTimerLabel</div>
            </div>

            <div class="gl-topbar-right">
                <button type="button"
                        class="gl-panel-toggle @(_fullProgramView ? "active" : null)"
                        data-testid="@UiTestIds.GoLive.FullProgramToggle"
                        @onclick="ToggleFullProgramViewAsync">
                    <UiIcon Kind="UiIconKind.Expand" Size="14" />
                </button>
                <button type="button"
                        class="gl-panel-toggle @(ShowRightRail ? "active" : null)"
                        data-testid="@UiTestIds.GoLive.RightPanelToggle"
                        @onclick="ToggleRightRailAsync">
                    <UiIcon Kind="UiIconKind.PanelRight" Size="14" />
                </button>
                <div class="gl-topbar-sep"></div>
                <div class="gl-mode-switch">
                    <button type="button"
                            class="gl-mode-btn gl-mode-director @(_activeStudioMode == GoLiveStudioMode.Director ? "active" : null)"
                            data-testid="@UiTestIds.GoLive.ModeDirector"
                            @onclick="() => SelectStudioModeAsync(GoLiveStudioMode.Director)">
                        <UiIcon Kind="UiIconKind.Users" Size="12" />
                        <span>@Text(GoLiveText.Chrome.DirectorModeLabel)</span>
                    </button>
                    <button type="button"
                            class="gl-mode-btn gl-mode-studio @(_activeStudioMode == GoLiveStudioMode.Studio ? "active" : null)"
                            data-testid="@UiTestIds.GoLive.ModeStudio"
                            @onclick="() => SelectStudioModeAsync(GoLiveStudioMode.Studio)">
                        <UiIcon Kind="UiIconKind.Monitor" Size="12" />
                        <span>@Text(GoLiveText.Chrome.StudioModeLabel)</span>
                    </button>
                </div>
                <a class="gl-settings-btn"
                   href="@AppRoutes.Settings"
                   data-testid="@UiTestIds.GoLive.OpenSettings">
                    <UiIcon Kind="UiIconKind.Settings" Size="16" />
                </a>
                <button type="button"
                        class="gl-rec-btn @(GoLiveSession.State.IsRecordingActive ? "active" : null)"
                        disabled="@(!CanControlProgram)"
                        data-testid="@UiTestIds.GoLive.StartRecording"
                        @onclick="ToggleRecordingSessionAsync">
                    <span class="gl-rec-dot"></span>
                    <span>@Text(GoLiveText.Session.RecordingIndicatorLabel)</span>
                </button>
                <button type="button"
                        class="gl-stream-btn @(GoLiveSession.State.IsStreamActive ? "active" : null)"
                        disabled="@(!CanControlProgram)"
                        data-testid="@UiTestIds.GoLive.StartStream"
                        @onclick="ToggleStreamSessionAsync">
                    <span class="gl-stream-icon">
                        <UiIcon Kind="UiIconKind.Broadcast" Size="16" />
                    </span>
                    <span>@StreamButtonDisplayText</span>
                </button>
            </div>
        </section>

        <section class="@GoLiveContentClass">
            @if (ShowLeftRail)
            {
                <aside class="gl-sources"
                       data-testid="@UiTestIds.GoLive.SourceRail">
                    <GoLiveSourcesCard Sources="@VisibleSceneCameras"
                                       ActiveSourceId="@ActiveCamera?.SourceId"
                                       LiveSourceIds="@LiveSourceIds"
                                       LiveState="@SessionIndicatorState"
                                       SelectedSourceId="@SelectedCamera?.SourceId"
                                       ShowSingleLocalPreviewHint="@ShowSingleLocalPreviewHint"
                                       SingleLocalPreviewHint="@SingleLocalPreviewHint"
                                       Title="@SourcesHeaderTitle"
                                       UtilitySources="@UtilitySources"
                                       HasPrimaryMicrophone="@HasPrimaryMicrophone"
                                       MicrophoneName="@PrimaryMicrophoneLabel"
                                       MicrophoneRouteLabel="@(HasPrimaryMicrophone ? PrimaryMicrophoneRoute : Text(GoLiveText.Audio.NoMicrophoneLabel))"
                                       CanAddCamera="@CanAddSceneCamera"
                                       AddCamera="AddAvailableCameraAsync"
                                       SelectSource="SelectSourceAsync"
                                       ToggleSource="ToggleSceneOutputAsync" />
                </aside>
            }

            <div class="gl-program">
                <GoLiveProgramFeedCard ActiveSourceLabel="@ActiveSourceLabel"
                                       ActiveSessionLabel="@ActiveSessionLabel"
                                       Camera="@LiveProgramCamera"
                                       IsRecordingActive="@GoLiveSession.State.IsRecordingActive"
                                       IsStreamActive="@GoLiveSession.State.IsStreamActive"
                                       ProgramResolutionLabel="@ProgramResolutionLabel"
                                       SelectedSourceLabel="@SelectedSourceLabel"
                                       StageFrameRateLabel="@StageFrameRateLabel" />
                <GoLiveSceneControls Scenes="@SceneChips"
                                     ActiveSceneId="@_activeSceneId"
                                     AddScene="AddSceneAsync"
                                     SelectScene="SelectSceneAsync"
                                     ActiveLayout="@_activeSceneLayout"
                                     SelectLayout="SelectSceneLayoutAsync"
                                     ActiveTransitionKind="@_activeTransitionKind"
                                     SelectTransitionKind="SelectTransitionKindAsync"
                                     ActiveTransitionDuration="@_activeTransitionDuration"
                                     SelectTransitionDuration="SelectTransitionDurationAsync"
                                     TakeToAir="SwitchSelectedSourceAsync"
                                     TakeToAirLabel="@SwitchActionLabel" />
            </div>

            @if (ShowRightRail)
            {
                <aside class="gl-sidebar-right"
                       data-testid="@UiTestIds.GoLive.PreviewRail">
                    <GoLiveCameraPreviewCard Camera="@LivePreviewCamera"
                                             Description="@ActiveSessionLabel"
                                             EmptyDescription="@LivePreviewEmptyDescription"
                                             EmptyTitle="@LivePreviewEmptyTitle"
                                             LiveState="@SessionIndicatorState"
                                             Title="@Text(GoLiveText.Chrome.LivePreviewTitle)" />
                    <GoLiveStudioSidebar ActiveTab="@_activeStudioTab"
                                         AudioChannels="@AudioChannels"
                                         CreateRoom="CreateRoomAsync"
                                         CueArmed="@_cueArmed"
                                         Destinations="@DestinationSummary"
                                         IsRoomActive="@IsRoomActive"
                                         MuteAllGuests="@_muteAllGuests"
                                         Participants="@Participants"
                                         RoomCode="@RoomCode"
                                         RuntimeMetrics="@RuntimeMetrics"
                                         SelectTab="SelectStudioTabAsync"
                                         SendCue="SendCueAsync"
                                         StatusMetrics="@StatusMetrics"
                                         TalkbackEnabled="@_talkbackEnabled"
                                         ToggleDestination="ToggleDestinationSummaryAsync"
                                         ToggleMuteAllGuests="ToggleMuteAllGuestsAsync"
                                         ToggleTalkback="ToggleTalkbackAsync" />
                </aside>
            }
        </section>
    </div>
</div>
