@page "/go-live"
@namespace PrompterOne.Shared.Pages
@using PrompterOne.Core.Models.Workspace
@using PrompterOne.Shared.Components.GoLive

<div id="screen-go-live"
     class="screen active"
     data-testid="@UiTestIds.GoLive.Page">
    <div class="go-live-page-shell"
         data-left-open="@_showLeftRail"
         data-right-open="@_showRightRail"
         data-full-program="@_fullProgramView"
         data-studio-mode="@_activeStudioMode">
        <section class="go-live-session-bar"
                 data-testid="@UiTestIds.GoLive.SessionBar">
            <div class="go-live-session-bar-left">
                <a class="go-live-back-link" href="@ReadRoute">Back</a>
                <strong>@_screenTitle</strong>
                <span class="go-live-live-badge">@PrimarySessionBadge</span>
                <button type="button"
                        class="go-live-panel-toggle @(_showLeftRail ? "active" : null)"
                        data-testid="@UiTestIds.GoLive.LeftPanelToggle"
                        @onclick="ToggleLeftRailAsync">Inputs</button>
            </div>

            <div class="go-live-session-timer"
                 data-testid="@UiTestIds.GoLive.SessionTimer">@ProgramTimerLabel</div>

            <div class="go-live-session-actions">
                <button type="button"
                        class="go-live-panel-toggle @(_fullProgramView ? "active" : null)"
                        data-testid="@UiTestIds.GoLive.FullProgramToggle"
                        @onclick="ToggleFullProgramViewAsync">Canvas</button>
                <button type="button"
                        class="go-live-panel-toggle @(_showRightRail ? "active" : null)"
                        data-testid="@UiTestIds.GoLive.RightPanelToggle"
                        @onclick="ToggleRightRailAsync">Info</button>
                <div class="go-live-mode-switch">
                    <button type="button"
                            class="go-live-mode-button @(_activeStudioMode == GoLiveStudioMode.Director ? "active" : null)"
                            data-testid="@UiTestIds.GoLive.ModeDirector"
                            @onclick="() => SelectStudioModeAsync(GoLiveStudioMode.Director)">Director</button>
                    <button type="button"
                            class="go-live-mode-button @(_activeStudioMode == GoLiveStudioMode.Studio ? "active" : null)"
                            data-testid="@UiTestIds.GoLive.ModeStudio"
                            @onclick="() => SelectStudioModeAsync(GoLiveStudioMode.Studio)">Studio</button>
                </div>
                <a class="go-live-settings-shortcut"
                   href="@AppRoutes.Settings"
                   data-testid="@UiTestIds.GoLive.OpenSettings">Settings</a>
                <button type="button"
                        class="go-live-record-pill"
                        @onclick="ToggleRecordingSessionAsync"
                        disabled="@(!CanControlProgram)"
                        data-testid="@UiTestIds.GoLive.StartRecording">@RecordingBadgeText</button>
                <button type="button"
                        class="go-live-stream-pill"
                        @onclick="ToggleStreamSessionAsync"
                        disabled="@(!CanControlProgram)"
                        data-testid="@UiTestIds.GoLive.StartStream">@StreamActionLabel</button>
            </div>
        </section>

        <section class="go-live-studio-shell">
            @if (_showLeftRail)
            {
                <aside class="go-live-left-rail">
                    <GoLiveSourcesCard Sources="@SceneCameras"
                                       ActiveSourceId="@ActiveCamera?.SourceId"
                                       SelectedSourceId="@SelectedCamera?.SourceId"
                                       CurrentScriptTitle="@_screenTitle"
                                       CurrentScriptProgressLabel="@CurrentScriptProgressLabel"
                                       UtilitySources="@UtilitySources"
                                       HasPrimaryMicrophone="@HasPrimaryMicrophone"
                                       MicrophoneName="@PrimaryMicrophoneLabel"
                                       MicrophoneRouteLabel="@(HasPrimaryMicrophone ? PrimaryMicrophoneRoute : NoMicrophoneLabel)"
                                       CanAddCamera="@CanAddSceneCamera"
                                       AddCamera="AddAvailableCameraAsync"
                                       SelectSource="SelectSourceAsync"
                                       ToggleSource="ToggleSceneOutputAsync" />
                </aside>
            }

            <div class="go-live-center-stage">
                <GoLiveProgramFeedCard ActiveSourceLabel="@ActiveSourceLabel"
                                       ActiveSessionLabel="@ActiveSessionLabel"
                                       Camera="@SelectedCamera"
                                       IsArmed="@HasAnyLiveOutput"
                                       IsRecordingActive="@GoLiveSession.State.IsRecordingActive"
                                       IsStreamActive="@GoLiveSession.State.IsStreamActive"
                                       ProgramResolutionLabel="@ProgramResolutionLabel"
                                       SelectedSourceLabel="@SelectedSourceLabel"
                                       StageFrameRateLabel="@StageFrameRateLabel" />
                <GoLiveSceneControls Scenes="@SceneChips"
                                     ActiveSceneId="@_activeSceneId"
                                     AddScene="AddSceneAsync"
                                     SelectScene="SelectSceneAsync"
                                     ActiveLayout="@_activeSceneLayout"
                                     SelectLayout="SelectSceneLayoutAsync"
                                     ActiveTransitionKind="@_activeTransitionKind"
                                     SelectTransitionKind="SelectTransitionKindAsync"
                                     ActiveTransitionDuration="@_activeTransitionDuration"
                                     SelectTransitionDuration="SelectTransitionDurationAsync"
                                     TakeToAir="SwitchSelectedSourceAsync"
                                     TakeToAirLabel="@SwitchActionLabel" />
            </div>

            @if (_showRightRail && !_fullProgramView)
            {
                <aside class="go-live-right-rail"
                       data-testid="@UiTestIds.GoLive.PreviewRail">
                    <GoLiveCameraPreviewCard Camera="@ActiveCamera"
                                             CanSwitchProgram="@CanSwitchProgram"
                                             Description="@ActiveSessionLabel"
                                             ShowSwitchAction="true"
                                             SwitchActionLabel="@SwitchActionLabel"
                                             SwitchSelectedSource="SwitchSelectedSourceAsync"
                                             Title="Live" />

                    <GoLiveStudioSidebar ActiveTab="@_activeStudioTab"
                                         AudioChannels="@AudioChannels"
                                         CreateRoom="CreateRoomAsync"
                                         CueArmed="@_cueArmed"
                                         Destinations="@DestinationSummary"
                                         IsRoomActive="@IsRoomActive"
                                         MuteAllGuests="@_muteAllGuests"
                                         Participants="@Participants"
                                         RoomCode="@RoomCode"
                                         RuntimeMetrics="@RuntimeMetrics"
                                         SelectTab="SelectStudioTabAsync"
                                         SendCue="SendCueAsync"
                                         SettingsRoute="@AppRoutes.Settings"
                                         StatusMetrics="@StatusMetrics"
                                         TalkbackEnabled="@_talkbackEnabled"
                                         ToggleDestination="ToggleDestinationSummaryAsync"
                                         ToggleMuteAllGuests="ToggleMuteAllGuestsAsync"
                                         ToggleTalkback="ToggleTalkbackAsync" />

                    @if (HasScriptContext)
                    {
                        <div class="live-session-links">
                            <a class="set-btn-outline"
                               href="@LearnRoute"
                               data-testid="@UiTestIds.GoLive.OpenLearn">Open Learn</a>
                            <a class="set-btn-golden"
                               href="@ReadRoute"
                               data-testid="@UiTestIds.GoLive.OpenRead">Open Read</a>
                        </div>
                    }
                </aside>
            }
        </section>
    </div>
</div>
