@namespace PrompterLive.Shared.Components.Library
@using PrompterLive.Shared.Localization
@inject IStringLocalizer<SharedResource> Localizer

<div class="lib-modal-backdrop"
     @onclick="HandleCancelCreateFolderAsync"
     data-testid="@UiTestIds.Library.NewFolderOverlay">
    <section class="lib-modal-card lib-folder-modal"
             role="dialog"
             aria-modal="true"
             aria-labelledby="library-folder-modal-title"
             @onclick:stopPropagation="true"
             data-testid="@UiTestIds.Library.NewFolderCard">
        <div class="lib-folder-modal-header">
            <div class="dcreate-icon lib-folder-modal-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                    <line x1="12" y1="11" x2="12" y2="17" />
                    <line x1="9" y1="14" x2="15" y2="14" />
                </svg>
            </div>
            <div class="lib-folder-modal-copy">
                <h2 id="library-folder-modal-title" data-testid="@UiTestIds.Library.NewFolderTitle">@Text(UiTextKey.LibraryCreateFolderTitle)</h2>
                <p>@Text(UiTextKey.LibraryCreateFolderDescription)</p>
            </div>
        </div>

        <div class="lib-folder-modal-body">
            <label class="folder-form-label">
                <span>@Text(UiTextKey.CommonName)</span>
                <input class="folder-form-input"
                       value="@FolderDraftName"
                       @oninput="HandleFolderNameInput"
                       placeholder="@Text(UiTextKey.LibraryFolderPlaceholder)"
                       autofocus
                       data-testid="@UiTestIds.Library.NewFolderName" />
            </label>
            <label class="folder-form-label">
                <span>@Text(UiTextKey.CommonParent)</span>
                <select class="folder-form-select"
                        value="@FolderDraftParentId"
                        @onchange="HandleFolderParentChange"
                        data-testid="@UiTestIds.Library.NewFolderParent">
                    <option value="@LibrarySelectionKeys.Root">@Text(UiTextKey.CommonTopLevel)</option>
                    @foreach (var folder in FolderOptions)
                    {
                        <option value="@folder.Id">@folder.Label</option>
                    }
                </select>
            </label>
        </div>

        <div class="folder-form-actions lib-folder-modal-actions">
            <button class="dcard-act"
                    type="button"
                    @onclick="HandleCancelCreateFolderAsync"
                    data-testid="@UiTestIds.Library.NewFolderCancel">@Text(UiTextKey.CommonCancel)</button>
            <button class="dcard-act dcard-act-go"
                    type="button"
                    @onclick="HandleSubmitCreateFolderAsync"
                    data-testid="@UiTestIds.Library.NewFolderSubmit">@Text(UiTextKey.CommonCreate)</button>
        </div>
    </section>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<LibraryFolderOptionViewModel> FolderOptions { get; set; } = [];

    [Parameter, EditorRequired] public string FolderDraftName { get; set; } = string.Empty;

    [Parameter, EditorRequired] public string FolderDraftParentId { get; set; } = LibrarySelectionKeys.Root;

    [Parameter, EditorRequired] public EventCallback OnCancelCreateFolder { get; set; }

    [Parameter, EditorRequired] public EventCallback OnSubmitCreateFolder { get; set; }

    [Parameter, EditorRequired] public EventCallback<string> OnFolderDraftNameChanged { get; set; }

    [Parameter, EditorRequired] public EventCallback<string> OnFolderDraftParentChanged { get; set; }

    private Task HandleCancelCreateFolderAsync() => OnCancelCreateFolder.InvokeAsync();

    private Task HandleSubmitCreateFolderAsync() => OnSubmitCreateFolder.InvokeAsync();

    private Task HandleFolderNameInput(ChangeEventArgs args) =>
        OnFolderDraftNameChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleFolderParentChange(ChangeEventArgs args) =>
        OnFolderDraftParentChanged.InvokeAsync(args.Value?.ToString() ?? LibrarySelectionKeys.Root);

    private string Text(UiTextKey key) => Localizer[key.ToString()];
}
