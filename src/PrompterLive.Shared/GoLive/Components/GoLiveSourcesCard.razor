@namespace PrompterLive.Shared.Components.GoLive

<section class="live-card go-live-sources-card" data-testid="@UiTestIds.GoLive.SourcesCard">
    <div class="live-card-header">
        <div>
            <h3 class="live-card-title">@Title</h3>
            <p class="live-card-desc">@Description</p>
        </div>
        <a class="set-btn-outline" href="@SettingsRoute" data-testid="@UiTestIds.GoLive.OpenSettings">@SettingsLabel</a>
    </div>

    <div class="live-source-stack">
        @if (Sources.Count == 0)
        {
            <div class="set-empty-card">@EmptyStateMessage</div>
        }
        else
        {
            @foreach (var source in Sources)
            {
                <article class="live-source-item go-live-source-item" data-testid="@UiTestIds.GoLive.SourceCamera(source.SourceId)">
                    <button type="button"
                            class="go-live-source-select"
                            data-active="@IsActive(source)"
                            data-selected="@IsSelected(source)"
                            @onclick="() => SelectSource.InvokeAsync(source.SourceId)"
                            data-testid="@UiTestIds.GoLive.SourceCameraSelect(source.SourceId)">
                        <div>
                            <div class="set-account-name">@source.Label</div>
                            <div class="set-account-status @(source.Transform.IncludeInOutput ? ConnectedCssClass : DisconnectedCssClass)">@GetSourceStatus(source)</div>
                        </div>
                        <div class="go-live-source-flags">
                            @if (IsSelected(source))
                            {
                                <span class="live-status pending">Selected</span>
                            }
                            @if (IsActive(source))
                            {
                                <span class="live-status ready">Program</span>
                            }
                        </div>
                    </button>
                    <button class="@(source.Transform.IncludeInOutput ? OutlineButtonCssClass : GoldenButtonCssClass)"
                            @onclick="() => ToggleSource.InvokeAsync(source.SourceId)"
                            data-testid="@UiTestIds.GoLive.SourceCameraAction(source.DeviceId)">
                        @(source.Transform.IncludeInOutput ? RemoveLabel : AddLabel)
                    </button>
                </article>
            }
        }
    </div>

    <div class="live-mic-summary">
        <div>
            <span class="set-section-label">@PrimaryMicLabel</span>
            <div class="set-account-name">@MicrophoneName</div>
        </div>
        <span class="live-status @(HasPrimaryMicrophone ? ReadyCssClass : PendingCssClass)">@MicrophoneRouteLabel</span>
    </div>
</section>

@code {
    private const string AddLabel = "Add To Live Feed";
    private const string ConnectedCssClass = "set-connected";
    private const string DefaultDescription = "Pick the camera that should be ready for the next switch, while keeping inclusion controls nearby.";
    private const string DefaultTitle = "Live Cameras";
    private const string DisconnectedCssClass = "set-disconnected";
    private const string EmptyStateMessage = "No scene cameras are configured yet. Add them in Settings first.";
    private const string GoldenButtonCssClass = "set-btn-golden";
    private const string OutlineButtonCssClass = "set-btn-outline";
    private const string PendingCssClass = "pending";
    private const string PrimaryMicLabel = "PRIMARY MIC";
    private const string ReadyCssClass = "ready";
    private const string RemoveLabel = "Remove From Live Feed";
    private const string SettingsLabel = "Camera Settings";
    private const string SourceIncludedLabel = "Included in program output";
    private const string SourceSceneOnlyLabel = "Available in scene only";

    [Parameter] public string? ActiveSourceId { get; set; }
    [Parameter] public string Description { get; set; } = DefaultDescription;
    [Parameter] public bool HasPrimaryMicrophone { get; set; }
    [Parameter] public string MicrophoneName { get; set; } = string.Empty;
    [Parameter] public string MicrophoneRouteLabel { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SelectSource { get; set; }
    [Parameter] public string? SelectedSourceId { get; set; }
    [Parameter] public string SettingsRoute { get; set; } = AppRoutes.Settings;
    [Parameter] public IReadOnlyList<SceneCameraSource> Sources { get; set; } = [];
    [Parameter] public string Title { get; set; } = DefaultTitle;
    [Parameter] public EventCallback<string> ToggleSource { get; set; }

    private bool IsActive(SceneCameraSource source) =>
        string.Equals(source.SourceId, ActiveSourceId, StringComparison.Ordinal);

    private bool IsSelected(SceneCameraSource source) =>
        string.Equals(source.SourceId, SelectedSourceId, StringComparison.Ordinal);

    private static string GetSourceStatus(SceneCameraSource source) =>
        source.Transform.IncludeInOutput ? SourceIncludedLabel : SourceSceneOnlyLabel;
}
