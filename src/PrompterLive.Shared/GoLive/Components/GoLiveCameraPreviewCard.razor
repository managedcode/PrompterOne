@implements IAsyncDisposable
@namespace PrompterLive.Shared.Components.GoLive
@inject CameraPreviewInterop CameraPreviewInterop
@inject Microsoft.Extensions.Logging.ILogger<GoLiveCameraPreviewCard> Logger

<section id="@UiDomIds.GoLive.PreviewCard"
         class="go-live-preview-shell"
         data-testid="@UiTestIds.GoLive.PreviewCard">
    <div class="go-live-preview-heading">
        <div>
            <span class="go-live-sidebar-title">@Title</span>
            <div class="set-account-name">@Description</div>
        </div>
        <span class="live-status @(HasCamera ? ReadyStatusCssClass : PendingStatusCssClass)">
            @(HasCamera ? LiveStatusLabel : EmptyStatusLabel)
        </span>
    </div>

    <div class="go-live-preview-stage">
        @if (HasCamera)
        {
            <video id="@UiDomIds.GoLive.PreviewVideo"
                   class="go-live-preview-video"
                   style="@PreviewVideoStyle"
                   autoplay
                   playsinline
                   muted
                   data-testid="@UiTestIds.GoLive.PreviewVideo"></video>
        }
        else
        {
            <div id="@UiDomIds.GoLive.PreviewEmpty"
                 class="set-empty-card go-live-preview-empty"
                 data-testid="@UiTestIds.GoLive.PreviewEmpty">
                <div class="set-account-name">@EmptyTitle</div>
                <div class="live-card-desc">@EmptyDescription</div>
            </div>
        }
    </div>

    <div class="go-live-preview-footer">
        <div>
            <span class="set-section-label">Program camera</span>
            <div class="set-account-name" data-testid="@UiTestIds.GoLive.PreviewSourceLabel">@(Camera?.Label ?? EmptyTitle)</div>
        </div>

        @if (ShowSwitchAction)
        {
            <button type="button"
                    class="go-live-preview-switch"
                    @onclick="SwitchSelectedSource"
                    disabled="@(!CanSwitchProgram)"
                    data-testid="@UiTestIds.GoLive.SwitchSelectedSource">@SwitchActionLabel</button>
        }
    </div>
</section>

@code {
    private const string DefaultDescription = "Preview the current live scene camera before arming or switching destinations.";
    private const string DefaultTitle = "Preview";
    private const string EmptyDescription = "Add a scene camera in Settings or include one in the live output to preview it here.";
    private const string EmptyStatusLabel = "Idle";
    private const string EmptyTitle = "No camera";
    private const string LiveStatusLabel = "Live Preview";
    private const string PendingStatusCssClass = "pending";
    private const string PreviewAttachFailureMessage = "Failed to attach Go Live preview camera for device {DeviceId}.";
    private const string PreviewDetachFailureMessage = "Failed to detach Go Live preview camera.";
    private const string ReadyStatusCssClass = "ready";

    [Parameter] public SceneCameraSource? Camera { get; set; }
    [Parameter] public bool CanSwitchProgram { get; set; }
    [Parameter] public string Description { get; set; } = DefaultDescription;
    [Parameter] public bool ShowSwitchAction { get; set; }
    [Parameter] public EventCallback SwitchSelectedSource { get; set; }
    [Parameter] public string SwitchActionLabel { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = DefaultTitle;

    private bool HasCamera => Camera is not null;

    private string? _attachedDeviceId;

    private string PreviewVideoStyle =>
        Camera is null
            ? string.Empty
            : BuildPreviewVideoStyle(Camera.Transform);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var nextDeviceId = Camera?.DeviceId;

        try
        {
            if (string.IsNullOrWhiteSpace(nextDeviceId))
            {
                if (!string.IsNullOrWhiteSpace(_attachedDeviceId))
                {
                    await CameraPreviewInterop.DetachCameraAsync(UiDomIds.GoLive.PreviewVideo);
                    _attachedDeviceId = null;
                }

                return;
            }

            if (string.Equals(_attachedDeviceId, nextDeviceId, StringComparison.Ordinal))
            {
                return;
            }

            _attachedDeviceId = nextDeviceId;
            await CameraPreviewInterop.AttachCameraAsync(UiDomIds.GoLive.PreviewVideo, nextDeviceId);
        }
        catch (Exception exception)
        {
            Microsoft.Extensions.Logging.LoggerExtensions.LogWarning(Logger, exception, PreviewAttachFailureMessage, nextDeviceId);
            _attachedDeviceId = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (string.IsNullOrWhiteSpace(_attachedDeviceId))
        {
            return;
        }

        try
        {
            await CameraPreviewInterop.DetachCameraAsync(UiDomIds.GoLive.PreviewVideo);
            _attachedDeviceId = null;
        }
        catch (Exception exception)
        {
            Microsoft.Extensions.Logging.LoggerExtensions.LogWarning(Logger, exception, PreviewDetachFailureMessage);
            _attachedDeviceId = null;
        }
    }

    private static string BuildPreviewVideoStyle(MediaSourceTransform transform)
    {
        var transforms = new List<string>();
        if (Math.Abs(transform.Rotation) > 0.01)
        {
            transforms.Add($"rotate({transform.Rotation.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}deg)");
        }

        if (transform.MirrorHorizontal)
        {
            transforms.Add("scaleX(-1)");
        }

        if (transform.MirrorVertical)
        {
            transforms.Add("scaleY(-1)");
        }

        if (transforms.Count == 0)
        {
            return string.Empty;
        }

        return string.Concat("transform:", string.Join(' ', transforms), ";");
    }
}
