@namespace PrompterLive.Shared.Components.Diagnostics
@inherits PrompterLive.Shared.Components.Diagnostics.LoggingErrorBoundaryBase
@using PrompterLive.Shared.Localization

@if (CurrentException is null)
{
    @ChildContent
}
else
{
    <section class="diag-fatal-shell" role="alertdialog" aria-modal="true" data-testid="@UiTestIds.Diagnostics.Fatal">
        <div class="diag-fatal-card">
            <span class="diag-fatal-eyebrow">Diagnostics</span>
            <h1>@CurrentDiagnostic?.Title</h1>
            <p>@CurrentDiagnostic?.Message</p>
            <div class="diag-fatal-detail">@CurrentDiagnostic?.Detail</div>
            <div class="diag-fatal-actions">
                <button class="diag-fatal-btn" type="button" @onclick="HandleRecover" data-testid="@UiTestIds.Diagnostics.Retry">@UiTextCatalog.Get(UiTextKey.DiagnosticsRetry)</button>
                <button class="diag-fatal-btn diag-fatal-btn-primary" type="button" @onclick="HandleReturnHome" data-testid="@UiTestIds.Diagnostics.Home">@UiTextCatalog.Get(UiTextKey.DiagnosticsLibrary)</button>
            </div>
        </div>
    </section>
}
