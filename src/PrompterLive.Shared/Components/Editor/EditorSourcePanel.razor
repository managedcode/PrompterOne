@namespace PrompterLive.Shared.Components.Editor
@using PrompterLive.Core.Models.Editor
@using PrompterLive.Shared.Services.Editor
@using Microsoft.AspNetCore.Components
@inject EditorInterop Interop

<div class="ed-main">
    <div class="ed-toolbar">
        @for (var sectionIndex = 0; sectionIndex < ToolbarSections.Count; sectionIndex++)
        {
            var toolbarSection = ToolbarSections[sectionIndex];
            <div class="@GetToolbarSectionCss(toolbarSection)">
                <div class="tb-label">@toolbarSection.Label</div>
                <div class="tb-row">
                    @foreach (var toolbarAction in toolbarSection.MainActions)
                    {
                        <button class="@toolbarAction.CssClass"
                                type="button"
                                style="@toolbarAction.Style"
                                title="@toolbarAction.Tooltip"
                                data-tip="@toolbarAction.Tooltip"
                                data-testid="@toolbarAction.TestId"
                                aria-expanded="@GetActionAriaExpanded(toolbarAction)"
                                disabled="@GetActionDisabled(toolbarAction)"
                                @onmousedown:preventDefault="@toolbarAction.PreventMouseDown"
                                @onclick="() => ExecuteToolbarActionAsync(toolbarAction)">@((MarkupString)toolbarAction.ContentHtml)</button>
                    }
                </div>

                @if (toolbarSection.HasDropdown)
                {
                    <div class="tb-dropdown" data-testid="@toolbarSection.DropdownTestId" style="@toolbarSection.DropdownStyle">
                        @for (var groupIndex = 0; groupIndex < toolbarSection.DropdownGroups.Count; groupIndex++)
                        {
                            var dropdownGroup = toolbarSection.DropdownGroups[groupIndex];
                            @if (dropdownGroup.HasSeparatorBefore)
                            {
                                <div class="tb-drop-sep"></div>
                            }
                            <div class="tb-drop-label">@dropdownGroup.Label</div>
                            <div class="@GetDropdownListCss(toolbarSection)">
                                @foreach (var dropdownAction in dropdownGroup.Actions)
                                {
                                    <button class="@dropdownAction.CssClass"
                                            type="button"
                                            style="@dropdownAction.Style"
                                            title="@dropdownAction.Tooltip"
                                            data-tip="@dropdownAction.Tooltip"
                                            data-testid="@dropdownAction.TestId"
                                            @onclick="() => ExecuteToolbarActionAsync(dropdownAction)">@((MarkupString)dropdownAction.ContentHtml)</button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            @if (sectionIndex < ToolbarSections.Count - 1)
            {
                <span class="tb-div"></span>
            }
        }
    </div>

    @if (_isAiPanelOpen)
    {
        <div class="ed-ai-panel" data-testid="editor-ai-panel">
            <div class="ed-ai-panel-head">
                <div>
                    <strong>Local Assistant</strong>
                    <p>Deterministic tools for rewrite, expand, and delivery cleanup without a backend.</p>
                </div>
                <button class="ed-ai-close" type="button" aria-label="Close AI panel" @onclick="ToggleAiPanel">×</button>
            </div>
            <div class="ed-ai-actions">
                <button class="ed-ai-action" type="button" data-testid="editor-ai-action-simplify" @onclick='() => ExecuteAiActionAsync(EditorAiAssistAction.Simplify)'>
                    <strong>Simplify</strong>
                    <span>Shorten dense phrases and normalize wording.</span>
                </button>
                <button class="ed-ai-action" type="button" data-testid="editor-ai-action-expand" @onclick='() => ExecuteAiActionAsync(EditorAiAssistAction.Expand)'>
                    <strong>Expand</strong>
                    <span>Add one follow-through sentence to the current selection.</span>
                </button>
                <button class="ed-ai-action" type="button" data-testid="editor-ai-action-pauses" @onclick='() => ExecuteAiActionAsync(EditorAiAssistAction.AddDeliveryPauses)'>
                    <strong>Add Delivery Pauses</strong>
                    <span>Convert punctuation into TPS-friendly pause markers.</span>
                </button>
            </div>
        </div>
    }

    <div class="ed-content ed-source-shell">
        <div class="ed-source-stage">
            <div class="ed-source-highlight"
                 @ref="_overlayRef"
                 data-testid="editor-source-highlight">@HighlightMarkup</div>
            <textarea class="ed-source-input"
                      data-testid="editor-source-input"
                      spellcheck="false"
                      autocapitalize="off"
                      autocomplete="off"
                      autocorrect="off"
                      value="@Text"
                      @ref="_textareaRef"
                      @oninput="OnSourceInputAsync"
                      @onkeyup="OnSelectionInteractionAsync"
                      @onmouseup="OnSelectionInteractionAsync"
                      @onselect="OnSelectionInteractionAsync"
                      @onscroll="OnScrollAsync"></textarea>

            @if (Selection.HasSelection)
            {
                <span class="ed-float-bar"
                      data-testid="editor-floating-bar"
                      style="@FloatingBarStyle">
                    @for (var groupIndex = 0; groupIndex < FloatingActionGroups.Count; groupIndex++)
                    {
                        var group = FloatingActionGroups[groupIndex];
                        @foreach (var action in group)
                        {
                            <button class="@action.CssClass"
                                    type="button"
                                    title="@action.Tooltip"
                                    data-testid="@action.TestId"
                                    @onmousedown:preventDefault="@action.PreventMouseDown"
                                    @onclick="() => ExecuteToolbarActionAsync(action)">@((MarkupString)action.ContentHtml)</button>
                        }

                        @if (groupIndex < FloatingActionGroups.Count - 1)
                        {
                            <span class="efb-sep"></span>
                        }
                    }
                </span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="ed-source-error" data-testid="editor-error">@ErrorMessage</div>
        }
    </div>

    <div class="ed-statusbar">
        <span>Ln @Status.Line, Col @Status.Column</span>
        <span>@Status.Profile</span>
        <span>@Status.BaseWpm WPM</span>
        <span>@Status.SegmentCount Segments</span>
        <span>~@Status.WordCount Words</span>
        <span>~@Status.Duration</span>
        <span>@($"TPS v{Status.Version}")</span>
    </div>
</div>
