<article class="glass-card library-card" data-testid="@Summary.RowAutomationId" @onclick="OpenAsync">
    <div class="library-card-cover">
        <span class="library-card-badge">TPS</span>
        <h3 data-testid="@Summary.TitleAutomationId">@Summary.Title</h3>
        <p>@Summary.WordCount words</p>
    </div>

    <div class="library-card-body">
        <div class="library-card-meta">
            <span>@Summary.DocumentName</span>
            <span>@Summary.UpdatedLabel</span>
        </div>

        <div class="library-card-actions">
            <button class="action-btn" data-testid="@($"{Summary.LoadAutomationId}-learn")" @onclick:stopPropagation="true" @onclick="LearnAsync">Learn</button>
            <button class="action-btn action-btn-primary" data-testid="@($"{Summary.LoadAutomationId}-read")" @onclick:stopPropagation="true" @onclick="ReadAsync">Read</button>
            <button class="icon-btn" data-testid="@($"{Summary.LoadAutomationId}-delete")" title="Delete script" @onclick:stopPropagation="true" @onclick="DeleteAsync">×</button>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public StoredScriptSummary Summary { get; set; } = default!;

    [Parameter]
    public EventCallback<string> OnOpen { get; set; }

    [Parameter]
    public EventCallback<string> OnLearn { get; set; }

    [Parameter]
    public EventCallback<string> OnRead { get; set; }

    [Parameter]
    public EventCallback<string> OnDelete { get; set; }

    private Task OpenAsync() => OnOpen.InvokeAsync(Summary.Id);

    private Task LearnAsync() => OnLearn.InvokeAsync(Summary.Id);

    private Task ReadAsync() => OnRead.InvokeAsync(Summary.Id);

    private Task DeleteAsync() => OnDelete.InvokeAsync(Summary.Id);
}
