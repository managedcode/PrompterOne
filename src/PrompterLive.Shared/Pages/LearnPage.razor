@page "/learn"
@using PrompterLive.Core.Services.Samples

<div id="screen-rsvp"
     class="screen active"
     data-testid="learn-page"
     data-screen-title="@_screenTitle"
     data-screen-subtitle="@_screenSubtitle"
     data-screen-wpm="@($"{_speed} WPM")">
    <div class="rsvp">
        <div class="rsvp-progress"><div class="rsvp-progress-fill" style="width:23%"></div></div>

        <div class="rsvp-display">
            <div class="rsvp-crosshair">
                <svg width="16" height="16" viewBox="0 0 16 16">
                    <line x1="8" y1="0" x2="8" y2="16" stroke="rgba(255,82,82,.3)" stroke-width="1.5" stroke-dasharray="3,2" />
                    <line x1="0" y1="8" x2="16" y2="8" stroke="rgba(255,82,82,.3)" stroke-width="1.5" stroke-dasharray="3,2" />
                    <circle cx="8" cy="8" r="2" fill="rgba(255,82,82,.5)" />
                </svg>
            </div>

            <div class="rsvp-h-row">
                <div class="rsvp-ctx-left" id="rsvp-ctx-l">
                    <span>what</span>
                    <span>I</span>
                    <span>believe</span>
                </div>

                <div class="rsvp-focus" id="rsvp-word">
                    <span>t</span><span>r</span><span class="orp">a</span><span>n</span><span>s</span><span>f</span><span>o</span><span>r</span><span>m</span><span>a</span><span>t</span><span>i</span><span>v</span><span>e</span>
                </div>

                <div class="rsvp-ctx-right" id="rsvp-ctx-r">
                    <span>moment</span>
                    <span>for</span>
                    <span>our</span>
                </div>
            </div>

            <div class="rsvp-orp-line"></div>

            <div class="rsvp-phrase">
                <span class="rsvp-phrase-label">Next</span>
                <p id="rsvp-next-phrase">@_nextPhrase</p>
            </div>

            <div class="rsvp-pause-track">
                <div class="rsvp-pause-fill"></div>
            </div>
        </div>

        <div class="rsvp-bottom">
            <div class="rsvp-speed">
                <button class="rsvp-btn" onclick="changeRsvpSpeed(-10)" data-testid="learn-speed-down"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12" /></svg></button>
                <div class="rsvp-speed-num"><span id="rsvp-speed">@_speed</span><small>WPM</small></div>
                <button class="rsvp-btn" onclick="changeRsvpSpeed(10)" data-testid="learn-speed-up"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg></button>
            </div>
            <div class="rsvp-play-row">
                <button class="rsvp-btn" onclick="stepRsvpWord(-5)" title="Back 5 words"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="19,20 9,12 19,4" /><line x1="5" y1="19" x2="5" y2="5" /></svg></button>
                <button class="rsvp-btn rsvp-btn-sm" onclick="stepRsvpWord(-1)" title="Back 1 word"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15,18 9,12 15,6" /></svg></button>
                <button class="rsvp-play" id="rsvp-play-btn" onclick="toggleRsvp()" data-testid="learn-play-toggle">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16" /><rect x="14" y="4" width="4" height="16" /></svg>
                </button>
                <button class="rsvp-btn rsvp-btn-sm" onclick="stepRsvpWord(1)" title="Forward 1 word"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,6 15,12 9,18" /></svg></button>
                <button class="rsvp-btn" onclick="stepRsvpWord(5)" title="Forward 5 words"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5,4 15,12 5,20" /><line x1="19" y1="5" x2="19" y2="19" /></svg></button>
            </div>
            <div class="rsvp-pos" id="rsvp-progress-label">@_progressLabel</div>
        </div>
    </div>
</div>

@code {
    [Inject] private AppBootstrapper Bootstrapper { get; set; } = null!;
    [Inject] private IScriptSessionService SessionService { get; set; } = null!;
    [Inject] private IScriptRepository ScriptRepository { get; set; } = null!;
    [Inject] private RsvpTextProcessor TextProcessor { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;

    [SupplyParameterFromQuery(Name = "id")]
    public string? ScriptId { get; set; }

    private string _screenTitle = "Product Launch";
    private string _screenSubtitle = "Intro / Opening Block";
    private string _nextPhrase = "Today, we're not just launching a product — we're introducing a solution...";
    private string _progressLabel = "Word 1 / 1 · ~0:00 left";
    private string[] _rsvpWords = ["Good", "morning", "everyone"];
    private int _speed = 300;
    private bool _loadState = true;
    private bool _syncWords;

    protected override Task OnParametersSetAsync()
    {
        _loadState = true;
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loadState)
        {
            _loadState = false;
            await Bootstrapper.EnsureReadyAsync();
            await EnsureSessionLoadedAsync();
            PopulateLearnState();
            StateHasChanged();
            return;
        }

        if (_syncWords)
        {
            _syncWords = false;
            await JS.InvokeVoidAsync(
                "PrompterLiveDesign.setRsvpWords",
                _rsvpWords,
                new
                {
                    speed = _speed,
                    index = Math.Min(12, Math.Max(_rsvpWords.Length - 1, 0))
                });
        }
    }

    private void PopulateLearnState()
    {
        var processed = TextProcessor.ParseScript(SessionService.State.Text);
        var words = processed.AllWords
            .Where(word => !string.IsNullOrWhiteSpace(word))
            .ToArray();

        if (words.Length == 0)
        {
            words = ["Ready"];
        }

        _rsvpWords = words;
        _screenTitle = SessionService.State.Title;
        _screenSubtitle = processed.Segments.FirstOrDefault()?.Title ?? "Intro / Opening Block";
        _speed = SessionService.State.LearnSettings.WordsPerMinute > 0
            ? SessionService.State.LearnSettings.WordsPerMinute
            : processed.Segments.FirstOrDefault()?.Speed ?? 300;
        _nextPhrase = string.Join(' ', _rsvpWords.Skip(1).Take(9));
        _progressLabel = BuildProgressLabel(0, _rsvpWords.Length, _speed);
        _syncWords = true;
    }

    private async Task EnsureSessionLoadedAsync()
    {
        if (!string.IsNullOrWhiteSpace(ScriptId))
        {
            var document = await ScriptRepository.GetAsync(ScriptId);
            if (document is not null &&
                !string.Equals(SessionService.State.ScriptId, document.Id, StringComparison.Ordinal))
            {
                await SessionService.OpenAsync(document);
            }

            return;
        }

        if (string.IsNullOrWhiteSpace(SessionService.State.ScriptId))
        {
            await SessionService.LoadSampleAsync(SampleScriptCatalog.DemoSampleId);
        }
    }

    private static string BuildProgressLabel(int currentIndex, int totalWords, int wordsPerMinute)
    {
        var safeTotalWords = Math.Max(1, totalWords);
        var safeWpm = Math.Max(100, wordsPerMinute);
        var remainingWords = Math.Max(0, safeTotalWords - (currentIndex + 1));
        var remainingSeconds = (int)Math.Ceiling((remainingWords / (double)safeWpm) * 60);
        return $"Word {Math.Min(currentIndex + 1, safeTotalWords)} / {safeTotalWords} · ~{remainingSeconds / 60}:{remainingSeconds % 60:00} left";
    }
}
