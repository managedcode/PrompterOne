@page "/teleprompter"

<div id="screen-teleprompter"
     class="screen active"
     data-testid="teleprompter-page"
     data-screen-title="Product Launch"
     data-screen-subtitle="Intro · Opening Block">
    <div class="rd">
        <div class="rd-gradient warm" id="rd-gradient"></div>
        <div class="rd-camera" id="rd-camera"></div>
        <div class="rd-camera-tint" id="rd-camera-tint"></div>

        <div class="rd-ui">
            <button class="rd-back" onclick="navigateTo('editor')" data-testid="teleprompter-back">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15,18 9,12 15,6" /></svg>
            </button>

            <div class="rd-countdown" id="rd-countdown">3</div>

            <div class="rd-sliders">
                <div class="rd-slider-group">
                    <svg class="rd-slider-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="8" x2="3" y2="16" /><line x1="21" y1="8" x2="21" y2="16" /></svg>
                    <input type="range" class="rd-vslider" id="rd-focal-slider" min="15" max="55" value="30" oninput="changeFocalPoint(this.value)" data-testid="teleprompter-focal-slider">
                    <span class="rd-slider-val" id="rd-focal-val">30%</span>
                </div>
                <div class="rd-slider-group">
                    <svg class="rd-slider-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="8,9 5,12 8,15" /><polyline points="16,9 19,12 16,15" /></svg>
                    <input type="range" class="rd-vslider" id="rd-width-slider" min="400" max="1100" value="750" oninput="changeTextWidth(this.value)" data-testid="teleprompter-width-slider">
                    <span class="rd-slider-val" id="rd-width-val">750</span>
                </div>
            </div>

            <div class="rd-stage">
                <div class="rd-center-guide"></div>
                <div class="rd-guide-h" id="rd-guide-h"></div>
                <div class="rd-guide-v rd-guide-v-l" id="rd-guide-v-l"></div>
                <div class="rd-guide-v rd-guide-v-r" id="rd-guide-v-r"></div>

                <div class="rd-cluster-wrap" id="rd-cluster-wrap">
                    <div class="rd-card rd-card-active" data-card="0">
                        <div class="rd-cluster rd-cluster-active">
                            <div class="rd-cluster-emotion">
                                <span class="rd-emo-dot" style="background:#F59E0B"></span>
                                <span class="rd-emo-name">Warm</span>
                                <span class="rd-emo-wpm">140 <small>WPM</small></span>
                            </div>
                            <p class="rd-cluster-text">
                                <span class="rd-g"><span class="rd-w">Good</span> <span class="rd-w">morning</span> <span class="rd-w">everyone,</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">and</span> <span class="rd-w tps-emphasis">welcome</span></span> <span class="rd-g"><span class="rd-w">to</span> <span class="rd-w">what</span> <span class="rd-w">I</span> <span class="rd-w">believe</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">will</span> <span class="rd-w">be</span> <span class="rd-w">a</span> <span class="rd-w tps-green">transformative</span> <span class="rd-w tps-green">moment</span></span>
                                <span class="rd-g"><span class="rd-w">for</span> <span class="rd-w">our</span> <span class="rd-w">company.</span></span><span class="rd-pause rd-pause-med" data-ms="600"></span>
                                <span class="rd-g"><span class="rd-w tps-emphasis">Today,</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">we're</span> <span class="rd-w">not</span> <span class="rd-w">just</span> <span class="rd-w">launching</span></span> <span class="rd-g"><span class="rd-w">a</span> <span class="rd-w">product</span> <span class="rd-w">&mdash;</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">we're</span> <span class="rd-w">introducing</span> <span class="rd-w">a</span> <span class="rd-w tps-highlight">solution</span></span>
                                <span class="rd-g"><span class="rd-w">that</span> <span class="rd-w">will</span> <span class="rd-w tps-emphasis">revolutionize</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">how</span> <span class="rd-w">our</span> <span class="rd-w">customers</span> <span class="rd-w">interact</span></span>
                                <span class="rd-g"><span class="rd-w">with</span> <span class="rd-w">technology.</span></span><span class="rd-pause rd-pause-med" data-ms="600"></span>
                            </p>
                        </div>
                    </div>

                    <div class="rd-card rd-card-next" data-card="1">
                        <div class="rd-cluster rd-cluster-active">
                            <div class="rd-cluster-emotion">
                                <span class="rd-emo-dot" style="background:#EF4444"></span>
                                <span class="rd-emo-name">Concerned</span>
                                <span class="rd-emo-wpm">150 <small>WPM</small></span>
                            </div>
                            <p class="rd-cluster-text">
                                <span class="rd-g"><span class="rd-w">But</span> <span class="rd-w">first,</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">let's</span> <span class="rd-w">address</span> <span class="rd-w">the</span></span> <span class="rd-g"><span class="rd-w tps-xslow tps-red">elephant</span> <span class="rd-w tps-xslow tps-red">in</span> <span class="rd-w tps-xslow tps-red">the</span> <span class="rd-w tps-xslow tps-red">room.</span></span><span class="rd-pause rd-pause-med" data-ms="600"></span>
                                <span class="rd-g"><span class="rd-w">Our</span> <span class="rd-w">industry</span> <span class="rd-w">has</span> <span class="rd-w">been</span> <span class="rd-w tps-emphasis">struggling</span></span>
                                <span class="rd-g"><span class="rd-w">with</span> <span class="rd-w">a</span> <span class="rd-w">fundamental</span> <span class="rd-w">problem.</span></span><span class="rd-pause rd-pause-med" data-ms="600"></span>
                                <span class="rd-g"><span class="rd-w">According</span> <span class="rd-w">to</span> <span class="rd-w">recent</span> <span class="rd-w">studies,</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w tps-slow tps-emphasis tps-red">73%</span> <span class="rd-w tps-slow tps-emphasis">of</span> <span class="rd-w tps-slow tps-emphasis">users</span> <span class="rd-w tps-slow tps-emphasis">abandon</span></span> <span class="rd-g"><span class="rd-w tps-slow">applications</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">within</span> <span class="rd-w">the</span> <span class="rd-w">first</span></span> <span class="rd-g"><span class="rd-w">three</span> <span class="rd-w">interactions</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">due</span> <span class="rd-w">to</span> <span class="rd-w tps-highlight">complexity</span></span>
                                <span class="rd-g"><span class="rd-w">and</span> <span class="rd-w tps-highlight">poor</span> <span class="rd-w tps-highlight">user</span> <span class="rd-w tps-highlight">experience.</span></span><span class="rd-pause rd-pause-med" data-ms="600"></span>
                            </p>
                        </div>
                    </div>

                    <div class="rd-card rd-card-next" data-card="2">
                        <div class="rd-cluster rd-cluster-active">
                            <div class="rd-cluster-emotion">
                                <span class="rd-emo-dot" style="background:#10B981"></span>
                                <span class="rd-emo-name">Focused</span>
                                <span class="rd-emo-wpm">160 <small>WPM</small></span>
                            </div>
                            <p class="rd-cluster-text">
                                <span class="rd-g"><span class="rd-w">That's</span> <span class="rd-w">where</span> <span class="rd-w">our</span></span> <span class="rd-g"><span class="rd-w tps-blue tps-emphasis">new</span> <span class="rd-w tps-blue tps-emphasis">platform</span> <span class="rd-w">comes</span> <span class="rd-w">in.</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">With</span> <span class="rd-w">our</span> <span class="rd-w">solution,</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">you</span> <span class="rd-w">can</span> <span class="rd-w">expect</span></span> <span class="rd-g"><span class="rd-w">a</span> <span class="rd-w tps-green tps-emphasis">50%</span> <span class="rd-w tps-green tps-emphasis">reduction</span></span>
                                <span class="rd-g"><span class="rd-w">in</span> <span class="rd-w">user</span> <span class="rd-w">abandonment</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w">and</span> <span class="rd-w">a</span> <span class="rd-w tps-green tps-emphasis">30%</span> <span class="rd-w tps-green tps-emphasis">increase</span></span> <span class="rd-g"><span class="rd-w">in</span> <span class="rd-w">engagement.</span></span><span class="rd-pause rd-pause-med" data-ms="600"></span>
                                <span class="rd-g"><span class="rd-w tps-xfast">Full</span> <span class="rd-w tps-xfast">details</span> <span class="rd-w tps-xfast">are</span> <span class="rd-w tps-xfast">available</span></span> <span class="rd-g"><span class="rd-w tps-xfast">in</span> <span class="rd-w tps-xfast">the</span> <span class="rd-w tps-xfast">handout.</span></span><span class="rd-pause" data-ms="300"></span>
                                <span class="rd-g"><span class="rd-w tps-highlight">Thank</span> <span class="rd-w tps-highlight">you</span> <span class="rd-w">for</span> <span class="rd-w">your</span> <span class="rd-w">time.</span></span><span class="rd-pause rd-pause-med" data-ms="600"></span>
                            </p>
                        </div>
                    </div>
                </div>

                <div class="rd-pause-indicator" id="rd-pause-bar">
                    <div class="rd-pause-fill"></div>
                </div>
            </div>

            <div class="rd-edge-progress">
                <div class="rd-edge-fill" id="rd-progress-fill" style="width:23%"></div>
                <div class="rd-edge-segs">
                    <div style="width:33%;--sc:rgba(245,158,11,.35)"></div>
                    <div style="width:40%;--sc:rgba(239,68,68,.35)"></div>
                    <div style="width:27%;--sc:rgba(16,185,129,.35)"></div>
                </div>
            </div>
            <div class="rd-edge-info">
                <span class="rd-edge-section">Intro</span>
                <span class="rd-time">0:00 / 2:27</span>
            </div>

            <div class="rd-controls">
                <div class="rd-ctrl-group">
                    <button class="rd-ctrl-btn" onclick="changeFontSize(-4)" title="Smaller text" data-testid="teleprompter-font-down">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    </button>
                    <span class="rd-ctrl-label" id="rd-font-label">36</span>
                    <button class="rd-ctrl-btn" onclick="changeFontSize(4)" title="Larger text" data-testid="teleprompter-font-up">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    </button>
                </div>

                <div class="rd-ctrl-group rd-ctrl-main">
                    <button class="rd-ctrl-btn" onclick="jumpCard(-1)" title="Previous block"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="19,20 9,12 19,4" /><line x1="5" y1="4" x2="5" y2="20" /></svg></button>
                    <button class="rd-ctrl-btn rd-ctrl-sm" onclick="stepWord(-1)" title="Back one word"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15,18 9,12 15,6" /></svg></button>
                    <button class="rd-ctrl-btn rd-ctrl-play" id="tp-play-btn" onclick="toggleTp()" title="Play / Pause" data-testid="teleprompter-play-toggle">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16" /><rect x="14" y="4" width="4" height="16" /></svg>
                    </button>
                    <button class="rd-ctrl-btn rd-ctrl-sm" onclick="stepWord(1)" title="Forward one word"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,6 15,12 9,18" /></svg></button>
                    <button class="rd-ctrl-btn" onclick="jumpCard(1)" title="Next block"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5,4 15,12 5,20" /><line x1="19" y1="4" x2="19" y2="20" /></svg></button>
                </div>

                <div class="rd-ctrl-group">
                    <span class="rd-ctrl-label rd-block-indicator" id="rd-block-indicator">1 / 3</span>
                    <button class="rd-ctrl-btn" id="rd-cam-btn" onclick="toggleReaderCamera()" title="Camera" data-testid="teleprompter-camera-toggle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" /><circle cx="12" cy="13" r="4" /></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
