@page "/editor"

<div id="screen-editor"
     class="screen active"
     data-testid="editor-page"
     data-screen-title="Product Launch">
    <div class="ed-layout">
        <div class="ed-sidebar">
            <div class="ed-structure">
                <div class="ed-section-label">STRUCTURE</div>
                <div class="ed-tree">
                    <div class="ed-tree-seg active" style="--sc:#F59E0B" data-nav="seg-0" onclick="edNavTo(this)">
                        <div class="ed-tree-dot"></div>
                        <span>Intro</span>
                        <small>Warm</small>
                    </div>
                    <div class="ed-tree-children">
                        <div class="ed-tree-block" data-nav="blk-0-0" onclick="edNavTo(this)"><span>Opening Block</span><code>140</code></div>
                        <div class="ed-tree-block" data-nav="blk-0-1" onclick="edNavTo(this)"><span>Purpose Block</span><code>150</code></div>
                    </div>

                    <div class="ed-tree-seg" style="--sc:#EF4444" data-nav="seg-1" onclick="edNavTo(this)">
                        <div class="ed-tree-dot"></div>
                        <span>Problem</span>
                        <small>Concerned</small>
                    </div>
                    <div class="ed-tree-children">
                        <div class="ed-tree-block" data-nav="blk-1-0" onclick="edNavTo(this)"><span>Statistics</span><code>150</code></div>
                        <div class="ed-tree-block" data-nav="blk-1-1" onclick="edNavTo(this)"><span>Impact</span><code>140</code></div>
                    </div>

                    <div class="ed-tree-seg" style="--sc:#10B981" data-nav="seg-2" onclick="edNavTo(this)">
                        <div class="ed-tree-dot"></div>
                        <span>Solution</span>
                        <small>Focused</small>
                    </div>
                    <div class="ed-tree-children">
                        <div class="ed-tree-block" data-nav="blk-2-0" onclick="edNavTo(this)"><span>Introduction</span><code>150</code></div>
                        <div class="ed-tree-block" data-nav="blk-2-1" onclick="edNavTo(this)"><span>Benefits</span><code>160</code></div>
                    </div>

                    <div class="ed-tree-seg" style="--sc:#A855F7" data-nav="seg-3" onclick="edNavTo(this)">
                        <div class="ed-tree-dot"></div>
                        <span>Call to Action</span>
                        <small>Motivational</small>
                    </div>
                    <div class="ed-tree-children">
                        <div class="ed-tree-block" data-nav="blk-3-0" onclick="edNavTo(this)"><span>Inspiration</span><code>130</code></div>
                        <div class="ed-tree-block" data-nav="blk-3-1" onclick="edNavTo(this)"><span>Closing</span><code>140</code></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="ed-main">
            <div class="ed-toolbar">
                <div class="tb-section">
                    <div class="tb-label">History</div>
                    <div class="tb-row">
                        <button class="tb-btn tb-tip" data-tip="Undo last action (Ctrl+Z)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1,4 1,10 7,10" /><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" /></svg></button>
                        <button class="tb-btn tb-tip" data-tip="Redo last undone action (Ctrl+Y)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23,4 23,10 17,10" /><path d="M20.49 15a9 9 0 1 1-2.13-9.36L23 10" /></svg></button>
                    </div>
                </div>
                <span class="tb-div"></span>

                <div class="tb-section tb-dropdown-wrap">
                    <div class="tb-label">Format</div>
                    <div class="tb-row">
                        <button class="tb-btn tb-tip" data-tip="Bold — strong emphasis level 2. Markdown: **text**" data-testid="editor-bold"><b>B</b></button>
                        <button class="tb-btn tb-tip" data-tip="Italic — emphasis level 1. Markdown: *text*"><i>I</i></button>
                        <button class="tb-btn tb-tip" data-tip="Emphasis — standard emphasis level 1. TPS: [emphasis]text[/emphasis]">Em</button>
                        <button class="tb-btn tb-has-dropdown tb-tip" data-tip="More formatting options">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6,9 12,15 18,9" /></svg>
                        </button>
                    </div>
                    <div class="tb-dropdown">
                        <div class="tb-drop-label">Formatting</div>
                        <div class="tb-emo-list">
                            <button class="tb-emo-item"><b style="color:var(--text-1)">B</b> Bold <small>**text**</small></button>
                            <button class="tb-emo-item"><i style="color:var(--text-1)">I</i> Italic <small>*text*</small></button>
                            <button class="tb-emo-item"><span style="color:var(--gold-text);font-weight:600">Em</span> Emphasis <small>[emphasis]</small></button>
                            <button class="tb-emo-item"><span style="background:rgba(255,232,122,.18);padding:1px 4px;border-radius:3px;color:#FFE87A">H</span> Highlight <small>[highlight]</small></button>
                        </div>
                    </div>
                </div>
                <span class="tb-div"></span>

                <div class="tb-section tb-dropdown-wrap">
                    <div class="tb-label">Color</div>
                    <div class="tb-row">
                        <button class="tb-btn tb-has-dropdown tb-tip" data-tip="Text color — wrap selected text with a color tag. 12 semantic colors optimized for dark teleprompter backgrounds">
                            <span class="cdot" style="background:#FF8A8A"></span>
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6,9 12,15 18,9" /></svg>
                        </button>
                    </div>
                    <div class="tb-dropdown">
                        <div class="tb-drop-label">TPS Colors</div>
                        <div class="tb-color-grid">
                            <button class="tb-cswatch tb-tip" style="background:#FF8A8A" data-tip="Red — warnings, emphasis. [red]text[/red]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#6FE89A" data-tip="Green — positive, success. [green]text[/green]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#8ECFFF" data-tip="Blue — calm, informational. [blue]text[/blue]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#FFE87A" data-tip="Yellow — caution, highlight. [yellow]text[/yellow]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#FFB86A" data-tip="Orange — attention. [orange]text[/orange]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#D88AFF" data-tip="Purple — creative, special. [purple]text[/purple]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#7DE8F0" data-tip="Cyan — cool, tech. [cyan]text[/cyan]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#FF96C5" data-tip="Magenta — accent. [magenta]text[/magenta]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#FFB3D1" data-tip="Pink — soft emphasis. [pink]text[/pink]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#5EECC2" data-tip="Teal — professional. [teal]text[/teal]"></button>
                            <button class="tb-cswatch tb-tip" style="background:#B8C0C8" data-tip="Gray — subdued, secondary text. [gray]text[/gray]"></button>
                            <button class="tb-cswatch tb-tip" style="background:transparent;border:1px dashed var(--gold-20)" data-tip="Remove color — strip color tags from selected text"></button>
                        </div>
                    </div>
                </div>
                <span class="tb-div"></span>

                <div class="tb-section tb-dropdown-wrap">
                    <div class="tb-label">Emotion</div>
                    <div class="tb-row">
                        <button class="tb-btn tb-has-dropdown tb-tip" data-tip="Emotion — applies mood-based color styling and presentation hints. Used on segments, blocks, or inline text">
                            <span class="cdot" style="background:#FFB840"></span>
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6,9 12,15 18,9" /></svg>
                        </button>
                    </div>
                    <div class="tb-dropdown">
                        <div class="tb-drop-label">TPS Emotions</div>
                        <div class="tb-emo-list">
                            <button class="tb-emo-item tb-tip" data-tip="Friendly, welcoming tone. Inline: [warm]text[/warm]"><span class="cdot" style="background:#FFB840"></span> Warm <small>😊</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Worried, empathetic. Inline: [concerned]text[/concerned]"><span class="cdot" style="background:#FF7A7A"></span> Concerned <small>😟</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Concentrated, precise. Inline: [focused]text[/focused]"><span class="cdot" style="background:#4AE0A0"></span> Focused <small>🎯</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Inspiring, encouraging. Inline: [motivational]text[/motivational]"><span class="cdot" style="background:#C88AFF"></span> Motivational <small>💪</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Default balanced tone. Inline: [neutral]text[/neutral]"><span class="cdot" style="background:#8ECFFF"></span> Neutral <small>😐</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Critical, immediate attention. Inline: [urgent]text[/urgent]"><span class="cdot" style="background:#FF6060"></span> Urgent <small>🚨</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Joyful, positive. Inline: [happy]text[/happy]"><span class="cdot" style="background:#FFE87A"></span> Happy <small>😄</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Enthusiastic, energetic. Inline: [excited]text[/excited]"><span class="cdot" style="background:#FF8AC8"></span> Excited <small>🚀</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Melancholy, somber. Inline: [sad]text[/sad]"><span class="cdot" style="background:#A0A8FF"></span> Sad <small>😢</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Peaceful, relaxed. Inline: [calm]text[/calm]"><span class="cdot" style="background:#5EECC2"></span> Calm <small>😌</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="High energy, dynamic. Inline: [energetic]text[/energetic]"><span class="cdot" style="background:#FFA050"></span> Energetic <small>⚡</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Business-like, formal. Inline: [professional]text[/professional]"><span class="cdot" style="background:#80B8FF"></span> Professional <small>💼</small></button>
                        </div>
                    </div>
                </div>
                <span class="tb-div"></span>

                <div class="tb-section tb-dropdown-wrap">
                    <div class="tb-label">Pause</div>
                    <div class="tb-row">
                        <button class="tb-btn tb-tip" data-tip="Short pause — inserts / marker (300ms silence)">/</button>
                        <button class="tb-btn tb-tip" data-tip="Medium pause — inserts // marker (600ms silence)">//</button>
                        <button class="tb-btn tb-has-dropdown tb-tip" data-tip="More pause options">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12,6 12,12 16,14" /></svg>
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6,9 12,15 18,9" /></svg>
                        </button>
                    </div>
                    <div class="tb-dropdown">
                        <div class="tb-drop-label">Pause Types</div>
                        <div class="tb-emo-list">
                            <button class="tb-emo-item tb-tip" data-tip="Short 300ms pause between clauses. Inserted as / in text"><span style="color:var(--gold-text);font-weight:700;width:20px;text-align:center">/</span> Short pause <small>300ms</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Medium 600ms pause between sentences. Inserted as // in text"><span style="color:var(--gold-text);font-weight:700;width:20px;text-align:center">//</span> Medium pause <small>600ms</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="1 second timed pause. [pause:1s]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" style="flex-shrink:0"><circle cx="12" cy="12" r="10" /><polyline points="12,6 12,12 16,14" /></svg> 1 second <small>[pause:1s]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="2 second timed pause. [pause:2s]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" style="flex-shrink:0"><circle cx="12" cy="12" r="10" /><polyline points="12,6 12,12 16,14" /></svg> 2 seconds <small>[pause:2s]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="3 second timed pause. [pause:3s]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" style="flex-shrink:0"><circle cx="12" cy="12" r="10" /><polyline points="12,6 12,12 16,14" /></svg> 3 seconds <small>[pause:3s]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Custom timed pause in milliseconds. [pause:500ms]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" style="flex-shrink:0"><circle cx="12" cy="12" r="10" /><polyline points="12,6 12,12 16,14" /></svg> Custom (ms) <small>[pause:Nms]</small></button>
                        </div>
                    </div>
                </div>
                <span class="tb-div"></span>

                <div class="tb-section tb-dropdown-wrap">
                    <div class="tb-label">Speed</div>
                    <div class="tb-row">
                        <button class="tb-btn tb-speed tb-tip" data-tip="Extra slow — base WPM × 0.6. Use for critical warnings, very careful delivery. [xslow]text[/xslow]" style="color:#FF8A8A">×.6</button>
                        <button class="tb-btn tb-speed tb-tip" data-tip="Slow — base WPM × 0.8. Use for important points, emphasis. [slow]text[/slow]" style="color:#FFB86A">×.8</button>
                        <button class="tb-btn tb-speed tb-tip" data-tip="Normal speed — resets to base WPM × 1.0. [normal]text[/normal]">×1</button>
                        <button class="tb-btn tb-speed tb-tip" data-tip="Fast — base WPM × 1.25. Use for quick mentions, asides. [fast]text[/fast]" style="color:#8ECFFF">×1.25</button>
                        <button class="tb-btn tb-speed tb-tip" data-tip="Extra fast — base WPM × 1.5. Use for rapid transitions, low-importance text. [xfast]text[/xfast]" style="color:#80B8FF">×1.5</button>
                        <button class="tb-btn tb-has-dropdown tb-tip" data-tip="Custom WPM and more speed options">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13,2 3,14 12,14 11,22 21,10 12,10" /></svg>
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6,9 12,15 18,9" /></svg>
                        </button>
                    </div>
                    <div class="tb-dropdown" style="min-width:240px">
                        <div class="tb-drop-label">Speed Presets</div>
                        <div class="tb-emo-list">
                            <button class="tb-emo-item tb-tip" data-tip="Very careful delivery. Critical warnings. base × 0.6 = 84 WPM at base 140"><span style="color:#FF8A8A;font-family:var(--font-mono);font-size:11px;font-weight:700;width:36px;text-align:right">×0.6</span> Extra Slow <small>[xslow]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Important points, emphasis. base × 0.8 = 112 WPM at base 140"><span style="color:#FFB86A;font-family:var(--font-mono);font-size:11px;font-weight:700;width:36px;text-align:right">×0.8</span> Slow <small>[slow]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Reset to base speed. base × 1.0 = 140 WPM at base 140"><span style="color:var(--text-2);font-family:var(--font-mono);font-size:11px;font-weight:700;width:36px;text-align:right">×1.0</span> Normal <small>[normal]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Quick mentions, asides. base × 1.25 = 175 WPM at base 140"><span style="color:#8ECFFF;font-family:var(--font-mono);font-size:11px;font-weight:700;width:36px;text-align:right">×1.25</span> Fast <small>[fast]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Rapid transitions, low-importance text. base × 1.5 = 210 WPM at base 140"><span style="color:#80B8FF;font-family:var(--font-mono);font-size:11px;font-weight:700;width:36px;text-align:right">×1.5</span> Extra Fast <small>[xfast]</small></button>
                        </div>
                        <div class="tb-drop-sep"></div>
                        <div class="tb-drop-label">Custom Speed</div>
                        <div class="tb-emo-list">
                            <button class="tb-emo-item tb-tip" data-tip="Set an absolute WPM value for a text span. [180WPM]text[/180WPM]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-2)" stroke-width="2" style="flex-shrink:0"><polygon points="13,2 3,14 12,14 11,22 21,10 12,10" /></svg> Custom WPM <small>[NWPM]</small></button>
                        </div>
                    </div>
                </div>
                <span class="tb-div"></span>

                <div class="tb-section tb-dropdown-wrap">
                    <div class="tb-label">Insert</div>
                    <div class="tb-row">
                        <button class="tb-btn tb-tip" data-tip="Edit Point — marks a natural place to stop or resume an editing session. [edit_point] or [edit_point:high]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFD060" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" /></svg></button>
                        <button class="tb-btn tb-tip" data-tip="Pronunciation guide — add IPA or simple pronunciation. [phonetic:IPA]word[/phonetic]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D88AFF" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" /><path d="M19 10v2a7 7 0 0 1-14 0v-2" /></svg></button>
                        <button class="tb-btn tb-tip" data-tip="Segment — major script section with name, WPM, and emotion. ## [Name|WPM|Emotion]">§</button>
                        <button class="tb-btn tb-has-dropdown tb-tip" data-tip="More insert options">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6,9 12,15 18,9" /></svg>
                        </button>
                    </div>
                    <div class="tb-dropdown" style="min-width:260px">
                        <div class="tb-drop-label">Structure</div>
                        <div class="tb-emo-list">
                            <button class="tb-emo-item tb-tip" data-tip="Segment — major section of the script (Intro, Problem, Solution). ## [Name|WPM|Emotion|Timing]"><span style="color:var(--gold-text);font-weight:700;width:20px;text-align:center">§</span> Segment <small>## [Name]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Block — topic group within a segment. ### [Name|WPM|Emotion]"><span style="color:var(--gold-text);font-weight:700;width:20px;text-align:center">¶</span> Block <small>### [Name]</small></button>
                        </div>
                        <div class="tb-drop-sep"></div>
                        <div class="tb-drop-label">Edit Points</div>
                        <div class="tb-emo-list">
                            <button class="tb-emo-item tb-tip" data-tip="High priority edit point — critical, must review. [edit_point:high]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FF6060" stroke-width="2" style="flex-shrink:0"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" /></svg> High priority <small>[edit_point:high]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Medium priority edit point — important but not critical. [edit_point:medium]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFB86A" stroke-width="2" style="flex-shrink:0"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" /></svg> Medium priority <small>[edit_point:medium]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Standard edit point — marks a natural break. [edit_point]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFD060" stroke-width="2" style="flex-shrink:0"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" /></svg> Standard <small>[edit_point]</small></button>
                        </div>
                        <div class="tb-drop-sep"></div>
                        <div class="tb-drop-label">Pronunciation</div>
                        <div class="tb-emo-list">
                            <button class="tb-emo-item tb-tip" data-tip="IPA phonetic notation for precise pronunciation. [phonetic:IPA]word[/phonetic]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D88AFF" stroke-width="2" style="flex-shrink:0"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" /><path d="M19 10v2a7 7 0 0 1-14 0v-2" /></svg> Phonetic (IPA) <small>[phonetic:...]</small></button>
                            <button class="tb-emo-item tb-tip" data-tip="Simple pronunciation guide for easy reading. [pronunciation:guide]word[/pronunciation]"><span style="color:#D88AFF;font-weight:600;width:14px;text-align:center;flex-shrink:0;font-size:13px">Aa</span> Pronunciation <small>[pronunciation:...]</small></button>
                        </div>
                    </div>
                </div>
                <span class="tb-div"></span>

                <div class="tb-section">
                    <div class="tb-label">AI</div>
                    <div class="tb-row">
                        <button class="tb-btn tb-ai tb-tip" data-tip="AI Assistant — rewrite, expand, simplify, or auto-format your script with AI" data-testid="editor-ai">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L9 9 2 12l7 3 3 7 3-7 7-3-7-3z" /></svg>
                            AI
                        </button>
                    </div>
                </div>
            </div>

            <div class="ed-content">
                <div class="ed-seg" data-e="warm">
                    <h2 class="ed-seg-h"><span class="h-mark">## </span><span class="h-br">[</span><span class="h-name">Intro</span><span class="h-sep">|</span><span class="h-wpm">140WPM</span><span class="h-sep">|</span><span class="h-emo">Warm</span><span class="h-br">]</span></h2>
                    <div class="ed-blk">
                        <h3 class="ed-blk-h"><span class="h-mark">### </span><span class="h-br">[</span><span class="h-name">Opening Block</span><span class="h-sep">|</span><span class="h-wpm">140WPM</span><span class="h-br">]</span></h3>
                        <p class="ed-p" style="position:relative">
                            Good morning everyone, <span class="mk-pause">/</span> and <span class="mk-tag">[emphasis]</span><span class="mk-em">welcome</span><span class="mk-tag">[/emphasis]</span> to what I believe <span class="mk-pause">/</span><br>
                            will be a <span class="mk-tag">[green]</span><span class="mk-color-green ed-text-selected" style="position:relative"><span class="ed-float-bar">
                                <button class="efb-btn" title="Bold"><b>B</b></button>
                                <button class="efb-btn" title="Italic"><i>I</i></button>
                                <button class="efb-btn" title="Emphasis [emphasis]">Em</button>
