@page "/settings"
@namespace PrompterLive.Shared.Pages
@using PrompterLive.Core.Abstractions
@using PrompterLive.Core.Models.Media
@using PrompterLive.Core.Models.Workspace
@using PrompterLive.Shared.Components.Settings
@using PrompterLive.Shared.Services.Diagnostics

@inject AppBootstrapper Bootstrapper
@inject AppShellService Shell
@inject BrowserSettingsStore SettingsStore
@inject StudioSettingsStore StudioSettingsStore
@inject UiDiagnosticsService Diagnostics
@inject IMediaPermissionService MediaPermissionService
@inject IMediaDeviceService MediaDeviceService
@inject IMediaSceneService MediaSceneService
@inject IScriptSessionService SessionService

<div id="screen-settings" class="screen active" data-testid="@UiTestIds.Settings.Page">
    <div class="set-layout">
        <div class="set-sidebar">
            <div class="set-back-row">
                <h2 class="set-title">Settings</h2>
            </div>
            <nav class="set-nav">
                <button type="button" class="@GetNavItemCssClass(SettingsSection.Cloud)" @onclick="() => ShowSection(SettingsSection.Cloud)" data-testid="@UiTestIds.Settings.NavCloud">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /></svg>
                    Cloud Sync
                </button>
                <button type="button" class="@GetNavItemCssClass(SettingsSection.Files)" @onclick="() => ShowSection(SettingsSection.Files)" data-testid="@UiTestIds.Settings.NavFiles">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" /></svg>
                    File Storage
                </button>
                <button type="button" class="@GetNavItemCssClass(SettingsSection.Cameras)" @onclick="() => ShowSection(SettingsSection.Cameras)" data-testid="@UiTestIds.Settings.NavCameras">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" /><circle cx="12" cy="13" r="4" /></svg>
                    Cameras
                </button>
                <button type="button" class="@GetNavItemCssClass(SettingsSection.Mics)" @onclick="() => ShowSection(SettingsSection.Mics)" data-testid="@UiTestIds.Settings.NavMics">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" /><path d="M19 10v2a7 7 0 0 1-14 0v-2" /><line x1="12" y1="19" x2="12" y2="23" /><line x1="8" y1="23" x2="16" y2="23" /></svg>
                    Microphones
                </button>
                <button type="button" class="@GetNavItemCssClass(SettingsSection.Streaming)" @onclick="() => ShowSection(SettingsSection.Streaming)" data-testid="@UiTestIds.Settings.NavStreaming">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14" /><path d="M12 5l7 7-7 7" /></svg>
                    Streaming
                </button>
                <button type="button" class="@GetNavItemCssClass(SettingsSection.Recording)" @onclick="() => ShowSection(SettingsSection.Recording)" data-testid="@UiTestIds.Settings.NavRecording">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="3" fill="currentColor" /></svg>
                    Recording
                </button>
                <button type="button" class="@GetNavItemCssClass(SettingsSection.Ai)" @onclick="() => ShowSection(SettingsSection.Ai)" data-testid="@UiTestIds.Settings.NavAi">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L9 9 2 12l7 3 3 7 3-7 7-3-7-3z" /></svg>
                    AI Provider
                </button>
                <button type="button" class="@GetNavItemCssClass(SettingsSection.Appearance)" @onclick="() => ShowSection(SettingsSection.Appearance)" data-testid="@UiTestIds.Settings.NavAppearance">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" /></svg>
                    Appearance
                </button>
                <button type="button" class="@GetNavItemCssClass(SettingsSection.About)" @onclick="() => ShowSection(SettingsSection.About)" data-testid="@UiTestIds.Settings.NavAbout">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                    About
                </button>
            </nav>
        </div>

        <div class="set-main">
            <div class="set-status-banner">
                <div>
                    <strong>@GoLiveBannerTitle</strong>
                    <span>@GoLiveBannerDescription</span>
                </div>
                <a class="set-btn-outline"
                   href="@GoLiveRoute"
                   data-testid="@UiTestIds.Settings.CameraRoutingCta">@GoLiveBannerAction</a>
            </div>

            <SettingsCloudSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Cloud)"
                                  IsCardOpen="IsCardOpen"
                                  OneDriveSyncFolder="@_pagePreferences.OneDriveSyncFolder"
                                  OneDriveSyncFolderChanged="UpdateOneDriveSyncFolderAsync"
                                  CloudAutoSyncOnSave="@_pagePreferences.CloudAutoSyncOnSave"
                                  CloudSyncOnStartup="@_pagePreferences.CloudSyncOnStartup"
                                  ToggleCard="TogglePreferenceCardAsync"
                                  ToggleAutoSyncOnSave="ToggleCloudAutoSyncOnSaveAsync"
                                  ToggleSyncOnStartup="ToggleCloudSyncOnStartupAsync" />

            <SettingsFilesSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Files)"
                                  IsCardOpen="IsCardOpen"
                                  ScriptsLocation="@_pagePreferences.ScriptsLocation"
                                  RecordingsLocation="@_pagePreferences.RecordingsLocation"
                                  ExportsLocation="@_pagePreferences.ExportsLocation"
                                  ExportFormat="@_pagePreferences.ExportFormat"
                                  RecordingsStorageLimit="@_pagePreferences.RecordingsStorageLimit"
                                  FileAutoSaveToggleCssClass="@FileAutoSaveToggleCssClass"
                                  FileBackupCopiesToggleCssClass="@FileBackupCopiesToggleCssClass"
                                  ToggleCard="TogglePreferenceCardAsync"
                                  ToggleAutoSave="ToggleAutoSaveAsync"
                                  ToggleBackupCopies="ToggleBackupCopiesAsync"
                                  UpdateExportFormat="UpdateExportFormatAsync"
                                  UpdateRecordingsStorageLimit="UpdateRecordingsStorageLimitAsync" />

            <section class="set-section set-panel set-section-media" id="set-cameras" style="@GetSectionDisplayStyle(SettingsSection.Cameras)" data-testid="@UiTestIds.Settings.CamerasPanel">
                <h3 class="set-section-title">Cameras</h3>
                <p class="set-section-desc">Configure cameras for teleprompter overlay and recording.</p>

                <div class="set-media-grid">
                    <div class="set-media-primary">
                        <div class="set-devices">
                            <div class="set-field">
                                <label>Default Camera</label>
                                <select class="set-select"
                                        value="@SelectedCameraId"
                                        @onchange="OnDefaultCameraChanged"
                                        data-testid="@UiTestIds.Settings.DefaultCamera">
                                    <option value="">No camera selected</option>
                                    @foreach (var camera in _cameraDevices)
                                    {
                                        <option value="@camera.DeviceId">@camera.Label</option>
                                    }
                                </select>
                            </div>
                            <div class="set-field">
                                <label>Resolution</label>
                                <select class="set-select"
                                        value="@_studioSettings.Camera.Resolution"
                                        @onchange="OnCameraResolutionChanged"
                                        data-testid="@UiTestIds.Settings.CameraResolution">
                                    <option value="@CameraResolutionPreset.FullHd1080">1920 x 1080 (Full HD)</option>
                                    <option value="@CameraResolutionPreset.Hd720">1280 x 720 (HD)</option>
                                    <option value="@CameraResolutionPreset.UltraHd4K">3840 x 2160 (4K)</option>
                                    <option value="@CameraResolutionPreset.Sd480">640 x 480 (SD)</option>
                                </select>
                            </div>
                            <div class="set-field">
                                <label>Frame Rate</label>
                                <select class="set-select"
                                        value="@_studioSettings.Camera.FrameRate"
                                        @onchange="OnCameraFrameRateChanged"
                                        data-testid="@UiTestIds.Settings.CameraFrameRate">
                                    <option value="@CameraFrameRatePreset.Fps24">24 FPS</option>
                                    <option value="@CameraFrameRatePreset.Fps30">30 FPS</option>
                                    <option value="@CameraFrameRatePreset.Fps60">60 FPS</option>
                                </select>
                            </div>
                            <div class="set-field set-field-toggle">
                                <label>Mirror Camera (Flip Horizontal)</label>
                                <div class="set-toggle @(_studioSettings.Camera.MirrorCamera ? "on" : null)"
                                     @onclick="ToggleDefaultCameraMirrorAsync"
                                     data-testid="@UiTestIds.Settings.CameraMirrorToggle">
                                    <div class="set-toggle-thumb"></div>
                                </div>
                            </div>
                            <div class="set-field set-field-toggle">
                                <label>Auto-start Camera on Read</label>
                                <div class="set-toggle @(SessionService.State.ReaderSettings.ShowCameraScene ? "on" : null)"
                                     @onclick="ToggleReaderCameraSceneAsync"
                                     data-testid="@UiTestIds.Settings.ReaderCameraToggle">
                                    <div class="set-toggle-thumb"></div>
                                </div>
                            </div>
                        </div>

                        <div class="set-status-banner">
                            <div>
                                <strong>@(_permissions.CameraGranted ? "Camera access is ready" : "Camera access is required")</strong>
                                <span>Teleprompter background video and multi-camera scene selection run directly in the browser.</span>
                            </div>
                            <button class="set-btn-golden" @onclick="RequestMediaAccessAsync" data-testid="@UiTestIds.Settings.RequestMedia">
                                @(_permissions.CameraGranted && _permissions.MicrophoneGranted ? "Refresh Devices" : "Enable Camera + Mic")
                            </button>
                        </div>
                    </div>

                    <div class="set-media-feedback">
                        <SettingsCameraPreviewCard AccessGranted="@_permissions.CameraGranted"
                                                   Camera="@SelectedCamera"
                                                   IsActive="@IsCameraSectionActive"
                                                   MirrorHorizontal="@(SelectedSceneCamera?.Transform.MirrorHorizontal ?? _studioSettings.Camera.MirrorCamera)"
                                                   MirrorVertical="@(SelectedSceneCamera?.Transform.MirrorVertical ?? false)" />
                    </div>
                </div>

                <div class="set-subsection">
                    <h4 class="set-sub-title">Scene Cameras</h4>
                    @if (_sceneCameras.Count == 0)
                    {
                        <div class="set-empty-card" data-testid="@UiTestIds.Settings.NoCameras">
                            Add at least one camera to drive the teleprompter background and stream scene.
                        </div>
                    }
                    else
                    {
                        <div class="set-device-list">
                            @foreach (var source in _sceneCameras)
                            {
                                var inOutput = source.Transform.IncludeInOutput;
                                <article class="set-scene-card" data-testid="@UiTestIds.Settings.SceneCamera(source.SourceId)">
                                    <div class="set-scene-head">
                                        <div>
                                            <span class="set-account-name">@source.Label</span>
                                            <span class="set-account-status set-connected">@source.DeviceId</span>
                                        </div>
                                        <button class="set-btn-outline" @onclick="() => RemoveSceneCameraAsync(source.SourceId)">Remove</button>
                                    </div>
                                    <div class="set-chip-row">
                                        <button class="set-chip-btn @(source.Transform.MirrorHorizontal ? "active" : null)"
                                                @onclick="() => ToggleSceneMirrorAsync(source.SourceId)"
                                                data-testid="@UiTestIds.Settings.SceneMirror(source.SourceId)">Mirror</button>
                                        <button class="set-chip-btn @(source.Transform.MirrorVertical ? "active" : null)"
                                                @onclick="() => ToggleSceneFlipAsync(source.SourceId)"
                                                data-testid="@UiTestIds.Settings.SceneFlip(source.SourceId)">Flip Vertical</button>
                                        <button class="set-chip-btn @(inOutput ? "active" : null)" @onclick="() => ToggleSceneOutputAsync(source.SourceId)">Include In Output</button>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </div>

                <div class="set-subsection">
                    <h4 class="set-sub-title">Available Cameras</h4>
                    <div class="set-device-list">
                        @if (_cameraDevices.Count == 0)
                        {
                            <div class="set-empty-card">No camera devices are currently visible to the browser.</div>
                        }
                        else
                        {
                            @foreach (var camera in _cameraDevices)
                            {
                                var alreadyAdded = _sceneCameras.Any(source => string.Equals(source.DeviceId, camera.DeviceId, StringComparison.Ordinal));
                                <article class="set-device-card" data-testid="@UiTestIds.Settings.CameraDevice(camera.DeviceId)">
                                    <div>
                                        <span class="set-account-name">@camera.Label</span>
                                        <span class="set-account-status @(camera.IsDefault ? "set-connected" : "set-disconnected")">@(camera.IsDefault ? "Browser default camera" : "Available camera")</span>
                                    </div>
                                    <button class="@(alreadyAdded ? "set-btn-outline" : "set-btn-golden")"
                                            @onclick="() => ToggleCameraSelectionAsync(camera)"
                                            data-testid="@UiTestIds.Settings.CameraDeviceAction(camera.DeviceId)">
                                        @(alreadyAdded ? "Remove From Scene" : "Add To Scene")
                                    </button>
                                </article>
                            }
                        }
                    </div>
                </div>
            </section>

            <section class="set-section set-panel set-section-media" id="set-mics" style="@GetSectionDisplayStyle(SettingsSection.Mics)" data-testid="@UiTestIds.Settings.MicsPanel">
                <h3 class="set-section-title">Microphones</h3>
                <p class="set-section-desc">Audio input for recording and streaming.</p>

                <div class="set-media-grid">
                    <div class="set-media-primary">
                        <div class="set-devices">
                            <div class="set-field">
                                <label>Default Microphone</label>
                                <select class="set-select"
                                        value="@SelectedMicrophoneId"
                                        @onchange="OnPrimaryMicrophoneChanged"
                                        data-testid="@UiTestIds.Settings.PrimaryMic">
                                    <option value="">No microphone selected</option>
                                    @foreach (var microphone in _microphoneDevices)
                                    {
                                        <option value="@microphone.DeviceId">@microphone.Label</option>
                                    }
                                </select>
                            </div>
                            <div class="set-field">
                                <label>Input Level</label>
                                <div class="set-level-bar">
                                    <div class="set-level-fill" style="width:@($"{_studioSettings.Microphone.InputLevelPercent}%")"></div>
                                    <div class="set-level-thumb" style="left:@($"{_studioSettings.Microphone.InputLevelPercent}%")"></div>
                                    <input type="range"
                                           class="set-level-range"
                                           min="0"
                                           max="100"
                                           step="1"
                                           value="@_studioSettings.Microphone.InputLevelPercent"
                                           @oninput="UpdatePrimaryMicLevelAsync"
                                           data-testid="@UiTestIds.Settings.MicLevel" />
                                </div>
                                <span class="set-inline-value" data-testid="@UiTestIds.Settings.MicLevelValue">@($"{_studioSettings.Microphone.InputLevelPercent}%")</span>
                            </div>
                            <div class="set-field set-field-toggle">
                                <label>Noise Suppression</label>
                                <div class="set-toggle @(_studioSettings.Microphone.NoiseSuppression ? "on" : null)"
                                     @onclick="ToggleNoiseSuppressionAsync"
                                     data-testid="@UiTestIds.Settings.NoiseSuppression">
                                    <div class="set-toggle-thumb"></div>
                                </div>
                            </div>
                            <div class="set-field set-field-toggle">
                                <label>Echo Cancellation</label>
                                <div class="set-toggle @(_studioSettings.Microphone.EchoCancellation ? "on" : null)"
                                     @onclick="ToggleEchoCancellationAsync"
                                     data-testid="@UiTestIds.Settings.EchoCancellation">
                                    <div class="set-toggle-thumb"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="set-media-feedback">
                        <SettingsMicrophoneLevelCard AccessGranted="@_permissions.MicrophoneGranted"
                                                     IsActive="@IsMicrophoneSectionActive"
                                                     Microphone="@SelectedMicrophone" />
                    </div>
                </div>

                <div class="set-subsection">
                    <h4 class="set-sub-title">Audio Sync + Routing</h4>
                    @if (_microphoneDevices.Count == 0)
                    {
                        <div class="set-empty-card" data-testid="@UiTestIds.Settings.NoMics">
                            No microphones are currently visible to the browser.
                        </div>
                    }
                    else
                    {
                        <div class="set-device-list">
                            @foreach (var microphone in _microphoneDevices)
                            {
                                var inputState = GetAudioInput(microphone);
                                <article class="set-scene-card" data-testid="@UiTestIds.Settings.MicDevice(microphone.DeviceId)">
                                    <div class="set-scene-head">
                                        <div>
                                            <span class="set-account-name">@microphone.Label</span>
                                            <span class="set-account-status @(string.Equals(_primaryMicrophoneId, microphone.DeviceId, StringComparison.Ordinal) ? "set-connected" : "set-disconnected")">
                                                @(string.Equals(_primaryMicrophoneId, microphone.DeviceId, StringComparison.Ordinal) ? "Primary input" : "Secondary input")
                                            </span>
                                        </div>
                                        <button class="set-btn-outline" @onclick="() => ToggleMicMuteAsync(microphone)">
                                            @(inputState.IsMuted ? "Unmute" : "Mute")
                                        </button>
                                    </div>

                                    <div class="set-inline-grid">
                                        <div class="set-field">
                                            <label>Delay</label>
                                            <input type="range"
                                                   class="set-range"
                                                   min="0"
                                                   max="1200"
                                                   step="20"
                                                   value="@inputState.DelayMs"
                                                   @oninput="args => UpdateAudioDelayAsync(microphone, args)"
                                                   data-testid="@UiTestIds.Settings.MicDelay(microphone.DeviceId)" />
                                            <span class="set-inline-value">@inputState.DelayMs ms</span>
                                        </div>
                                        <div class="set-field">
                                            <label>Gain</label>
                                            <input type="range"
                                                   class="set-range"
                                                   min="0"
                                                   max="200"
                                                   step="5"
                                                   value="@Math.Round(inputState.Gain * 100)"
                                                   @oninput="args => UpdateAudioGainAsync(microphone, args)" />
                                            <span class="set-inline-value">@($"{Math.Round(inputState.Gain * 100)}%")</span>
                                        </div>
                                        <div class="set-field">
                                            <label>Route</label>
                                            <select class="set-select" @onchange="args => UpdateAudioRouteAsync(microphone, args)">
                                                @foreach (var option in _routeTargets)
                                                {
                                                    <option value="@option" selected="@(inputState.RouteTarget == option)">@FormatRouteTarget(option)</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </div>
            </section>

            <section class="set-section set-panel"
                     id="set-streaming"
                     style="@GetSectionDisplayStyle(SettingsSection.Streaming)"
                     data-testid="@UiTestIds.Settings.StreamingPanel">
                <h3 class="set-section-title">Streaming + Outputs</h3>
                <p class="set-section-desc">Store output targets, browser-side stream credentials, and source routing here so Go Live stays focused on switching and running the session.</p>

                <SettingsStreamingPanel Settings="@_studioSettings.Streaming"
                                        Sources="@_sceneCameras"
                                        SelectedOutputModeValue="@SelectedStreamingOutputModeValue"
                                        IsCardOpen="IsCardOpen"
                                        ToggleObs="ToggleObsOutputAsync"
                                        ToggleNdi="ToggleNdiOutputAsync"
                                        ToggleRecording="ToggleRecordingOutputAsync"
                                        ToggleLiveKit="ToggleLiveKitSettingsAsync"
                                        ToggleVdo="ToggleVdoSettingsAsync"
                                        ToggleYoutube="ToggleYoutubeSettingsAsync"
                                        ToggleTwitch="ToggleTwitchSettingsAsync"
                                        ToggleCustomRtmp="ToggleCustomRtmpSettingsAsync"
                                        ToggleCard="TogglePreferenceCardAsync"
                                        ToggleDestinationSource="ToggleStreamingDestinationSourceAsync"
                                        OutputModeChanged="OnStreamingOutputModeChanged"
                                        OutputResolutionChanged="OnStreamingOutputResolutionChanged"
                                        BitrateChanged="UpdateStreamingBitrateAsync"
                                        ToggleTextOverlay="ToggleSettingsTextOverlayAsync"
                                        ToggleIncludeCamera="ToggleSettingsIncludeCameraAsync"
                                        LiveKitServerChanged="UpdateLiveKitServerSettingAsync"
                                        LiveKitRoomChanged="UpdateLiveKitRoomSettingAsync"
                                        LiveKitTokenChanged="UpdateLiveKitTokenSettingAsync"
                                        VdoRoomChanged="UpdateVdoRoomSettingAsync"
                                        VdoPublishUrlChanged="UpdateVdoPublishUrlSettingAsync"
                                        YoutubeUrlChanged="UpdateYoutubeUrlSettingAsync"
                                        YoutubeKeyChanged="UpdateYoutubeKeySettingAsync"
                                        TwitchUrlChanged="UpdateTwitchUrlSettingAsync"
                                        TwitchKeyChanged="UpdateTwitchKeySettingAsync"
                                        CustomRtmpNameChanged="UpdateCustomRtmpNameSettingAsync"
                                        CustomRtmpUrlChanged="UpdateCustomRtmpUrlSettingAsync"
                                        CustomRtmpKeyChanged="UpdateCustomRtmpKeySettingAsync" />
            </section>

            <SettingsRecordingSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Recording)"
                                      IsCardOpen="IsCardOpen"
                                      AutoRecordWhenStreaming="@_pagePreferences.AutoRecordWhenStreaming"
                                      SplitRecordingHourly="@_pagePreferences.SplitRecordingHourly"
                                      RecordingFolder="@_pagePreferences.RecordingFolder"
                                      RecordingNamingPattern="@_pagePreferences.RecordingNamingPattern"
                                      RecordingContainer="@_pagePreferences.RecordingContainer"
                                      RecordingVideoCodec="@_pagePreferences.RecordingVideoCodec"
                                      RecordingVideoResolution="@_pagePreferences.RecordingVideoResolution"
                                      RecordingVideoFrameRate="@_pagePreferences.RecordingVideoFrameRate"
                                      RecordingVideoBitrateKbps="@_pagePreferences.RecordingVideoBitrateKbps"
                                      RecordingAudioCodec="@_pagePreferences.RecordingAudioCodec"
                                      RecordingAudioSampleRate="@_pagePreferences.RecordingAudioSampleRate"
                                      RecordingAudioBitrateKbps="@_pagePreferences.RecordingAudioBitrateKbps"
                                      RecordingAudioChannels="@_pagePreferences.RecordingAudioChannels"
                                      ToggleCard="TogglePreferenceCardAsync"
                                      ToggleAutoRecordWhenStreaming="ToggleAutoRecordWhenStreamingAsync"
                                      ToggleSplitRecordingHourly="ToggleSplitRecordingHourlyAsync"
                                      UpdateRecordingNamingPattern="UpdateRecordingNamingPatternAsync"
                                      UpdateRecordingContainer="UpdateRecordingContainerAsync"
                                      UpdateRecordingVideoCodec="UpdateRecordingVideoCodecAsync"
                                      UpdateRecordingVideoResolution="UpdateRecordingVideoResolutionAsync"
                                      UpdateRecordingVideoFrameRate="UpdateRecordingVideoFrameRateAsync"
                                      UpdateRecordingVideoBitrate="UpdateRecordingVideoBitrateAsync"
                                      UpdateRecordingAudioCodec="UpdateRecordingAudioCodecAsync"
                                      UpdateRecordingAudioSampleRate="UpdateRecordingAudioSampleRateAsync"
                                      UpdateRecordingAudioBitrate="UpdateRecordingAudioBitrateAsync"
                                      UpdateRecordingAudioChannels="UpdateRecordingAudioChannelsAsync" />

            <SettingsAiSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Ai)"
                               IsCardOpen="IsCardOpen"
                               SelectedProviderId="@_pagePreferences.SelectedAiProviderId"
                               SelectProvider="SelectAiProviderAsync"
                               ToggleCard="TogglePreferenceCardAsync" />

            <SettingsAppearanceSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.Appearance)"
                                       IsCardOpen="IsCardOpen"
                                       ColorScheme="@_pagePreferences.ColorScheme"
                                       AccentColor="@_pagePreferences.AccentColor"
                                       TeleprompterFont="@_pagePreferences.TeleprompterFont"
                                       TeleprompterFontSize="@_pagePreferences.TeleprompterFontSize"
                                       TeleprompterTextColor="@_pagePreferences.TeleprompterTextColor"
                                       MirrorTeleprompterText="@_pagePreferences.MirrorTeleprompterText"
                                       ShowWordHighlight="@_pagePreferences.ShowWordHighlight"
                                       UiDensity="@_pagePreferences.UiDensity"
                                       ReduceMotion="@_pagePreferences.ReduceMotion"
                                       ShowShortcutOverlay="@_pagePreferences.ShowShortcutOverlay"
                                       ShowHeaderChromeToggleCssClass="@ShowHeaderChromeToggleCssClass"
                                       AmbientGradientMotionToggleCssClass="@AmbientGradientMotionToggleCssClass"
                                       ToggleCard="TogglePreferenceCardAsync"
                                       UpdateColorScheme="UpdateColorSchemeAsync"
                                       UpdateAccentColor="UpdateAccentColorAsync"
                                       UpdateTeleprompterFont="UpdateTeleprompterFontAsync"
                                       UpdateTeleprompterFontSize="UpdateTeleprompterFontSizeAsync"
                                       UpdateTeleprompterTextColor="UpdateTeleprompterTextColorAsync"
                                       ToggleMirrorTeleprompterText="ToggleMirrorTeleprompterTextAsync"
                                       ToggleShowWordHighlight="ToggleShowWordHighlightAsync"
                                       UpdateUiDensity="UpdateUiDensityAsync"
                                       ToggleReduceMotion="ToggleReduceMotionAsync"
                                       ToggleShowShortcutOverlay="ToggleShowShortcutOverlayAsync"
                                       ToggleShowHeaderChrome="ToggleShowHeaderChromeAsync"
                                       ToggleAmbientGradientMotion="ToggleAmbientGradientMotionAsync" />

            <SettingsAboutSection DisplayStyle="@GetSectionDisplayStyle(SettingsSection.About)"
                                  IsCardOpen="IsCardOpen"
                                  ToggleCard="TogglePreferenceCardAsync" />
        </div>
    </div>
</div>

@code {
    private const string SetNavItemCssClass = "set-nav-item";
    private const string SetToggleCssClass = "set-toggle";
    private bool _loadState = true;
    private MediaPermissionsState _permissions = new(false, false);
    private IReadOnlyList<MediaDeviceInfo> _devices = [];
    private IReadOnlyList<MediaDeviceInfo> _cameraDevices = [];
    private IReadOnlyList<MediaDeviceInfo> _microphoneDevices = [];
    private StudioSettings _studioSettings = StudioSettings.Default;
    private string? _primaryMicrophoneId;
    private readonly IReadOnlyList<AudioRouteTarget> _routeTargets = Enum.GetValues<AudioRouteTarget>();
    private const string LoadSettingsOperation = "Settings load";
    private const string LoadSettingsMessage = "Unable to load settings right now.";
    private const string RefreshMediaOperation = "Settings media refresh";
    private const string RefreshMediaMessage = "Unable to refresh camera and microphone access.";
    private const string PersistSceneOperation = "Settings save scene";
    private const string PersistSceneMessage = "Unable to save scene changes.";
    private const string PersistStudioOperation = "Settings save studio";
    private const string PersistStudioMessage = "Unable to save studio settings.";
    private const string GoLiveBannerAction = "Open Go Live";
    private const string GoLiveBannerDescription = "Configure cameras, outputs, and stream destinations here, then use Go Live only to switch sources and run the session.";
    private const string GoLiveBannerTitle = "Go Live runs the session you configure here";

    private IReadOnlyList<SceneCameraSource> _sceneCameras => MediaSceneService.State.Cameras;
    private string SelectedCameraId => ResolveSelectedCamera()?.DeviceId ?? string.Empty;
    private string SelectedMicrophoneId => ResolveSelectedMicrophone()?.DeviceId ?? string.Empty;
    private string GoLiveRoute => string.IsNullOrWhiteSpace(SessionService.State.ScriptId)
        ? AppRoutes.GoLive
        : AppRoutes.GoLiveWithId(SessionService.State.ScriptId);

    protected override void OnInitialized()
    {
        Shell.ShowSettings();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loadState)
        {
            return;
        }

        _loadState = false;
        await Diagnostics.RunAsync(
            LoadSettingsOperation,
            LoadSettingsMessage,
            async () =>
            {
                await LoadAsync();
                StateHasChanged();
            });
    }

    private async Task LoadAsync()
    {
        await Bootstrapper.EnsureReadyAsync();
        await LoadPreferencesAsync();
        _permissions = await MediaPermissionService.QueryAsync();

        try
        {
            _devices = await MediaDeviceService.GetDevicesAsync();
        }
        catch
        {
            _devices = [];
        }

        _cameraDevices = _devices.Where(device => device.Kind == MediaDeviceKind.Camera).ToList();
        _microphoneDevices = _devices.Where(device => device.Kind == MediaDeviceKind.Microphone).ToList();
        _primaryMicrophoneId = MediaSceneService.State.PrimaryMicrophoneId;

        await SeedSceneDefaultsAsync();
        var loadedSettings = await StudioSettingsStore.LoadAsync();
        _studioSettings = StreamingSettingsNormalizer.Normalize(loadedSettings, _sceneCameras);
        if (!EqualityComparer<StudioSettings>.Default.Equals(loadedSettings, _studioSettings))
        {
            await PersistStudioSettingsAsync();
        }

        await NormalizeStudioSettingsAsync();
    }

    private async Task SeedSceneDefaultsAsync()
    {
        var changed = false;

        if (_sceneCameras.Count == 0 && _cameraDevices.Count > 0)
        {
            var defaultCamera = _cameraDevices.FirstOrDefault(device => device.IsDefault) ?? _cameraDevices.First();
            MediaSceneService.AddCamera(defaultCamera.DeviceId, defaultCamera.Label);
            changed = true;
        }

        if (string.IsNullOrWhiteSpace(MediaSceneService.State.PrimaryMicrophoneId) && _microphoneDevices.Count > 0)
        {
            var defaultMicrophone = _microphoneDevices.FirstOrDefault(device => device.IsDefault) ?? _microphoneDevices.First();
            MediaSceneService.SetPrimaryMicrophone(defaultMicrophone.DeviceId, defaultMicrophone.Label);
            MediaSceneService.UpsertAudioInput(new AudioInputState(defaultMicrophone.DeviceId, defaultMicrophone.Label));
            _primaryMicrophoneId = defaultMicrophone.DeviceId;
            changed = true;
        }

        if (changed)
        {
            await PersistSceneAsync();
        }
    }

    private async Task RequestMediaAccessAsync()
    {
        await Diagnostics.RunAsync(
            RefreshMediaOperation,
            RefreshMediaMessage,
            async () =>
            {
                _permissions = await MediaPermissionService.RequestAsync();
                await LoadAsync();
            });
    }

    private async Task NormalizeStudioSettingsAsync()
    {
        var selectedCamera = ResolveSelectedCameraCandidate();
        var selectedMicrophone = ResolveSelectedMicrophoneCandidate();
        var selectedSceneCamera = ResolveSceneCamera(selectedCamera?.DeviceId);
        var selectedAudioInput = selectedMicrophone is null ? null : GetAudioInput(selectedMicrophone);
        var nextSettings = _studioSettings with
        {
            Camera = _studioSettings.Camera with
            {
                DefaultCameraId = selectedCamera?.DeviceId,
                MirrorCamera = selectedSceneCamera?.Transform.MirrorHorizontal ?? _studioSettings.Camera.MirrorCamera,
                AutoStartOnRead = SessionService.State.ReaderSettings.ShowCameraScene
            },
            Microphone = _studioSettings.Microphone with
            {
                DefaultMicrophoneId = selectedMicrophone?.DeviceId,
                InputLevelPercent = ClampPercent(selectedAudioInput is null
                    ? _studioSettings.Microphone.InputLevelPercent
                    : (int)Math.Round(selectedAudioInput.Gain * 100d))
            },
            Streaming = _studioSettings.Streaming with
            {
                IncludeCameraInOutput = _sceneCameras.Count == 0
                    ? _studioSettings.Streaming.IncludeCameraInOutput
                    : _sceneCameras.Any(camera => camera.Transform.IncludeInOutput)
            }
        };

        var hasChanges = !EqualityComparer<StudioSettings>.Default.Equals(_studioSettings, nextSettings);
        _studioSettings = nextSettings;
        if (hasChanges)
        {
            await PersistStudioSettingsAsync();
        }
    }

    private async Task ToggleCameraSelectionAsync(MediaDeviceInfo camera)
    {
        var existing = _sceneCameras.FirstOrDefault(source => string.Equals(source.DeviceId, camera.DeviceId, StringComparison.Ordinal));
        if (existing is null)
        {
            MediaSceneService.AddCamera(camera.DeviceId, camera.Label);
        }
        else
        {
            MediaSceneService.RemoveCamera(existing.SourceId);
        }

        await PersistSceneAsync();
        await NormalizeStudioSettingsAsync();
    }

    private async Task RemoveSceneCameraAsync(string sourceId)
    {
        MediaSceneService.RemoveCamera(sourceId);
        await PersistSceneAsync();
        await NormalizeStudioSettingsAsync();
    }

    private async Task ToggleSceneMirrorAsync(string sourceId)
    {
        var source = _sceneCameras.FirstOrDefault(item => string.Equals(item.SourceId, sourceId, StringComparison.Ordinal));
        if (source is null)
        {
            return;
        }

        MediaSceneService.UpdateTransform(sourceId, source.Transform with { MirrorHorizontal = !source.Transform.MirrorHorizontal });
        await PersistSceneAsync();
        await NormalizeStudioSettingsAsync();
    }

    private async Task ToggleSceneFlipAsync(string sourceId)
    {
        var source = _sceneCameras.FirstOrDefault(item => string.Equals(item.SourceId, sourceId, StringComparison.Ordinal));
        if (source is null)
        {
            return;
        }

        MediaSceneService.UpdateTransform(sourceId, source.Transform with { MirrorVertical = !source.Transform.MirrorVertical });
        await PersistSceneAsync();
        await NormalizeStudioSettingsAsync();
    }

    private async Task ToggleSceneOutputAsync(string sourceId)
    {
        var source = _sceneCameras.FirstOrDefault(item => string.Equals(item.SourceId, sourceId, StringComparison.Ordinal));
        if (source is null)
        {
            return;
        }

        MediaSceneService.SetIncludeInOutput(sourceId, !source.Transform.IncludeInOutput);
        await PersistSceneAsync();
        await NormalizeStudioSettingsAsync();
    }

    private async Task OnDefaultCameraChanged(ChangeEventArgs args)
    {
        var deviceId = args.Value?.ToString();
        var camera = _cameraDevices.FirstOrDefault(device => string.Equals(device.DeviceId, deviceId, StringComparison.Ordinal));
        _studioSettings = _studioSettings with
        {
            Camera = _studioSettings.Camera with
            {
                DefaultCameraId = camera?.DeviceId
            }
        };

        if (camera is not null && !_sceneCameras.Any(source => string.Equals(source.DeviceId, camera.DeviceId, StringComparison.Ordinal)))
        {
            MediaSceneService.AddCamera(camera.DeviceId, camera.Label);
            await PersistSceneAsync();
        }

        var selectedSceneCamera = ResolveSceneCamera(camera?.DeviceId);
        if (selectedSceneCamera is not null)
        {
            _studioSettings = _studioSettings with
            {
                Camera = _studioSettings.Camera with
                {
                    MirrorCamera = selectedSceneCamera.Transform.MirrorHorizontal
                }
            };
        }

        await PersistStudioSettingsAsync();
    }

    private async Task OnCameraResolutionChanged(ChangeEventArgs args)
    {
        if (!Enum.TryParse<CameraResolutionPreset>(args.Value?.ToString(), out var resolution))
        {
            return;
        }

        _studioSettings = _studioSettings with
        {
            Camera = _studioSettings.Camera with { Resolution = resolution }
        };

        await PersistStudioSettingsAsync();
    }

    private async Task OnCameraFrameRateChanged(ChangeEventArgs args)
    {
        if (!Enum.TryParse<CameraFrameRatePreset>(args.Value?.ToString(), out var frameRate))
        {
            return;
        }

        _studioSettings = _studioSettings with
        {
            Camera = _studioSettings.Camera with { FrameRate = frameRate }
        };

        await PersistStudioSettingsAsync();
    }

    private async Task ToggleDefaultCameraMirrorAsync()
    {
        var nextMirror = !_studioSettings.Camera.MirrorCamera;
        var selectedSceneCamera = ResolveSceneCamera(SelectedCameraId);
        if (selectedSceneCamera is not null)
        {
            MediaSceneService.UpdateTransform(selectedSceneCamera.SourceId, selectedSceneCamera.Transform with { MirrorHorizontal = nextMirror });
            await PersistSceneAsync();
        }

        _studioSettings = _studioSettings with
        {
            Camera = _studioSettings.Camera with { MirrorCamera = nextMirror }
        };

        await PersistStudioSettingsAsync();
    }

    private async Task ToggleReaderCameraSceneAsync()
    {
        var current = SessionService.State.ReaderSettings;
        var next = current with { ShowCameraScene = !current.ShowCameraScene };
        await SessionService.UpdateReaderSettingsAsync(next);
        await SettingsStore.SaveAsync("prompterlive.reader", next);

        _studioSettings = _studioSettings with
        {
            Camera = _studioSettings.Camera with { AutoStartOnRead = next.ShowCameraScene }
        };

        await PersistStudioSettingsAsync();
    }

    private async Task OnPrimaryMicrophoneChanged(ChangeEventArgs args)
    {
        var deviceId = args.Value?.ToString();
        var microphone = _microphoneDevices.FirstOrDefault(device => string.Equals(device.DeviceId, deviceId, StringComparison.Ordinal));
        _primaryMicrophoneId = microphone?.DeviceId;
        MediaSceneService.SetPrimaryMicrophone(microphone?.DeviceId, microphone?.Label);

        if (microphone is not null)
        {
            MediaSceneService.UpsertAudioInput(GetAudioInput(microphone));
        }

        await PersistSceneAsync();
        _studioSettings = _studioSettings with
        {
            Microphone = _studioSettings.Microphone with { DefaultMicrophoneId = microphone?.DeviceId }
        };
        await NormalizeStudioSettingsAsync();
    }

    private async Task ToggleMicMuteAsync(MediaDeviceInfo microphone)
    {
        var current = GetAudioInput(microphone);
        MediaSceneService.UpsertAudioInput(current with { IsMuted = !current.IsMuted });
        await PersistSceneAsync();
    }

    private async Task UpdateAudioDelayAsync(MediaDeviceInfo microphone, ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var delay))
        {
            return;
        }

        var current = GetAudioInput(microphone);
        MediaSceneService.UpsertAudioInput(current with { DelayMs = delay });
        await PersistSceneAsync();
    }

    private async Task UpdateAudioGainAsync(MediaDeviceInfo microphone, ChangeEventArgs args)
    {
        if (!double.TryParse(args.Value?.ToString(), out var gainPercent))
        {
            return;
        }

        var current = GetAudioInput(microphone);
        MediaSceneService.UpsertAudioInput(current with { Gain = gainPercent / 100d });
        await PersistSceneAsync();

        if (string.Equals(_primaryMicrophoneId, microphone.DeviceId, StringComparison.Ordinal))
        {
            _studioSettings = _studioSettings with
            {
                Microphone = _studioSettings.Microphone with
                {
                    InputLevelPercent = ClampPercent((int)Math.Round(gainPercent))
                }
            };
            await PersistStudioSettingsAsync();
        }
    }

    private async Task UpdateAudioRouteAsync(MediaDeviceInfo microphone, ChangeEventArgs args)
    {
        if (!Enum.TryParse<AudioRouteTarget>(args.Value?.ToString(), out var routeTarget))
        {
            return;
        }

        var current = GetAudioInput(microphone);
        MediaSceneService.UpsertAudioInput(current with { RouteTarget = routeTarget });
        await PersistSceneAsync();
    }

    private AudioInputState GetAudioInput(MediaDeviceInfo microphone)
    {
        return MediaSceneService.State.AudioBus.Inputs
            .FirstOrDefault(input => string.Equals(input.DeviceId, microphone.DeviceId, StringComparison.Ordinal))
            ?? new AudioInputState(microphone.DeviceId, microphone.Label);
    }

    private async Task PersistSceneAsync()
    {
        _primaryMicrophoneId = MediaSceneService.State.PrimaryMicrophoneId;
        await Diagnostics.RunAsync(
            PersistSceneOperation,
            PersistSceneMessage,
            () => SettingsStore.SaveAsync("prompterlive.scene", MediaSceneService.State));
    }

    private Task PersistStudioSettingsAsync() =>
        Diagnostics.RunAsync(
            PersistStudioOperation,
            PersistStudioMessage,
            () => StudioSettingsStore.SaveAsync(_studioSettings));

    private MediaDeviceInfo? ResolveSelectedCamera() =>
        _cameraDevices.FirstOrDefault(device => string.Equals(device.DeviceId, ResolveSelectedCameraCandidate()?.DeviceId, StringComparison.Ordinal))
        ?? ResolveSelectedCameraCandidate();

    private MediaDeviceInfo? ResolveSelectedCameraCandidate()
    {
        if (!string.IsNullOrWhiteSpace(_studioSettings.Camera.DefaultCameraId))
        {
            var configured = _cameraDevices.FirstOrDefault(device => string.Equals(device.DeviceId, _studioSettings.Camera.DefaultCameraId, StringComparison.Ordinal));
            if (configured is not null)
            {
                return configured;
            }
        }

        var sceneCamera = _sceneCameras.FirstOrDefault();
        if (sceneCamera is not null)
        {
            return _cameraDevices.FirstOrDefault(device => string.Equals(device.DeviceId, sceneCamera.DeviceId, StringComparison.Ordinal))
                ?? new MediaDeviceInfo(sceneCamera.DeviceId, sceneCamera.Label, MediaDeviceKind.Camera);
        }

        return _cameraDevices.FirstOrDefault(device => device.IsDefault) ?? _cameraDevices.FirstOrDefault();
    }

    private SceneCameraSource? ResolveSceneCamera(string? deviceId)
    {
        if (!string.IsNullOrWhiteSpace(deviceId))
        {
            return _sceneCameras.FirstOrDefault(camera => string.Equals(camera.DeviceId, deviceId, StringComparison.Ordinal));
        }

        return _sceneCameras.FirstOrDefault();
    }

    private MediaDeviceInfo? ResolveSelectedMicrophone() =>
        _microphoneDevices.FirstOrDefault(device => string.Equals(device.DeviceId, ResolveSelectedMicrophoneCandidate()?.DeviceId, StringComparison.Ordinal))
        ?? ResolveSelectedMicrophoneCandidate();

    private MediaDeviceInfo? ResolveSelectedMicrophoneCandidate()
    {
        if (!string.IsNullOrWhiteSpace(_primaryMicrophoneId))
        {
            var current = _microphoneDevices.FirstOrDefault(device => string.Equals(device.DeviceId, _primaryMicrophoneId, StringComparison.Ordinal));
            if (current is not null)
            {
                return current;
            }
        }

        if (!string.IsNullOrWhiteSpace(_studioSettings.Microphone.DefaultMicrophoneId))
        {
            var configured = _microphoneDevices.FirstOrDefault(device => string.Equals(device.DeviceId, _studioSettings.Microphone.DefaultMicrophoneId, StringComparison.Ordinal));
            if (configured is not null)
            {
                return configured;
            }
        }

        return _microphoneDevices.FirstOrDefault(device => device.IsDefault) ?? _microphoneDevices.FirstOrDefault();
    }

    private async Task UpdatePrimaryMicLevelAsync(ChangeEventArgs args)
    {
        if (!double.TryParse(args.Value?.ToString(), out var percent))
        {
            return;
        }

        var clampedPercent = ClampPercent((int)Math.Round(percent));
        _studioSettings = _studioSettings with
        {
            Microphone = _studioSettings.Microphone with { InputLevelPercent = clampedPercent }
        };

        var primaryMicrophone = ResolveSelectedMicrophone();
        if (primaryMicrophone is not null)
        {
            var current = GetAudioInput(primaryMicrophone);
            MediaSceneService.UpsertAudioInput(current with { Gain = clampedPercent / 100d });
            await PersistSceneAsync();
        }

        await PersistStudioSettingsAsync();
    }

    private async Task ToggleNoiseSuppressionAsync()
    {
        _studioSettings = _studioSettings with
        {
            Microphone = _studioSettings.Microphone with
            {
                NoiseSuppression = !_studioSettings.Microphone.NoiseSuppression
            }
        };

        await PersistStudioSettingsAsync();
    }

    private async Task ToggleEchoCancellationAsync()
    {
        _studioSettings = _studioSettings with
        {
            Microphone = _studioSettings.Microphone with
            {
                EchoCancellation = !_studioSettings.Microphone.EchoCancellation
            }
        };

        await PersistStudioSettingsAsync();
    }

    private static int ClampPercent(int value) => Math.Max(0, Math.Min(100, value));

    private static string FormatRouteTarget(AudioRouteTarget routeTarget) =>
        routeTarget switch
        {
            AudioRouteTarget.Monitor => "Monitor only",
            AudioRouteTarget.Stream => "Stream only",
            _ => "Monitor + Stream"
        };
}
