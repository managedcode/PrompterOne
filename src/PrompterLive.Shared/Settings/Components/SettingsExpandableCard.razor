@namespace PrompterLive.Shared.Components.Settings

<article class="@CardCssClass"
         data-testid="@TestId"
         @onclick="OnToggle">
    <div class="set-dest-header">
        <div class="@IconCssClass" style="@IconStyle">
            @if (Icon is not null)
            {
                @Icon
            }
        </div>
        <div class="set-dest-info">
            <span class="set-dest-name">@Title</span>
            <span class="set-dest-account">@Subtitle</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(StatusLabel))
        {
            <span class="@StatusCssClass">@StatusLabel</span>
        }
        <svg class="set-dest-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6,9 12,15 18,9" />
        </svg>
    </div>
    <div class="set-dest-body" @onclick:stopPropagation="true">
        @ChildContent
    </div>
</article>

@code {
    private string CardCssClass =>
        string.Join(
            ' ',
            new[]
            {
                "set-dest-card",
                IsOpen ? "open" : string.Empty,
                AdditionalCssClass
            }.Where(cssClass => !string.IsNullOrWhiteSpace(cssClass)));

    private string IconCssClass =>
        string.IsNullOrWhiteSpace(IconClass)
            ? "set-dest-icon"
            : $"set-dest-icon {IconClass}";

    private string StatusCssClass =>
        string.IsNullOrWhiteSpace(StatusClass)
            ? "set-dest-status"
            : $"set-dest-status {StatusClass}";

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public RenderFragment? Icon { get; set; }

    [Parameter] public string IconClass { get; set; } = string.Empty;

    [Parameter] public string IconStyle { get; set; } = string.Empty;

    [Parameter] public bool IsOpen { get; set; }

    [Parameter] public string AdditionalCssClass { get; set; } = string.Empty;

    [Parameter] public EventCallback OnToggle { get; set; }

    [Parameter] public string StatusClass { get; set; } = string.Empty;

    [Parameter] public string StatusLabel { get; set; } = string.Empty;

    [Parameter] public string Subtitle { get; set; } = string.Empty;

    [Parameter] public string TestId { get; set; } = string.Empty;

    [Parameter] public string Title { get; set; } = string.Empty;
}
