@implements IAsyncDisposable
@namespace PrompterLive.Shared.Components
@inject CameraPreviewInterop CameraPreviewInterop
@inject Microsoft.Extensions.Logging.ILogger<SettingsCameraPreviewCard> Logger

<section class="set-camera-preview-panel"
         data-testid="@UiTestIds.Settings.CameraPreviewCard">
    <div class="set-camera-preview-feed">
        @if (CanPreview)
        {
            <video id="@UiDomIds.Settings.CameraPreviewVideo"
                   class="live-preview-video"
                   style="@PreviewVideoStyle"
                   autoplay
                   playsinline
                   muted
                   data-testid="@UiTestIds.Settings.CameraPreviewVideo"></video>
            <span class="set-camera-preview-label">
                <span class="live-dot"></span>
                @PreviewEyebrow
            </span>
        }
        else
        {
            <div class="set-camera-preview-empty"
                 data-testid="@UiTestIds.Settings.CameraPreviewEmpty">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                    <circle cx="12" cy="13" r="4" />
                </svg>
                <span>@EmptyTitle</span>
            </div>
        }
    </div>

    <div class="set-camera-preview-info">
        <span class="set-camera-preview-name"
              data-testid="@UiTestIds.Settings.CameraPreviewLabel">
            @(CanPreview ? CameraLabel : EmptyTitle)
        </span>
        <span class="set-camera-preview-meta">
            @(CanPreview ? PreviewDescription : EmptyDescription)
        </span>
    </div>
</section>

@code {
    private const string DefaultDescription = "Preview the selected camera exactly where device setup happens, before going live or opening Reader.";
    private const string DefaultTitle = "Camera Preview";
    private const string NoCameraDescription = "Pick a default camera or add one to the scene to see a live preview here.";
    private const string NoCameraTitle = "No camera selected";
    private const string PermissionDescription = "Enable camera access to confirm framing, mirror mode, and the active device before reading.";
    private const string PermissionTitle = "Camera access required";
    private const string PreviewAttachFailureMessage = "Failed to attach Settings camera preview for device {DeviceId}.";
    private const string PreviewDetachFailureMessage = "Failed to detach Settings camera preview.";
    private const string PreviewEyebrow = "PREVIEW";
    private const string PreviewReadyDescription = "This preview follows the current default camera selection and mirror state.";

    [Parameter] public bool AccessGranted { get; set; }

    [Parameter] public MediaDeviceInfo? Camera { get; set; }

    [Parameter] public bool IsActive { get; set; }

    [Parameter] public bool MirrorHorizontal { get; set; }

    [Parameter] public bool MirrorVertical { get; set; }

    [Parameter] public string Description { get; set; } = DefaultDescription;

    [Parameter] public string Title { get; set; } = DefaultTitle;

    private bool CanPreview => AccessGranted && !string.IsNullOrWhiteSpace(Camera?.DeviceId);

    private string CameraLabel => Camera?.Label ?? string.Empty;

    private string EmptyDescription =>
        !AccessGranted
            ? PermissionDescription
            : NoCameraDescription;

    private string EmptyTitle =>
        !AccessGranted
            ? PermissionTitle
            : NoCameraTitle;

    private string PreviewDescription => PreviewReadyDescription;

    private string PreviewVideoStyle => BuildPreviewVideoStyle(MirrorHorizontal, MirrorVertical);

    private string? _attachedDeviceId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (!IsActive || !CanPreview)
            {
                await DetachAsync();
                return;
            }

            var nextDeviceId = Camera!.DeviceId;
            if (string.Equals(_attachedDeviceId, nextDeviceId, StringComparison.Ordinal))
            {
                return;
            }

            await DetachAsync();
            _attachedDeviceId = nextDeviceId;
            await CameraPreviewInterop.AttachCameraAsync(UiDomIds.Settings.CameraPreviewVideo, nextDeviceId);
        }
        catch (Exception exception)
        {
            Microsoft.Extensions.Logging.LoggerExtensions.LogWarning(Logger, exception, PreviewAttachFailureMessage, Camera?.DeviceId);
            _attachedDeviceId = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DetachAsync();
    }

    private async Task DetachAsync()
    {
        if (string.IsNullOrWhiteSpace(_attachedDeviceId))
        {
            return;
        }

        try
        {
            await CameraPreviewInterop.DetachCameraAsync(UiDomIds.Settings.CameraPreviewVideo);
        }
        catch (Exception exception)
        {
            Microsoft.Extensions.Logging.LoggerExtensions.LogWarning(Logger, exception, PreviewDetachFailureMessage);
        }
        finally
        {
            _attachedDeviceId = null;
        }
    }

    private static string BuildPreviewVideoStyle(bool mirrorHorizontal, bool mirrorVertical)
    {
        var transforms = new List<string>(capacity: 2);

        if (mirrorHorizontal)
        {
            transforms.Add("scaleX(-1)");
        }

        if (mirrorVertical)
        {
            transforms.Add("scaleY(-1)");
        }

        return transforms.Count == 0
            ? string.Empty
            : string.Concat("transform:", string.Join(' ', transforms), ";");
    }
}
