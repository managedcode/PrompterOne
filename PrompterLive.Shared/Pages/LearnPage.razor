@page "/learn"
@implements IDisposable
@inject AppBootstrapper Bootstrapper
@inject IScriptSessionService Session
@inject IScriptRepository Repository
@inject RsvpOrpCalculator OrpCalculator
@inject BrowserSettingsStore SettingsStore

<section class="view-shell" data-testid="learn-page">
    <div class="section-header">
        <div>
            <p class="eyebrow">RSVP Rehearsal</p>
            <h1>Learn mode</h1>
            <p class="section-copy">Practice the current script at a controlled pace with optimal recognition point focus.</p>
        </div>
        <div class="hero-actions">
            <button class="action-btn" data-testid="learn-back" @onclick="PreviousWord">Back</button>
            <button class="action-btn action-btn-primary" data-testid="learn-playback" @onclick="TogglePlaybackAsync">@(_isPlaying ? "Pause" : "Play")</button>
            <button class="action-btn" data-testid="learn-next" @onclick="NextWord">Next</button>
        </div>
    </div>

    <div class="hero-card">
        <div>
            <span class="stat-label">Current script</span>
            <strong>@Session.State.Title</strong>
        </div>
        <div class="hero-actions">
            <label class="inline-field">
                <span>WPM</span>
                <input type="range" data-testid="learn-wpm" min="100" max="700" step="10" value="@Session.State.LearnSettings.WordsPerMinute" @oninput="OnWpmChanged" />
                <strong>@Session.State.LearnSettings.WordsPerMinute</strong>
            </label>
        </div>
    </div>

    @if (_words.Count == 0)
    {
        <div class="empty-state">
            <h2>No compiled words available</h2>
            <p>Open a TPS document in the editor first, or load a sample script from the library.</p>
        </div>
    }
    else
    {
        <div class="rsvp-layout">
            <div class="glass-card rsvp-stage">
                <div class="rsvp-context" data-testid="learn-left-context">@LeftContext</div>
                <div class="rsvp-word" data-testid="learn-word">
                    <span>@CurrentSplit.Pre</span><strong>@CurrentSplit.Orp</strong><span>@CurrentSplit.Post</span>
                </div>
                <div class="rsvp-context" data-testid="learn-right-context">@RightContext</div>
            </div>

            @if (Session.State.LearnSettings.ShowPhrasePreview)
            {
                <div class="glass-card phrase-card">
                    <h2>Phrase preview</h2>
                    <p>@CurrentPhrasePreview</p>
                </div>
            }

            <div class="glass-card control-strip">
                <div class="stat-card">
                    <span class="stat-label">Progress</span>
                    <strong>@(_currentWordIndex + 1) / @_words.Count</strong>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Ignore script speeds</span>
                    <strong>@(Session.State.LearnSettings.IgnoreScriptSpeeds ? "Yes" : "No")</strong>
                </div>
                <button class="action-btn" data-testid="learn-toggle-speed-mode" @onclick="ToggleIgnoreScriptSpeedsAsync">Toggle speed mode</button>
            </div>
        </div>
    }
</section>

@code {
    [SupplyParameterFromQuery]
    public string? Id { get; set; }

    private List<PrompterLive.Core.Models.CompiledScript.CompiledWord> _words = [];
    private CancellationTokenSource? _playbackCts;
    private bool _isPlaying;
    private bool _ready;
    private string? _loadedId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Bootstrapper.EnsureReadyAsync();
        Session.StateChanged += OnSessionChanged;
        _ready = true;
        await EnsureRequestedScriptLoadedAsync();
        RefreshWords();
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_ready)
        {
            await EnsureRequestedScriptLoadedAsync();
        }
    }

    private async Task EnsureRequestedScriptLoadedAsync()
    {
        if (string.IsNullOrWhiteSpace(Id) || string.Equals(_loadedId, Id, StringComparison.Ordinal))
        {
            return;
        }

        var document = await Repository.GetAsync(Id);
        if (document is null)
        {
            return;
        }

        _loadedId = document.Id;
        await Session.OpenAsync(document);
        RefreshWords();
    }

    private void OnSessionChanged(object? sender, EventArgs args)
    {
        RefreshWords();
        _ = InvokeAsync(StateHasChanged);
    }

    private void RefreshWords()
    {
        _words = Session.State.CompiledScript?.Segments
            .SelectMany(segment => segment.Words ?? [])
            .Where(word => word.Metadata?.IsPause != true && !string.IsNullOrWhiteSpace(word.CleanText))
            .ToList() ?? [];

        if (_currentWordIndex >= _words.Count)
        {
            _currentWordIndex = Math.Max(0, _words.Count - 1);
        }
    }

    private int _currentWordIndex;

    private PrompterLive.Core.Models.CompiledScript.CompiledWord CurrentWord =>
        _words.Count == 0 ? new() : _words[_currentWordIndex];

    private (string Pre, string Orp, string Post) CurrentSplit
    {
        get
        {
            var text = CurrentWord.CleanText ?? string.Empty;
            if (string.IsNullOrWhiteSpace(text))
            {
                return ("", "•", "");
            }

            var split = OrpCalculator.SplitWordAtORP(text);
            return (split.PreORP, split.OrpChar, split.PostORP);
        }
    }

    private string LeftContext =>
        string.Join(" ", _words.Skip(Math.Max(0, _currentWordIndex - Session.State.LearnSettings.ContextWords)).Take(Session.State.LearnSettings.ContextWords).Select(word => word.CleanText));

    private string RightContext =>
        string.Join(" ", _words.Skip(_currentWordIndex + 1).Take(Session.State.LearnSettings.ContextWords).Select(word => word.CleanText));

    private string CurrentPhrasePreview =>
        string.Join(" ", _words.Skip(_currentWordIndex).Take(8).Select(word => word.CleanText));

    private async Task TogglePlaybackAsync()
    {
        if (_isPlaying)
        {
            _playbackCts?.Cancel();
            _isPlaying = false;
            return;
        }

        _isPlaying = true;
        _playbackCts = new CancellationTokenSource();

        try
        {
            while (!_playbackCts.IsCancellationRequested && _currentWordIndex < _words.Count - 1)
            {
                await Task.Delay(GetDelay(CurrentWord), _playbackCts.Token);
                _currentWordIndex++;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            _isPlaying = false;
        }
    }

    private int GetDelay(PrompterLive.Core.Models.CompiledScript.CompiledWord word)
    {
        if (!Session.State.LearnSettings.IgnoreScriptSpeeds)
        {
            return Math.Max(90, (int)word.DisplayDuration.TotalMilliseconds);
        }

        var baseDelay = 60000d / Math.Max(100, Session.State.LearnSettings.WordsPerMinute);
        var multiplier = word.CleanText?.LastOrDefault() switch
        {
            '.' or '!' or '?' => 2.6,
            ',' or ';' or ':' => 1.7,
            _ when (word.CleanText?.Length ?? 0) > 10 => 1.3,
            _ => 1.0
        };

        return Math.Max(70, (int)(baseDelay * multiplier));
    }

    private void PreviousWord()
    {
        if (_currentWordIndex > 0)
        {
            _currentWordIndex--;
        }
    }

    private void NextWord()
    {
        if (_currentWordIndex < _words.Count - 1)
        {
            _currentWordIndex++;
        }
    }

    private async Task OnWpmChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var wpm))
        {
            return;
        }

        var settings = Session.State.LearnSettings with { WordsPerMinute = wpm };
        await Session.UpdateLearnSettingsAsync(settings);
        await SettingsStore.SaveAsync("prompterlive.learn", settings);
    }

    private async Task ToggleIgnoreScriptSpeedsAsync()
    {
        var settings = Session.State.LearnSettings with
        {
            IgnoreScriptSpeeds = !Session.State.LearnSettings.IgnoreScriptSpeeds
        };

        await Session.UpdateLearnSettingsAsync(settings);
        await SettingsStore.SaveAsync("prompterlive.learn", settings);
    }

    public void Dispose()
    {
        _playbackCts?.Cancel();
        _playbackCts?.Dispose();
        Session.StateChanged -= OnSessionChanged;
    }
}
