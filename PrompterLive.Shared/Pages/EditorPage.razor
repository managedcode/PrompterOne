@page "/editor"
@implements IDisposable
@inject AppBootstrapper Bootstrapper
@inject IScriptSessionService Session
@inject IScriptRepository Repository
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<section class="view-shell editor-shell" data-testid="editor-page">
    <div class="section-header">
        <div>
            <p class="eyebrow">TPS Authoring</p>
            <h1>Script editor</h1>
            <p class="section-copy">Write structured TPS, inspect the parsed outline, and keep rehearsal and reader modes in sync.</p>
        </div>
        <div class="hero-actions">
            <button class="action-btn" data-testid="editor-insert-segment" @onclick="InsertSegmentAsync">+ Segment</button>
            <button class="action-btn" data-testid="editor-insert-pause" @onclick="InsertPauseAsync">+ Pause</button>
            <button class="action-btn" data-testid="editor-insert-emphasis" @onclick="InsertEmphasisAsync">+ Emphasis</button>
            <button class="action-btn" data-testid="editor-export" @onclick="ExportAsync">Export .tps</button>
            <button class="action-btn action-btn-primary" data-testid="editor-save" @onclick="SaveAsync">Save</button>
        </div>
    </div>

    <div class="editor-grid">
        <aside class="glass-card sidebar-panel">
            <div class="panel-header">
                <h2>Structure</h2>
                <span>@(Session.State.ScriptData?.Segments?.Length ?? 0) segments</span>
            </div>

            @if (Session.State.ScriptData?.Segments is { Length: > 0 } segments)
            {
                <div class="outline-list">
                    @foreach (var segment in segments)
                    {
                        <div class="outline-item">
                            <div class="outline-title">
                                <strong>@segment.Name</strong>
                                <span>@segment.Emotion</span>
                            </div>
                            @if (segment.Blocks is { Length: > 0 } blocks)
                            {
                                @foreach (var block in blocks)
                                {
                                    <div class="outline-subitem">
                                        <span>@block.Name</span>
                                        <code>@(block.WpmOverride ?? segment.WpmOverride ?? Session.State.ScriptData?.TargetWpm ?? 150)</code>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="muted-copy">No structure yet. Start typing TPS headers or load a sample script.</p>
            }
        </aside>

        <section class="editor-column">
            <div class="glass-card form-panel">
                <div class="field-grid">
                    <label class="field">
                        <span>Title</span>
                        <input class="text-input" data-testid="editor-title" @bind="_title" @bind:event="oninput" @bind:after="QueueDraftRefreshAsync" />
                    </label>
                    <label class="field">
                        <span>Document name</span>
                        <input class="text-input" data-testid="editor-document-name" @bind="_documentName" @bind:event="oninput" @bind:after="QueueDraftRefreshAsync" />
                    </label>
                </div>

                <label class="field">
                    <span>TPS source</span>
                    <textarea class="script-textarea" data-testid="editor-source" @bind="_text" @bind:event="oninput" @bind:after="QueueDraftRefreshAsync"></textarea>
                </label>

                @if (!string.IsNullOrWhiteSpace(Session.State.ErrorMessage))
                {
                    <p class="error-copy">@Session.State.ErrorMessage</p>
                }
            </div>

            <div class="glass-card preview-panel">
                <div class="panel-header">
                    <h2>Preview</h2>
                    <span>@Session.State.WordCount words · @FormattedDuration</span>
                </div>

                @if (Session.State.PreviewSegments.Count == 0)
                {
                    <p class="muted-copy">The preview will appear here as soon as the TPS parser can build segments and blocks.</p>
                }
                else
                {
                    <div class="preview-stack">
                        @foreach (var segment in Session.State.PreviewSegments)
                        {
                            <article class="preview-card">
                                <div class="preview-card-head">
                                    <strong>@segment.Title</strong>
                                    <span>@segment.Emotion · @segment.TargetWpm WPM</span>
                                </div>

                                @if (segment.Blocks.Count > 0)
                                {
                                    @foreach (var block in segment.Blocks)
                                    {
                                        <div class="preview-block">
                                            <div class="preview-block-head">
                                                <strong>@block.Title</strong>
                                                <span>@block.TargetWpm WPM</span>
                                            </div>
                                            <p>@block.Text</p>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p>@segment.Content</p>
                                }
                            </article>
                        }
                    </div>
                }
            </div>
        </section>
    </div>

    <div class="quick-nav">
        <button class="action-btn" @onclick="@(() => Navigation.NavigateTo($"/learn?id={Uri.EscapeDataString(Session.State.ScriptId)}"))">Go to learn mode</button>
        <button class="action-btn action-btn-primary" @onclick="@(() => Navigation.NavigateTo($"/teleprompter?id={Uri.EscapeDataString(Session.State.ScriptId)}"))">Go to reader</button>
    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    public string? Id { get; set; }

    private string _title = string.Empty;
    private string _text = string.Empty;
    private string _documentName = string.Empty;
    private bool _ready;
    private string? _loadedId;
    private CancellationTokenSource? _draftCts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Bootstrapper.EnsureReadyAsync();
        Session.StateChanged += OnSessionStateChanged;
        _ready = true;
        SyncFromState();
        await EnsureRequestedScriptLoadedAsync();
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_ready)
        {
            await EnsureRequestedScriptLoadedAsync();
        }
    }

    private async Task EnsureRequestedScriptLoadedAsync()
    {
        if (string.IsNullOrWhiteSpace(Id) || string.Equals(_loadedId, Id, StringComparison.Ordinal))
        {
            return;
        }

        var document = await Repository.GetAsync(Id);
        if (document is null)
        {
            return;
        }

        _loadedId = document.Id;
        await Session.OpenAsync(document);
        SyncFromState();
    }

    private void SyncFromState()
    {
        _title = Session.State.Title;
        _text = Session.State.Text;
        _documentName = Session.State.DocumentName;
    }

    private void OnSessionStateChanged(object? sender, EventArgs args)
    {
        SyncFromState();
        _ = InvokeAsync(StateHasChanged);
    }

    private Task QueueDraftRefreshAsync()
    {
        _draftCts?.Cancel();
        _draftCts?.Dispose();
        _draftCts = new CancellationTokenSource();
        var token = _draftCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(180, token);
                await Session.UpdateDraftAsync(_title, _text, _documentName, Session.State.ScriptId, token);
            }
            catch (OperationCanceledException)
            {
            }
        }, token);

        return Task.CompletedTask;
    }

    private async Task SaveAsync()
    {
        await Session.UpdateDraftAsync(_title, _text, _documentName, Session.State.ScriptId);
        var document = await Session.SaveAsync();
        _loadedId = document.Id;
        Navigation.NavigateTo($"/editor?id={Uri.EscapeDataString(document.Id)}", forceLoad: false);
    }

    private async Task ExportAsync()
    {
        await JSRuntime.InvokeVoidAsync("PrompterLive.downloads.saveText", _documentName, _text);
    }

    private async Task InsertSegmentAsync()
    {
        _text += $"""

        ## [New Segment|150WPM|neutral]
        ### [Block|150WPM]
        Add your lines here.
        """;
        await QueueDraftRefreshAsync();
    }

    private async Task InsertPauseAsync()
    {
        _text += " [pause:500ms]";
        await QueueDraftRefreshAsync();
    }

    private async Task InsertEmphasisAsync()
    {
        _text += " [emphasis]focus[/emphasis]";
        await QueueDraftRefreshAsync();
    }

    private string FormattedDuration => Session.State.EstimatedDuration.ToString(@"mm\:ss");

    public void Dispose()
    {
        Session.StateChanged -= OnSessionStateChanged;
        _draftCts?.Cancel();
        _draftCts?.Dispose();
    }
}
